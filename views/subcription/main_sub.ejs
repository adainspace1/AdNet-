      <!-- Custom -->
      <div class="card tier-custom">
        <div class="card-header">
          <h3>Custom</h3>
          <p>Large & regulated sectors</p>
        </div>
        <div class="price">₦20m – ₦150m<span>/year</span></div>
        <div class="features">
          <ul>
            <li><svg fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> Unlimited users</li>
