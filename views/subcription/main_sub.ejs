        <a href="/subcription/custom" class="btn">Explore Custom →</a>
      </div>

    </div>
  </div>

  <!-- Bottom CTA -->
  <div class="bottom-cta">
    <p>Need help choosing the right plan? <a href="#contact">Talk to our sales team →</a></p>
  </div>

</body>
</html>