<!DOCTYPE html> <html lang="en"> <head> <meta charset="UTF-8">
   <title>Login | Adnet</title> 
   <meta name="viewport" content="width=device-width, initial-scale=1.0"/> 
   <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" /> <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">
  <style>
    /* Apply Poppins everywhere */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Poppins', sans-serif !important;
    }

    body {
      background: linear-gradient(135deg, #1a73e8, #0a4aa3); /* Adnet blue */
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
    }

    .login-container {
      background: #fff;
      width: 540px; /* slightly bigger */
      padding: 80px 65px; /* more space */
      border-radius: 24px;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
      text-align: center;
      animation: fadeIn 0.8s ease-in-out;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .login-container h2 {
      margin-bottom: 40px;
      font-size: 34px;
      font-weight: 700;
      color: #1a73e8;
    }

    .login-container input {
      width: 100%;
      padding: 18px;
      margin: 15px 0;
      border: 1px solid #ddd;
      border-radius: 14px;
      font-size: 17px;
      transition: 0.3s ease;
    }

    .login-container input:focus {
      border-color: #1a73e8;
      box-shadow: 0 0 10px rgba(26, 115, 232, 0.3);
      outline: none;
    }

    /* Styled placeholders in Poppins */
    .login-container input::placeholder {
      color: #888;
      font-size: 15px;
      font-weight: 500;
      font-family: 'Poppins', sans-serif;
    }

    .login-container button {
      width: 100%;
      padding: 18px;
      margin-top: 25px;
      background: #1a73e8;
      border: none;
      border-radius: 14px;
      color: #fff;
      font-size: 20px;
      font-weight: 600;
      cursor: pointer;
      transition: 0.3s ease;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
    }

    .login-container button:hover {
      background: #0a4aa3;
    }

    .extras {
      margin-top: 25px;
      display: flex;
      justify-content: space-between;
      font-size: 15px;
    }

    .extras a {
      text-decoration: none;
      color: #1a73e8;
      font-weight: 500;
      transition: 0.3s ease;
    }

    .extras a:hover {
      text-decoration: underline;
    }
  </style>
</head>
<body>

  <div class="login-container">
    <form action="/api/auth/login" method="POST">
      <h2>Welcome Back</h2>
      <input type="email" name="email" placeholder="Enter your email address" required>
      <input type="password" name="password" placeholder="Enter your password" required>

      <input type="hidden" name="redirect" value="<%= redirect %>">

      

      <!-- Hidden redirect input -->
      <input type="text" name="redirectAfterLogin" id="redirectInput" hidden>

     <button type="submit"><i class="fas fa-sign-in-alt"></i> Log In</button>

      <div class="extras">
        <a href="/forgot-password">Forgot password?</a>
        <a href="/Personal">Create account</a>
      </div>
    </form>
  </div>

  <script>
    const storedRedirect = sessionStorage.getItem('redirect');
    if (storedRedirect) {
      document.getElementById('redirectInput').value = storedRedirect;
    }
  </script>
</body>
</html>
