<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css"
      rel="stylesheet"
    />
      <script src="https://cdn.tailwindcss.com"></script>
  <style>
    .category-item:hover { background-color: #f1f5f9; cursor: pointer; }
  </style>
    <link rel="stylesheet" href="/css/dashboard.css" />
    <link rel="stylesheet" href="/css/transaction.css" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <title>Adnet</title>
  </head>
  <body>



    <div class="all">
         <!-- Sidebar -->
    <%- include ("_sidebar1") %>

    <div class="main-content">

      
    <%- include ("_topnav") %>
      
          <!-- Main Content -->
    <div class="container">
      <!-- Navbar -->


    
      








       <div class="container mx-auto p-4">
    <h1 class="text-3xl font-bold mb-6 text-center">Transactions Dashboard</h1>

    <!-- Transactions Summary -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
      <div class="bg-white p-6 rounded-lg shadow-md text-center">
        <h2 class="text-xl font-semibold mb-2">Total Transactions Today</h2>
        <p class="text-3xl font-bold text-blue-600"><%= totalTransactions %></p>
      </div>
      <div class="bg-white p-6 rounded-lg shadow-md text-center">
        <h2 class="text-xl font-semibold mb-2">Sales Amount Today</h2>
        <p class="text-3xl font-bold text-green-600">₦<%= totalSales.toLocaleString() %></p>
      </div>
      <div class="bg-white p-6 rounded-lg shadow-md text-center">
        <h2 class="text-xl font-semibold mb-2">Expenses Amount Today</h2>
        <p class="text-3xl font-bold text-red-600">₦<%= totalExpenses.toLocaleString() %></p>
      </div>
         <div class="bg-white p-6 rounded-lg shadow-md text-center">
        <h2 class="text-xl font-semibold mb-2">Production Amount Today</h2>
        <p class="text-3xl font-bold text-red-600">₦<%= totalProduction.toLocaleString() %></p>
      </div>
    </div>

    <!-- Transaction Types and Details -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Transaction Types List -->
      <div class="bg-white p-6 rounded-lg shadow-md">
        <h2 class="text-2xl font-semibold mb-4">Transaction Types</h2>
        <ul class="divide-y divide-gray-200">
          <% ["Sales", "Expenses", "Production"].forEach(type => { %>
            <a href="?type=<%= type %>"><li class="category-item p-2">
              <%= type %>
            </li>
            </a>
          <% }) %>
        </ul>
      </div>

      <!-- Transaction Details Table -->
      <div class="bg-white p-6 rounded-lg shadow-md">
        <h2 class="text-2xl font-semibold mb-4">Transaction Details</h2>

        <% if (selectedType === "Sales") { %>

          <div id="salesSection" class="section">
               <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-gray-200">
                <th class="p-2">Item</th>
                <th class="p-2">Amount</th>
                <th class="p-2">Time</th>
                <th class="p-2">Quantity</th>
                <th class="p-2">Customer Name</th>
                <th class="border px-4 py-2">Note</th>
              </tr>
            </thead>
            <tbody>
              <% sales.forEach(sale => { %>
                <tr class="border-b">
                  <td class="p-2"><%= sale.item %></td>
                  <td class="p-2">₦<%= sale.amount.toLocaleString() %></td>
                  <td class="p-2"><%= new Date(sale.date).toDateString() %></td>
                  <td class="p-2"><%= sale.quantity %></td>
                  <td class="p-2"><%= sale.custormername %></td>
                  <td class="p-2"> <%= sale.discription ? sale.discription : '-' %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
          </div>
        <% } else if (selectedType === "Expenses") { %>
          <div id="expensesSection" class="section" style="display:none;">
              <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-gray-200">
                <th class="p-2">Category</th>
                <th class="p-2">Amount</th>
                <th class="p-2">Time</th>
                <th class="p-2">Description</th>
              </tr>
            </thead>
            <tbody>
              <% expenses.forEach(exp => { %>
                <tr class="border-b">
                  <td class="p-2"><%= exp.category %></td>
                  <td class="p-2">₦<%= exp.amount.toLocaleString() %></td>
                  <td class="p-2"><%= exp.time %></td>
                  <td class="p-2"><%= exp.description %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
          </div>
        <% } else if (selectedType === "Production") { %>
          <div id="summarySection" class="section" style="display:none;">
             <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-gray-200">
                <th class="p-2">Item</th>
                <th class="p-2">Cost</th>
                <th class="p-2">Time</th>
                <th class="p-2">Description</th>
              </tr>
            </thead>
            <tbody>
              <% production.forEach(prod => { %>
                <tr class="border-b">
                  <td class="p-2"><%= prod.category %></td>
                  <td class="p-2">₦<%= prod.amount.toLocaleString() %></td>
                  <td class="p-2"><%= prod.time %></td>
                  <td class="p-2"><%= prod.notes %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
          </div>
        <% } else { %>
          <p>Select a transaction type to view details.</p>
        <% } %>
      </div>
    </div>
  </div>
    </div>
    </div>
    </div>
 







    <script src="/js/dashbord.js"></script>
    <script src="/js/transaction.js"></script>
  </body>
</html>