<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Vendor Auth | AdNet</title>
  <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
  <style>
    .form-container { transition: all 0.4s ease; }
    .hidden { display: none; }
  </style>
</head>
<body class="bg-gray-100 flex items-center justify-center min-h-screen">

  <div class="bg-white shadow-lg rounded-xl p-8 w-full max-w-md">
    <h2 id="formTitle" class="text-2xl font-semibold text-center mb-6">Vendor Signup</h2>

    <!-- Signup Form -->
    <form id="signupForm" class="form-container space-y-4">
      <input type="text" name="name" placeholder="Full Name" required class="w-full border p-3 rounded">
      <input type="text" name="companyName" placeholder="Company Name" required class="w-full border p-3 rounded">
      <input type="email" name="email" placeholder="Email" required class="w-full border p-3 rounded">
      <input type="tel" name="phone" placeholder="Phone Number" required class="w-full border p-3 rounded">
      <input type="password" name="password" placeholder="Password" required class="w-full border p-3 rounded">
      <input type="password" name="confirmPassword" placeholder="Confirm Password" required class="w-full border p-3 rounded">

      <textarea name="description" placeholder="About your company..." class="w-full border p-3 rounded"></textarea>
      <input type="text" name="address" placeholder="Company Address" class="w-full border p-3 rounded">

      <div>
        <label class="block text-sm font-medium mb-1">Product Categories</label>
        <div id="categoryList" class="space-y-2"></div>
        <div class="flex gap-2">
          <input type="text" id="categoryInput" placeholder="Add a category" class="flex-1 border p-2 rounded">
          <button type="button" id="addCategoryBtn" class="bg-blue-500 text-white px-3 rounded">Add</button>
        </div>
      </div>

      <!-- 🔥 NEW FIELDS -->
      <input type="text" name="category" placeholder="Main Vendor Category (e.g. Logistics)" class="w-full border p-3 rounded">
      <input type="text" name="registrationNumber" placeholder="Registration Number (optional)" class="w-full border p-3 rounded">

      <h3 class="text-lg font-semibold mt-4">Contact Person</h3>
      <input type="text" name="contactPersonName" placeholder="Contact Person Name" class="w-full border p-3 rounded">
      <input type="email" name="contactPersonEmail" placeholder="Contact Person Email" class="w-full border p-3 rounded">
      <input type="tel" name="contactPersonPhone" placeholder="Contact Person Phone" class="w-full border p-3 rounded">

      <h3 class="text-lg font-semibold mt-4">Bank Details</h3>
      <input type="text" name="bankName" placeholder="Bank Name" class="w-full border p-3 rounded">
      <input type="text" name="accountNumber" placeholder="Account Number" class="w-full border p-3 rounded">
      <input type="text" name="paymentMethod" placeholder="Payment Method (e.g. Wire Transfer)" class="w-full border p-3 rounded">

      <button type="submit" class="w-full bg-green-600 text-white py-2 rounded">Sign Up</button>

      <p class="text-sm text-center mt-3">
        Already have an account?
        <span id="showLogin" class="text-blue-600 cursor-pointer">Login here</span>
      </p>
    </form>

    <!-- Login Form -->
    <form id="loginForm" class="form-container hidden space-y-4">
      <input type="email" name="email" placeholder="Email" required class="w-full border p-3 rounded">
      <input type="password" name="password" placeholder="Password" required class="w-full border p-3 rounded">
      <button type="submit" class="w-full bg-blue-600 text-white py-2 rounded">Login</button>

      <p class="text-sm text-center mt-3">
        Don't have an account?
        <span id="showSignup" class="text-green-600 cursor-pointer">Sign up here</span>
      </p>
    </form>
  </div>

  <script>
    const signupForm = document.getElementById('signupForm');
    const loginForm = document.getElementById('loginForm');
    const formTitle = document.getElementById('formTitle');

    document.getElementById('showLogin').addEventListener('click', () => {
      signupForm.classList.add('hidden');
      loginForm.classList.remove('hidden');
      formTitle.textContent = 'Vendor Login';
    });

    document.getElementById('showSignup').addEventListener('click', () => {
      loginForm.classList.add('hidden');
      signupForm.classList.remove('hidden');
      formTitle.textContent = 'Vendor Signup';
    });

    // ✅ Dynamic category add/remove
    const categories = [];
    document.getElementById('addCategoryBtn').addEventListener('click', () => {
      const input = document.getElementById('categoryInput');
      const value = input.value.trim();
      if (value && !categories.includes(value)) {
        categories.push(value);
        const div = document.createElement('div');
        div.className = 'flex justify-between items-center bg-gray-200 px-2 py-1 rounded';
        div.innerHTML = `<span>${value}</span><button type="button" class="text-red-600" onclick="removeCategory('${value}')">x</button>`;
        document.getElementById('categoryList').appendChild(div);
        input.value = '';
      }
    });

    function removeCategory(value) {
      const index = categories.indexOf(value);
      if (index > -1) categories.splice(index, 1);
      document.getElementById('categoryList').innerHTML = '';
      categories.forEach(cat => {
        const div = document.createElement('div');
        div.className = 'flex justify-between items-center bg-gray-200 px-2 py-1 rounded';
        div.innerHTML = `<span>${cat}</span><button type="button" class="text-red-600" onclick="removeCategory('${cat}')">x</button>`;
        document.getElementById('categoryList').appendChild(div);
      });
    }

    // ✅ Signup
    signupForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(signupForm);
      formData.append('productCategories', JSON.stringify(categories));
      const payload = Object.fromEntries(formData.entries());
      try {
        const res = await axios.post('/api/vendors/signup', payload);
        alert(res.data.message);
        window.location.href = '/Vendors';
      } catch (err) {
        alert(err.response?.data?.message || 'Signup failed');
      }
    });

    // ✅ Login
    loginForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const payload = Object.fromEntries(new FormData(loginForm).entries());
      try {
        const res = await axios.post('/api/vendors/login', payload);
        alert(res.data.message);
        window.location.href = '/Vendors';
      } catch (err) {
        alert(err.response?.data?.message || 'Login failed');
      }
    });
  </script>
</body>

</html>
