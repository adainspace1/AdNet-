      const itemsCostInput = document.querySelector("#itemsCostInput");
      const subtotalInput = document.querySelector("#subtotalInput");
      const grandTotalInput = document.querySelector("#grandTotalInput");
      const deliveryTypeSelect = document.querySelector("#deliveryType");
      const deliveryExtraFields = document.querySelector("#deliveryExtraFields");

      function refreshIndexes() {
        const rows = [...orderItems.querySelectorAll(".item-row")];
