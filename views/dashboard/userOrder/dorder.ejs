<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Create New Order</title>
  
        <link rel="stylesheet" href="/css/dashall.css">
      <link rel="stylesheet" href="/css/order.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@600&display=swap" rel="stylesheet">

  <style>
    :root {
      --blue: #4d9eff;
      --gold: #f4b740;
      --gold-light: #fbbf24;
      --dark: #1e293b;
      --gray: #64748b;
      --light: #f8fafc;
      --border: #e2e8f0;
      --success: #10b981;
      --shadow: 0 10px 30px rgba(77, 158, 255, 0.12);
    }

    body {
      margin: 0;
      background: #f1f5f9;
      font-family: 'Inter', sans-serif;
      color: var(--dark);
      min-height: 100vh;
    }

    .page-header {
      background: linear-gradient(135deg, var(--blue), var(--gold-light));
      color: white;
      padding: 2.5rem 0;
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      text-align: center;
      box-shadow: 0 10px 30px rgba(77, 158, 255, 0.3);
    }

    .page-header h1 {
      font-family: 'Playfair Display', serif;
      font-size: 2.8rem;
      font-weight: 600;
      width: 100%;
      text-align: center;
      display: flex;
      justify-content: center;
    }

    .page-header p {
      margin: 0.5rem 0 0;
      opacity: 0.95;
      font-size: 1.1rem;
    }

    .breadcrumb {
      background: white;
      padding: 1rem 0;
      border-bottom: 1px solid var(--border);
      font-size: 0.95rem;
      color: var(--gray);
    }

    .breadcrumb a {
      color: var(--blue);
      text-decoration: none;
    }

    .breadcrumb a:hover {
      text-decoration: underline;
    }

    .container {
      max-width: 1100px;
      margin: 2rem auto;
      padding: 0 1.5rem;
    }

    .order-card {
      background: white;
      border-radius: 20px;
      box-shadow: var(--shadow);
      overflow: hidden;
      margin-bottom: 2rem;
    }

    .card-header {
      background: linear-gradient(135deg, var(--blue), var(--gold-light));
      color: white;
      padding: 1.5rem 2rem;
      font-size: 1.4rem;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .card-body {
      padding: 2rem;
    }

    .section-title {
      font-size: 1.3rem;
      font-weight: 600;
      color: var(--dark);
      margin: 2rem 0 1.5rem;
      padding-bottom: 0.5rem;
      border-bottom: 2px solid var(--gold);
      display: inline-block;
    }

    .items-section {
      background: #f8fafc;
      padding: 1.5rem;
      border-radius: 16px;
      border: 1px dashed var(--border);
      margin: 1.5rem 0;
    }

    .item-row {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr auto;
      gap: 1rem;
      align-items: end;
      padding: 1rem 0;
      border-bottom: 1px solid #e2e8f0;
    }

    .item-row:last-child {
      border-bottom: none;
    }

    @media (max-width: 768px) {
      .item-row {
        grid-template-columns: 1fr;
      }
      .remove-item { justify-self: start; }
    }

    .add-item {
      background: var(--blue);
      color: white;
      border: none;
      padding: 0.8rem 1.2rem;
      border-radius: 12px;
      font-weight: 500;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      transition: all 0.3s ease;
    }

    .add-item:hover {
      background: #3b82f6;
      transform: translateY(-2px);
    }

    .remove-item {
      background: #ef4444;
      color: white;
      border: none;
      width: 36px;
      height: 36px;
      border-radius: 50%;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s ease;
    }

    .remove-item:hover {
      background: #dc2626;
      transform: scale(1.1);
    }

    .total-section {
      background: #1e293b;
      color: white;
      padding: 1.5rem 2rem;
      border-radius: 16px;
      margin: 2rem 0;
      font-size: 1.1rem;
    }

    .total-row {
      display: flex;
      justify-content: space-between;
      margin-bottom: 0.8rem;
    }

    .grand-total {
      font-size: 1.4rem;
      font-weight: 700;
      padding-top: 1rem;
      border-top: 2px solid var(--gold);
      color: var(--gold-light);
    }

    .notes textarea {
      min-height: 100px;
      resize: vertical;
    }

    .submit-section {
      text-align: right;
      padding: 2rem;
      background: white;
      border-top: 1px solid var(--border);
    }

    /* Keep your form styling untouched - only enhance layout */
    .createOrderForm .form-row {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
      margin-bottom: 1rem;
    }

    .createOrderForm .form-group {
      margin-bottom: 0;
    }

    #deliveryExtraFields {
      margin: 1.5rem 0;
      padding: 1.5rem;
      background: #f0f9ff;
      border-radius: 12px;
      border: 1px solid var(--blue);
    }

    .order-summary {
      background: linear-gradient(135deg, #f0fdf4, #ecfdf5);
      border: 1px solid #86efac;
      border-radius: 16px;
      padding: 1.5rem;
      margin: 2rem 0;
      text-align: center;
      font-size: 1.1rem;
    }

    .order-summary i {
      color: var(--success);
      font-size: 2rem;
      margin-bottom: 0.5rem;
    }
  </style>
</head>
<body>

  <!-- Enhanced Page Header -->
  <div class="page-header">
    <h1>Create New Order</h1>
    <p>Fill in the details below to create a customer order</p>
  </div>

  <div class="breadcrumb">
    <div class="container" style="max-width: 1100px; margin: 0 auto;">
      <a href="/dashboard">Dashboard</a> → 
      <a href="/orders">Orders</a> → 
      <strong>Create Order</strong>
    </div>
  </div>

  <div class="container">

    <div class="order-card">
      <div class="card-header">
        Customer & Delivery Information
      </div>

      <div class="card-body">

        <!-- YOUR ORIGINAL FORM — 100% UNTOUCHED -->
        <form class="createOrderForm" method="POST" action="/api/auth/createOrder" enctype="application/x-www-form-urlencoded">
          <input type="hidden" name="recipientId" value="<%= company.reciepientId %>">

          <div class="form-row">
            <div class="form-group">
              <label for="buyer-name">Buyer Name</label>
              <input type="text" name="buyername" id="buyer-name" placeholder="Enter Buyer's Full Name" required>
            </div>

            <div class="form-group">
              <label for="buyer-email">Buyer Email</label>
              <input type="text" name="buyeremail" id="buyer-email" placeholder="Enter Buyer's Email" required>
            </div>

            <div class="form-group">
              <label for="deliveryType">Delivery Type</label>
              <select name="delivery.type" id="deliveryType" required>
                <option value="">Select Delivery Type</option>
                <option value="self_pickup">Self Pickup</option>
                <option value="waybill">Waybill</option>
                <option value="motorcycle">Motorcycle</option>
                <option value="truck">Truck</option>
              </select>
            </div>

            <div class="form-group">
              <label for="productpassword">Product Confirmation Password</label>
              <input type="text" name="productpassword" placeholder="Enter Buyer's preferred confirmation code" required>
            </div>

            <div class="form-group">
              <label for="expectedDelivery">Expected Delivery Date</label>
              <input type="date" id="expectedDelivery" name="expectedDelivery">
            </div>
          </div>

          <div id="deliveryExtraFields"></div>

          <!-- Order Items Section -->
          <div class="section-title">Order Items</div>
          <div class="items-section">
            <div id="orderItems">
              <div class="item-row">
                <div class="form-group">
                  <label>Product</label>
                  <select class="product-select" name="items[0][product]" required>
                    <option value="">Select Product</option>
                    <% products.forEach(prod => { %>
                      <option value="<%= prod._id %>" 
                              data-price="<%= prod.scost %>" 
                              data-stock="<%= prod.currentquantity %>">
                        <%= prod.itemName %> - $<%= prod.scost.toFixed(2) %>
                      </option>
                    <% }) %>
                  </select>
                </div>

                <div class="form-group">
                  <label>Quantity</label>
                  <input type="number" class="quantity-input" name="items[0][quantity]" min="1" value="1" required>
                </div>

                <div class="form-group">
                  <label>Unit Price ($)</label>
                  <input type="number" class="price" name="items[0][unitPrice]" step="0.01" required readonly>
                </div>

                <button type="button" class="remove-item" onclick="removeItem(this)">
                  <i class="fas fa-times"></i>
                </button>
              </div>
            </div>

            <button type="button" class="add-item" onclick="addItem()">
              Add Another Item
            </button>
          </div>

          <!-- Totals -->
          <div class="total-section">
            <div class="total-row">
              <span>Items Cost:</span>
              <input type="hidden" name="itemsCost" id="itemsCostInput">
              <span id="itemsCost">$0.00</span>
            </div>
            <div class="total-row">
              <span>Subtotal:</span>
              <input type="hidden" name="subtotal" id="subtotalInput">
              <span id="subtotal">$0.00</span>
            </div>
            <div class="total-row grand-total">
              <span>Grand Total:</span>
              <input type="hidden" name="grandTotal" id="grandTotalInput">
              <span id="grandTotal">$0.00</span>
            </div>
          </div>

          <div class="form-group">
            <label for="orderNotes">Notes (Optional)</label>
            <textarea id="orderNotes" name="notes" rows="3" placeholder="Any special instructions or notes..."></textarea>
          </div>

          <div class="submit-section">
            <button type="submit" class="btn btn-primary" style="padding: 1rem 2.5rem; font-size: 1.1rem; border-radius: 12px;">
              Create Order
            </button>
          </div>
        </form>
      </div>
    </div>

    <div class="order-summary">
      <div>Tips: Double-check the delivery type and confirmation password before submitting!</div>
    </div>
  </div>

  <!-- Your existing JS is fully preserved and working -->
  <script>
    // === YOUR FULL ORIGINAL SCRIPT — UNCHANGED ===
    document.addEventListener("DOMContentLoaded", () => {
      const form = document.querySelector(".createOrderForm");
      const orderItems = document.querySelector("#orderItems");
      const itemsCostEl = document.querySelector("#itemsCost");
