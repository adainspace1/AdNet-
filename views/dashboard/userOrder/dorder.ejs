      deliveryTypeSelect.addEventListener("change", (e) => {
        renderDeliveryFields(e.target.value);
      });
      renderDeliveryFields(deliveryTypeSelect.value);

      function updateRow(row) { /* unchanged */ }
      function updateTotals() { /* unchanged */ }

      window.addItem = function () { /* unchanged */ };
      window.removeItem = function (btn) { /* unchanged */ };

      orderItems.addEventListener("input", e => {
        const row = e.target.closest(".item-row");
        if (row) updateRow(row);
      });
    });
  </script>
</body>
</html>