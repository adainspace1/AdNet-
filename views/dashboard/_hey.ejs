                    <i class='bx bx-search' style="margin-left: 8px; cursor: pointer;"></i>
                </div> -->

            <!-- Profile -->
            <div
              class="profile"
              style="
                position: relative;
                display: flex;
                align-items: center;
                cursor: pointer;
              "
            >
              <div
                class="info"
                style="display: flex; align-items: center; gap: 10px"
              >
                <img
                  src="/images/profile.png"
                  alt="Profile Picture"
                  style="width: 35px; height: 35px; border-radius: 50%"
                />
                <div>
                <a href="#" style="display: block; font-weight: bold; text-decoration: none;">
              <%= user.firstName.charAt(0).toUpperCase() + user.firstName.slice(1).toLowerCase() %>
              <%= user.lastName.charAt(0).toUpperCase() + user.lastName.slice(1).toLowerCase() %>
            </a>

                  <% if (companyinfo) { %>
            <p style="margin: 0; font-size: 12px"><%= companyinfo.businessStructure %></p>
          <% } else { %>
            <p style="margin: 0; font-size: 12px; color: gray">No company info</p>
          <% } %>

                </div>
              </div>
              <i
                class="bx bx-chevron-down"
                id="profileToggle"
                style="margin-left: 8px"
              ></i>

              <div
                id="profileDropdown"
                style="
                  display: none;
                  position: absolute;
                  top: 120%;
                  right: 0;
                  background: white;
                  border: 1px solid #ccc;
                  width: 150px;
                  flex-direction: column;
                  z-index: 100;
                  border-radius: 10px;
                  box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
                "
              >
                <a
                  href="#"
                  style="
                    padding: 10px;
                    text-decoration: none;
                    color: #333;
                    display: block;
                  "
                  >Profile</a
                >
                <a
                  href="#"
                  style="
                    padding: 10px;
                    text-decoration: none;
                    color: #333;
                    display: block;
                  "
                  >Settings</a
                >
                <a
                  href="#"
                  style="
                    padding: 10px;
                    text-decoration: none;
                    color: #333;
                    display: block;
                  "
                  >Logout</a
                >
              </div>
            </div>
          </div>
        </div>