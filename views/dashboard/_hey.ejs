


<div class="nav">
          <div class="logo">
            <i class="bx bxl-codepen"></i>
            <a href="#">Adnet</a>
          </div>

          <div
            class="right-section"
            style="
              display: flex;
              align-items: center;
              gap: 20px;
              position: relative;
            "
          >
            <!-- Notification -->
            <div
              class="notification"
              style="position: relative; display: flex; align-items: center"
            >
              <i
                class="bx bx-bell"
                id="notificationToggle"
                style="cursor: pointer; position: relative"
              >
                <span
                  class="badge"
                  style="
                    background-color: red;
                    color: white;
                    font-size: 10px;
                    padding: 2px 6px;
                    border-radius: 50%;
                    position: absolute;
                    top: -5px;
                    right: -5px;
                  "
                  >5</span
                >
              </i>

              <div
                id="notificationDropdown"
                style="
                  display: none;
                  position: absolute;
                  top: 120%;
                  right: 0;
                  background: white;
                  border: 1px solid #ccc;
                  width: 220px;
                  flex-direction: column;
                  z-index: 100;
                  border-radius: 10px;
                  box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
                "
              >
                <p
                  style="
                    padding: 10px;
                    font-weight: bold;
                    border-bottom: 1px solid #eee;
                  "
                >
                  Notifications
                </p>
                <a
                  href="#"
                  style="
                    padding: 10px;
                    text-decoration: none;
                    color: #333;
                    font-size: 14px;
                    display: flex;
                    align-items: center;
                  "
                  ><i class="bx bx-comment-detail" style="margin-right: 8px"></i
                  >New comment on product</a
                >
                <a
                  href="#"
                  style="
                    padding: 10px;
                    text-decoration: none;
                    color: #333;
                    font-size: 14px;
                    display: flex;
                    align-items: center;
                  "
                  ><i class="bx bx-user-plus" style="margin-right: 8px"></i>You
                  have a new buyer</a
                >
                <a
                  href="#"
                  style="
                    padding: 10px;
                    text-decoration: none;
                    color: #333;
                    font-size: 14px;
                    display: flex;
                    align-items: center;
                  "
                  ><i class="bx bx-message" style="margin-right: 8px"></i>New
                  message from Sarah</a
                >
                <a
                  href="#"
                  style="
                    padding: 10px;
                    text-decoration: none;
                    text-align: center;
                    display: block;
                    border-top: 1px solid #eee;
                  "
                  >View All</a
                >
              </div>
            </div>

