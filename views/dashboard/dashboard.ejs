<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/boxicons@2.1.4/css/boxicons.min.css"
    />
    <link rel="stylesheet" href="/css/dashboard.css" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <title>Adnet</title>
  </head>

  <body>
    <div class="all">
      <!-- Sidebar -->
      <%- include ("_sidebar1") %>

      <!-- Main Content -->
      <div class="top-container">
        <!-- Navbar -->
        <div class="nav">
          <div class="logo">
            <i class="bx bxl-codepen"></i>
            <a href="#">Adnet</a>
          </div>

          <div
            class="right-section"
            style="
              display: flex;
              align-items: center;
              gap: 20px;
              position: relative;
            "
          >
            <!-- Notification -->
            <div
              class="notification"
              style="position: relative; display: flex; align-items: center"
            >
              <i
                class="bx bx-bell"
                id="notificationToggle"
                style="cursor: pointer; position: relative"
              >
                <span
                  class="badge"
                  style="
                    background-color: red;
                    color: white;
                    font-size: 10px;
                    padding: 2px 6px;
                    border-radius: 50%;
                    position: absolute;
                    top: -5px;
                    right: -5px;
                  "
                  >5</span
                >
              </i>

              <div
                id="notificationDropdown"
                style="
                  display: none;
                  position: absolute;
                  top: 120%;
                  right: 0;
                  background: white;
                  border: 1px solid #ccc;
                  width: 220px;
                  flex-direction: column;
                  z-index: 100;
                  border-radius: 10px;
                  box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
                "
              >
                <p
                  style="
                    padding: 10px;
                    font-weight: bold;
                    border-bottom: 1px solid #eee;
                  "
                >
                  Notifications
                </p>
                <a
                  href="#"
                  style="
                    padding: 10px;
                    text-decoration: none;
                    color: #333;
                    font-size: 14px;
                    display: flex;
                    align-items: center;
                  "
                  ><i class="bx bx-comment-detail" style="margin-right: 8px"></i
                  >New comment on product</a
                >
                <a
                  href="#"
                  style="
                    padding: 10px;
                    text-decoration: none;
                    color: #333;
                    font-size: 14px;
                    display: flex;
                    align-items: center;
                  "
                  ><i class="bx bx-user-plus" style="margin-right: 8px"></i>You
                  have a new buyer</a
                >
                <a
                  href="#"
                  style="
                    padding: 10px;
                    text-decoration: none;
                    color: #333;
                    font-size: 14px;
                    display: flex;
                    align-items: center;
                  "
                  ><i class="bx bx-message" style="margin-right: 8px"></i>New
                  message from Sarah</a
                >
                <a
                  href="#"
                  style="
                    padding: 10px;
                    text-decoration: none;
                    text-align: center;
                    display: block;
                    border-top: 1px solid #eee;
                  "
                  >View All</a
                >
              </div>
            </div>

            <!-- Search -->
            <!-- <div class="search-bar" style="display: flex; align-items: center; border: 1px solid #363636; border-radius: 8px; padding: 5px 10px;">
                    <input type="text" placeholder="Search..." style="border: none; outline: none; font-size: 14px; background-color: none;">
                    <i class='bx bx-search' style="margin-left: 8px; cursor: pointer;"></i>
                </div> -->

            <!-- Profile -->
            <div
              class="profile"
              style="
                position: relative;
                display: flex;
                align-items: center;
                cursor: pointer;
              "
            >
              <div
                class="info"
                style="display: flex; align-items: center; gap: 10px"
              >
                <img
                  src="/images/profile.png"
                  alt="Profile Picture"
                  style="width: 35px; height: 35px; border-radius: 50%"
                />
                <div>
                <a href="#" style="display: block; font-weight: bold; text-decoration: none;">
  <%= user.firstName.charAt(0).toUpperCase() + user.firstName.slice(1).toLowerCase() %>
  <%= user.lastName.charAt(0).toUpperCase() + user.lastName.slice(1).toLowerCase() %>
</a>

                  <% if (companyinfo) { %>
  <p style="margin: 0; font-size: 12px"><%= companyinfo.businessStructure %></p>
<% } else { %>
  <p style="margin: 0; font-size: 12px; color: gray">No company info</p>
<% } %>

                </div>
              </div>
              <i
                class="bx bx-chevron-down"
                id="profileToggle"
                style="margin-left: 8px"
              ></i>

              <div
                id="profileDropdown"
                style="
                  display: none;
                  position: absolute;
                  top: 120%;
                  right: 0;
                  background: white;
                  border: 1px solid #ccc;
                  width: 150px;
                  flex-direction: column;
                  z-index: 100;
                  border-radius: 10px;
                  box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
                "
              >
                <a
                  href="#"
                  style="
                    padding: 10px;
                    text-decoration: none;
                    color: #333;
                    display: block;
                  "
                  >Profile</a
                >
                <a
                  href="#"
                  style="
                    padding: 10px;
                    text-decoration: none;
                    color: #333;
                    display: block;
                  "
                  >Settings</a
                >
                <a
                  href="#"
                  style="
                    padding: 10px;
                    text-decoration: none;
                    color: #333;
                    display: block;
                  "
                  >Logout</a
                >
              </div>
            </div>
          </div>
        </div>

        <!-- Status Section -->
        <div class="status">
          <div class="header">
            <h4 id="big">Your Analysis</h4>
            <h4 id="small">Weekly Activity</h4>
          </div>

          <div class="items-list">
            <div class="item">
              <div class="info">
                <div>
                  <h5>Total Sales/Income</h5>
                  
   <% todaySales.forEach(sale => { %>
  <p>- ₦ <%= sale.amount %> <%= sale.item %></p>
<% }) %>

                  
                </div>
                <i class="bx bx-coin-stack"></i>
              </div>
  <div class="percent-label">
    <strong style="color: <%= salesPercentage < 0 ? 'red' : 'inherit' %>;">
      <%= salesPercentage %>%
    </strong>
  </div>

<progress value="<%= salesPercentage %>" max="100" style="width: 100%; height: 10px;"></progress>

            </div>

            <div class="item">
              <div class="info">
                <div>
                  <h5>Gross Profit</h5>
                 <% todaySales.forEach(sale => { %>
  <p>- ₦ <%= sale.amount %> <%= sale.item %></p>
<% }) %>
                </div>
                <i class="bx bx-wallet"></i>
              </div>
 <div class="percent-label">
    <strong style="color: <%= grossProfitPercentage < 0 ? 'red' : 'inherit' %>;">
      <%= grossProfitPercentage %>%
    </strong>
  </div>
       
  
    <progress value="<%= grossProfitPercentage %>" max="100" style="width: 100%; height: 10px;"></progress>

            </div>
            <div class="item">
              <div class="info">
                <div>
                  <h5>Total Loss</h5>
                  <% todayExpenses.forEach(expense => { %>
                    <p>- ₦ <%= expense.amount %> <%= expense.category %></p>
                  <% }) %>
                </div>
                <i class="bx bx-sad"></i>
              </div>
  <div class="percent-label">
    <strong style="color: <%= lossPercentage < 0 ? 'red' : 'inherit' %>;">
      <%= lossPercentage %>%
    </strong>
  </div>
       
  
    <progress value="<%= lossPercentage  %>" max="100" style="width: 100%; height: 10px;"></progress>

            </div>
            <div class="item">
              <canvas class="activity-chart"></canvas>
            </div>
          </div>
        </div>

        <!-- Bottom Container -->
        <div class="bottom-container">
          <!-- Performance Overview Section -->
          <div class="prog-status">
            <div class="header">
              <h4>Performance Overview</h4>
              <div class="tabs">
                <a href="#" class="active">1Y</a>
                <a href="#">6M</a>
                <a href="#">3W</a>
              </div>
            </div>

            <div class="details">
              <div class="item">
                <h2>3.45</h2>
                <p>Current Performance Index (CPI)</p>
              </div>
              <div class="separator"></div>
              <div class="item">
                <h2>4.78</h2>
                <p>Industry Benchmark (Class Avg. CPI)</p>
              </div>
              <div class="separator"></div>
              <div class="item">
                <h2>8.18</h2>
                <p>Total Performance Yield</p>
              </div>
            </div>
            <canvas class="prog-chart"></canvas>
          </div>

          <!-- Market Trends Section -->
          <div class="popular">
            <div class="header">
              <h4>Market Trends</h4>
              <a href="#"># Growth</a>
            </div>
            <canvas id="pieChart"></canvas>

            <div class="audio">
              <i class="bx bx-podcast"></i>
              <a href="#">Podcast: The Business Edge</a>
            </div>
            <p>
              Unlock strategies to scale your business and stay ahead in the
              market.
            </p>
            <div class="listen">
              <div class="author">
                <img src="/images/profile.png" />
                <div>
                  <a href="#">Alex</a>
                  <p>Industry Expert</p>
                </div>
              </div>
              <button>Tune In<i class="bx bx-right-arrow-alt"></i></button>
            </div>
          </div>

          <!-- Upcoming Events Section -->
          <div class="upcoming">
            <div class="header">
              <h4>You may like it</h4>
              <a href="#">November <i class="bx bx-chevron-down"></i></a>
            </div>
            <div class="dates">
              <div class="item">
                <h5>Mo</h5>
                <a href="#">18</a>
              </div>
              <div class="item active">
                <h5>Tu</h5>
                <a href="#">19</a>
              </div>
              <div class="item">
                <h5>We</h5>
                <a href="#">20</a>
              </div>
              <div class="item">
                <h5>Th</h5>
                <a href="#">21</a>
              </div>
              <div class="item">
                <h5>Fr</h5>
                <a href="#">22</a>
              </div>
              <div class="item">
                <h5>Sa</h5>
                <a href="#">23</a>
              </div>
              <div class="item">
                <h5>Su</h5>
                <a href="#">24</a>
              </div>
            </div>
            <div class="events">
              <div class="item">
                <div>
                  <i class="bx bx-time"></i>
                  <div class="event-info">
                    <a href="#">Data Science</a>
                    <p>10:00-11:30</p>
                  </div>
                </div>
                <i class="bx bx-dots-horizontal-rounded"></i>
              </div>
              <div class="item">
                <div>
                  <i class="bx bx-time"></i>
                  <div class="event-info">
                    <a href="#">Machine Learning</a>
                    <p>13:30-15:00</p>
                  </div>
                </div>
                <i class="bx bx-dots-horizontal-rounded"></i>
              </div>
              <div class="item">
                <div>
                  <i class="bx bx-time"></i>
                  <div class="event-info">
                    <a href="#">Beginner Python</a>
                    <p>11:30-13:00</p>
                  </div>
                </div>
                <i class="bx bx-dots-horizontal-rounded"></i>
              </div>
              <div class="item">
                <div>
                  <i class="bx bx-time"></i>
                  <div class="event-info">
                    <a href="#">Introduction to SQL</a>
                    <p>10:00-11:30</p>
                  </div>
                </div>
                <i class="bx bx-dots-horizontal-rounded"></i>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>


    <script>
  const ctx = document.querySelector(".activity-chart");

  const weeklyData = <%- JSON.stringify(weeklySalesData) %>;

  new Chart(ctx, {
    type: "bar",
    data: {
      labels: ["M", "T", "W", "T", "F", "S", "S"],
      datasets: [
        {
          label: "Sales",
          data: weeklyData,
          backgroundColor: "#F5F5DC",
          borderWidth: 3,
          borderRadius: 6,
          hoverBackgroundColor: "#60a5fa",
        },
      ],
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      scales: {
        x: {
          border: { display: true },
          grid: { display: true, color: "#1e293b" },
        },
        y: {
          ticks: { display: false },
        },
      },
      plugins: { legend: { display: false } },
      animation: {
        duration: 1000,
        easing: "easeInOutQuad",
      },
    },
  });
</script>


    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="/js/dashbord.js"></script>
  </body>
</html>
