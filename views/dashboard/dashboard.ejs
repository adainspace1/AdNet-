<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/boxicons@2.1.4/css/boxicons.min.css"
    />
    <link rel="stylesheet" href="/css/dashboard.css" />
    <link rel="stylesheet" href="/css/dashall.css" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <title>Adnet</title>
  </head>

  <body>
    <div class="all">
      <!-- Sidebar -->
      <%- include ("_sidebar1") %>

      <!-- Main Content -->
      <div class="main-content">
        <!-- Navbar -->
        
        <%- include ("_topnav") %>
        <!-- Status Section -->
        <div class="status">
          <div class="header">
            <h4 id="big">Your Analysis</h4>
            <h4 id="small">Weekly Activity</h4>
          </div>

          <div class="items-list">
            <div class="item">
              <div class="info">
                <div>
                  <h5>Total Sales/Income</h5>
                  
   <% todaySales.forEach(sale => { %>
  <p>- ₦ <%= sale.amount %> <%= sale.item %></p>
<% }) %>

                  
                </div>
                <i class="bx bx-coin-stack"></i>
              </div>
  <div class="percent-label">
    <strong style="color: <%= salesPercentage < 0 ? 'red' : 'inherit' %>;">
      <%= salesPercentage %>%
    </strong>
  </div>

<progress value="<%= salesPercentage %>" max="100" style="width: 100%; height: 20px;"></progress>

            </div>

            <div class="item">
              <div class="info">
                <div>
                  <h5>Gross Profit</h5>
                 <% todaySales.forEach(sale => { %>
  <p>- ₦ <%= sale.amount %> <%= sale.item %></p>
<% }) %>
                </div>
                <i class="bx bx-wallet"></i>
              </div>
 <div class="percent-label">
    <strong style="color: <%= grossProfitPercentage < 0 ? 'red' : 'inherit' %>;">
      <%= grossProfitPercentage %>%
    </strong>
  </div>
       
  
    <progress value="<%= grossProfitPercentage %>" max="100" style="width: 100%; height: 20px;"></progress>

            </div>
            <div class="item">
              <div class="info">
                <div>
                  <h5>Total Loss</h5>
                  <% todayExpenses.forEach(expense => { %>
                    <p>- ₦ <%= expense.amount %> <%= expense.category %></p>
                  <% }) %>
                </div>
                <i class="bx bx-sad"></i>
              </div>
  <div class="percent-label">
    <strong style="color: <%= lossPercentage < 0 ? 'red' : 'inherit' %>;">
      <%= lossPercentage %>%
    </strong>
  </div>
       
  
    <progress value="<%= lossPercentage  %>" max="100" style="width: 100%; height: 20px;"></progress>

            </div>
            <div class="item">
              <canvas class="activity-chart"></canvas>
            </div>
          </div>
        </div>

        <!-- Bottom Container -->
          <div class="bottom-container">
    <!-- Performance Overview Section -->
    <div class="prog-status myDiv">
      <div class="header">
        <h4>Performance Overview</h4>
        <div class="tabs">
          <a href="#" class="active">1Y</a>
          <a href="#">6M</a>
          <a href="#">3W</a>
        </div>
      </div>
      <div class="details">
        <div class="item">
          <h2 id="cpi-value">3.45</h2> <!-- Will update live -->
          <p>Current Performance Index (CPI)</p>
        </div>
        <div class="separator"></div>
        <div class="item">
          <h2 id="benchmark-value">4.78</h2> <!-- Will update live -->
          <p>Industry Benchmark (Class Avg. CPI)</p>
        </div>
        <div class="separator"></div>
        <div class="item">
          <h2 id="yield-value">8.18</h2> <!-- Will update live -->
          <p>Total Performance Yield</p>
        </div>
      </div>
      <canvas class="prog-chart"></canvas>
    </div>

    <!-- Market Trends Section -->
    <div class="popular myDiv">
      <div class="header">
        <h4>Market Trends</h4>
        <a href="#"># Growth</a>
      </div>
      <canvas id="pieChart"></canvas>
      <div class="audio">
        <i class="bx bx-podcast"></i>
        <a href="#">Podcast: The Business Edge</a>
      </div>
      <p id="marketNews">
        Unlock strategies to scale your business and stay ahead in the market.
      </p>
  
    </div>
  </div>
      </div>
    </div>


    
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>






    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="/js/dashbord.js"></script>
  </body>
</html>
