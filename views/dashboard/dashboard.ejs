<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/boxicons@2.1.4/css/boxicons.min.css"
    />
    <link rel="stylesheet" href="/css/dashboard.css" />
    <link rel="stylesheet" href="/css/dashall.css" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <title>Adnet</title>
  </head>

  <body>
    <div class="all">
      <!-- Sidebar -->
      <%- include ("_sidebar1") %>

      <!-- Main Content -->
      <div class="top-container">
        <!-- Navbar -->
        
        <%- include ("_topnav") %>
        <!-- Status Section -->
        <div class="status">
          <div class="header">
            <h4 id="big">Your Analysis</h4>
            <h4 id="small">Weekly Activity</h4>
          </div>

          <div class="items-list">
            <div class="item">
              <div class="info">
                <div>
                  <h5>Total Sales/Income</h5>
                  
   <% todaySales.forEach(sale => { %>
  <p>- ₦ <%= sale.amount %> <%= sale.item %></p>
<% }) %>

                  
                </div>
                <i class="bx bx-coin-stack"></i>
              </div>
  <div class="percent-label">
    <strong style="color: <%= salesPercentage < 0 ? 'red' : 'inherit' %>;">
      <%= salesPercentage %>%
    </strong>
  </div>

<progress value="<%= salesPercentage %>" max="100" style="width: 100%; height: 10px;"></progress>

            </div>

            <div class="item">
              <div class="info">
                <div>
                  <h5>Gross Profit</h5>
                 <% todaySales.forEach(sale => { %>
  <p>- ₦ <%= sale.amount %> <%= sale.item %></p>
<% }) %>
                </div>
                <i class="bx bx-wallet"></i>
              </div>
 <div class="percent-label">
    <strong style="color: <%= grossProfitPercentage < 0 ? 'red' : 'inherit' %>;">
      <%= grossProfitPercentage %>%
    </strong>
  </div>
       
  
    <progress value="<%= grossProfitPercentage %>" max="100" style="width: 100%; height: 10px;"></progress>

            </div>
            <div class="item">
              <div class="info">
                <div>
                  <h5>Total Loss</h5>
                  <% todayExpenses.forEach(expense => { %>
                    <p>- ₦ <%= expense.amount %> <%= expense.category %></p>
                  <% }) %>
                </div>
                <i class="bx bx-sad"></i>
              </div>
  <div class="percent-label">
    <strong style="color: <%= lossPercentage < 0 ? 'red' : 'inherit' %>;">
      <%= lossPercentage %>%
    </strong>
  </div>
       
  
    <progress value="<%= lossPercentage  %>" max="100" style="width: 100%; height: 10px;"></progress>

            </div>
            <div class="item">
              <canvas class="activity-chart"></canvas>
            </div>
          </div>
        </div>

        <!-- Bottom Container -->
        <div class="bottom-container">
          <!-- Performance Overview Section -->
          <div class="prog-status myDiv">
            <div class="header">
              <h4>Performance Overview</h4>
              <div class="tabs">
                <a href="#" class="active">1Y</a>
                <a href="#">6M</a>
                <a href="#">3W</a>
              </div>
            </div>

            <div class="details">
              <div class="item">
                <h2>3.45</h2>
                <p>Current Performance Index (CPI)</p>
              </div>
              <div class="separator"></div>
              <div class="item">
                <h2>4.78</h2>
                <p>Industry Benchmark (Class Avg. CPI)</p>
              </div>
              <div class="separator"></div>
              <div class="item">
                <h2>8.18</h2>
                <p>Total Performance Yield</p>
              </div>
            </div>
            <canvas class="prog-chart"></canvas>
          </div>

          <!-- Market Trends Section -->
          <div class="popular myDiv">
            <div class="header">
              <h4>Market Trends</h4>
              <a href="#"># Growth</a>
            </div>
            <canvas id="pieChart"></canvas>

            <div class="audio">
              <i class="bx bx-podcast"></i>
              <a href="#">Podcast: The Business Edge</a>
            </div>
            <p>
              Unlock strategies to scale your business and stay ahead in the
              market.
            </p>
            <div class="listen">
              <div class="author">
                <img src="/images/profile.png" />
                <div>
                  <a href="#">Alex</a>
                  <p>Industry Expert</p>
                </div>
              </div>
              <button>Tune In<i class="bx bx-right-arrow-alt"></i></button>
            </div>
          </div>

          <!-- Upcoming Events Section -->
          <div class="upcoming myDiv">
            <div class="header">
              <h4>You may like it</h4>
              <a href="#">November <i class="bx bx-chevron-down"></i></a>
            </div>
            <div class="dates">
              <div class="item">
                <h5>Mo</h5>
                <a href="#">18</a>
              </div>
              <div class="item active">
                <h5>Tu</h5>
                <a href="#">19</a>
              </div>
              <div class="item">
                <h5>We</h5>
                <a href="#">20</a>
              </div>
              <div class="item">
                <h5>Th</h5>
                <a href="#">21</a>
              </div>
              <div class="item">
                <h5>Fr</h5>
                <a href="#">22</a>
              </div>
              <div class="item">
                <h5>Sa</h5>
                <a href="#">23</a>
              </div>
              <div class="item">
                <h5>Su</h5>
                <a href="#">24</a>
              </div>
            </div>
            <div class="events">
              <div class="item">
                <div>
                  <i class="bx bx-time"></i>
                  <div class="event-info">
                    <a href="#">Data Science</a>
                    <p>10:00-11:30</p>
                  </div>
                </div>
                <i class="bx bx-dots-horizontal-rounded"></i>
              </div>
              <div class="item">
                <div>
                  <i class="bx bx-time"></i>
                  <div class="event-info">
                    <a href="#">Machine Learning</a>
                    <p>13:30-15:00</p>
                  </div>
                </div>
                <i class="bx bx-dots-horizontal-rounded"></i>
              </div>
              <div class="item">
                <div>
                  <i class="bx bx-time"></i>
                  <div class="event-info">
                    <a href="#">Beginner Python</a>
                    <p>11:30-13:00</p>
                  </div>
                </div>
                <i class="bx bx-dots-horizontal-rounded"></i>
              </div>
              <div class="item">
                <div>
                  <i class="bx bx-time"></i>
                  <div class="event-info">
                    <a href="#">Introduction to SQL</a>
                    <p>10:00-11:30</p>
                  </div>
                </div>
                <i class="bx bx-dots-horizontal-rounded"></i>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>


    <script>
  const ctx = document.querySelector(".activity-chart");

  const weeklyData = <%- JSON.stringify(weeklySalesData) %>;

  new Chart(ctx, {
    type: "bar",
    data: {
      labels: ["M", "T", "W", "T", "F", "S", "S"],
      datasets: [
        {
          label: "Sales",
          data: weeklyData,
          backgroundColor: "#F5F5DC",
          borderWidth: 3,
          borderRadius: 6,
          hoverBackgroundColor: "#60a5fa",
        },
      ],
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      scales: {
        x: {
          border: { display: true },
          grid: { display: true, color: "#1e293b" },
        },
        y: {
          ticks: { display: false },
        },
      },
      plugins: { legend: { display: false } },
      animation: {
        duration: 1000,
        easing: "easeInOutQuad",
      },
    },
  });
</script>


    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="/js/dashbord.js"></script>
  </body>
</html>
