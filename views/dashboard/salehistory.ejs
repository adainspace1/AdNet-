<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sales History & Invoice Generator</title>
    
    <link rel="stylesheet" href="/css/salehistory.css" />
        <link rel="stylesheet" href="/css/dashall.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" integrity="sha512-Evv84Mr4kqVGRNSgIGL/F/aIDqQb7xQ2vcrdIwxfjThSH8CSR7PBEakCr51Ck+w+/U6swU2Im1vVX0SVk9ABhg==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/lucide/0.263.1/lucide.min.css">
              <link
      href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/boxicons@2.1.4/css/boxicons.min.css"
    />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">


</head>
<body>


            
    
            <div class="all">       
            <%- include ("_sidebar1") %>


    <div class="main-content">
        <%- include ("_topnav") %>
            <div class="container">
        <!-- Top Navigation Bar -->
        <!-- Header -->
        <div class="header">
            <h1>Sales History & Invoice Generator</h1>
            <p>Manage your sales transactions and generate professional invoices</p>
        </div>

        <!-- Summary Cards -->
        <div class="summary-cards">
            <div class="summary-card">
                <div class="icon"><i class="fa-solid fa-coins"></i></div>
                <h3 id="todayTotal">$0</h3>
                <p>Total Sales Today</p>
            </div>
            <div class="summary-card">
                <div class="icon"><i class="fa-solid fa-money-bill-trend-up"></i></div>
                <h3 id="monthRevenue">$0</h3>
                <p>Revenue This Month</p>
            </div>
            <div class="summary-card">
                <div class="icon"><i class="fa-solid fa-file-invoice"></i></div>
                <h3 id="invoicesGenerated">0</h3>
                <p>Invoices Generated</p>
            </div>
            <div class="summary-card">
                <div class="icon"><i class="	fa-solid fa-hourglass-half"></i></div>
                <h3 id="outstandingPayments">$0</h3>
                <p>Outstanding Payments</p>
            </div>
        </div>

        <!-- Search and Filter Controls -->
        <div class="controls">
            <div class="search-bar">
                <input type="text" id="searchInput" class="search-input" placeholder="Search by customer name or product...">
                <button class="filter-toggle" onclick="toggleFilters()">
                    <i data-lucide="filter"></i>
                    Filters
                </button>
            </div>
            
            <div class="filters hidden" id="filtersPanel">
                <div class="filter-group">
                    <label for="startDate">Start Date</label>
                    <input type="date" id="startDate">
                </div>
                <div class="filter-group">
                    <label for="endDate">End Date</label>
                    <input type="date" id="endDate">
                </div>
                <div class="filter-group">
                    <label for="paymentFilter">Payment Method</label>
                    <select id="paymentFilter">
                        <option value="all">All Methods</option>
                        <option value="Credit Card">Credit Card</option>
                        <option value="PayPal">PayPal</option>
                        <option value="Bank Transfer">Bank Transfer</option>
                        <option value="Cash">Cash</option>
                    </select>
                </div>
                <div class="filter-group">
                    <label for="statusFilter">Invoice Status</label>
                    <select id="statusFilter">
                        <option value="all">All Status</option>
                        <option value="Generated">Generated</option>
                        <option value="Not Generated">Not Generated</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- Sales Table -->
        <div class="table-container">
            <div class="table-header">
                <h2>Sales Transactions</h2>
                <div class="table-actions">
                    <button class="btn btn-primary" onclick="generateBulkInvoices()">
                        <i data-lucide="file-text"></i>
                        Generate Selected
                    </button>
                    <button class="btn btn-secondary" onclick="exportData('csv')">
                        <i data-lucide="download"></i>
                        Export CSV
                    </button>
                    <button class="btn btn-secondary" onclick="exportData('pdf')">
                        <i data-lucide="file-pdf"></i>
                        Export PDF
                    </button>
                </div>
            </div>
            <div class="tab">
                  <table class="sales-table">
                <thead>
                    <tr>
                        <th class="checkbox-cell">
                            <input type="checkbox" id="selectAll" onchange="selectAllSales()">
                        </th>
                        <th onclick="sortTable('date')">Date</th>
                        <th onclick="sortTable('customer')">Customer</th>
                        <th onclick="sortTable('products')">Products</th>
                        <th onclick="sortTable('total')">Total</th>
                        <th onclick="sortTable('paymentMethod')">Payment</th>
                        <th onclick="sortTable('invoiceStatus')">Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="salesTableBody">
                    <!-- Sales data will be populated here -->
                </tbody>
            </table>
            </div>
          

            <div class="pagination" id="pagination">
                <!-- Pagination will be populated here -->
            </div>
        </div>
    </div>

    <!-- Invoice Modal -->
    <div id="invoiceModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Generate Invoice</h2>
                <span class="close" onclick="closeInvoiceModal()">&times;</span>
            </div>
            <div class="modal-body">
                <form class="invoice-form" id="invoiceForm">
                    <div class="form-row">
                        <div class="form-group">
                            <label for="invoiceNumber">Invoice Number</label>
                            <input type="text" id="invoiceNumber" readonly>
                        </div>
                        <div class="form-group">
                            <label for="issueDate">Issue Date</label>
                            <input type="date" id="issueDate">
                        </div>
                    </div>
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label for="customerName">Customer Name</label>
                            <input type="text" id="customerName" readonly>
                        </div>
                        <div class="form-group">
                            <label for="dueDate">Due Date</label>
                            <input type="date" id="dueDate">
                        </div>
                    </div>

                    <div class="invoice-items">
                        <h3>Items</h3>
                        <div class="item-row">
                            <div><strong>Product</strong></div>
                            <div><strong>Quantity</strong></div>
                            <div><strong>Price</strong></div>
                            <div><strong>Total</strong></div>
                        </div>
                        <div id="invoiceItems">
                            <!-- Items will be populated here -->
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="paymentTerms">Payment Terms</label>
                        <input type="text" id="paymentTerms" value="Net 30">
                    </div>

                    <div class="form-group">
                        <label for="invoiceNotes">Notes</label>
                        <textarea id="invoiceNotes" placeholder="Additional notes or instructions..."></textarea>
                    </div>

                    <div class="total-section">
                        <div class="total-row">
                            <span>Subtotal:</span>
                            <span id="subtotalAmount">$0.00</span>
                        </div>
                        <div class="total-row">
                            <span>Tax (0%):</span>
                            <span id="taxAmount">$0.00</span>
                        </div>
                        <div class="total-row">
                            <span>Total:</span>
                            <span id="totalAmount">$0.00</span>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" onclick="closeInvoiceModal()">Cancel</button>
                <button class="btn btn-primary" onclick="printInvoice()">
                    <i data-lucide="printer"></i>
                    Print
                </button>
                <button class="btn btn-success" onclick="downloadInvoice()">
                    <i data-lucide="download"></i>
                    Download PDF
                </button>
            </div>
        </div>
    </div>
   <!-- Sidebar -->
    </div>




<script src="https://unpkg.com/lucide@0.441.0/dist/umd/lucide.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
let salesData = [];
let selectedSales = [];
let currentPage = 1;
const itemsPerPage = 10;
let sortField = 'date';
let sortOrder = 'desc';

// 🔹 Helper: Format large numbers (K, M, B)
function formatNumber(num) {
    if (num === null || num === undefined || isNaN(num)) return "0";
    if (num >= 1_000_000_000) return (num / 1_000_000_000).toFixed(1) + "B";
    if (num >= 1_000_000) return (num / 1_000_000).toFixed(1) + "M";
    if (num >= 1_000) return (num / 1_000).toFixed(1) + "K";
    return num.toFixed(0);
}

// 🔹 Helper: Animate numbers (smooth count-up)
function animateValue(element, start, end, duration, isCurrency = false) {
    const range = end - start;
    const startTime = performance.now();
    const step = (currentTime) => {
        const elapsed = currentTime - startTime;
        const progress = Math.min(elapsed / duration, 1);
        const value = start + range * progress;
        element.textContent = isCurrency ? `$${formatNumber(value)}` : formatNumber(value);
        if (progress < 1) requestAnimationFrame(step);
    };
    requestAnimationFrame(step);
}

document.addEventListener('DOMContentLoaded', async () => {
    // Wait for Lucide to load
    if (typeof lucide === 'undefined') {
        console.error('❌ Lucide not loaded; retrying...');
        await new Promise(resolve => setTimeout(resolve, 1000)); // Wait 1s
        if (typeof lucide === 'undefined') {
            console.warn('⚠️ Lucide failed; proceeding without icons');
        } else {
            lucide.createIcons();
        }
    } else {
        lucide.createIcons();
    }

    await Promise.all([loadSalesData(), loadChartData()]);
    setupEventListeners();
});

async function loadSalesData() {
    try {
        console.log("🔁 Fetching sales data...");
        const resp = await fetch('/api/sales');
        if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
        salesData = await resp.json();
        // Map server schema to client (amount → total, item/quantity → products)
        salesData = salesData.map(sale => ({
            id: sale._id.toString(),
            date: new Date(sale.date).toISOString().split('T')[0],
            customer: sale.customer || 'Unknown',
            products: [{ name: sale.item, quantity: sale.quantity || 1, price: sale.amount / (sale.quantity || 1) }],
            total: sale.amount,
            paymentMethod: sale.paymentMethod || 'Unknown',
            invoiceStatus: sale.invoiceStatus || 'Not Generated',
            notes: sale.notes || ''
        }));
        console.log("📦 Sales data fetched:", salesData.length, "records");
        updateSummaryCards(salesData);
        renderSalesTable(salesData);
    } catch (err) {
        console.error("❌ Error fetching sales:", err.message);
        salesData = [];
        updateSummaryCards([]);
        renderSalesTable([]);
    }
}

async function loadChartData() {
    try {
        console.log("📊 Fetching chart data...");
        const resp = await fetch('/api/sales-chart-data?type=monthly');
        if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
        const chartData = await resp.json();
        console.log("📦 Chart data fetched:", chartData);
    } catch (err) {
        console.error("❌ Error fetching chart data:", err.message);
    }
}

function setupEventListeners() {
    document.getElementById('searchInput')?.addEventListener('input', () => renderSalesTable(salesData));
    document.getElementById('startDate')?.addEventListener('change', () => renderSalesTable(salesData));
    document.getElementById('endDate')?.addEventListener('change', () => renderSalesTable(salesData));
    document.getElementById('paymentFilter')?.addEventListener('change', () => renderSalesTable(salesData));
    document.getElementById('statusFilter')?.addEventListener('change', () => renderSalesTable(salesData));
}

// 🔹 Updated to use K/M/B + animation
function updateSummaryCards(salesData) {
    const today = new Date().toISOString().split('T')[0];
    const thisMonth = new Date().toISOString().slice(0, 7);

    const todaySales = salesData.filter(sale => sale.date === today);
    const monthSales = salesData.filter(sale => sale.date.startsWith(thisMonth));
    const generatedInvoices = salesData.filter(sale => sale.invoiceStatus === 'Generated');
    const outstanding = salesData.filter(sale => sale.invoiceStatus === 'Not Generated');

    const todayTotal = todaySales.reduce((sum, sale) => sum + sale.total, 0);
    const monthRevenue = monthSales.reduce((sum, sale) => sum + sale.total, 0);
    const invoicesGenerated = generatedInvoices.length;
    const outstandingPayments = outstanding.reduce((sum, sale) => sum + sale.total, 0);

    // Animate the updates
    animateValue(document.getElementById('todayTotal'), 0, todayTotal, 800, true);
    animateValue(document.getElementById('monthRevenue'), 0, monthRevenue, 800, true);
    animateValue(document.getElementById('invoicesGenerated'), 0, invoicesGenerated, 800, false);
    animateValue(document.getElementById('outstandingPayments'), 0, outstandingPayments, 800, true);
}

function getFilteredSales(salesData) {
    const searchTerm = document.getElementById('searchInput')?.value.toLowerCase() || '';
    const startDate = document.getElementById('startDate')?.value || '';
    const endDate = document.getElementById('endDate')?.value || '';
    const paymentFilter = document.getElementById('paymentFilter')?.value || 'all';
    const statusFilter = document.getElementById('statusFilter')?.value || 'all';

    let filtered = salesData.filter(sale => {
        const matchesSearch = sale.customer.toLowerCase().includes(searchTerm) ||
            sale.products.some(product => product.name.toLowerCase().includes(searchTerm));
        const matchesPayment = paymentFilter === 'all' || sale.paymentMethod === paymentFilter;
        const matchesStatus = statusFilter === 'all' || sale.invoiceStatus === statusFilter;
        const matchesDateRange = (!startDate || sale.date >= startDate) &&
            (!endDate || sale.date <= endDate);
        return matchesSearch && matchesPayment && matchesStatus && matchesDateRange;
    });

    filtered.sort((a, b) => {
        let aValue = a[sortField];
        let bValue = b[sortField];

        if (sortField === 'date') {
            aValue = new Date(aValue);
            bValue = new Date(bValue);
        } else if (sortField === 'total') {
            aValue = Number(aValue);
            bValue = Number(bValue);
        } else if (sortField === 'products') {
            aValue = a.products.map(p => p.name).join(', ');
            bValue = b.products.map(p => p.name).join(', ');
        }

        return sortOrder === 'asc' ? (aValue > bValue ? 1 : -1) : (aValue < bValue ? 1 : -1);
    });

    return filtered;
}
function renderSalesTable(salesData) {
    const filteredSales = getFilteredSales(salesData);
    const totalPages = Math.ceil(filteredSales.length / itemsPerPage);
    const startIndex = (currentPage - 1) * itemsPerPage;
    const endIndex = startIndex + itemsPerPage;
    const currentSales = filteredSales.slice(startIndex, endIndex);

    const tableBody = document.getElementById('salesTableBody');
    if (!tableBody) return console.error("❌ salesTableBody not found");
    tableBody.innerHTML = '';

    currentSales.forEach(sale => {
        const productsText = sale.products.map(p => `${p.name} (${p.quantity})`).join(', ');
        const statusClass = sale.invoiceStatus === 'Generated' ? 'status-generated' : 'status-not-generated';

        const row = document.createElement('tr');
        row.innerHTML = `
            <td class="checkbox-cell">
                <input type="checkbox" value="${sale.id}" onchange="toggleSaleSelection('${sale.id}')">
            </td>
            <td>${formatDate(sale.date)}</td>
            <td>${sale.customer}</td>
            <td>${productsText}</td>
            <td>${sale.total.toLocaleString()}</td>
            <td><span class="payment-method">${sale.paymentMethod}</span></td>
            <td><span class="status-badge ${statusClass}">${sale.invoiceStatus}</span></td>
            <td>
                <button class="btn btn-primary" onclick="generateInvoice('${sale.id}')" style="padding: 6px 12px; font-size: 0.8rem;">
                    <i data-lucide="file-text"></i>
                    Invoice
                </button>
                <button class="btn btn-secondary" onclick="editSale('${sale.id}')" style="padding: 6px 12px; font-size: 0.8rem;">
                    <i data-lucide="edit"></i>
                    Edit
                </button>
            </td>
        `;
        tableBody.appendChild(row);
    });

    if (typeof lucide !== 'undefined') lucide.createIcons();
    renderPagination(totalPages);
    updateSelectAllCheckbox();
}


function renderPagination(totalPages) {
    const pagination = document.getElementById('pagination');
    if (!pagination) return console.error("❌ pagination not found");
    pagination.innerHTML = '';

    const prevBtn = document.createElement('button');
    prevBtn.textContent = 'Previous';
    prevBtn.disabled = currentPage === 1;
    prevBtn.onclick = () => {
        if (currentPage > 1) {
            currentPage--;
            renderSalesTable(salesData);
        }
    };
    pagination.appendChild(prevBtn);

    for (let i = 1; i <= totalPages; i++) {
        const pageBtn = document.createElement('button');
        pageBtn.textContent = i;
        pageBtn.className = i === currentPage ? 'active' : '';
        pageBtn.onclick = () => {
            currentPage = i;
            renderSalesTable(salesData);
        };
        pagination.appendChild(pageBtn);
    }

    const nextBtn = document.createElement('button');
    nextBtn.textContent = 'Next';
    nextBtn.disabled = currentPage === totalPages;
    nextBtn.onclick = () => {
        if (currentPage < totalPages) {
            currentPage++;
            renderSalesTable(salesData);
        }
    };
    pagination.appendChild(nextBtn);
}

function formatDate(dateString) {
    const date = new Date(dateString);
    return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}

function toggleSaleSelection(saleId) {
    const checkbox = document.querySelector(`input[value="${saleId}"]`);
    if (checkbox.checked) {
        if (!selectedSales.includes(saleId)) selectedSales.push(saleId);
    } else {
        selectedSales = selectedSales.filter(id => id !== saleId);
    }
    updateSelectAllCheckbox();
}

function selectAllSales() {
    const selectAllCheckbox = document.getElementById('selectAll');
    const checkboxes = document.querySelectorAll('#salesTableBody input[type="checkbox"]');

    checkboxes.forEach(checkbox => {
        checkbox.checked = selectAllCheckbox.checked;
        const saleId = checkbox.value;
        if (selectAllCheckbox.checked) {
            if (!selectedSales.includes(saleId)) selectedSales.push(saleId);
        } else {
            selectedSales = selectedSales.filter(id => id !== saleId);
        }
    });
}

function updateSelectAllCheckbox() {
    const selectAllCheckbox = document.getElementById('selectAll');
    if (!selectAllCheckbox) return;
    const checkboxes = document.querySelectorAll('#salesTableBody input[type="checkbox"]');
    const checkedCheckboxes = document.querySelectorAll('#salesTableBody input[type="checkbox"]:checked');

    if (checkboxes.length === 0) {
        selectAllCheckbox.checked = false;
        selectAllCheckbox.indeterminate = false;
    } else if (checkedCheckboxes.length === checkboxes.length) {
        selectAllCheckbox.checked = true;
        selectAllCheckbox.indeterminate = false;
    } else if (checkedCheckboxes.length > 0) {
        selectAllCheckbox.checked = false;
        selectAllCheckbox.indeterminate = true;
    } else {
        selectAllCheckbox.checked = false;
        selectAllCheckbox.indeterminate = false;
    }
}

function generateInvoice(saleId) {
    fetch(`/api/sales/${saleId}`)
        .then(resp => {
            if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
            return resp.json();
        })
        .then(sale => {
            document.getElementById('invoiceNumber').value = `INV-${Date.now()}`;
            document.getElementById('issueDate').value = new Date().toISOString().split('T')[0];
            document.getElementById('customerName').value = sale.customer;
            document.getElementById('dueDate').value = new Date(Date.now() + 30 * 24 * 60 * 60 * 1000).toISOString().split('T')[0];
            document.getElementById('paymentTerms').value = 'Net 30';
            document.getElementById('invoiceNotes').value = sale.notes || '';

            const itemsContainer = document.getElementById('invoiceItems');
            itemsContainer.innerHTML = '';
            sale.products.forEach(product => {
                const itemRow = document.createElement('div');
                itemRow.className = 'item-row';
                itemRow.innerHTML = `
                    <div>${product.name}</div>
                    <div>${product.quantity}</div>
                    <div>${product.price.toLocaleString()}</div>
                    <div>${(product.quantity * product.price).toLocaleString()}</div>
                `;
                itemsContainer.appendChild(itemRow);
            });

            document.getElementById('subtotalAmount').textContent = `$${sale.total.toLocaleString()}`;
            document.getElementById('taxAmount').textContent = '$0.00';
            document.getElementById('totalAmount').textContent = `$${sale.total.toLocaleString()}`;

            document.getElementById('invoiceModal').dataset.saleId = saleId;
            document.getElementById('invoiceModal').style.display = 'block';
        })
        .catch(err => console.error("❌ Error fetching sale:", err.message));
}

async function generateBulkInvoices() {
    if (selectedSales.length === 0) {
        alert('Please select at least one sale to generate invoices.');
        return;
    }

    if (confirm(`Generate invoices for ${selectedSales.length} selected sales?`)) {
        try {
            await Promise.all(selectedSales.map(saleId =>
                fetch(`/api/sales/${saleId}/generate-invoice`, { method: 'PATCH' })
            ));
            selectedSales = [];
            await loadSalesData();
            alert(`Successfully generated ${selectedSales.length} invoices!`);
        } catch (err) {
            console.error("❌ Error generating invoices:", err.message);
            alert("Failed to generate invoices.");
        }
    }
}

function editSale(saleId) {
    fetch(`/api/sales/${saleId}`)
        .then(resp => {
            if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
            return resp.json();
        })
        .then(sale => {
            alert(`Edit functionality would open a form to edit sale ${saleId} for customer ${sale.customer}`);
        })
        .catch(err => console.error("❌ Error fetching sale:", err.message));
}

function closeInvoiceModal() {
    document.getElementById('invoiceModal').style.display = 'none';
}

function printInvoice() {
    alert('Invoice sent to printer!');
    closeInvoiceModal();
}

async function downloadInvoice() {
    const saleId = document.getElementById('invoiceModal').dataset.saleId;
    try {
        const resp = await fetch(`/api/sales/${saleId}/generate-invoice`, { method: 'PATCH' });
        if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
        alert('Invoice downloaded as PDF!');
        await loadSalesData();
        closeInvoiceModal();
    } catch (err) {
        console.error("❌ Error updating invoice status:", err.message);
    }
}

function exportData(format) {
    const filteredSales = getFilteredSales(salesData);
    if (format === 'csv') {
        const headers = ['Date', 'Customer', 'Products', 'Total', 'Payment Method', 'Invoice Status'];
        const csvContent = [
            headers.join(','),
            ...filteredSales.map(sale => [
                sale.date,
                `"${sale.customer}"`,
                `"${sale.products.map(p => `${p.name} (${p.quantity})`).join(', ')}"`,
                sale.total,
                `"${sale.paymentMethod}"`,
                `"${sale.invoiceStatus}"`
            ].join(','))
        ].join('\n');

        const blob = new Blob([csvContent], { type: 'text/csv' });
        const url = window.URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `sales-history-${new Date().toISOString().split('T')[0]}.csv`;
        a.click();
        window.URL.revokeObjectURL(url);
    } else if (format === 'pdf') {
        alert('PDF export functionality would generate a detailed sales report here!');
    }
}

window.onclick = function (event) {
    const modal = document.getElementById('invoiceModal');
    if (event.target === modal) {
        closeInvoiceModal();
    }
};

document.addEventListener('keydown', function (event) {
    if (event.key === 'Escape') {
        closeInvoiceModal();
    }
});
</script>
</body>
</html>