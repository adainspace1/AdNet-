<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bank & Wallet Dashboard - Adnet</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background: #f8fafc;
            color: #334155;
            line-height: 1.6;
        }

        .dashboard-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }

        .dashboard-header {
            text-align: center;
            margin-bottom: 40px;
            padding: 30px 0;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border-radius: 16px;
            box-shadow: 0 10px 40px rgba(102, 126, 234, 0.3);
        }

        .dashboard-header h1 {
            font-size: 2.5rem;
            font-weight: 700;
            margin-bottom: 10px;
        }

        .dashboard-header p {
            font-size: 1.1rem;
            opacity: 0.9;
        }

        .dashboard-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            margin-bottom: 40px;
        }

        .section-card {
            background: white;
            border-radius: 16px;
            padding: 30px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
            border: 1px solid #e2e8f0;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .section-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12);
        }

        .section-title {
            font-size: 1.5rem;
            font-weight: 700;
            color: #1e293b;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .section-title::before {
            content: "";
            width: 4px;
            height: 24px;
            background: linear-gradient(135deg, #667eea, #764ba2);
            border-radius: 2px;
        }

        /* Wallet Section */
        .wallet-balance {
            background: linear-gradient(135deg, #10b981 0%, #059669 100%);
            color: white;
            padding: 25px;
            border-radius: 12px;
            margin-bottom: 25px;
            text-align: center;
        }

        .balance-label {
            font-size: 0.9rem;
            opacity: 0.9;
            margin-bottom: 5px;
        }

        .balance-amount {
            font-size: 2.5rem;
            font-weight: 700;
            letter-spacing: -1px;
        }

        .wallet-actions {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin-bottom: 15px;
        }

        .wallet-actions.three-col {
            grid-template-columns: 1fr 1fr 1fr;
        }

        .btn {
            padding: 12px 20px;
            border: none;
            border-radius: 8px;
            font-size: 0.9rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            text-decoration: none;
            text-align: center;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .btn-primary {
            background: linear-gradient(135deg, #3b82f6, #1d4ed8);
            color: white;
        }

        .btn-primary:hover {
            background: linear-gradient(135deg, #2563eb, #1e40af);
            transform: translateY(-1px);
        }

        .btn-success {
            background: linear-gradient(135deg, #10b981, #059669);
            color: white;
        }

        .btn-success:hover {
            background: linear-gradient(135deg, #059669, #047857);
            transform: translateY(-1px);
        }

        .btn-outline {
            background: white;
            color: #6366f1;
            border: 2px solid #6366f1;
        }

        .btn-outline:hover {
            background: #6366f1;
            color: white;
        }

        .btn-secondary {
            background: #64748b;
            color: white;
        }

        .btn-secondary:hover {
            background: #475569;
        }

        /* Bank Linking Form */
        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            font-weight: 600;
            color: #374151;
            margin-bottom: 8px;
            font-size: 0.9rem;
        }

        .form-control {
            width: 100%;
            padding: 12px 16px;
            border: 2px solid #e2e8f0;
            border-radius: 8px;
            font-size: 0.95rem;
            transition: border-color 0.3s ease, box-shadow 0.3s ease;
        }

        .form-control:focus {
            outline: none;
            border-color: #6366f1;
            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
        }

        .form-control.error {
            border-color: #ef4444;
        }

        .consent-checkbox {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            margin: 20px 0;
            padding: 15px;
            background: #f1f5f9;
            border-radius: 8px;
            border: 1px solid #e2e8f0;
        }

        .consent-checkbox input[type="checkbox"] {
            margin-top: 2px;
        }

        .consent-text {
            font-size: 0.85rem;
            color: #64748b;
        }

        .additional-fields {
            margin-top: 20px;
            padding: 20px;
            background: #fef3c7;
            border-radius: 8px;
            border: 1px solid #f59e0b;
            display: none;
        }

        .additional-fields.show {
            display: block;
            animation: slideDown 0.3s ease;
        }

        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .alert {
            padding: 12px 16px;
            border-radius: 8px;
            margin-bottom: 20px;
            font-size: 0.9rem;
        }

        .alert-warning {
            background: #fef3c7;
            color: #92400e;
            border: 1px solid #f59e0b;
        }

        /* Linked Banks Section */
        .linked-banks-section {
            grid-column: 1 / -1;
        }

        .banks-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
            gap: 25px;
        }

        .bank-card {
            background: white;
            border-radius: 12px;
            padding: 25px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
            border: 1px solid #e2e8f0;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .bank-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.12);
        }

        .bank-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 20px;
            padding-bottom: 15px;
            border-bottom: 1px solid #e2e8f0;
        }

        .bank-info h3 {
            font-size: 1.2rem;
            font-weight: 700;
            color: #1e293b;
            margin-bottom: 5px;
        }

        .bank-details {
            font-size: 0.85rem;
            color: #64748b;
        }

        .bank-balance {
            text-align: right;
        }

        .balance-text {
            font-size: 0.8rem;
            color: #64748b;
            margin-bottom: 2px;
        }

        .balance-value {
            font-size: 1.3rem;
            font-weight: 700;
            color: #059669;
        }

        .transactions-section h4 {
            font-size: 1rem;
            font-weight: 600;
            color: #374151;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .transactions-table {
            width: 100%;
            border-collapse: collapse;
        }

        .transactions-table th {
            background: #f8fafc;
            padding: 10px 12px;
            text-align: left;
            font-size: 0.8rem;
            font-weight: 600;
            color: #64748b;
            border-bottom: 2px solid #e2e8f0;
        }

        .transactions-table td {
            padding: 10px 12px;
            font-size: 0.85rem;
            border-bottom: 1px solid #f1f5f9;
        }

        .transactions-table tr:hover {
            background: #f8fafc;
        }

        .amount-credit {
            color: #059669;
            font-weight: 600;
        }

        .amount-debit {
            color: #dc2626;
            font-weight: 600;
        }

        .type-badge {
            padding: 3px 8px;
            border-radius: 12px;
            font-size: 0.75rem;
            font-weight: 600;
        }

        .type-credit {
            background: #dcfce7;
            color: #166534;
        }

        .type-debit {
            background: #fee2e2;
            color: #991b1b;
        }

        .no-transactions {
            text-align: center;
            color: #64748b;
            font-style: italic;
            padding: 30px;
        }

        .no-banks {
            text-align: center;
            color: #64748b;
            font-style: italic;
            padding: 40px;
        }

        .loading-spinner {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 3px solid #f3f4f6;
            border-radius: 50%;
            border-top-color: #3b82f6;
            animation: spin 1s ease-in-out infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* Responsive Design */
        @media (max-width: 768px) {
            .dashboard-grid {
                grid-template-columns: 1fr;
                gap: 20px;
            }

            .dashboard-header h1 {
                font-size: 2rem;
            }

            .wallet-actions {
                grid-template-columns: 1fr;
            }

            .wallet-actions.three-col {
                grid-template-columns: 1fr;
            }

            .banks-grid {
                grid-template-columns: 1fr;
            }

            .bank-header {
                flex-direction: column;
                align-items: flex-start;
                gap: 15px;
            }

            .bank-balance {
                text-align: left;
            }

            .transactions-table {
                font-size: 0.8rem;
            }

            .transactions-table th,
            .transactions-table td {
                padding: 8px 6px;
            }
        }

        @media (max-width: 480px) {
            .dashboard-container {
                padding: 15px;
            }

            .section-card {
                padding: 20px;
            }

            .balance-amount {
                font-size: 2rem;
            }
        }
    </style>
</head>
<body>
    <div class="dashboard-container">
        <!-- Dashboard Header -->
        <div class="dashboard-header">
            <h1>Bank & Wallet Dashboard</h1>
            <p>Manage your finances securely with Adnet</p>
        </div>

        <!-- Main Dashboard Grid -->
        <div class="dashboard-grid">
            <!-- Wallet Section -->
            <div class="section-card">
                <h2 class="section-title">💳 My Wallet</h2>
                
                <div class="wallet-balance">
                    <div class="balance-label">Available Balance</div>
                    <div class="balance-amount" id="walletBalance">₦0.00</div>
                </div>

                <div class="wallet-actions">
                    <button class="btn btn-success" onclick="fundWallet()">
                        💰 Fund Wallet
                    </button>
                    <button class="btn btn-outline" onclick="withdrawFunds()">
                        📤 Withdraw
                    </button>
                </div>

                <button class="btn btn-secondary" onclick="createWallet()" style="width: 100%; margin-top: 10px;">
                    🏦 Create Wallet (OnePipe)
                </button>
            </div>

            <!-- Bank Linking Form -->
            <div class="section-card">
                <h2 class="section-title">🏦 Link Bank Account</h2>
                
                <form id="bankLinkingForm">
                    <div class="form-group">
                        <label for="bankSelect">Select Bank</label>
                        <select id="bankSelect" name="bank" class="form-control" required>
                            <option value="">Choose your bank...</option>
                            <!-- Banks will be populated dynamically -->
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="accountNumber">Account Number</label>
                        <input type="text" id="accountNumber" name="accountNumber" class="form-control" 
                               placeholder="Enter 10-digit account number" maxlength="10" required>
                    </div>

                    <div class="form-group">
                        <label for="bvn">BVN (Optional)</label>
                        <input type="text" id="bvn" name="bvn" class="form-control" 
                               placeholder="Enter 11-digit BVN" maxlength="11">
                    </div>

                    <!-- Consent Checkbox -->
                    <div class="consent-checkbox">
                        <input type="checkbox" id="consent" name="consent" required>
                        <label for="consent" class="consent-text">
                            I authorize Adnet to securely access my account information in compliance with applicable data protection laws.
                        </label>
                    </div>

                    <!-- Additional Fields (Dynamic) -->
                    <div id="additionalFields" class="additional-fields">
                        <div class="alert alert-warning">
                            <strong>Additional verification required</strong><br>
                            Your selected bank requires additional authentication.
                        </div>
                        <!-- Dynamic fields will be inserted here -->
                    </div>

                    <button type="submit" class="btn btn-primary" style="width: 100%;">
                        🔗 Link Bank Account
                    </button>
                </form>
            </div>
        </div>

        <!-- Linked Banks Section -->
        <div class="section-card linked-banks-section">
            <h2 class="section-title">🏛️ Linked Bank Accounts</h2>
            
            <div id="linkedBanksContainer">
                <div class="banks-grid" id="banksGrid">
                    <!-- Bank cards will be populated here -->
                </div>
                
                <div class="no-banks" id="noBanks">
                    <p>No bank accounts linked yet. Use the form above to link your first account.</p>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Sample data for demonstration
        const supportedBanks = [
            { code: '044', name: 'Access Bank' },
            { code: '023', name: 'Citibank Nigeria' },
            { code: '050', name: 'Ecobank Nigeria' },
            { code: '011', name: 'First Bank of Nigeria' },
            { code: '214', name: 'First City Monument Bank' },
            { code: '070', name: 'Fidelity Bank' },
            { code: '058', name: 'Guaranty Trust Bank' },
            { code: '030', name: 'Heritage Bank' },
            { code: '082', name: 'Keystone Bank' },
            { code: '076', name: 'Polaris Bank' },
            { code: '221', name: 'Stanbic IBTC Bank' },
            { code: '068', name: 'Standard Chartered Bank' },
            { code: '232', name: 'Sterling Bank' },
            { code: '032', name: 'Union Bank of Nigeria' },
            { code: '033', name: 'United Bank For Africa' },
            { code: '215', name: 'Unity Bank' },
            { code: '035', name: 'Wema Bank' },
            { code: '057', name: 'Zenith Bank' }
        ];

        // Sample linked banks data
        const linkedBanks = [
            {
                id: 1,
                bankName: 'Access Bank',
                accountName: 'John Doe',
                accountNumber: '0123456789',
                balance: 150000.50,
                transactions: [
                    { date: '2024-09-20', description: 'Salary Credit', amount: 50000, type: 'Credit' },
                    { date: '2024-09-19', description: 'Transfer to Savings', amount: -10000, type: 'Debit' },
                    { date: '2024-09-18', description: 'Online Purchase', amount: -2500.75, type: 'Debit' },
                    { date: '2024-09-17', description: 'Refund', amount: 1200, type: 'Credit' },
                    { date: '2024-09-16', description: 'ATM Withdrawal', amount: -5000, type: 'Debit' }
                ]
            },
            {
                id: 2,
                bankName: 'GTBank',
                accountName: 'John Doe',
                accountNumber: '0987654321',
                balance: 75300.25,
                transactions: [
                    { date: '2024-09-21', description: 'Transfer In', amount: 15000, type: 'Credit' },
                    { date: '2024-09-20', description: 'Grocery Shopping', amount: -3500, type: 'Debit' },
                    { date: '2024-09-19', description: 'Bill Payment', amount: -8000, type: 'Debit' },
                    { date: '2024-09-18', description: 'Dividend Credit', amount: 2500, type: 'Credit' }
                ]
            }
        ];

        // Initialize dashboard
        document.addEventListener('DOMContentLoaded', function() {
            populateBankDropdown();
            loadWalletBalance();
            displayLinkedBanks();
            initializeFormHandlers();
        });

        // Populate bank dropdown
        function populateBankDropdown() {
            const bankSelect = document.getElementById('bankSelect');
            
            supportedBanks.forEach(bank => {
                const option = document.createElement('option');
                option.value = bank.code;
                option.textContent = bank.name;
                bankSelect.appendChild(option);
            });
        }

        // Load wallet balance (placeholder for API call)
        async function loadWalletBalance() {
            // Simulate API call
            try {
                const balance = await fetchWalletBalance();
                document.getElementById('walletBalance').textContent = formatCurrency(balance);
            } catch (error) {
                console.error('Error loading wallet balance:', error);
                document.getElementById('walletBalance').textContent = '₦0.00';
            }
        }

        // Fetch wallet balance from API (placeholder)
        async function fetchWalletBalance() {
            // TODO: Replace with actual API call
            return new Promise(resolve => {
                setTimeout(() => resolve(25000.75), 1000);
            });
        }

        // Display linked banks
        function displayLinkedBanks() {
            const banksGrid = document.getElementById('banksGrid');
            const noBanks = document.getElementById('noBanks');
            
            if (linkedBanks.length === 0) {
                noBanks.style.display = 'block';
                banksGrid.style.display = 'none';
                return;
            }
            
            noBanks.style.display = 'none';
            banksGrid.style.display = 'grid';
            
            banksGrid.innerHTML = '';
            
            linkedBanks.forEach(bank => {
                const bankCard = createBankCard(bank);
                banksGrid.appendChild(bankCard);
            });
        }

        // Create bank card element
        function createBankCard(bank) {
            const card = document.createElement('div');
            card.className = 'bank-card';
            
            card.innerHTML = `
                <div class="bank-header">
                    <div class="bank-info">
                        <h3>${bank.bankName}</h3>
                        <div class="bank-details">
                            ${bank.accountName}<br>
                            ${bank.accountNumber}
                        </div>
                    </div>
                    <div class="bank-balance">
                        <div class="balance-text">Balance</div>
                        <div class="balance-value">${formatCurrency(bank.balance)}</div>
                    </div>
                </div>
                
                <div class="transactions-section">
                    <h4>📊 Recent Transactions</h4>
                    ${createTransactionsTable(bank.transactions)}
                </div>
            `;
            
            return card;
        }

        // Create transactions table
        function createTransactionsTable(transactions) {
            if (!transactions || transactions.length === 0) {
                return '<div class="no-transactions">No recent transactions</div>';
            }
            
            let tableHTML = `
                <table class="transactions-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Description</th>
                            <th>Amount</th>
                            <th>Type</th>
                        </tr>
                    </thead>
                    <tbody>
            `;
            
            transactions.forEach(tx => {
                const amountClass = tx.amount > 0 ? 'amount-credit' : 'amount-debit';
                const typeClass = tx.type.toLowerCase() === 'credit' ? 'type-credit' : 'type-debit';
                const amountText = tx.amount > 0 ? `+${formatCurrency(tx.amount)}` : formatCurrency(tx.amount);
                
                tableHTML += `
                    <tr>
                        <td>${formatDate(tx.date)}</td>
                        <td>${tx.description}</td>
                        <td class="${amountClass}">${amountText}</td>
                        <td><span class="type-badge ${typeClass}">${tx.type}</span></td>
                    </tr>
                `;
            });
            
            tableHTML += '</tbody></table>';
            return tableHTML;
        }

        // Initialize form handlers
        function initializeFormHandlers() {
            const form = document.getElementById('bankLinkingForm');
            const bankSelect = document.getElementById('bankSelect');
            const accountNumber = document.getElementById('accountNumber');
            
            // Bank selection handler
            bankSelect.addEventListener('change', function() {
                handleBankSelection(this.value);
            });
            
            // Account number validation
            accountNumber.addEventListener('input', function() {
                this.value = this.value.replace(/\D/g, '');
                validateAccountNumber(this);
            });
            
            // BVN validation
            document.getElementById('bvn').addEventListener('input', function() {
                this.value = this.value.replace(/\D/g, '');
            });
            
            // Form submission
            form.addEventListener('submit', function(e) {
                e.preventDefault();
                handleBankLinking();
            });
        }

        // Handle bank selection
        function handleBankSelection(bankCode) {
            const additionalFields = document.getElementById('additionalFields');
            
            // Some banks might require additional fields
            const banksRequiringAuth = ['044', '058']; // Access Bank, GTBank
            
            if (banksRequiringAuth.includes(bankCode)) {
                showAdditionalFields();
            } else {
                hideAdditionalFields();
            }
        }

        // Show additional authentication fields
        function showAdditionalFields() {
            const container = document.getElementById('additionalFields');
            container.innerHTML = `
                <div class="alert alert-warning">
                    <strong>Additional verification required</strong><br>
                    Your selected bank requires additional authentication.
                </div>
                <div class="form-group">
                    <label for="pin">Transaction PIN</label>
                    <input type="password" id="pin" name="pin" class="form-control" 
                           placeholder="Enter your 4-digit PIN" maxlength="4" required>
                </div>
            `;
            container.classList.add('show');
        }

        // Hide additional fields
        function hideAdditionalFields() {
            const container = document.getElementById('additionalFields');
            container.classList.remove('show');
            setTimeout(() => {
                container.innerHTML = '';
            }, 300);
        }

        // Validate account number
        function validateAccountNumber(input) {
            const value = input.value;
            if (value.length !== 10) {
                input.classList.add('error');
            } else {
                input.classList.remove('error');
            }
        }

        // Handle bank linking
        async function handleBankLinking() {
            const form = document.getElementById('bankLinkingForm');
            const formData = new FormData(form);
            const submitBtn = form.querySelector('button[type="submit"]');
            
            // Show loading state
            const originalText = submitBtn.innerHTML;
            submitBtn.innerHTML = '<span class="loading-spinner"></span> Linking Account...';
            submitBtn.disabled = true;
            
            try {
                // TODO: Replace with actual API call
                const response = await linkBankAccount({
                    bank: formData.get('bank'),
                    accountNumber: formData.get('accountNumber'),
                    bvn: formData.get('bvn'),
                    pin: formData.get('pin'),
                    consent: formData.get('consent')
                });
                
                if (response.success) {
                    alert('Bank account linked successfully!');
                    form.reset();
                    hideAdditionalFields();
                    // Refresh linked banks display
                    displayLinkedBanks();
                } else {
                    alert('Failed to link bank account: ' + response.message);
                }
            } catch (error) {
                console.error('Error linking bank account:', error);
                alert('An error occurred while linking your bank account. Please try again.');
            } finally {
                submitBtn.innerHTML = originalText;
                submitBtn.disabled = false;
            }
        }

        // Wallet actions
        function fundWallet() {
            alert('Fund Wallet functionality - integrate with Paystack/OnePipe API');
        }

        function withdrawFunds() {
            alert('Withdraw functionality - integrate with payment provider');
        }

        function createWallet() {
            alert('Create Wallet functionality - integrate with OnePipe wallet API');
        }

        // API placeholder functions
        async function linkBankAccount(data) {
            // TODO: Replace with actual API call to OnePipe
            return new Promise(resolve => {
                setTimeout(() => {
                    resolve({ success: true, message: 'Account linked successfully' });
                }, 2000);
            });
        }

        // Utility functions
        function formatCurrency(amount) {
            return new Intl.NumberFormat('en-NG', {
                style: 'currency',
                currency: 'NGN',
                minimumFractionDigits: 2
            }).format(Math.abs(amount));
        }

        function formatDate(dateString) {
            const date = new Date(dateString);
            return date.toLocaleDateString('en-NG', {
                month: 'short',
                day: 'numeric'
            });
        }
    </script>
</body>
</html>