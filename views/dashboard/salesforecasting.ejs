<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sales Forecasting - Adnet</title>
    <link rel="stylesheet" href="/css/saleforecast.css">
    <link rel="stylesheet" href="/css/dashall.css">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/iconify/2.0.0/iconify.min.js"></script>
     <link
      href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/boxicons@2.1.4/css/boxicons.min.css"
    />
</head>
<body>


    <div class="all">
              <!-- Sidebar -->
      <%- include ("_sidebar1") %>

       <div class="main-content">
                <%- include ("_topnav") %>
    <div class="container">
 

            <header class="header">
                <h1>Sales Forecasting Dashboard</h1>
                
            </header>
            
            <div class="content-grid">
                <section class="forecast-section">
                    <h2 class="section-title">
                        <div class="section-icon">
                            <iconify-icon icon="tabler:chart-line" width="20" height="20"></iconify-icon>
                        </div>
                        Future Sales Prediction
                    </h2>
                    
                    <div class="forecast-cards">
                        <div class="forecast-card">
<div class="forecast-value">₦<%= Number(forecast.nextMonth).toLocaleString() %></div>
                            <div class="forecast-label">Next Month</div>
                            <div class="forecast-trend trend-up">
                                  <iconify-icon icon="tabler:trending-up" width="16" height="16"></iconify-icon>
                                <%= forecast.trendPercent %>%
                            </div>
                        </div>
                        
                        <div class="forecast-card">
<div class="forecast-value">₦<%= Number(forecast.nextQuarter).toLocaleString() %></div>
                            <div class="forecast-label">Next Quarter</div>
                             <div class="forecast-trend trend-up">
                                <iconify-icon icon="tabler:trending-up" width="16" height="16"></iconify-icon>
                                <%= forecast.trendPercent %>%
                            </div>
                        </div>
                    </div>
                    
                   
                        <!-- Sales Forecasting Section -->
                <section id="sales-forecast" class="dashboard-section">
                    <h2 class="section-title">AI Sales Forecast</h2>
                    <div class="ai-forecast-cards">
                        <div class="ai-card" id="predicted-sales">
                        <h3>Predicted Sales (Next Month)</h3>
                        <p class="value">₦<%= Number(forecast.nextMonth).toLocaleString() %></p>
                        </div>
                        <div class="ai-card" id="revenue-trend">
                        <h3>Revenue Trend</h3>
                        <p class="value"><%= forecast.trendPercent %>%</p>
                        </div>
                        <div class="ai-card" id="sales-cycle-length">
                        <h3>Sales Cycle Length</h3>
                        <p class="value"><%= forecast.cycleLength %> days</p>
                        </div>
                    </div>
                </section>
                        </section>
                
             
                
                <section class="forecast-section">
                    <h2 class="section-title">
                        <div class="section-icon">
                            <iconify-icon icon="tabler:currency-dollar" width="20" height="20"></iconify-icon>
                        </div>
                        Revenue Forecasting
                    </h2>
                    
                    <div class="forecast-cards">
                        <div class="forecast-card">
                            <div class="forecast-value">₦<%= Number(forecast.nextMonth).toLocaleString() %></div>
                            <div class="forecast-label">Projected Revenue</div>
                         <div class="forecast-trend trend-up">
                            <iconify-icon icon="tabler:trending-up" width="16" height="16"></iconify-icon>
                            <%= forecast.trendPercent %>%
                            </div>
                        </div>
                        
                        <div class="forecast-card">
                           <div class="forecast-value pulse"><%= forecast.confidenceLevel %>%</div>
                            <div class="forecast-label">Confidence Level</div>
                            <div class="forecast-trend confidence-high">
                            <iconify-icon icon="tabler:shield-check" width="16" height="16"></iconify-icon>
                            <%= forecast.accuracyNote %>
                            </div>
                        </div>
                    </div>

                       <!-- Revenue Trend Analysis Section -->
                <section id="revenue-trend-analysis" class="trend-analysis-section">
                <div class="trend-header">
                    <h2>Revenue Trend Analysis</h2>
                    <span class="trend-subtext">Powered by AI</span>
                </div>
                <div class="trend-grid">
                    <div class="trend-card">
                    <h3>MONTHLY REVENUE</h3>
                    <div class="trend-metric">
                        <span class="trend-value">₦<%= Number(forecast.monthlyTotal).toLocaleString() %></span>
                        <span class="trend-change trend-up">
                        <iconify-icon icon="tabler:arrow-up" width="16"></iconify-icon>
                        <%= forecast.trendPercent %>%
                        </span>
                    </div>
                    <canvas class="sparkline" id="revenue-sparkline"></canvas>
                    </div>
                    <div class="trend-card">
                    <h3>QUARTERLY GROWTH</h3>
                    <div class="trend-metric">
                        
                        <span class="trend-value">₦<%= Number(forecast.quarterlyTotal).toLocaleString() %></span>
                        <span class="trend-change trend-down">
                        <iconify-icon icon="tabler:arrow-down" width="16"></iconify-icon>
                        <%= forecast.trendPercent %>%
                        </span>
                    </div>
                    <canvas class="sparkline" id="quarterly-sparkline"></canvas>
                    </div>
                </div>
                </section>
                </section>

                    
            <section class="cycle-analysis">
                <h2 class="section-title">
                    <div class="section-icon">
                        <iconify-icon icon="tabler:chart-dots" width="20" height="20"></iconify-icon>
                    </div>
                    Sales Cycle Length Analysis
                </h2>
                
                <div class="cycle-metrics">
                    <div class="cycle-metric">
                        <div class="metric-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 256 256"><g fill="none" stroke="#2d9bdd" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"><rect width="224" height="224" x="16" y="16" ry="32"/><path d="M 160.00003,192.00003 V 111.99998"/><path d="M 192.00002,192.00003 V 63.999974"/><path d="m 63.999979,192.00003 v -32"/><path d="m 95.99997,128 v 64.00003"/><path d="m 128,144 v 48.00003"/></g></svg>
                        </div>
                        <div class="metric-value">24.5</div>
                        <div class="metric-label">Average Cycle Days</div>
                    </div>
                    
                    <div class="cycle-metric">
                        <div class="metric-icon">
                           <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24"><path fill="#2d9bdd" d="m9.154 20.885l1-6.885h-4.25l7.48-10.788h.462L12.866 11h5l-8.25 9.885z"/></svg>
                        </div>
                        <div class="metric-value">18.2</div>
                        <div class="metric-label">Fastest Cycle Days</div>
                    </div>
                    
                    <div class="cycle-metric">
                        <div class="metric-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24"><path fill="#2d9bdd" d="M3.4 18L2 16.6l7.4-7.45l4 4L18.6 8H16V6h6v6h-2V9.4L13.4 16l-4-4z"/></svg>
                        </div>
                        <div class="metric-value">42.7</div>
                        <div class="metric-label">Longest Cycle Days</div>
                    </div>
                    
                    <div class="cycle-metric">
                        <div class="metric-icon">
                          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24"><path fill="#2d9bdd" d="m18.5 3.5l-15 15l2 2l15-15M7 4a3 3 0 0 0-3 3a3 3 0 0 0 3 3a3 3 0 0 0 3-3a3 3 0 0 0-3-3m10 10a3 3 0 0 0-3 3a3 3 0 0 0 3 3a3 3 0 0 0 3-3a3 3 0 0 0-3-3"/></svg>
                        </div>
                        <div class="metric-value">73%</div>
                        <div class="metric-label">Conversion Rate</div>
                    </div>
                    
                    <div class="cycle-metric">
                        <div class="metric-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24"><path fill="#2d9bdd" d="M11.1 19h1.75v-1.25q1.25-.225 2.15-.975t.9-2.225q0-1.05-.6-1.925T12.9 11.1q-1.5-.5-2.075-.875T10.25 9.2t.463-1.025T12.05 7.8q.8 0 1.25.387t.65.963l1.6-.65q-.275-.875-1.012-1.525T12.9 6.25V5h-1.75v1.25q-1.25.275-1.95 1.1T8.5 9.2q0 1.175.688 1.9t2.162 1.25q1.575.575 2.188 1.025t.612 1.175q0 .825-.587 1.213t-1.413.387t-1.463-.512T9.75 14.1l-1.65.65q.35 1.2 1.088 1.938T11.1 17.7zm.9 3q-2.075 0-3.9-.788t-3.175-2.137T2.788 15.9T2 12t.788-3.9t2.137-3.175T8.1 2.788T12 2t3.9.788t3.175 2.137T21.213 8.1T22 12t-.788 3.9t-2.137 3.175t-3.175 2.138T12 22"/></svg>
                        </div>
                        <div class="metric-value">₦2.8M</div>
                        <div class="metric-label">Avg Deal Size</div>
                    </div>
                </div>
            </section>
                    </div>
               
           
            </div>
   
    </div>
    </div>
   

    <script src="/js/salesforecast.js"></script>
</body>
</html>