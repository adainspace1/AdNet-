<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Easy Audit – Auto & Manual</title>
  <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css" rel="stylesheet">
  <style>
    .match-green { @apply bg-green-100 text-green-800; }
    .match-yellow { @apply bg-yellow-100 text-yellow-800; }
    .match-red { @apply bg-red-100 text-red-800; }
    .tab-active { @apply bg-blue-600 text-white; }
    .Adnetlogo{
    color: black;
}
  </style>
</head>
<body class="bg-gray-50 font-sans">



    <div  class="all">

        <%- include ("../_sidebar1") %>

            <div class="main-content">
                    <%- include ("../_topnav") %>

                <div class="container mx-auto p-4 max-w-7xl">

                <!-- Header -->
                <div class="flex justify-between items-center mb-6">
                    <h1 class="text-3xl font-bold text-gray-800">Easy Audit Dashboard</h1>
                    <button id="export-report" class="bg-green-600 text-white px-4 py-2 rounded-lg flex items-center gap-2">
                    <i class="ti ti-download"></i> Export Report
                    </button>
                </div>

                <!-- Tabs: Auto vs Manual -->
                <div class="flex space-x-1 mb-6 bg-gray-100 p-1 rounded-lg w-fit">
                    <button id="tab-auto" class="tab-active px-6 py-2 rounded-md font-medium">Automatic Audit</button>
                    <button id="tab-manual" class="px-6 py-2 rounded-md font-medium text-gray-600 hover:bg-gray-200">Manual Audit</button>
                </div>

                <!-- DASHBOARD WIDGETS -->
                <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4 mb-8">
                    <div class="bg-white p-4 rounded-lg shadow text-center">
                    <p class="text-2xl font-bold text-blue-600" id="total-audits">0</p>
                    <p class="text-sm text-gray-500">Audits This Month</p>
                    </div>
                    <div class="bg-white p-4 rounded-lg shadow text-center">
                    <p class="text-2xl font-bold text-red-600" id="mismatches">0</p>
                    <p class="text-sm text-gray-500">Mismatches Found</p>
                    </div>
                    <div class="bg-white p-4 rounded-lg shadow text-center">
                    <p class="text-2xl font-bold text-orange-600" id="amount-diff">₦0</p>
                    <p class="text-sm text-gray-500">Amount Difference</p>
                    </div>
                    <div class="bg-white p-4 rounded-lg shadow text-center">
                    <p class="text-2xl font-bold text-purple-600" id="stock-diff">0</p>
                    <p class="text-sm text-gray-500">Stock Discrepancy</p>
                    </div>
                    <div class="bg-white p-4 rounded-lg shadow text-center">
                    <p class="text-2xl font-bold text-green-600" id="approved">0</p>
                    <p class="text-sm text-gray-500">Approved</p>
                    </div>
                    <div class="bg-white p-4 rounded-lg shadow text-center">
                    <p class="text-2xl font-bold text-red-600" id="disapproved">0</p>
                    <p class="text-sm text-gray-500">Disapproved</p>
                    </div>
                </div>

                <!-- Filters -->
                <div class="bg-white p-4 rounded-lg shadow mb-6 flex flex-wrap gap-3 items-center">
                    <input type="date" id="filter-date-from" class="px-3 py-2 border rounded-md">
                    <input type="date" id="filter-date-to" class="px-3 py-2 border rounded-md">
                    <select id="filter-staff" class="px-3 py-2 border rounded-md">
                    <option>All Staff</option>
                    </select>
                    <select id="filter-product" class="px-3 py-2 border rounded-md">
                    <option>All Products</option>
                    </select>
                    <select id="filter-type" class="px-3 py-2 border rounded-md">
                    <option>All Types</option>
                    <option>Automatic</option>
                    <option>Manual</option>
                    </select>
                    <input type="text" id="search" placeholder="Search receipt, product..." class="flex-1 px-3 py-2 border rounded-md">
                </div>

                <!-- AUTOMATIC MODE -->
                <div id="auto-mode">
                        <!-- NEW AUDIT MODULE SELECTION -->
                  <div id="audit-selection" class="bg-white p-6 rounded-lg shadow mb-6">
                    <h2 class="text-xl font-bold mb-4">Start Automatic Audit</h2>
                    <p class="text-gray-600 mb-4">Choose a primary module, then select its comparison module.</p>

                    <!-- Primary -->
                    <div class="mb-4">
                      <label class="block text-gray-700 font-medium mb-1">Primary Module</label>
                      <select id="primary-module" class="w-full border px-3 py-2 rounded-lg">
                        <option value="">Select...</option>
                        <option value="inventory">Inventory</option>
                        <option value="sales">Sales</option>
                        <option value="production">Production</option>
                        <option value="order">Orders</option>
                        <option value="expense">Expenses</option>
                        <option value="budget">Budget</option>
                    </select>
                    </div>

                    <!-- Secondary (Dynamic) -->
                    <div class="mb-4">
                      <label class="block text-gray-700 font-medium mb-1">Secondary Module</label>
                      <select id="secondary-module" class="w-full border px-3 py-2 rounded-lg">
                        <option value="">Select primary first...</option>
                      </select>
                    </div>

                    <button id="start-audit" class="mt-4 bg-blue-600 text-white px-6 py-3 rounded-lg w-full">
                      Continue
                    </button>
                  </div>



                    <div id="auto-results" class="hidden bg-white rounded-lg shadow overflow-hidden">
                    <div class="p-4 border-b">
                        <h3 class="font-semibold">Automatic Audit Results</h3>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="min-w-full">
                        <thead class="bg-gray-50">
                            <tr>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Product</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Goods Received</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Sold</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Expected $</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actual $</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Difference</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Action</th>
                            </tr>
                        </thead>
                        <tbody id="auto-table-body"></tbody>
                        </table>
                    </div>
                    </div>
                </div>

                <!-- MANUAL MODE -->
                <div id="manual-mode" class="hidden">
                    <div class="bg-white rounded-lg shadow p-6">
                    <h2 class="text-xl font-bold mb-4">Manual Audit – Enter Your Records</h2>
                    <form id="manual-form" class="grid md:grid-cols-2 gap-4">
    <input 
        type="text" 
        name="product" 
        placeholder="Product Name" 
        required 
        class="px-4 py-2 border rounded-lg"
    >

    <input 
        type="number" 
        name="received" 
        placeholder="Quantity Received" 
        required 
        class="px-4 py-2 border rounded-lg"
    >

    <input 
        type="number" 
        name="sold" 
        placeholder="Quantity Sold" 
        required 
        class="px-4 py-2 border rounded-lg"
    >

    <input 
        type="number" 
        name="expected" 
        placeholder="Expected Amount ($)" 
        required 
        class="px-4 py-2 border rounded-lg"
    >

    <input 
        type="number" 
        name="actual" 
        placeholder="Actual Amount Paid ($)" 
        required 
        class="px-4 py-2 border rounded-lg"
    >

    <input 
        type="file" 
        name="files" 
        multiple 
        accept=".pdf,.jpg,.png" 
        class="md:col-span-2"
    >

    <textarea 
        name="notes" 
        placeholder="Add notes or explain difference..." 
        class="md:col-span-2 px-4 py-2 border rounded-lg" 
        rows="3"
    ></textarea>

    <button 
        type="submit" 
        class="bg-green-600 text-white px-6 py-2 rounded-lg md:col-span-2"
    >
        Compare & Save
    </button>
</form>

                    </div>

                    <div id="manual-results" class="mt-6 hidden bg-white rounded-lg shadow p-6">
                    <h3 class="font-bold mb-4">Your Manual Audit Result</h3>
                    <div id="manual-result-body"></div>
                    </div>
                </div>

                </div>
            </div>

                <!-- MODAL -->
                <div id="detail-modal" class="fixed inset-0 bg-black bg-opacity-50 hidden flex items-center justify-center z-50">
                <div class="bg-white rounded-xl p-6 max-w-2xl w-full max-h-screen overflow-y-auto">
                    <div class="flex justify-between items-center mb-4">
                    <h3 class="text-xl font-bold">Audit Detail</h3>
                    <button onclick="closeModal()" class="text-gray-500"><i class="ti ti-x"></i></button>
                    </div>
                    <div id="modal-content"></div>
                </div>
                </div>

    </div>










<script>
// --- 1. Dynamic Dropdown Logic ---
const primarySelect = document.getElementById('primary-module');
const secondarySelect = document.getElementById('secondary-module');
const startAuditButton = document.getElementById('start-audit');
const autoResultsContainer = document.getElementById('auto-results');
const autoTableBody = document.getElementById('auto-table-body');

// Renamed variable to avoid conflicts
const auditModules = [
    { val: 'inventory', txt: 'Inventory' },
    { val: 'sales', txt: 'Sales' },
    { val: 'production', txt: 'Production' },
    { val: 'order', txt: 'Orders' },
    { val: 'expense', txt: 'Expenses' },
    { val: 'budget', txt: 'Budget' } // <--- ADDED BUDGET MODULE
];

primarySelect.addEventListener('change', function() {
    const selected = this.value;
    secondarySelect.innerHTML = '<option value="">None (Single Audit)</option>';
    
    auditModules.forEach(mod => {
        if (mod.val !== selected) {
            const opt = document.createElement('option');
            opt.value = mod.val;
            opt.innerText = mod.txt;
            secondarySelect.appendChild(opt);
        }
    });
});

// --- 2. Main Audit Function (Start Audit Button) ---
startAuditButton.addEventListener('click', async () => {
    const primary = primarySelect.value;
    const secondary = secondarySelect.value;
    
    // Optional Date Filters
    const startDate = document.getElementById('filter-date-from').value;
    const endDate = document.getElementById('filter-date-to').value;

    if (!primary) {
        alert("Please select a Primary Module.");
        return;
    }

    // UI Feedback
    startAuditButton.innerHTML = '<i class="ti ti-loader animate-spin"></i> Auditing...';
    startAuditButton.disabled = true;

    try {
        const response = await fetch('/user/analyze', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ primary, secondary, startDate, endDate })
        });

        const data = await response.json();

        if (data.success) {
            updateStats(data.stats);
            renderTable(data.results, primary, secondary);
            autoResultsContainer.classList.remove('hidden');
        } else {
            alert("Audit failed: " + data.message);
        }

    } catch (err) {
        console.error(err);
        alert("Error connecting to server. Check console for details.");
    } finally {
        startAuditButton.innerHTML = 'Continue';
        startAuditButton.disabled = false;
    }
});

// --- 3. Utility & Render Functions ---


function formatCompact(num) {
    if (num >= 1_000_000_000) return (num / 1_000_000_000).toFixed(1).replace(/\.0$/, '') + "B";
    if (num >= 1_000_000) return (num / 1_000_000).toFixed(1).replace(/\.0$/, '') + "M";
    if (num >= 1_000) return (num / 1_000).toFixed(1).replace(/\.0$/, '') + "K";
    return num.toString();
}


function updateStats(stats) {
    // Use compact formatter
    document.getElementById('total-audits').innerText = formatCompact(stats.totalItems || 0);
    
    const mmEl = document.getElementById('mismatches');
    mmEl.innerText = formatCompact(stats.mismatches || 0);
    mmEl.className = stats.mismatches > 0 
        ? "text-2xl font-bold text-red-600" 
        : "text-2xl font-bold text-green-600";

    // Amount Difference with Naira sign
    document.getElementById('amount-diff').innerText = '₦' + formatCompact(stats.totalAmountDiff || 0);

    document.getElementById('stock-diff').innerText = formatCompact(stats.stockDiscrepancy || 0);
    
    // Approved / Disapproved also compact
    const approved = (stats.totalItems || 0) - (stats.mismatches || 0);
    const disapproved = stats.mismatches || 0;

    document.getElementById('approved').innerText = formatCompact(approved);
    document.getElementById('disapproved').innerText = formatCompact(disapproved);
}


function renderTable(results, primaryName, secondaryName) {
    autoTableBody.innerHTML = '';

    results.forEach(row => {
        const tr = document.createElement('tr');
        
        let statusClass = 'bg-green-100 text-green-800';
        
        if (row.status === 'Mismatch') {
            statusClass = 'bg-red-100 text-red-800';
        }

        // Use secondaryQty || 0 and secondaryAmt || 0 for safer function calls
        const secondaryQtySafe = row.secondaryQty || 0;
        const secondaryAmtSafe = row.secondaryAmt || 0;

        // Custom label for 'Qty' columns if modules are Expense/Budget (where Qty is just 1)
        let primaryQtyLabel = 'Qty';
        let secondaryQtyLabel = '';
        if (primaryName === 'expense' || primaryName === 'budget') primaryQtyLabel = 'Count';
        if (secondaryName === 'expense' || secondaryName === 'budget') secondaryQtyLabel = 'Count';

        tr.innerHTML = `
            <td class="px-4 py-3 whitespace-nowrap font-medium text-gray-900">${row.product}</td>
            <td class="px-4 py-3 text-gray-600">${row.primaryQty} <span class="text-xs text-gray-400">(${primaryQtyLabel})</span></td>
            <td class="px-4 py-3 text-gray-600">${secondaryName ? secondaryQtySafe : '-'} <span class="text-xs text-gray-400">(${secondaryQtyLabel})</span></td>
            <td class="px-4 py-3 text-gray-600">₦${row.primaryAmt.toLocaleString()}</td>
            <td class="px-4 py-3 text-gray-600">${secondaryName ? '₦'+secondaryAmtSafe.toLocaleString() : '-'}</td>
            <td class="px-4 py-3 font-bold ${row.diffAmt < 0 ? 'text-red-600' : 'text-gray-700'}">
                ${secondaryName ? '₦'+row.diffAmt.toLocaleString() : '-'}
            </td>
            <td class="px-4 py-3">
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full ${statusClass}">
                    ${row.status}
                </span>
            </td>
            <td class="px-4 py-3 text-sm">
                <button class="text-blue-600 hover:text-blue-900" 
                    onclick="openDetail(
                        '${row.product.replace(/'/g, "\\'")}', 
                        ${row.primaryQty}, 
                        ${secondaryQtySafe}, 
                        ${row.diffAmt}
                    )">
                    View
                </button>
            </td>
        `;
        autoTableBody.appendChild(tr);
    });
}

// --- 4. Tabs Logic (Auto/Manual) ---
const tabAuto = document.getElementById('tab-auto');
const tabManual = document.getElementById('tab-manual');
const viewAuto = document.getElementById('auto-mode');
const viewManual = document.getElementById('manual-mode');

tabAuto.addEventListener('click', () => {
    tabAuto.classList.add('tab-active', 'bg-blue-600', 'text-white');
    tabAuto.classList.remove('text-gray-600', 'hover:bg-gray-200');
    tabManual.classList.remove('tab-active', 'bg-blue-600', 'text-white');
    tabManual.classList.add('text-gray-600', 'hover:bg-gray-200');
    
    viewAuto.classList.remove('hidden');
    viewManual.classList.add('hidden');
});

tabManual.addEventListener('click', () => {
    tabManual.classList.add('tab-active', 'bg-blue-600', 'text-white');
    tabManual.classList.remove('text-gray-600', 'hover:bg-gray-200');
    tabAuto.classList.remove('tab-active', 'bg-blue-600', 'text-white');
    tabAuto.classList.add('text-gray-600', 'hover:bg-gray-200');
    
    viewManual.classList.remove('hidden');
    viewAuto.classList.add('hidden');
});

// --- 5. MODAL & DETAIL LOGIC (Full API version) ---

function closeModal() {
    document.getElementById('detail-modal').classList.add('hidden');
}

async function openDetail(itemName, pQty, sQty, diff) {
    const modal = document.getElementById('detail-modal');
    const content = document.getElementById('modal-content');
    
    // 1. Show Loading State
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    content.innerHTML = `
        <div class="text-center py-10">
            <i class="ti ti-loader animate-spin text-3xl text-blue-600"></i>
            <p class="mt-2 text-gray-500">Investigating ${itemName}...</p>
        </div>
    `;

    try {
        // 2. Fetch Deep Details
        const res = await fetch(`/user/detail/${encodeURIComponent(itemName)}`);
        const data = await res.json();

        if (!data.success) throw new Error(data.message);

        // 3. Build UI
        let timelineHTML = data.timeline.map(t => {
            
            // Determine the label for quantity. For finance types ('Spent', 'Budgeted'), we hide the QTY.
            const isFinance = t.type === 'Spent' || t.type === 'Budgeted';
            const qtyDisplay = isFinance ? '' : ` (${t.qty})`; // Only display qty for product types
            
            return `
                <div class="flex items-start mb-4">
                    <div class="w-24 text-xs text-gray-500 pt-1">${new Date(t.date).toLocaleDateString()}</div>
                    <div class="flex-1 ml-4 pb-4 border-b border-gray-100">
                        <p class="font-medium text-sm ${t.qty < 0 ? 'text-red-600' : 'text-green-600'}">
                            ${t.type}${qtyDisplay}
                        </p>
                        <p class="text-xs text-gray-600">${t.info}</p>
                    </div>
                </div>
            `;
        }).join('');

        if(timelineHTML.length === 0) timelineHTML = '<p class="text-gray-400 text-sm">No transaction history found.</p>';

        content.innerHTML = `
            <div class="border-b pb-4 mb-4">
                <h2 class="text-2xl font-bold text-gray-800">${itemName}</h2>
                <div class="flex gap-4 mt-2 text-sm">
                    <span class="bg-blue-100 text-blue-800 px-2 py-1 rounded">Current Inventory: <b>${data.inventoryCurrent || 'N/A'}</b></span>
                    <span class="bg-green-100 text-green-800 px-2 py-1 rounded">Value: <b>₦${(data.inventoryValue || 0).toLocaleString()}</b></span>
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4 mb-6 bg-gray-50 p-4 rounded-lg">
                <div>
                    <p class="text-xs text-gray-500">Audit Found (Primary)</p>
                    <p class="font-bold text-lg">${pQty}</p>
                </div>
                 <div>
                    <p class="text-xs text-gray-500">Audit Found (Secondary)</p>
                    <p class="font-bold text-lg">${sQty || 0}</p>
                </div>
            </div>

            <h4 class="font-bold text-gray-700 mb-3 text-sm uppercase">Transaction Timeline</h4>
            <div class="max-h-60 overflow-y-auto mb-6">
                ${timelineHTML}
            </div>

            <div class="flex justify-end gap-2 pt-4 border-t">
                <button onclick="closeModal()" class="px-4 py-2 text-gray-600 hover:bg-gray-100 rounded">Close</button>
                <button onclick="saveForApproval('${itemName.replace(/'/g, "\\'")}', ${pQty}, ${sQty || 0}, ${diff})" 
                    class="px-4 py-2 bg-orange-600 text-white rounded hover:bg-orange-700 flex items-center gap-2">
                    <i class="ti ti-gavel"></i> Save for Approval
                </button>
            </div>
        `;

    } catch (err) {
        content.innerHTML = `<p class="text-red-600">Error: ${err.message}</p>`;
    }
}


// --- 6. SAVE COMPARISON ITEM (Button inside Modal) ---
async function saveForApproval(itemName, rx, sold, variance) {
    if(!confirm(`Submit ${itemName} for manager approval?`)) return;

    try {
        const res = await fetch('/user/save-comparison', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({
                itemName, 
                qtyReceived: rx, 
                qtySold: sold, 
                variance: variance,
                notes: "Flagged from Automatic Audit"
            })
        });
        const d = await res.json();
        if(d.success) alert("Item saved for approval successfully!");
    } catch(e) {
        console.error(e);
        alert("Failed to save item for approval.");
    }
}

</script>




</body>
</html>