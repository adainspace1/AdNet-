<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Easy Audit – Auto & Manual</title>
  <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css" rel="stylesheet">
  <style>
    .match-green { @apply bg-green-100 text-green-800; }
    .match-yellow { @apply bg-yellow-100 text-yellow-800; }
    .match-red { @apply bg-red-100 text-red-800; }
    .tab-active { @apply bg-blue-600 text-white; }
    .Adnetlogo{
    color: black;
}
  </style>
</head>
<body class="bg-gray-50 font-sans">



    <div  class="all">

        <%- include ("../_sidebar1") %>

            <div class="main-content">
                    <%- include ("../_topnav") %>

                <div class="container mx-auto p-4 max-w-7xl">

                <!-- Header -->
                <div class="flex justify-between items-center mb-6">
                    <h1 class="text-3xl font-bold text-gray-800">Easy Audit Dashboard</h1>
                    <button id="export-report" class="bg-green-600 text-white px-4 py-2 rounded-lg flex items-center gap-2">
                    <i class="ti ti-download"></i> Export Report
                    </button>
                </div>

                <!-- Tabs: Auto vs Manual -->
                <div class="flex space-x-1 mb-6 bg-gray-100 p-1 rounded-lg w-fit">
                    <button id="tab-auto" class="tab-active px-6 py-2 rounded-md font-medium">Automatic Audit</button>
                    <button id="tab-manual" class="px-6 py-2 rounded-md font-medium text-gray-600 hover:bg-gray-200">Manual Audit</button>
                </div>

                <!-- DASHBOARD WIDGETS -->
                <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4 mb-8">
                    <div class="bg-white p-4 rounded-lg shadow text-center">
                    <p class="text-2xl font-bold text-blue-600" id="total-audits">0</p>
                    <p class="text-sm text-gray-500">Audits This Month</p>
                    </div>
                    <div class="bg-white p-4 rounded-lg shadow text-center">
                    <p class="text-2xl font-bold text-red-600" id="mismatches">0</p>
                    <p class="text-sm text-gray-500">Mismatches Found</p>
                    </div>
                    <div class="bg-white p-4 rounded-lg shadow text-center">
                    <p class="text-2xl font-bold text-orange-600" id="amount-diff">₦0</p>
                    <p class="text-sm text-gray-500">Amount Difference</p>
                    </div>
                    <div class="bg-white p-4 rounded-lg shadow text-center">
                    <p class="text-2xl font-bold text-purple-600" id="stock-diff">0</p>
                    <p class="text-sm text-gray-500">Stock Discrepancy</p>
                    </div>
                    <div class="bg-white p-4 rounded-lg shadow text-center">
                    <p class="text-2xl font-bold text-green-600" id="approved">0</p>
                    <p class="text-sm text-gray-500">Approved</p>
                    </div>
                    <div class="bg-white p-4 rounded-lg shadow text-center">
                    <p class="text-2xl font-bold text-red-600" id="disapproved">0</p>
                    <p class="text-sm text-gray-500">Disapproved</p>
                    </div>
                </div>

                <!-- Filters -->
                <div class="bg-white p-4 rounded-lg shadow mb-6 flex flex-wrap gap-3 items-center">
                    <input type="date" id="filter-date-from" class="px-3 py-2 border rounded-md">
                    <input type="date" id="filter-date-to" class="px-3 py-2 border rounded-md">
                    <select id="filter-staff" class="px-3 py-2 border rounded-md">
                    <option>All Staff</option>
                    </select>
                    <select id="filter-product" class="px-3 py-2 border rounded-md">
                    <option>All Products</option>
                    </select>
                    <select id="filter-type" class="px-3 py-2 border rounded-md">
                    <option>All Types</option>
                    <option>Automatic</option>
                    <option>Manual</option>
                    </select>
                    <input type="text" id="search" placeholder="Search receipt, product..." class="flex-1 px-3 py-2 border rounded-md">
                </div>

                <!-- AUTOMATIC MODE -->
                <div id="auto-mode">
                        <!-- NEW AUDIT MODULE SELECTION -->
<div id="audit-selection" class="bg-white p-6 rounded-lg shadow mb-6">
  <h2 class="text-xl font-bold mb-4">Start Automatic Audit</h2>
  <p class="text-gray-600 mb-4">Choose a primary module, then select its comparison module.</p>

  <!-- Primary -->
  <div class="mb-4">
    <label class="block text-gray-700 font-medium mb-1">Primary Module</label>
    <select id="primary-module" class="w-full border px-3 py-2 rounded-lg">
      <option value="">Select...</option>
      <option value="inventory">Inventory</option>
      <option value="expense">Expense</option>
      <option value="payments">Payments</option>
      <option value="withdrawals">Withdrawals</option>
    </select>
  </div>

  <!-- Secondary (Dynamic) -->
  <div class="mb-4">
    <label class="block text-gray-700 font-medium mb-1">Secondary Module</label>
    <select id="secondary-module" class="w-full border px-3 py-2 rounded-lg">
      <option value="">Select primary first...</option>
    </select>
  </div>

  <button id="start-audit" class="mt-4 bg-blue-600 text-white px-6 py-3 rounded-lg w-full">
    Continue
  </button>
</div>



                    <div id="auto-results" class="hidden bg-white rounded-lg shadow overflow-hidden">
                    <div class="p-4 border-b">
                        <h3 class="font-semibold">Automatic Audit Results</h3>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="min-w-full">
                        <thead class="bg-gray-50">
                            <tr>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Product</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Goods Received</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Sold</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Expected $</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actual $</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Difference</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Action</th>
                            </tr>
                        </thead>
                        <tbody id="auto-table-body"></tbody>
                        </table>
                    </div>
                    </div>
                </div>

                <!-- MANUAL MODE -->
                <div id="manual-mode" class="hidden">
                    <div class="bg-white rounded-lg shadow p-6">
                    <h2 class="text-xl font-bold mb-4">Manual Audit – Enter Your Records</h2>
                    <form id="manual-form" class="grid md:grid-cols-2 gap-4">
    <input 
        type="text" 
        name="product" 
        placeholder="Product Name" 
        required 
        class="px-4 py-2 border rounded-lg"
    >

    <input 
        type="number" 
        name="received" 
        placeholder="Quantity Received" 
        required 
        class="px-4 py-2 border rounded-lg"
    >

    <input 
        type="number" 
        name="sold" 
        placeholder="Quantity Sold" 
        required 
        class="px-4 py-2 border rounded-lg"
    >

    <input 
        type="number" 
        name="expected" 
        placeholder="Expected Amount ($)" 
        required 
        class="px-4 py-2 border rounded-lg"
    >

    <input 
        type="number" 
        name="actual" 
        placeholder="Actual Amount Paid ($)" 
        required 
        class="px-4 py-2 border rounded-lg"
    >

    <input 
        type="file" 
        name="files" 
        multiple 
        accept=".pdf,.jpg,.png" 
        class="md:col-span-2"
    >

    <textarea 
        name="notes" 
        placeholder="Add notes or explain difference..." 
        class="md:col-span-2 px-4 py-2 border rounded-lg" 
        rows="3"
    ></textarea>

    <button 
        type="submit" 
        class="bg-green-600 text-white px-6 py-2 rounded-lg md:col-span-2"
    >
        Compare & Save
    </button>
</form>

                    </div>

                    <div id="manual-results" class="mt-6 hidden bg-white rounded-lg shadow p-6">
                    <h3 class="font-bold mb-4">Your Manual Audit Result</h3>
                    <div id="manual-result-body"></div>
                    </div>
                </div>

                </div>
            </div>

                <!-- MODAL -->
                <div id="detail-modal" class="fixed inset-0 bg-black bg-opacity-50 hidden flex items-center justify-center z-50">
                <div class="bg-white rounded-xl p-6 max-w-2xl w-full max-h-screen overflow-y-auto">
                    <div class="flex justify-between items-center mb-4">
                    <h3 class="text-xl font-bold">Audit Detail</h3>
                    <button onclick="closeModal()" class="text-gray-500"><i class="ti ti-x"></i></button>
                    </div>
                    <div id="modal-content"></div>
                </div>
                </div>

    </div>

<script>
document.addEventListener('DOMContentLoaded', () => {
  // Elements
  const primaryEl = document.getElementById('primary-module');
  const secondaryEl = document.getElementById('secondary-module');
  const startBtn = document.getElementById('start-audit');
  const autoResultsEl = document.getElementById('auto-results');
  const tbody = document.getElementById('auto-table-body');

  // Mapping: primary -> possible secondaries
  const SECONDARY_MAP = {
    inventory: [
      { value: '', label: '— (optional) —' },
      { value: 'sales', label: 'Sales' },
      { value: 'production', label: 'Production' },
      { value: 'orders', label: 'Orders' }
    ],
    expense: [
      { value: '', label: '— (optional) —' },
      { value: 'budget', label: 'Budget' }
    ],
    payments: [
      { value: '', label: '— (optional) —' },
      { value: 'receipts', label: 'Receipts' }
    ],
    withdrawals: [
      { value: '', label: '— (optional) —' },
      { value: 'records', label: 'Records' }
    ]
  };

  // Helper: escape HTML
  function escapeHtml(text) {
    return text.replace(/[&<>"']/g, (m) => ({
      '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;'
    }[m]));
  }

  // Initialize secondary
  populateSecondary('', true);

  // Primary change -> populate secondary
  primaryEl.addEventListener('change', () => {
    const prim = primaryEl.value;
    populateSecondary(prim);
    startBtn.disabled = !prim;
    startBtn.classList.toggle('opacity-50', !prim);
    startBtn.classList.toggle('cursor-not-allowed', !prim);
  });

  function populateSecondary(primaryValue = '', initial = false) {
    secondaryEl.innerHTML = '';
    const list = SECONDARY_MAP[primaryValue] || [{ value: '', label: '— (optional) —' }];
    list.forEach(opt => {
      const o = document.createElement('option');
      o.value = opt.value;
      o.textContent = opt.label;
      secondaryEl.appendChild(o);
    });
    secondaryEl.disabled = !primaryValue;
    secondaryEl.classList.toggle('opacity-50', !primaryValue);
    secondaryEl.classList.toggle('cursor-not-allowed', !primaryValue);
  }

  // Progress bar
  let progressInterval = null;
  function createProgressBar() {
    removeIfExists('audit-progress-wrap');
    const wrap = document.createElement('div');
    wrap.id = 'audit-progress-wrap';
    wrap.className = 'p-4';
    wrap.innerHTML = `
      <div class="mb-2 text-sm text-gray-600">Running audit...</div>
      <div class="w-full bg-gray-200 rounded-full h-2 overflow-hidden">
        <div id="audit-progress" style="width:0%;height:100%" class="transition-all"></div>
      </div>
      <div id="audit-progress-percent" class="text-xs text-gray-500 mt-1">0%</div>
    `;
    autoResultsEl.classList.remove('hidden');
    autoResultsEl.insertAdjacentElement('afterbegin', wrap);

    let pct = 0;
    const bar = document.getElementById('audit-progress');
    const pctEl = document.getElementById('audit-progress-percent');
    progressInterval = setInterval(() => {
      if (pct < 95) pct += (pct < 60 ? 6 : 2);
      else pct += 1;
      if (pct > 95) pct = 95;
      bar.style.width = pct + '%';
      pctEl.textContent = pct + '%';
    }, 180);
  }

  function finishProgressBar() {
    const bar = document.getElementById('audit-progress');
    const pctEl = document.getElementById('audit-progress-percent');
    if (progressInterval) clearInterval(progressInterval);
    if (bar) {
      bar.style.width = '100%';
      if (pctEl) pctEl.textContent = '100%';
      setTimeout(() => removeIfExists('audit-progress-wrap'), 450);
    }
  }

  // Render results
  function renderAutoResults(results) {
    if (!tbody) return;
    if (!results.length) {
      tbody.innerHTML = `<tr><td colspan="9" class="p-6 text-center">No Inventory Data</td></tr>`;
      return;
    }
    tbody.innerHTML = results.map(r => `
      <tr>
        <td>${r.product}</td>
        <td>${r.received}</td>
        <td>${r.sold}</td>
        <td>${r.expected}</td>
        <td>${r.actual}</td>
        <td>${r.diff}</td>
        <td>${r.status}</td>
        <td>${r.approvalStatus}</td>
      </tr>
    `).join('');
  }

  startBtn.addEventListener('click', async () => {
    const primary = primaryEl.value;
    const secondary = secondaryEl.value;
    if (!primary) return alert('Pick a Primary Module first');

    const payload = {
      inventory: false,
      expense: false,
      payments: false,
      withdrawals: false,
      sales: false,
      budget: false,
      receipts: false,
      production: false,
      orders: false,
      records: false
    };
    if (payload.hasOwnProperty(primary)) payload[primary] = true;
    if (secondary && payload.hasOwnProperty(secondary)) payload[secondary] = true;

    createProgressBar();
    startBtn.disabled = true;
    startBtn.classList.add('opacity-50', 'cursor-not-allowed');

    tbody.innerHTML = `<tr><td colspan="9" class="p-6 text-center">Running audit…</td></tr>`;
    removeIfExists('expense-results-container');
    removeIfExists('payment-results-container');
    removeIfExists('withdrawal-results-container');

    try {
      const res = await fetch('/user/api/audit/auto', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      finishProgressBar();

      if (!res.ok) {
        const text = await res.text();
        tbody.innerHTML = `<tr><td colspan="9" class="p-6 text-center text-red-600">Audit failed: ${escapeHtml(text)}</td></tr>`;
        startBtn.disabled = false;
        startBtn.classList.remove('opacity-50', 'cursor-not-allowed');
        return;
      }

      const payloadJson = await res.json();
      const inventoryResults = payloadJson.results?.inventoryResults || [];
      const stats = payloadJson.stats || {};

      renderAutoResults(inventoryResults);

      if (typeof updateDashboard === 'function') {
        updateDashboard({
          total: stats.inventoryStats?.total ?? inventoryResults.length,
          mismatches: stats.inventoryStats?.mismatches ?? inventoryResults.filter(r=>r.diff!==0).length,
          amountDiff: stats.inventoryStats?.amountDiff ?? inventoryResults.reduce((a,c)=>a+Math.abs(c.diff||0),0),
          stockDiff: stats.inventoryStats?.stockDiff ?? inventoryResults.reduce((a,c)=>a+Math.abs((c.received||0)-(c.sold||0)),0),
          approved: stats.inventoryStats?.approved ?? inventoryResults.filter(r=>r.approvalStatus==='approved').length,
          disapproved: stats.inventoryStats?.disapproved ?? inventoryResults.filter(r=>r.approvalStatus==='disapproved').length
        });
      }

      startBtn.disabled = false;
      startBtn.classList.remove('opacity-50', 'cursor-not-allowed');

    } catch (err) {
      console.error('Auto audit error:', err);
      finishProgressBar();
      tbody.innerHTML = `<tr><td colspan="9" class="p-6 text-center text-red-600">Unexpected error running audit.</td></tr>`;
      startBtn.disabled = false;
      startBtn.classList.remove('opacity-50', 'cursor-not-allowed');
    }
  });

  function removeIfExists(id) {
    const el = document.getElementById(id);
    if (el) el.remove();
  }

  // init
  startBtn.disabled = !primaryEl.value;
  startBtn.classList.toggle('opacity-50', !primaryEl.value);
});
</script>



</body>
</html>