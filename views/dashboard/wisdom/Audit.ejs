<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Easy Audit – Auto & Manual</title>
  <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css" rel="stylesheet">
  <style>
    .match-green { @apply bg-green-100 text-green-800; }
    .match-yellow { @apply bg-yellow-100 text-yellow-800; }
    .match-red { @apply bg-red-100 text-red-800; }
    .tab-active { @apply bg-blue-600 text-white; }
    .Adnetlogo{
    color: black;
}
  </style>
</head>
<body class="bg-gray-50 font-sans">



    <div  class="all">

        <%- include ("../_sidebar1") %>

            <div class="main-content">
                    <%- include ("../_topnav") %>

                <div class="container mx-auto p-4 max-w-7xl">

                <!-- Header -->
                <div class="flex justify-between items-center mb-6">
                    <h1 class="text-3xl font-bold text-gray-800">Easy Audit Dashboard</h1>
                    <button id="export-report" class="bg-green-600 text-white px-4 py-2 rounded-lg flex items-center gap-2">
                    <i class="ti ti-download"></i> Export Report
                    </button>
                </div>

                <!-- Tabs: Auto vs Manual -->
                <div class="flex space-x-1 mb-6 bg-gray-100 p-1 rounded-lg w-fit">
                    <button id="tab-auto" class="tab-active px-6 py-2 rounded-md font-medium">Automatic Audit</button>
                    <button id="tab-manual" class="px-6 py-2 rounded-md font-medium text-gray-600 hover:bg-gray-200">Manual Audit</button>
                </div>

                <!-- DASHBOARD WIDGETS -->
                <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4 mb-8">
                    <div class="bg-white p-4 rounded-lg shadow text-center">
                    <p class="text-2xl font-bold text-blue-600" id="total-audits">0</p>
                    <p class="text-sm text-gray-500">Audits This Month</p>
                    </div>
                    <div class="bg-white p-4 rounded-lg shadow text-center">
                    <p class="text-2xl font-bold text-red-600" id="mismatches">0</p>
                    <p class="text-sm text-gray-500">Mismatches Found</p>
                    </div>
                    <div class="bg-white p-4 rounded-lg shadow text-center">
                    <p class="text-2xl font-bold text-orange-600" id="amount-diff">$0</p>
                    <p class="text-sm text-gray-500">Amount Difference</p>
                    </div>
                    <div class="bg-white p-4 rounded-lg shadow text-center">
                    <p class="text-2xl font-bold text-purple-600" id="stock-diff">0</p>
                    <p class="text-sm text-gray-500">Stock Discrepancy</p>
                    </div>
                    <div class="bg-white p-4 rounded-lg shadow text-center">
                    <p class="text-2xl font-bold text-green-600" id="approved">0</p>
                    <p class="text-sm text-gray-500">Approved</p>
                    </div>
                    <div class="bg-white p-4 rounded-lg shadow text-center">
                    <p class="text-2xl font-bold text-red-600" id="disapproved">0</p>
                    <p class="text-sm text-gray-500">Disapproved</p>
                    </div>
                </div>

                <!-- Filters -->
                <div class="bg-white p-4 rounded-lg shadow mb-6 flex flex-wrap gap-3 items-center">
                    <input type="date" id="filter-date-from" class="px-3 py-2 border rounded-md">
                    <input type="date" id="filter-date-to" class="px-3 py-2 border rounded-md">
                    <select id="filter-staff" class="px-3 py-2 border rounded-md">
                    <option>All Staff</option>
                    </select>
                    <select id="filter-product" class="px-3 py-2 border rounded-md">
                    <option>All Products</option>
                    </select>
                    <select id="filter-type" class="px-3 py-2 border rounded-md">
                    <option>All Types</option>
                    <option>Automatic</option>
                    <option>Manual</option>
                    </select>
                    <input type="text" id="search" placeholder="Search receipt, product..." class="flex-1 px-3 py-2 border rounded-md">
                </div>

                <!-- AUTOMATIC MODE -->
                <div id="auto-mode">
                    <div class="bg-white rounded-lg shadow p-6 mb-6 text-center">
                    <h2 class="text-xl font-bold mb-4">Run Automatic Audit Scanner</h2>
                    <p class="text-gray-600 mb-4">The system will compare your inventory, sales, and payments.</p>
                    <button id="scan-database" class="bg-blue-600 text-white px-6 py-3 rounded-lg flex items-center gap-2 mx-auto">
                        <i class="ti ti-search"></i> Scan Database Now
                    </button>
                    <div id="progress" class="mt-4 hidden">
                        <div class="bg-gray-200 h-2 rounded-full overflow-hidden">
                        <div class="bg-blue-600 h-full transition-all" style="width: 0%"></div>
                        </div>
                        <p class="text-sm mt-2">Scanning... <span id="progress-text">0%</span></p>
                    </div>
                    </div>

                    <div id="auto-results" class="hidden bg-white rounded-lg shadow overflow-hidden">
                    <div class="p-4 border-b">
                        <h3 class="font-semibold">Automatic Audit Results</h3>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="min-w-full">
                        <thead class="bg-gray-50">
                            <tr>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Product</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Goods Received</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Sold</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Expected $</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actual $</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Difference</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Action</th>
                            </tr>
                        </thead>
                        <tbody id="auto-table-body"></tbody>
                        </table>
                    </div>
                    </div>
                </div>

                <!-- MANUAL MODE -->
                <div id="manual-mode" class="hidden">
                    <div class="bg-white rounded-lg shadow p-6">
                    <h2 class="text-xl font-bold mb-4">Manual Audit – Enter Your Records</h2>
                    <form id="manual-form" class="grid md:grid-cols-2 gap-4">
                        <input type="text" placeholder="Product Name" required class="px-4 py-2 border rounded-lg">
                        <input type="number" placeholder="Quantity Received" required class="px-4 py-2 border rounded-lg">
                        <input type="number" placeholder="Quantity Sold" required class="px-4 py-2 border rounded-lg">
                        <input type="number" placeholder="Expected Amount ($)" required class="px-4 py-2 border rounded-lg">
                        <input type="number" placeholder="Actual Amount Paid ($)" required class="px-4 py-2 border rounded-lg">
                        <input type="file" multiple accept=".pdf,.jpg,.png" class="md:col-span-2">
                        <textarea placeholder="Add notes or explain difference..." class="md:col-span-2 px-4 py-2 border rounded-lg" rows="3"></textarea>
                        <button type="submit" class="bg-green-600 text-white px-6 py-2 rounded-lg md:col-span-2">
                        Compare & Save
                        </button>
                    </form>
                    </div>

                    <div id="manual-results" class="mt-6 hidden bg-white rounded-lg shadow p-6">
                    <h3 class="font-bold mb-4">Your Manual Audit Result</h3>
                    <div id="manual-result-body"></div>
                    </div>
                </div>

                </div>
            </div>

                <!-- MODAL -->
                <div id="detail-modal" class="fixed inset-0 bg-black bg-opacity-50 hidden flex items-center justify-center z-50">
                <div class="bg-white rounded-xl p-6 max-w-2xl w-full max-h-screen overflow-y-auto">
                    <div class="flex justify-between items-center mb-4">
                    <h3 class="text-xl font-bold">Audit Detail</h3>
                    <button onclick="closeModal()" class="text-gray-500"><i class="ti ti-x"></i></button>
                    </div>
                    <div id="modal-content"></div>
                </div>
                </div>

    </div>

<script>
  // Tab Switching
  document.getElementById('tab-auto').onclick = () => switchTab('auto');
  document.getElementById('tab-manual').onclick = () => switchTab('manual');

  function switchTab(mode) {
    document.querySelectorAll('.tab-active').forEach(t => t.classList.remove('tab-active'));
    document.getElementById(`tab-${mode}`).classList.add('tab-active');
    document.getElementById('auto-mode').classList.toggle('hidden', mode !== 'auto');
    document.getElementById('manual-mode').classList.toggle('hidden', mode !== 'manual');
  }

  // Auto Scan
  document.getElementById('scan-database').onclick = async () => {
    const progress = document.getElementById('progress');
    const bar = progress.querySelector('div');
    const text = document.getElementById('progress-text');
    progress.classList.remove('hidden');

    for (let i = 0; i <= 100; i += 10) {
      bar.style.width = i + '%';
      text.textContent = i + '%';
      await new Promise(r => setTimeout(r, 300));
    }

    const res = await fetch('/api/audit/auto');
    const { results, stats } = await res.json();
    renderAutoResults(results);
    updateDashboard(stats);
    document.getElementById('auto-results').classList.remove('hidden');
  };

  function renderAutoResults(items) {
    const tbody = document.getElementById('auto-table-body');
    tbody.innerHTML = items.map(item => `
      <tr class="border-t">
        <td class="px-4 py-3">${item.product}</td>
        <td class="px-4 py-3">${item.received}</td>
        <td class="px-4 py-3">${item.sold}</td>
        <td class="px-4 py-3">$${item.expected}</td>
        <td class="px-4 py-3">$${item.actual}</td>
        <td class="px-4 py-3">
          <span class="px-2 py-1 text-xs font-medium rounded-full ${getMatchClass(item.diff)}">
            $${Math.abs(item.diff).toFixed(2)}
          </span>
        </td>
        <td class="px-4 py-3">${item.status}</td>
        <td class="px-4 py-3">
          <button onclick="openDetail('${item._id}')" class="text-blue-600 text-sm">Review</button>
        </td>
      </tr>
    `).join('');
  }

  // Manual Form
  document.getElementById('manual-form').onsubmit = async (e) => {
    e.preventDefault();
    const form = e.target;
    const data = {
      product: form[0].value,
      received: +form[1].value,
      sold: +form[2].value,
      expected: +form[3].value,
      actual: +form[4].value,
      notes: form[6].value,
      type: 'manual'
    };

    const res = await fetch('/api/audit/manual', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data)
    });

    const result = await res.json();
    document.getElementById('manual-results').classList.remove('hidden');
    document.getElementById('manual-result-body').innerHTML = `
      <div class="p-4 bg-gray-50 rounded-lg">
        <p><strong>Product:</strong> ${result.product}</p>
        <p><strong>Difference Found:</strong> 
          <span class="${getMatchClass(result.diff)}">$${Math.abs(result.diff).toFixed(2)}</span>
        </p>
        <p><strong>Accuracy Score:</strong> ${result.score}%</p>
        <div class="mt-4 flex gap-2">
          <button onclick="approve('${result._id}')" class="bg-green-600 text-white px-4 py-1 rounded">Approve</button>
          <button onclick="disapprove('${result._id}')" class="bg-red-600 text-white px-4 py-1 rounded">Disapprove</button>
        </div>
      </div>
    `;
  };

  function getMatchClass(diff) {
    const abs = Math.abs(diff);
    if (abs === 0) return 'match-green';
    if (abs <= 5) return 'match-yellow';
    return 'match-red';
  }

  window.openDetail = (id) => {
    // Fetch full detail + show modal
    document.getElementById('modal-content').innerHTML = `<p>Full record for ID: ${id}</p>`;
    document.getElementById('detail-modal').classList.remove('hidden');
  };

  window.closeModal = () => document.getElementById('detail-modal').classList.add('hidden');

  window.approve = async (id) => await action(id, 'approve');
  window.disapprove = async (id) => await action(id, 'disapprove');

  async function action(id, act) {
    await fetch(`/api/audit/action/${id}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action: act, user: 'You' })
    });
    alert(`Transaction ${act}d!`);
    location.reload();
  }

  function updateDashboard(stats) {
    document.getElementById('total-audits').textContent = stats.total;
    document.getElementById('mismatches').textContent = stats.mismatches;
    document.getElementById('amount-diff').textContent = `$${stats.amountDiff}`;
    document.getElementById('stock-diff').textContent = stats.stockDiff;
    document.getElementById('approved').textContent = stats.approved;
    document.getElementById('disapproved').textContent = stats.disapproved;
  }
</script>

</body>
</html>