<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Easy Audit – Auto & Manual</title>
  <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css" rel="stylesheet">
  <style>
    .match-green { @apply bg-green-100 text-green-800; }
    .match-yellow { @apply bg-yellow-100 text-yellow-800; }
    .match-red { @apply bg-red-100 text-red-800; }
    .tab-active { @apply bg-blue-600 text-white; }
    .Adnetlogo{
    color: black;
}
  </style>
</head>
<body class="bg-gray-50 font-sans">



    <div  class="all">

        <%- include ("../_sidebar1") %>

            <div class="main-content">
                    <%- include ("../_topnav") %>

                <div class="container mx-auto p-4 max-w-7xl">

                <!-- Header -->
                <div class="flex justify-between items-center mb-6">
                    <h1 class="text-3xl font-bold text-gray-800">Easy Audit Dashboard</h1>
                    <button id="export-report" class="bg-green-600 text-white px-4 py-2 rounded-lg flex items-center gap-2">
                    <i class="ti ti-download"></i> Export Report
                    </button>
                </div>

                <!-- Tabs: Auto vs Manual -->
                <div class="flex space-x-1 mb-6 bg-gray-100 p-1 rounded-lg w-fit">
                    <button id="tab-auto" class="tab-active px-6 py-2 rounded-md font-medium">Automatic Audit</button>
                    <button id="tab-manual" class="px-6 py-2 rounded-md font-medium text-gray-600 hover:bg-gray-200">Manual Audit</button>
                </div>

                <!-- DASHBOARD WIDGETS -->
                <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4 mb-8">
                    <div class="bg-white p-4 rounded-lg shadow text-center">
                    <p class="text-2xl font-bold text-blue-600" id="total-audits">0</p>
                    <p class="text-sm text-gray-500">Audits This Month</p>
                    </div>
                    <div class="bg-white p-4 rounded-lg shadow text-center">
                    <p class="text-2xl font-bold text-red-600" id="mismatches">0</p>
                    <p class="text-sm text-gray-500">Mismatches Found</p>
                    </div>
                    <div class="bg-white p-4 rounded-lg shadow text-center">
                    <p class="text-2xl font-bold text-orange-600" id="amount-diff">₦0</p>
                    <p class="text-sm text-gray-500">Amount Difference</p>
                    </div>
                    <div class="bg-white p-4 rounded-lg shadow text-center">
                    <p class="text-2xl font-bold text-purple-600" id="stock-diff">0</p>
                    <p class="text-sm text-gray-500">Stock Discrepancy</p>
                    </div>
                    <div class="bg-white p-4 rounded-lg shadow text-center">
                    <p class="text-2xl font-bold text-green-600" id="approved">0</p>
                    <p class="text-sm text-gray-500">Approved</p>
                    </div>
                    <div class="bg-white p-4 rounded-lg shadow text-center">
                    <p class="text-2xl font-bold text-red-600" id="disapproved">0</p>
                    <p class="text-sm text-gray-500">Disapproved</p>
                    </div>
                </div>

                <!-- Filters -->
                <div class="bg-white p-4 rounded-lg shadow mb-6 flex flex-wrap gap-3 items-center">
                    <input type="date" id="filter-date-from" class="px-3 py-2 border rounded-md">
                    <input type="date" id="filter-date-to" class="px-3 py-2 border rounded-md">
                    <select id="filter-staff" class="px-3 py-2 border rounded-md">
                    <option>All Staff</option>
                    </select>
                    <select id="filter-product" class="px-3 py-2 border rounded-md">
                    <option>All Products</option>
                    </select>
                    <select id="filter-type" class="px-3 py-2 border rounded-md">
                    <option>All Types</option>
                    <option>Automatic</option>
                    <option>Manual</option>
                    </select>
                    <input type="text" id="search" placeholder="Search receipt, product..." class="flex-1 px-3 py-2 border rounded-md">
                </div>

                <!-- AUTOMATIC MODE -->
                <div id="auto-mode">
                    <!-- AUDIT MODULE SELECTION -->
                        <div id="audit-selection" class="bg-white p-6 rounded-lg shadow text-center mb-6">
                        <h2 class="text-xl font-bold mb-4">Choose What To Audit</h2>
                        <p class="text-gray-600 mb-4">Select one or more modules to compare.</p>

                        <div class="grid grid-cols-2 gap-4 text-left">
                            <label class="flex items-center gap-2">
                            <input type="checkbox" id="audit-inventory" checked>
                            <span>Inventory vs Sales</span>
                            </label>

                            <label class="flex items-center gap-2">
                            <input type="checkbox" id="audit-expense" checked>
                            <span>Expense vs Budget</span>
                            </label>

                            <label class="flex items-center gap-2">
                            <input type="checkbox" id="audit-payments">
                            <span>Payments vs Receipts</span>
                            </label>

                            <label class="flex items-center gap-2">
                            <input type="checkbox" id="audit-withdrawals">
                            <span>Withdrawals vs Records</span>
                            </label>
                        </div>

                        <button id="start-audit" class="mt-6 bg-blue-600 text-white px-6 py-3 rounded-lg">
                            Continue
                        </button>
                        </div>


                    <div id="auto-results" class="hidden bg-white rounded-lg shadow overflow-hidden">
                    <div class="p-4 border-b">
                        <h3 class="font-semibold">Automatic Audit Results</h3>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="min-w-full">
                        <thead class="bg-gray-50">
                            <tr>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Product</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Goods Received</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Sold</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Expected $</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actual $</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Difference</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Action</th>
                            </tr>
                        </thead>
                        <tbody id="auto-table-body"></tbody>
                        </table>
                    </div>
                    </div>
                </div>

                <!-- MANUAL MODE -->
                <div id="manual-mode" class="hidden">
                    <div class="bg-white rounded-lg shadow p-6">
                    <h2 class="text-xl font-bold mb-4">Manual Audit – Enter Your Records</h2>
                    <form id="manual-form" class="grid md:grid-cols-2 gap-4">
    <input 
        type="text" 
        name="product" 
        placeholder="Product Name" 
        required 
        class="px-4 py-2 border rounded-lg"
    >

    <input 
        type="number" 
        name="received" 
        placeholder="Quantity Received" 
        required 
        class="px-4 py-2 border rounded-lg"
    >

    <input 
        type="number" 
        name="sold" 
        placeholder="Quantity Sold" 
        required 
        class="px-4 py-2 border rounded-lg"
    >

    <input 
        type="number" 
        name="expected" 
        placeholder="Expected Amount ($)" 
        required 
        class="px-4 py-2 border rounded-lg"
    >

    <input 
        type="number" 
        name="actual" 
        placeholder="Actual Amount Paid ($)" 
        required 
        class="px-4 py-2 border rounded-lg"
    >

    <input 
        type="file" 
        name="files" 
        multiple 
        accept=".pdf,.jpg,.png" 
        class="md:col-span-2"
    >

    <textarea 
        name="notes" 
        placeholder="Add notes or explain difference..." 
        class="md:col-span-2 px-4 py-2 border rounded-lg" 
        rows="3"
    ></textarea>

    <button 
        type="submit" 
        class="bg-green-600 text-white px-6 py-2 rounded-lg md:col-span-2"
    >
        Compare & Save
    </button>
</form>

                    </div>

                    <div id="manual-results" class="mt-6 hidden bg-white rounded-lg shadow p-6">
                    <h3 class="font-bold mb-4">Your Manual Audit Result</h3>
                    <div id="manual-result-body"></div>
                    </div>
                </div>

                </div>
            </div>

                <!-- MODAL -->
                <div id="detail-modal" class="fixed inset-0 bg-black bg-opacity-50 hidden flex items-center justify-center z-50">
                <div class="bg-white rounded-xl p-6 max-w-2xl w-full max-h-screen overflow-y-auto">
                    <div class="flex justify-between items-center mb-4">
                    <h3 class="text-xl font-bold">Audit Detail</h3>
                    <button onclick="closeModal()" class="text-gray-500"><i class="ti ti-x"></i></button>
                    </div>
                    <div id="modal-content"></div>
                </div>
                </div>

    </div>

<script>
/* ---------- TAB SWITCHING ---------- */
document.getElementById('tab-auto').onclick = () => switchTab('auto');
document.getElementById('tab-manual').onclick = () => switchTab('manual');

function switchTab(mode) {
  document.querySelectorAll('.tab-active').forEach(t => t.classList.remove('tab-active'));
  document.getElementById(`tab-${mode}`).classList.add('tab-active');
  document.getElementById('auto-mode').classList.toggle('hidden', mode !== 'auto');
  document.getElementById('manual-mode').classList.toggle('hidden', mode !== 'manual');
}

/* ---------- START AUDIT (module selector) ---------- */
document.getElementById('start-audit').onclick = async () => {
  try {
    // collect selection
    const selected = {
      inventory: document.getElementById('audit-inventory').checked,
      expense: document.getElementById('audit-expense').checked,
      payments: document.getElementById('audit-payments').checked,
      withdrawals: document.getElementById('audit-withdrawals').checked
    };

    // show loader UI
    const autoResultsEl = document.getElementById('auto-results');
    autoResultsEl.classList.remove('hidden');
    const tbody = document.getElementById('auto-table-body');
    tbody.innerHTML = `<tr><td colspan="9" class="p-6 text-center">Running audit…</td></tr>`;

    const res = await fetch('/user/api/audit/auto', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(selected)
    });

    if (!res.ok) {
      const text = await res.text();
      tbody.innerHTML = `<tr><td colspan="9" class="p-6 text-center text-red-600">Audit failed: ${text}</td></tr>`;
      return;
    }

    const payload = await res.json();

    // backend might return { results, stats } as in your controller
    const inventoryResults = payload.results?.inventoryResults || payload.inventoryResults || [];
    const expenseResults = payload.results?.expenseResults || payload.expenseResults || [];
    const paymentResults = payload.results?.paymentResults || payload.paymentResults || [];
    const withdrawalResults = payload.results?.withdrawalResults || payload.withdrawalResults || [];
    const stats = payload.stats || payload;

    // render
    renderAutoResults(inventoryResults);
    renderExpenseResults(expenseResults);
    renderPaymentResults(paymentResults);
    renderWithdrawalResults(withdrawalResults);

    // update dashboard (safe guards)
    updateDashboard({
      total: stats.inventoryStats?.total ?? (inventoryResults.length || 0),
      mismatches: stats.inventoryStats?.mismatches ?? (inventoryResults.filter(r => r.diff !== 0).length || 0),
      amountDiff: stats.inventoryStats?.amountDiff ?? (inventoryResults.reduce((a,c)=>a+Math.abs(c.diff||0),0) || 0),
      stockDiff: stats.inventoryStats?.stockDiff ?? (inventoryResults.reduce((a,c)=>a+Math.abs((c.received||0)-(c.sold||0)),0) || 0),
      approved: stats.inventoryStats?.approved ?? (inventoryResults.filter(r => r.approvalStatus === 'approved').length || 0),
      disapproved: stats.inventoryStats?.disapproved ?? (inventoryResults.filter(r => r.approvalStatus === 'disapproved').length || 0)
    });

  } catch (err) {
    console.error("Auto audit error:", err);
    const tbody = document.getElementById('auto-table-body');
    tbody.innerHTML = `<tr><td colspan="9" class="p-6 text-center text-red-600">Unexpected error running audit.</td></tr>`;
  }
};

/* ---------- RENDERING: INVENTORY TABLE (main table) ---------- */
function renderAutoResults(items) {
  const tbody = document.getElementById('auto-table-body');

  if (!items || !items.length) {
    tbody.innerHTML = `<tr><td colspan="9" class="p-6 text-center text-gray-600">No inventory results</td></tr>`;
    return;
  }

  tbody.innerHTML = items.map(item => `
    <tr class="border-t">
      <td class="px-4 py-3">${escapeHtml(item.product || '—')}</td>
      <td class="px-4 py-3">${formatNumber(item.received ?? 0)}</td>
      <td class="px-4 py-3">${formatNumber(item.sold ?? 0)}</td>
      <td class="px-4 py-3">$${numberFormat(item.expected ?? 0)}</td>
      <td class="px-4 py-3">$${numberFormat(item.actual ?? 0)}</td>
      <td class="px-4 py-3">
        <span class="px-2 py-1 text-xs font-medium rounded-full ${getMatchClass(item.diff ?? 0)}">
          $${numberFormat(Math.abs(item.diff ?? 0))}
        </span>
      </td>
      <td class="px-4 py-3">${escapeHtml(item.status || '—')}</td>

      <td class="px-4 py-3">
        <span class="px-2 py-1 rounded text-xs ${approvalClass(item.approvalStatus)}">
          ${escapeHtml(item.approvalStatus || 'pending')}
        </span>
      </td>

      <td class="px-4 py-3">
        <button onclick="openDetail('${item._id}', 'inventory')" class="text-blue-600 text-sm underline">
          Review
        </button>
      </td>
    </tr>
  `).join('');
}

/* ---------- RENDERING: OTHER MODULES (simple tables under the main table) ---------- */
function renderExpenseResults(items) {
  removeIfExists('expense-results-container');
  if (!items || !items.length) return;

  const container = document.createElement('div');
  container.id = 'expense-results-container';
  container.className = 'mt-6 bg-white rounded-lg shadow overflow-hidden';
  container.innerHTML = `
    <div class="p-4 border-b"><h3 class="font-semibold">Expense vs Budget Results</h3></div>
    <div class="overflow-x-auto p-4">
      <table class="min-w-full">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Category</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Budgeted</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Spent</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Remaining</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Action</th>
          </tr>
        </thead>
        <tbody>
          ${items.map(it => `
            <tr class="border-t">
                <td class="px-4 py-3">${escapeHtml(it.name || it.category || '—')}</td>
              <td class="px-4 py-3">₦${numberFormat(it.budgeted ?? it.budget ?? 0)}</td>
              <td class="px-4 py-3">₦${numberFormat(it.spent ?? 0)}</td>
              <td class="px-4 py-3">₦${numberFormat(it.remaining ?? 0)}</td>
              <td class="px-4 py-3">${escapeHtml(it.status || '—')}</td>
              <td class="px-4 py-3">
                <button onclick="openDetail('${it._id ?? ''}', 'expense')" class="text-blue-600 text-sm underline">Review</button>
              </td>
            </tr>
          `).join('')}
        </tbody>
      </table>
    </div>
  `;
  document.getElementById('auto-mode').appendChild(container);
}

function renderPaymentResults(items) {
  removeIfExists('payment-results-container');
  if (!items || !items.length) return;

  const container = document.createElement('div');
  container.id = 'payment-results-container';
  container.className = 'mt-6 bg-white rounded-lg shadow overflow-hidden';
  container.innerHTML = `
    <div class="p-4 border-b"><h3 class="font-semibold">Payments vs Receipts Results</h3></div>
    <div class="overflow-x-auto p-4">
      <table class="min-w-full">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Payer</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Expected</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Received</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Diff</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Action</th>
          </tr>
        </thead>
        <tbody>
          ${items.map(it => `
            <tr class="border-t">
              <td class="px-4 py-3">${escapeHtml(it.payer || '—')}</td>
              <td class="px-4 py-3">₦${numberFormat(it.expected ?? 0)}</td>
              <td class="px-4 py-3">₦${numberFormat(it.received ?? 0)}</td>
              <td class="px-4 py-3">${numberFormat(it.diff ?? 0)}</td>
              <td class="px-4 py-3">${escapeHtml(it.status || '—')}</td>
              <td class="px-4 py-3"><button onclick="openDetail('${it._id ?? ''}', 'payment')" class="text-blue-600 underline">Review</button></td>
            </tr>
          `).join('')}
        </tbody>
      </table>
    </div>
  `;
  document.getElementById('auto-mode').appendChild(container);
}

function renderWithdrawalResults(items) {
  removeIfExists('withdrawal-results-container');
  if (!items || !items.length) return;

  const container = document.createElement('div');
  container.id = 'withdrawal-results-container';
  container.className = 'mt-6 bg-white rounded-lg shadow overflow-hidden';
  container.innerHTML = `
    <div class="p-4 border-b"><h3 class="font-semibold">Withdrawals vs Records Results</h3></div>
    <div class="overflow-x-auto p-4">
      <table class="min-w-full">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Account</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Expected</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actual</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Diff</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Action</th>
          </tr>
        </thead>
        <tbody>
          ${items.map(it => `
            <tr class="border-t">
              <td class="px-4 py-3">${escapeHtml(it.account || '—')}</td>
              <td class="px-4 py-3">₦${numberFormat(it.expected ?? 0)}</td>
              <td class="px-4 py-3">₦${numberFormat(it.actual ?? 0)}</td>
              <td class="px-4 py-3">${numberFormat(it.diff ?? 0)}</td>
              <td class="px-4 py-3">${escapeHtml(it.status || '—')}</td>
              <td class="px-4 py-3"><button onclick="openDetail('${it._id ?? ''}', 'withdrawal')" class="text-blue-600 underline">Review</button></td>
            </tr>
          `).join('')}
        </tbody>
      </table>
    </div>
  `;
  document.getElementById('auto-mode').appendChild(container);
}

/* ---------- OPEN DETAIL (robust) ---------- */
async function openDetail(id, type = 'inventory') {
  // show modal
  document.getElementById('modal-content').innerHTML = `<div class="text-center py-6">Loading...</div>`;
  document.getElementById('detail-modal').classList.remove('hidden');

  // Try standard inventory detail endpoint first
  try {
    const res = await fetch(`/user/api/audit/detail/${id}`);
    if (res.ok) {
      const data = await res.json();
      return showDetailModal(data, type);
    }

    // if 404 and we have type, try type-specific route if your backend supports it
    if (type) {
      const fallback = await fetch(`/user/api/audit/detail/${type}/${id}`);
      if (fallback.ok) {
        const data2 = await fallback.json();
        return showDetailModal(data2, type);
      }
    }

    // nothing found
    const text = await res.text();
    document.getElementById('modal-content').innerHTML = `<p class="text-red-600">Detail not found: ${text}</p>`;
  } catch (err) {
    console.error('Detail fetch failed:', err);
    document.getElementById('modal-content').innerHTML = `<p class="text-red-600">Failed to load detail</p>`;
  }
}

function showDetailModal(data, type = 'inventory') {
  const item = data.item || data;
  const approval = item.approvalStatus || 'pending';
  const toggleAction = approval === 'approved' ? 'disapprove' : 'approve';
  const toggleLabel = toggleAction.charAt(0).toUpperCase() + toggleAction.slice(1);

  document.getElementById('modal-content').innerHTML = `
    <div class="space-y-4">
      <div>
        <h4 class="font-semibold text-lg">${escapeHtml(item.product || item.itemName || '')}</h4>
        <p class="text-sm text-gray-500">Audit Mode: <strong>${escapeHtml(data.mode || 'live')}</strong></p>
      </div>

      <div class="grid grid-cols-2 gap-4 p-4 bg-gray-50 rounded-lg">
        <p><strong>Received:</strong> ${formatNumber(item.received ?? 0)}</p>
        <p><strong>Sold:</strong> ${formatNumber(item.sold ?? 0)}</p>
        <p><strong>Expected Value:</strong> $${numberFormat(item.expected ?? 0)}</p>
        <p><strong>Actual Value:</strong> $${numberFormat(item.actual ?? 0)}</p>
        <p><strong>Difference:</strong> 
          <span class="px-2 py-1 rounded ${item.diff === 0 ? 'bg-green-100 text-green-700' : item.diff > 0 ? 'bg-yellow-100 text-yellow-700' : 'bg-red-100 text-red-700'}">
            $${numberFormat(Math.abs(item.diff ?? 0))}
          </span>
        </p>
        <p><strong>Approval:</strong> <span id="audit-status">${escapeHtml(approval)}</span></p>
      </div>

      <div class="p-4 bg-gray-100 rounded-lg">
        <h5 class="font-semibold mb-2">Audit Summary</h5>
        <p><strong>Total Items:</strong> ${data.stats?.total ?? 1}</p>
        <p><strong>Mismatches:</strong> ${data.stats?.mismatches ?? (item.diff !== 0 ? 1 : 0)}</p>
        <p><strong>Total Amount Difference:</strong> $${numberFormat(data.stats?.amountDiff ?? Math.abs(item.diff ?? 0))}</p>
        <p><strong>Total Stock Difference:</strong> ${numberFormat(data.stats?.stockDiff ?? Math.abs((item.received||0)-(item.sold||0)))}</p>
        <p><strong>Approved:</strong> ${data.stats?.approved ?? (approval === 'approved' ? 1 : 0)}</p>
        <p><strong>Disapproved:</strong> ${data.stats?.disapproved ?? (approval === 'disapproved' ? 1 : 0)}</p>
      </div>

      <div class="flex justify-end gap-3">
        <button id="modal-toggle-action" onclick="sendAuditAction('${item._id}', '${toggleAction}', '${type}')" 
          class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700">
          ${toggleLabel}
        </button>
        <button onclick="closeModal()" 
          class="px-4 py-2 bg-gray-300 rounded hover:bg-gray-400">
          Close
        </button>
      </div>
    </div>
  `;
  return;
}

window.closeModal = () => document.getElementById('detail-modal').classList.add('hidden');

/* ---------- SEND AUDIT ACTION (approve/disapprove) ---------- */
async function sendAuditAction(id, action, type = 'inventory') {
  try {
    const res = await fetch(`/user/api/audit/action/${id}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action, user: 'You', type })
    });

    const data = await res.json();
    if (!res.ok) {
      alert(data.error || 'Action failed');
      return;
    }

    // update modal text quickly
    const newStatus = action === 'approve' ? 'approved' : 'disapproved';
    const statusEl = document.getElementById('audit-status');
    if (statusEl) statusEl.innerText = newStatus;

    // update the toggle button label / onclick
    const btn = document.getElementById('modal-toggle-action');
    if (btn) {
      const nextAction = action === 'approve' ? 'disapprove' : 'approve';
      btn.innerText = nextAction.charAt(0).toUpperCase() + nextAction.slice(1);
      btn.setAttribute('onclick', `sendAuditAction('${id}', '${nextAction}', '${type}')`);
    }

    // feedback & refresh counts
    alert(`Record ${newStatus}`);
    // optionally refresh the audit list - you can call start-audit handler again
    // location.reload(); // uncomment if you want a full reload
  } catch (err) {
    console.error('Action failed', err);
    alert('Failed to perform action');
  }
}

/* ---------- UTILITIES ---------- */
function getMatchClass(diff) {
  const abs = Math.abs(diff || 0);
  if (abs === 0) return 'match-green';
  if (abs <= 5) return 'match-yellow';
  return 'match-red';
}

function approvalClass(status) {
  if (!status) return 'bg-gray-200 text-gray-700';
  if (status === 'approved') return 'bg-green-200 text-green-700';
  if (status === 'disapproved') return 'bg-red-200 text-red-700';
  return 'bg-gray-200 text-gray-700';
}

function numberFormat(n) {
  if (n === null || n === undefined) return '0.00';
  return Number(n).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

function formatNumber(n) {
  if (n === null || n === undefined) return 0;
  if (n >= 1_000_000_000) return (n / 1_000_000_000).toFixed(1) + 'B';
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + 'M';
  if (n >= 1_000) return (n / 1_000).toFixed(1) + 'K';
  return n;
}

function escapeHtml(str) {
  if (str === null || str === undefined) return '';
  return String(str)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#039;');
}

function removeIfExists(id) {
  const el = document.getElementById(id);
  if (el) el.remove();
}

/* ---------- DASHBOARD UPDATE ---------- */
function updateDashboard(stats) {
  document.getElementById('total-audits').textContent = formatNumber(stats.total || 0);
  document.getElementById('mismatches').textContent = formatNumber(stats.mismatches || 0);
  document.getElementById('amount-diff').textContent = `₦${formatNumber(stats.amountDiff || 0)}`;
  document.getElementById('stock-diff').textContent = formatNumber(stats.stockDiff || 0);
  document.getElementById('approved').textContent = formatNumber(stats.approved || 0);
  document.getElementById('disapproved').textContent = formatNumber(stats.disapproved || 0);
}

/* ---------- MANUAL FORM (unchanged but safe) ---------- */
document.getElementById('manual-form').onsubmit = async (e) => {
  e.preventDefault();
  const form = e.target;
  const data = {
    product: form.product.value,
    received: +form.received.value || 0,
    sold: +form.sold.value || 0,
    expected: +form.expected.value || 0,
    actual: +form.actual.value || 0,
    notes: form.notes.value || '',
    type: 'manual'
  };

  try {
    const res = await fetch('/user/api/audit/manual', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data)
    });
    const result = await res.json();
    document.getElementById('manual-results').classList.remove('hidden');

    // backend should return the record object; if it returns { record } adjust accordingly
    const record = result.record || result;
    document.getElementById('manual-result-body').innerHTML = `
      <div class="p-4 bg-gray-50 rounded-lg">
        <p><strong>Product:</strong> ${escapeHtml(record.product)}</p>
        <p><strong>Difference Found:</strong> 
          <span class="${getMatchClass(record.diff)}">$${numberFormat(Math.abs(record.diff || 0))}</span>
        </p>
        <p><strong>Accuracy Score:</strong> ${record.score ?? 'N/A'}%</p>
        <div class="mt-4 flex gap-2">
          <button onclick="sendAuditAction('${record._id || ''}', 'approve', 'manual')" class="bg-green-600 text-white px-4 py-1 rounded">Approve</button>
          <button onclick="sendAuditAction('${record._id || ''}', 'disapprove', 'manual')" class="bg-red-600 text-white px-4 py-1 rounded">Disapprove</button>
        </div>
      </div>
    `;
  } catch (err) {
    console.error('Manual audit failed', err);
    alert('Manual audit failed');
  }
};
</script>


