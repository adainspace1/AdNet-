<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CRM & Sales Pipeline</title>
    <!-- Google Fonts: Poppins -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>


    <link rel="stylesheet" href="/css/crm.css">
</head>
<body>

  <div  class="all">

        <%- include ("../_sidebar1") %>

                <div class="main-content">
                    <%- include ("../_topnav") %>

        <div class="headerr">
            <h1>CRM & Sales Pipeline</h1>
            <p>Convert leads, close deals, grow revenue</p>
        </div>

        <!-- Stats -->
        <div class="stats-grid" id="stats-container">
            <div class="stat-card"><div class="stat-icon" style="background: var(--primary-color);"><i class="fas fa-users"></i></div><div class="stat-value" id="total-leads">0</div><div class="stat-label">Leads</div></div>
            <div class="stat-card"><div class="stat-icon" style="background: var(--success-color);"><i class="fas fa-dollar-sign"></i></div><div class="stat-value" id="pipeline-value">$0</div><div class="stat-label">Pipeline</div></div>
            <div class="stat-card"><div class="stat-icon" style="background: var(--warning-color);"><i class="fas fa-clock"></i></div><div class="stat-value" id="avg-velocity">0</div><div class="stat-label">Avg Velocity</div></div>
            <div class="stat-card"><div class="stat-icon" style="background: var(--info-color);"><i class="fas fa-percentage"></i></div><div class="stat-value" id="conversion-rate">0%</div><div class="stat-label">Conversion</div></div>
        </div>

        <!-- Lead Capture -->
        <section id="lead-capture" class="section active">
            <div class="card">
                <h3><i class="fas fa-user-plus"></i> Capture Lead</h3>
                <div class="form-grid">
                    <div class="form-group"><label>Name *</label><input type="text" id="lead-name" placeholder="John Doe" required></div>
                    <div class="form-group"><label>Email *</label><input type="email" id="lead-email" placeholder="john@company.com"></div>
                    <div class="form-group"><label>Phone</label><input type="tel" id="lead-phone" placeholder="+1234567890"></div>
                    <div class="form-group"><label>Company</label><input type="text" id="lead-company" placeholder="Acme Inc"></div>
                    <div class="form-group"><label>Source</label><select id="lead-source"><option>Web Form</option><option>Referral</option><option>Cold Call</option><option>Social</option></select></div>
                    <div class="form-group"><label>Score</label><input type="number" id="lead-score" min="0" max="100" value="50"></div>
                </div>
                <button class="btn btn-primary" onclick="addLead()"><i class="fas fa-save"></i> Save Lead</button>
            </div>

            <div class="card">
                <h3><i class="fas fa-list-ul"></i> Lead Directory</h3>
                <div class="table-container">
                    <table id="lead-table">
                        <thead><tr><th>Name</th><th>Email</th><th>Source</th><th>Score</th><th>Act</th></tr></thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </section>

        <!-- Pipeline -->
        <section id="pipeline" class="section">
            <div class="card">
                <h3><i class="fas fa-project-diagram"></i> Sales Pipeline</h3>
                <div class="pipeline" id="pipeline-stages">
                    <!-- JS will populate -->
                </div>
            </div>

            <div class="card">
                <h3><i class="fas fa-plus-circle"></i> Add Opportunity</h3>
                <div class="form-grid">
                    <div class="form-group"><label>Lead</label><select id="opp-lead"></select></div>
                    <div class="form-group"><label>Value *</label><input type="number" id="opp-value" placeholder="50000" min="0"></div>
                    <div class="form-group"><label>Product</label><input type="text" id="opp-product" placeholder="Pro Plan"></div>
                    <div class="form-group"><label>Stage</label><select id="opp-stage"><option>Qualification</option><option>Proposal</option><option>Negotiation</option><option>Closed Won</option><option>Closed Lost</option></select></div>
                </div>
                <button class="btn btn-success" onclick="addOpportunity()"><i class="fas fa-arrow-right"></i> Add to Pipeline</button>
            </div>
        </section>

        <!-- Activities -->
        <section id="activities" class="section">
            <div class="card">
                <h3><i class="fas fa-plus"></i> Log Activity</h3>
                <div class="form-grid">
                    <div class="form-group"><label>Lead/Deal</label><select id="act-entity"></select></div>
                    <div class="form-group"><label>Type</label><select id="act-type"><option>Call</option><option>Email</option><option>Meeting</option><option>Note</option></select></div>
                    <div class="form-group"><label>Notes</label><textarea id="act-notes" placeholder="Discussed pricing..."></textarea></div>
                </div>
                <button class="btn btn-info" onclick="logActivity()"><i class="fas fa-check"></i> Log</button>
            </div>

            <div class="card">
                <h3><i class="fas fa-history"></i> Communication History</h3>
                <div id="activity-feed" style="max-height: 400px; overflow-y: auto;">
                    <!-- JS populated -->
                </div>
            </div>
        </section>

        <!-- Analytics -->
        <section id="analytics" class="section">
            <div class="card">
                <h3 class="chart-title"><i class="fas fa-chart-bar"></i> Pipeline Velocity</h3>
                <div class="chart-container">
                    <div class="chart-wrapper">
                        <canvas id="velocityChart"></canvas>
                    </div>
                </div>
            </div>

            <div class="card">
                <h3 class="chart-title"><i class="fas fa-funnel-dollar"></i> Conversion Funnel</h3>
                <div class="chart-container">
                    <div class="chart-wrapper">
                        <canvas id="funnelChart"></canvas>
                    </div>
                </div>
            </div>
        </section>

        <!-- Integrations -->
        <section id="integrations" class="section">
            <div class="card">
                <h3><i class="fas fa-plug"></i> Connect Tools</h3>
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 12px;">
                    <div class="card" style="text-align: center; padding: 16px;">
                        <i class="fab fa-whatsapp" style="font-size: 2rem; color: #25d366;"></i>
                        <p style="margin: 8px 0 4px; font-weight: 600;">WhatsApp</p>
                        <button class="btn btn-success btn-sm">Connect</button>
                    </div>
                    <div class="card" style="text-align: center; padding: 16px;">
                        <i class="fas fa-envelope" style="font-size: 2rem; color: #ea4335;"></i>
                        <p style="margin: 8px 0 4px; font-weight: 600;">Gmail</p>
                        <button class="btn btn-danger btn-sm">Connect</button>
                    </div>
                    <div class="card" style="text-align: center; padding: 16px;">
                        <i class="fas fa-calendar-alt" style="font-size: 2rem; color: #4285f4;"></i>
                        <p style="margin: 8px 0 4px; font-weight: 600;">Google Calendar</p>
                        <button class="btn btn-info btn-sm">Connect</button>
                    </div>
                    <div class="card" style="text-align: center; padding: 16px;">
                        <i class="fas fa-phone-volume" style="font-size: 2rem; color: #7c3aed;"></i>
                        <p style="margin: 8px 0 4px; font-weight: 600;">VoIP</p>
                        <button class="btn btn-primary btn-sm">Connect</button>
                    </div>
                </div>
            </div>
        </section>
    </div>
</div>

  
</body>
</html>