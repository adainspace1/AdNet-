<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>HR & Payroll Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#1d4ed8',
                        'primary-dark': '#1e40af',
                        secondary: '#64748b',
                        success: '#10b981',
                        warning: '#f59e0b',
                        danger: '#ef4444',
                    }
                }
            }
        }
    </script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <style>
        [x-cloak] {
            display: none !important;
        }

        .sidebar-active {
            @apply bg-primary text-white;
        }

        .sidebar-hover:hover {
            @apply bg-blue-50 text-primary;
        }
    </style>
</head>

<body class="bg-gray-100 font-sans" x-data="{ 
  currentTab: 'dashboard',
  mobileMenuOpen: false,
  modals: {
    addEmployee: false,
    leaveRequest: false
  }
}">

    <div class="flex h-screen overflow-hidden">
        <!-- Sidebar -->
        <aside class="w-64 bg-white shadow-lg flex flex-col hidden lg:flex">
            <div class="p-6 border-b">
                <h1 class="text-2xl font-bold text-primary">HRPayroll Pro</h1>
                <p class="text-xs text-gray-500 mt-1">Enterprise HR System</p>
            </div>
            <nav class="flex-1 px-4 py-6 space-y-1 overflow-y-auto">
                <a href="#" @click.prevent="currentTab = 'dashboard'"
                    :class="currentTab === 'dashboard' ? 'sidebar-active' : 'sidebar-hover'"
                    class="flex items-center px-4 py-3 rounded-lg transition-colors text-gray-700">
                    <i class="fas fa-tachometer-alt mr-3 w-5 text-center"></i> Dashboard
                </a>
                <a href="#" @click.prevent="currentTab = 'employees'"
                    :class="currentTab === 'employees' ? 'sidebar-active' : 'sidebar-hover'"
                    class="flex items-center px-4 py-3 rounded-lg transition-colors text-gray-700">
                    <i class="fas fa-users mr-3 w-5 text-center"></i> Employee Records
                </a>
                <a href="#" @click.prevent="currentTab = 'payroll'"
                    :class="currentTab === 'payroll' ? 'sidebar-active' : 'sidebar-hover'"
                    class="flex items-center px-4 py-3 rounded-lg transition-colors text-gray-700">
                    <i class="fas fa-money-bill-wave mr-3 w-5 text-center"></i> Payroll Engine
                </a>
                <a href="#" @click.prevent="currentTab = 'attendance'"
                    :class="currentTab === 'attendance' ? 'sidebar-active' : 'sidebar-hover'"
                    class="flex items-center px-4 py-3 rounded-lg transition-colors text-gray-700">
                    <i class="fas fa-clock mr-3 w-5 text-center"></i> Attendance & Leave
                </a>
                <a href="#" @click.prevent="currentTab = 'selfservice'"
                    :class="currentTab === 'selfservice' ? 'sidebar-active' : 'sidebar-hover'"
                    class="flex items-center px-4 py-3 rounded-lg transition-colors text-gray-700">
                    <i class="fas fa-user-circle mr-3 w-5 text-center"></i> Self-Service
                </a>
                <a href="#" @click.prevent="currentTab = 'compliance'"
                    :class="currentTab === 'compliance' ? 'sidebar-active' : 'sidebar-hover'"
                    class="flex items-center px-4 py-3 rounded-lg transition-colors text-gray-700">
                    <i class="fas fa-file-contract mr-3 w-5 text-center"></i> Compliance
                </a>
            </nav>
            <div class="p-4 border-t bg-gray-50">
                <div class="flex items-center">
                    <div
                        class="w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center font-bold">
                                                    <% if (user && user.firstName && user.lastName) { %>
  <%= user.firstName.charAt(0).toUpperCase() + user.firstName.slice(1).toLowerCase() %> 
  <%= user.lastName.charAt(0).toUpperCase() + user.lastName.slice(1).toLowerCase() %>
<% } else if (worker && worker.name) { %>
  <%= worker.name %>
<% } else if (user && user.name) { %> 
  <!-- vendor session case -->
  <%= user.name %>
<% } else { %>
  Guest User
<% } %>
                    </div>
                    <div class="ml-3">
                        <p class="text-sm font-medium text-gray-900">
                            <%= user ? user.name : 'Admin' %>
                        </p>
                        <p class="text-xs text-gray-500">Administrator</p>
                    </div>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <div class="flex-1 flex flex-col overflow-hidden">
            <!-- Topbar -->
            <header class="bg-white shadow-sm border-b z-10">
                <div class="flex items-center justify-between px-6 py-4">
                    <div class="flex items-center space-x-4">
                        <button @click="mobileMenuOpen = !mobileMenuOpen"
                            class="lg:hidden text-gray-600 hover:text-gray-900">
                            <i class="fas fa-bars text-xl"></i>
                        </button>
                        <div class="text-sm text-gray-500 hidden sm:block">
                            <span>HR Portal</span> <span class="mx-2">/</span> <span
                                class="text-primary font-medium capitalize" x-text="currentTab"></span>
                        </div>
                    </div>
                    <div class="flex items-center space-x-4">
                        <button class="relative text-gray-600 hover:text-primary transition">
                            <i class="fas fa-bell text-xl"></i>
                            <span
                                class="absolute -top-1 -right-1 bg-red-500 text-white text-xs rounded-full w-5 h-5 flex items-center justify-center">3</span>
                        </button>
                        <a href="/logout"
                            class="text-sm font-medium text-gray-600 hover:text-red-600 transition">Logout</a>
                    </div>
                </div>
            </header>

            <!-- Content Area -->
            <main class="flex-1 overflow-y-auto bg-gray-100 p-6">

                <!-- DASHBOARD TAB -->
                <div x-show="currentTab === 'dashboard'" x-transition.opacity>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
                        <!-- Stat Cards -->
                        <div class="bg-white rounded-xl shadow-sm p-6 border-l-4 border-blue-500">
                            <div class="flex justify-between items-start">
                                <div>
                                    <p class="text-sm font-medium text-gray-500">Total Employees</p>
                                    <h3 class="text-3xl font-bold text-gray-900 mt-2">
                                        <%= stats.totalEmployees %>
                                    </h3>
                                </div>
                                <div class="p-3 bg-blue-50 rounded-lg text-blue-600">
                                    <i class="fas fa-users text-xl"></i>
                                </div>
                            </div>
                        </div>
                        <div class="bg-white rounded-xl shadow-sm p-6 border-l-4 border-green-500">
                            <div class="flex justify-between items-start">
                                <div>
                                    <p class="text-sm font-medium text-gray-500">Active Contracts</p>
                                    <h3 class="text-3xl font-bold text-gray-900 mt-2">
                                        <%= stats.activeContracts %>
                                    </h3>
                                </div>
                                <div class="p-3 bg-green-50 rounded-lg text-green-600">
                                    <i class="fas fa-file-signature text-xl"></i>
                                </div>
                            </div>
                        </div>
                        <div class="bg-white rounded-xl shadow-sm p-6 border-l-4 border-purple-500">
                            <div class="flex justify-between items-start">
                                <div>
                                    <p class="text-sm font-medium text-gray-500">Payroll Runs</p>
                                    <h3 class="text-3xl font-bold text-gray-900 mt-2">
                                        <%= stats.payrollRuns %>
                                    </h3>
                                </div>
                                <div class="p-3 bg-purple-50 rounded-lg text-purple-600">
                                    <i class="fas fa-money-check-alt text-xl"></i>
                                </div>
                            </div>
                        </div>
                        <div class="bg-white rounded-xl shadow-sm p-6 border-l-4 border-orange-500">
                            <div class="flex justify-between items-start">
                                <div>
                                    <p class="text-sm font-medium text-gray-500">Pending Leaves</p>
                                    <h3 class="text-3xl font-bold text-gray-900 mt-2">
                                        <%= stats.pendingLeaves %>
                                    </h3>
                                </div>
                                <div class="p-3 bg-orange-50 rounded-lg text-orange-600">
                                    <i class="fas fa-calendar-minus text-xl"></i>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Recent Activity & Quick Actions -->
                    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                        <div class="lg:col-span-2 bg-white rounded-xl shadow-sm p-6">
                            <h3 class="text-lg font-bold text-gray-800 mb-4">Quick Actions</h3>
                            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                                <button @click="modals.addEmployee = true"
                                    class="p-4 border rounded-xl hover:bg-blue-50 hover:border-blue-200 transition text-center group">
                                    <div
                                        class="w-12 h-12 mx-auto bg-blue-100 text-blue-600 rounded-full flex items-center justify-center mb-3 group-hover:bg-blue-600 group-hover:text-white transition">
                                        <i class="fas fa-user-plus"></i>
                                    </div>
                                    <span class="text-sm font-medium text-gray-700">Add Employee</span>
                                </button>
                                <a href="/expenses"
                                    class="p-4 border rounded-xl hover:bg-green-50 hover:border-green-200 transition text-center group block">
                                    <div
                                        class="w-12 h-12 mx-auto bg-green-100 text-green-600 rounded-full flex items-center justify-center mb-3 group-hover:bg-green-600 group-hover:text-white transition">
                                        <i class="fas fa-play"></i>
                                    </div>
                                    <span class="text-sm font-medium text-gray-700">Run Payroll</span>
                                </a>
                                <button @click="currentTab = 'attendance'"
                                    class="p-4 border rounded-xl hover:bg-orange-50 hover:border-orange-200 transition text-center group">
                                    <div
                                        class="w-12 h-12 mx-auto bg-orange-100 text-orange-600 rounded-full flex items-center justify-center mb-3 group-hover:bg-orange-600 group-hover:text-white transition">
                                        <i class="fas fa-clock"></i>
                                    </div>
                                    <span class="text-sm font-medium text-gray-700">Timesheets</span>
                                </button>
                                <button @click="currentTab = 'compliance'"
                                    class="p-4 border rounded-xl hover:bg-purple-50 hover:border-purple-200 transition text-center group">
                                    <div
                                        class="w-12 h-12 mx-auto bg-purple-100 text-purple-600 rounded-full flex items-center justify-center mb-3 group-hover:bg-purple-600 group-hover:text-white transition">
                                        <i class="fas fa-file-export"></i>
                                    </div>
                                    <span class="text-sm font-medium text-gray-700">Reports</span>
                                </button>
                            </div>
                        </div>

                        <div class="bg-white rounded-xl shadow-sm p-6">
                            <h3 class="text-lg font-bold text-gray-800 mb-4">System Status</h3>
                            <div class="space-y-4">
                                <div class="flex items-center justify-between p-3 bg-green-50 rounded-lg">
                                    <div class="flex items-center">
                                        <i class="fas fa-check-circle text-green-500 mr-3"></i>
                                        <span class="text-sm font-medium text-gray-700">Payroll System</span>
                                    </div>
                                    <span
                                        class="text-xs font-bold text-green-600 bg-green-100 px-2 py-1 rounded">Active</span>
                                </div>
                                <div class="flex items-center justify-between p-3 bg-green-50 rounded-lg">
                                    <div class="flex items-center">
                                        <i class="fas fa-check-circle text-green-500 mr-3"></i>
                                        <span class="text-sm font-medium text-gray-700">Tax Compliance</span>
                                    </div>
                                    <span class="text-xs font-bold text-green-600 bg-green-100 px-2 py-1 rounded">Up to
                                        date</span>
                                </div>
                                <div class="flex items-center justify-between p-3 bg-blue-50 rounded-lg">
                                    <div class="flex items-center">
                                        <i class="fas fa-info-circle text-blue-500 mr-3"></i>
                                        <span class="text-sm font-medium text-gray-700">Next Pay Run</span>
                                    </div>
                                    <span class="text-xs font-bold text-blue-600 bg-blue-100 px-2 py-1 rounded">In 5
                                        days</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- EMPLOYEES TAB -->
                <div x-show="currentTab === 'employees'" x-cloak>
                    <div class="bg-white rounded-xl shadow-sm overflow-hidden">
                        <div class="p-6 border-b flex flex-col sm:flex-row justify-between items-center gap-4">
                            <h2 class="text-xl font-bold text-gray-800">Employee Records</h2>
                            <button @click="modals.addEmployee = true"
                                class="bg-primary text-white px-4 py-2 rounded-lg hover:bg-primary-dark transition flex items-center">
                                <i class="fas fa-plus mr-2"></i> Add Employee
                            </button>
                        </div>
                        <div class="overflow-x-auto">
                            <table class="w-full text-left border-collapse">
                                <thead class="bg-gray-50">
                                    <tr>
                                        <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase">Employee
                                        </th>
                                        <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase">Role</th>
                                        <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase">Status</th>
                                        <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase">Joined</th>
                                        <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase">Actions</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-100">
                                    <% if (workers && workers.length> 0) { %>
                                        <% workers.forEach(function(w) { %>
                                            <tr class="hover:bg-gray-50 transition">
                                                <td class="px-6 py-4">
                                                    <div class="flex items-center">
                                                        <div
                                                            class="w-8 h-8 rounded-full bg-gray-200 flex items-center justify-center text-xs font-bold text-gray-600 mr-3">
                                                                                        <% if (user && user.firstName && user.lastName) { %>
  <%= user.firstName.charAt(0).toUpperCase() + user.firstName.slice(1).toLowerCase() %> 
  <%= user.lastName.charAt(0).toUpperCase() + user.lastName.slice(1).toLowerCase() %>
<% } else if (worker && worker.name) { %>
  <%= worker.name %>
<% } else if (user && user.name) { %> 
  <!-- vendor session case -->
  <%= user.name %>
<% } else { %>
  Guest User
<% } %>
                                                        </div>
                                                        <div>
                                                            <p class="text-sm font-medium text-gray-900">
                                                                <%= w.name %>
                                                            </p>
                                                            <p class="text-xs text-gray-500">
                                                                <%= w.email %>
                                                            </p>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td class="px-6 py-4">
                                                    <span class="text-sm text-gray-700">
                                                        <%= w.roles && w.roles.length> 0 ? w.roles[0].role : 'Staff' %>
                                                    </span>
                                                </td>
                                                <td class="px-6 py-4">
                                                    <span
                                                        class="px-2 py-1 text-xs font-semibold rounded-full bg-green-100 text-green-700">Active</span>
                                                </td>
                                                <td class="px-6 py-4 text-sm text-gray-500">
                                                    <%= new Date(w.createdAt).toLocaleDateString() %>
                                                </td>
                                                <td class="px-6 py-4">
                                                    <button
                                                        class="text-blue-600 hover:text-blue-800 text-sm font-medium">Edit</button>
                                                </td>
                                            </tr>
                                            <% }); %>
                                                <% } else { %>
                                                    <tr>
                                                        <td colspan="5" class="px-6 py-8 text-center text-gray-500">
                                                            No employees found. Add your first employee!
                                                        </td>
                                                    </tr>
                                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- PAYROLL TAB -->
                <div x-show="currentTab === 'payroll'" x-cloak>
                    <div class="bg-white rounded-xl shadow-sm p-8 text-center">
                        <div
                            class="w-20 h-20 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center mx-auto mb-6">
                            <i class="fas fa-rocket text-3xl"></i>
                        </div>
                        <h2 class="text-2xl font-bold text-gray-800 mb-2">Payroll Engine</h2>
                        <p class="text-gray-600 mb-8 max-w-md mx-auto">Manage salaries, run payroll, and generate
                            payslips. Redirecting you to the main payroll module.</p>
                        <a href="/expenses"
                            class="inline-flex items-center px-6 py-3 bg-primary text-white rounded-lg hover:bg-primary-dark transition shadow-lg hover:shadow-xl transform hover:-translate-y-1">
                            <i class="fas fa-external-link-alt mr-2"></i> Launch Payroll System
                        </a>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-8">
                        <div class="bg-white p-6 rounded-xl shadow-sm">
                            <h3 class="font-bold text-gray-800 mb-2">PAYE Calculator</h3>
                            <p class="text-sm text-gray-500 mb-4">Preview tax deductions instantly.</p>
                            <button class="text-primary text-sm font-medium hover:underline">Open Calculator
                                &rarr;</button>
                        </div>
                        <div class="bg-white p-6 rounded-xl shadow-sm">
                            <h3 class="font-bold text-gray-800 mb-2">Pension Remittance</h3>
                            <p class="text-sm text-gray-500 mb-4">Generate monthly pension schedules.</p>
                            <button class="text-primary text-sm font-medium hover:underline">View Schedules
                                &rarr;</button>
                        </div>
                        <div class="bg-white p-6 rounded-xl shadow-sm">
                            <h3 class="font-bold text-gray-800 mb-2">Payslip Generator</h3>
                            <p class="text-sm text-gray-500 mb-4">Bulk generate and email payslips.</p>
                            <button class="text-primary text-sm font-medium hover:underline">Generate Now
                                &rarr;</button>
                        </div>
                    </div>
                </div>

                <!-- ATTENDANCE TAB -->
                <div x-show="currentTab === 'attendance'" x-cloak>
                    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                        <div class="lg:col-span-2 bg-white rounded-xl shadow-sm p-6">
                            <div class="flex justify-between items-center mb-6">
                                <h2 class="text-xl font-bold text-gray-800">Attendance Overview</h2>
                                <button class="text-sm text-primary hover:underline">View Full Report</button>
                            </div>
                            <div class="overflow-x-auto">
                                <table class="w-full text-left">
                                    <thead class="bg-gray-50">
                                        <tr>
                                            <th class="px-4 py-3 text-xs font-semibold text-gray-500 uppercase">Employee
                                            </th>
                                            <th class="px-4 py-3 text-xs font-semibold text-gray-500 uppercase">Date
                                            </th>
                                            <th class="px-4 py-3 text-xs font-semibold text-gray-500 uppercase">Clock In
                                            </th>
                                            <th class="px-4 py-3 text-xs font-semibold text-gray-500 uppercase">Clock
                                                Out</th>
                                            <th class="px-4 py-3 text-xs font-semibold text-gray-500 uppercase">Status
                                            </th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-gray-100">
                                        <!-- Placeholder Data -->
                                        <tr>
                                            <td class="px-4 py-3 text-sm font-medium">John Doe</td>
                                            <td class="px-4 py-3 text-sm text-gray-500">Today</td>
                                            <td class="px-4 py-3 text-sm text-gray-500">08:55 AM</td>
                                            <td class="px-4 py-3 text-sm text-gray-500">--</td>
                                            <td class="px-4 py-3"><span
                                                    class="px-2 py-1 text-xs font-semibold rounded-full bg-green-100 text-green-700">Present</span>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="px-4 py-3 text-sm font-medium">Jane Smith</td>
                                            <td class="px-4 py-3 text-sm text-gray-500">Today</td>
                                            <td class="px-4 py-3 text-sm text-gray-500">09:15 AM</td>
                                            <td class="px-4 py-3 text-sm text-gray-500">--</td>
                                            <td class="px-4 py-3"><span
                                                    class="px-2 py-1 text-xs font-semibold rounded-full bg-yellow-100 text-yellow-700">Late</span>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <div class="bg-white rounded-xl shadow-sm p-6">
                            <h3 class="text-lg font-bold text-gray-800 mb-4">Leave Requests</h3>
                            <div class="space-y-4">
                                <% if (stats.pendingLeaves> 0) { %>
                                    <div class="p-4 border rounded-lg bg-yellow-50 border-yellow-100">
                                        <div class="flex justify-between items-start mb-2">
                                            <span class="font-medium text-gray-800">Pending Approval</span>
                                            <span
                                                class="text-xs text-yellow-600 bg-yellow-200 px-2 py-0.5 rounded-full">Urgent</span>
                                        </div>
                                        <p class="text-sm text-gray-600 mb-3">You have <%= stats.pendingLeaves %>
                                                pending leave requests requiring your attention.</p>
                                        <button
                                            class="w-full py-2 bg-white border border-yellow-300 text-yellow-700 rounded hover:bg-yellow-50 transition text-sm font-medium">Review
                                            Requests</button>
                                    </div>
                                    <% } else { %>
                                        <div class="text-center py-8 text-gray-500">
                                            <i class="fas fa-check-circle text-4xl text-green-200 mb-3"></i>
                                            <p>No pending requests.</p>
                                        </div>
                                        <% } %>
                                            <button @click="modals.leaveRequest = true"
                                                class="w-full py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition">New
                                                Leave Request</button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- SELF SERVICE TAB -->
                <div x-show="currentTab === 'selfservice'" x-cloak>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="bg-white rounded-xl shadow-sm p-6">
                            <h3 class="text-lg font-bold text-gray-800 mb-4">My Profile</h3>
                            <div class="flex items-center mb-6">
                                <div
                                    class="w-16 h-16 rounded-full bg-gray-200 flex items-center justify-center text-xl font-bold text-gray-600 mr-4">
                                                                <% if (user && user.firstName && user.lastName) { %>
  <%= user.firstName.charAt(0).toUpperCase() + user.firstName.slice(1).toLowerCase() %> 
  <%= user.lastName.charAt(0).toUpperCase() + user.lastName.slice(1).toLowerCase() %>
<% } else if (worker && worker.name) { %>
  <%= worker.name %>
<% } else if (user && user.name) { %> 
  <!-- vendor session case -->
  <%= user.name %>
<% } else { %>
  Guest User
<% } %>
                                </div>
                                <div>
                                    <h4 class="text-xl font-bold">
                                        <%= user ? user.name : 'Admin User' %>
                                    </h4>
                                    <p class="text-gray-500">Administrator</p>
                                </div>
                            </div>
                            <div class="space-y-3">
                                <div class="flex justify-between py-2 border-b">
                                    <span class="text-gray-600">Email</span>
                                    <span class="font-medium">
                                        <%= user ? user.email : 'admin@example.com' %>
                                    </span>
                                </div>
                                <div class="flex justify-between py-2 border-b">
                                    <span class="text-gray-600">Employee ID</span>
                                    <span class="font-medium">ADM-001</span>
                                </div>
                                <div class="flex justify-between py-2 border-b">
                                    <span class="text-gray-600">Department</span>
                                    <span class="font-medium">Management</span>
                                </div>
                            </div>
                            <button
                                class="mt-6 w-full py-2 border border-primary text-primary rounded-lg hover:bg-blue-50 transition">Edit
                                Profile</button>
                        </div>

                        <div class="bg-white rounded-xl shadow-sm p-6">
                            <h3 class="text-lg font-bold text-gray-800 mb-4">My Payslips</h3>
                            <div class="space-y-3">
                                <div
                                    class="flex items-center justify-between p-3 border rounded-lg hover:bg-gray-50 cursor-pointer transition">
                                    <div class="flex items-center">
                                        <i class="fas fa-file-invoice-dollar text-green-500 mr-3 text-xl"></i>
                                        <div>
                                            <p class="font-medium text-gray-800">October 2025</p>
                                            <p class="text-xs text-gray-500">Paid on Oct 25, 2025</p>
                                        </div>
                                    </div>
                                    <i class="fas fa-download text-gray-400 hover:text-primary"></i>
                                </div>
                                <div
                                    class="flex items-center justify-between p-3 border rounded-lg hover:bg-gray-50 cursor-pointer transition">
                                    <div class="flex items-center">
                                        <i class="fas fa-file-invoice-dollar text-green-500 mr-3 text-xl"></i>
                                        <div>
                                            <p class="font-medium text-gray-800">September 2025</p>
                                            <p class="text-xs text-gray-500">Paid on Sep 25, 2025</p>
                                        </div>
                                    </div>
                                    <i class="fas fa-download text-gray-400 hover:text-primary"></i>
                                </div>
                            </div>
                            <button class="mt-4 text-sm text-primary hover:underline w-full text-center">View All
                                History</button>
                        </div>
                    </div>
                </div>

                <!-- COMPLIANCE TAB -->
                <div x-show="currentTab === 'compliance'" x-cloak>
                    <div class="bg-white rounded-xl shadow-sm p-6">
                        <h2 class="text-xl font-bold text-gray-800 mb-6">Compliance & Statutory Reporting</h2>
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                            <div class="p-4 border rounded-xl hover:shadow-md transition cursor-pointer">
                                <div
                                    class="w-12 h-12 bg-red-100 text-red-600 rounded-lg flex items-center justify-center mb-4">
                                    <i class="fas fa-university text-xl"></i>
                                </div>
                                <h3 class="font-bold text-gray-800 mb-1">PAYE Schedule</h3>
                                <p class="text-xs text-gray-500 mb-3">Monthly tax remittance report.</p>
                                <span class="text-xs font-bold text-primary">Download PDF &rarr;</span>
                            </div>
                            <div class="p-4 border rounded-xl hover:shadow-md transition cursor-pointer">
                                <div
                                    class="w-12 h-12 bg-blue-100 text-blue-600 rounded-lg flex items-center justify-center mb-4">
                                    <i class="fas fa-piggy-bank text-xl"></i>
                                </div>
                                <h3 class="font-bold text-gray-800 mb-1">Pension Report</h3>
                                <p class="text-xs text-gray-500 mb-3">PFA remittance schedule.</p>
                                <span class="text-xs font-bold text-primary">Download Excel &rarr;</span>
                            </div>
                            <div class="p-4 border rounded-xl hover:shadow-md transition cursor-pointer">
                                <div
                                    class="w-12 h-12 bg-green-100 text-green-600 rounded-lg flex items-center justify-center mb-4">
                                    <i class="fas fa-home text-xl"></i>
                                </div>
                                <h3 class="font-bold text-gray-800 mb-1">NHF Report</h3>
                                <p class="text-xs text-gray-500 mb-3">National Housing Fund.</p>
                                <span class="text-xs font-bold text-primary">Download CSV &rarr;</span>
                            </div>
                            <div class="p-4 border rounded-xl hover:shadow-md transition cursor-pointer">
                                <div
                                    class="w-12 h-12 bg-orange-100 text-orange-600 rounded-lg flex items-center justify-center mb-4">
                                    <i class="fas fa-shield-alt text-xl"></i>
                                </div>
                                <h3 class="font-bold text-gray-800 mb-1">NSITF Report</h3>
                                <p class="text-xs text-gray-500 mb-3">Social Insurance Trust Fund.</p>
                                <span class="text-xs font-bold text-primary">Download PDF &rarr;</span>
                            </div>
                        </div>
                    </div>
                </div>

            </main>
        </div>
    </div>

    <!-- MODALS -->

    <!-- Add Employee Modal -->
    <div x-show="modals.addEmployee" class="fixed inset-0 z-50 overflow-y-auto" x-cloak>
        <div class="flex items-center justify-center min-h-screen px-4 pt-4 pb-20 text-center sm:block sm:p-0">
            <div class="fixed inset-0 transition-opacity" aria-hidden="true" @click="modals.addEmployee = false">
                <div class="absolute inset-0 bg-gray-500 opacity-75"></div>
            </div>
            <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>
            <div
                class="inline-block align-bottom bg-white rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full">
                <div class="bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
                    <h3 class="text-lg leading-6 font-medium text-gray-900 mb-4">Add New Employee</h3>
                    <form action="/HR/employee" method="POST">
                        <div class="grid grid-cols-1 gap-4">
                            <div>
                                <label class="block text-sm font-medium text-gray-700">Full Name</label>
                                <input type="text" name="name" required
                                    class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-primary focus:border-primary sm:text-sm border p-2">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700">Email</label>
                                <input type="email" name="email" required
                                    class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-primary focus:border-primary sm:text-sm border p-2">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700">Role</label>
                                <select name="role"
                                    class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-primary focus:border-primary sm:text-sm border p-2">
                                    <option value="staff">Staff</option>
                                    <option value="hr">HR Manager</option>
                                    <option value="finance">Finance</option>
                                </select>
                            </div>
                            <!-- Hidden fields for compatibility with Worker model if needed -->
                            <input type="hidden" name="password" value="password123">
                            <!-- Default password, should be changed -->
                            <input type="hidden" name="username" value="generated_user">
                            <!-- Logic needed in controller -->
                        </div>
                        <div class="mt-5 sm:mt-6 sm:grid sm:grid-cols-2 sm:gap-3 sm:grid-flow-row-dense">
                            <button type="submit"
                                class="w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-primary text-base font-medium text-white hover:bg-primary-dark focus:outline-none sm:col-start-2 sm:text-sm">
                                Create
                            </button>
                            <button type="button" @click="modals.addEmployee = false"
                                class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-gray-700 hover:bg-gray-50 focus:outline-none sm:mt-0 sm:col-start-1 sm:text-sm">
                                Cancel
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Leave Request Modal -->
    <div x-show="modals.leaveRequest" class="fixed inset-0 z-50 overflow-y-auto" x-cloak>
        <div class="flex items-center justify-center min-h-screen px-4 pt-4 pb-20 text-center sm:block sm:p-0">
            <div class="fixed inset-0 transition-opacity" aria-hidden="true" @click="modals.leaveRequest = false">
                <div class="absolute inset-0 bg-gray-500 opacity-75"></div>
            </div>
            <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>
            <div
                class="inline-block align-bottom bg-white rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full">
                <div class="bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
                    <h3 class="text-lg leading-6 font-medium text-gray-900 mb-4">Request Leave</h3>
                    <form action="/HR/leave" method="POST">
                        <div class="grid grid-cols-1 gap-4">
                            <div>
                                <label class="block text-sm font-medium text-gray-700">Leave Type</label>
                                <select name="type"
                                    class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-primary focus:border-primary sm:text-sm border p-2">
                                    <option value="Annual">Annual Leave</option>
                                    <option value="Sick">Sick Leave</option>
                                    <option value="Maternity">Maternity Leave</option>
                                    <option value="Unpaid">Unpaid Leave</option>
                                </select>
                            </div>
                            <div class="grid grid-cols-2 gap-4">
                                <div>
                                    <label class="block text-sm font-medium text-gray-700">Start Date</label>
                                    <input type="date" name="startDate" required
                                        class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-primary focus:border-primary sm:text-sm border p-2">
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-700">End Date</label>
                                    <input type="date" name="endDate" required
                                        class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-primary focus:border-primary sm:text-sm border p-2">
                                </div>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700">Reason</label>
                                <textarea name="reason" rows="3"
                                    class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-primary focus:border-primary sm:text-sm border p-2"></textarea>
                            </div>
                        </div>
                        <div class="mt-5 sm:mt-6 sm:grid sm:grid-cols-2 sm:gap-3 sm:grid-flow-row-dense">
                            <button type="submit"
                                class="w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-primary text-base font-medium text-white hover:bg-primary-dark focus:outline-none sm:col-start-2 sm:text-sm">
                                Submit Request
                            </button>
                            <button type="button" @click="modals.leaveRequest = false"
                                class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-gray-700 hover:bg-gray-50 focus:outline-none sm:mt-0 sm:col-start-1 sm:text-sm">
                                Cancel
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

</body>

</html>