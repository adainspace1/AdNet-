<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Debt Management & Cost of Capital</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/boxicons/2.1.4/css/boxicons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/debtmanagement.css">
        <link rel="stylesheet" href="/css/dashall.css">
</head>


<body>



<div class="all">
                <%- include ("_sidebar1") %>

            <div class="main-content">
                <%- include ("_topnav") %>




                        <div class="container">
                <div class="main-container">
                    <!-- Header -->
                     <header class="page-header">
    <div class="header-content">
      <h1> Debt Management & Cost of Capital</h1>
      <p>Manage your company's capital structure and financing costs</p>
    </div>
    <div class="header-actions">
      <a href="/Debtmanagement/export" class="btn-secondary">
        <i class="bx bx-export"></i> Export Report
      </a>
      <button class="btn-primary" form="analysis-form" type="submit">
        <i class="bx bx-save"></i> Save Analysis
      </button>
    </div>
                        </header>

                        <div class="content-wrapper">
                            <% if (error) { %>
                            <p class="error-message"><%= error %></p>
                            <% } %>
                            <% if (success) { %>
                            <p class="success-message"><%= success %></p>
                            <% } %>

                            <div class="overview-cards">
                            <div class="overview-card">
                                <div class="card-icon"><i class="bx bx-trending-down"></i></div>
                                <div class="card-content">
                                <h3>Current WACC</h3>
                                <div class="metric-value" id="current-wacc">
                                    <%= analysis.results && analysis.results.wacc ? analysis.results.wacc.toFixed(2) + '%' : '--' %>
                                </div>
                                <span class="metric-label">Weighted Average Cost</span>
                                </div>
                            </div>
                            <div class="overview-card">
                                <div class="card-icon"><i class="bx bx-pie-chart-alt-2"></i></div>
                                <div class="card-content">
                                <h3>Debt Ratio</h3>
                                <div class="metric-value" id="debt-ratio">
                                    <%= analysis.results && analysis.results.debtRatio ? analysis.results.debtRatio.toFixed(1) + '%' : '--' %>
                                </div>
                                <span class="metric-label">Debt / Total Capital</span>
                                </div>
                            </div>
                            <div class="overview-card">
                                <div class="card-icon"><i class="bx bx-shield"></i></div>
                                <div class="card-content">
                                <h3>Tax Shield</h3>
                                <div class="metric-value" id="tax-shield">
                                    <%= analysis.results && analysis.results.taxShield ? '$' + analysis.results.taxShield.toFixed(1) + 'M' : '--' %>
                                </div>
                                <span class="metric-label">Annual Tax Savings</span>
                                </div>
                            </div>
                            <div class="overview-card">
                                <div class="card-icon"><i class="bx bx-chart"></i></div>
                                <div class="card-content">
                                <h3>Cost of Equity</h3>
                                <div class="metric-value" id="cost-equity">
                                    <%= analysis.results && analysis.results.costOfEquity ? analysis.results.costOfEquity.toFixed(2) + '%' : '--' %>
                                </div>
                                <span class="metric-label">Required Return</span>
                                </div>
                            </div>
                            </div>

                            <div class="calculator-grid">
                            <!-- Company Information -->
                            <div class="calculator-section">
                                <div class="section-header">
                                <h2><i class="bx bx-building"></i> Company Information</h2>
                                <button class="btn-icon" form="company-form" type="reset">
                                    <i class="bx bx-refresh"></i>
                                </button>
                                </div>
                                <div class="section-content">
                                <form id="company-form" action="/Debtmanagement/company" method="POST">
                                    <div class="input-group">
                                    <label for="company-name">Company Name</label>
                                    <input type="text" id="company-name" name="companyName" value="<%= company.companyName || '' %>" placeholder="Enter company name">
                                    </div>
                                    <div class="input-row">
                                    <div class="input-group">
                                        <label for="market-cap">Market Capitalization</label>
                                        <div class="input-with-currency">
                                        <span class="currency">$</span>
                                        <input type="number" id="market-cap" name="marketCap" value="<%= company.marketCap || '' %>" placeholder="0" step="1000000">
                                        <span class="unit">M</span>
                                        </div>
                                    </div>
                                    <div class="input-group">
                                        <label for="total-debt">Total Debt</label>
                                        <div class="input-with-currency">
                                        <span class="currency">$</span>
                                        <input type="number" id="total-debt" name="totalDebt" value="<%= company.totalDebt || '' %>" placeholder="0" step="1000000">
                                        <span class="unit">M</span>
                                        </div>
                                    </div>
                                    </div>
                                    <div class="input-row">
                                    <div class="input-group">
                                        <label for="tax-rate">Corporate Tax Rate</label>
                                        <div class="input-with-currency">
                                        <input type="number" id="tax-rate" name="taxRate" value="<%= company.taxRate || '' %>" placeholder="25" step="0.1" min="0" max="100">
                                        <span class="unit">%</span>
                                        </div>
                                    </div>
                                    <div class="input-group">
                                        <label for="shares-outstanding">Shares Outstanding</label>
                                        <div class="input-with-currency">
                                        <input type="number" id="shares-outstanding" name="sharesOutstanding" value="<%= company.sharesOutstanding || '' %>" placeholder="0" step="1000000">
                                        <span class="unit">M</span>
                                        </div>
                                    </div>
                                    </div>
                                    <button type="submit" class="btn-primary">Save Company Info</button>
                                </form>
                                </div>
                            </div>

                            <!-- Cost of Debt Calculator -->
                            <div class="calculator-section">
                                <div class="section-header">
                                <h2><i class="bx bx-credit-card"></i> Cost of Debt</h2>
                                <div class="toggle-switch">
                                    <input type="checkbox" id="after-tax-toggle" name="afterTax" <%= analysis.costOfDebtInputs && analysis.costOfDebtInputs.afterTax ? 'checked' : '' %>>
                                    <label for="after-tax-toggle">After-Tax</label>
                                </div>
                                </div>
                                <div class="section-content">
                                <form id="analysis-form" action="/Debtmanagement/save" method="POST">
                                    <input type="hidden" name="analysisName" value="Default Analysis">
                                    <div class="input-row">
                                    <div class="input-group">
                                        <label for="risk-free-rate">Risk-Free Rate</label>
                                        <div class="input-with-currency">
                                        <input type="number" id="risk-free-rate" name="riskFreeRate" value="<%= analysis.costOfDebtInputs ? analysis.costOfDebtInputs.riskFreeRate : '' %>" placeholder="2.5" step="0.01">
                                        <span class="unit">%</span>
                                        </div>
                                    </div>
                                    <div class="input-group">
                                        <label for="credit-spread">Credit Spread</label>
                                        <div class="input-with-currency">
                                        <input type="number" id="credit-spread" name="creditSpread" value="<%= analysis.costOfDebtInputs ? analysis.costOfDebtInputs.creditSpread : '' %>" placeholder="1.5" step="0.01">
                                        <span class="unit">%</span>
                                        </div>
                                    </div>
                                    </div>
                                    <div class="calculation-result">
                                    <div class="result-label">Cost of Debt</div>
                                    <div class="result-value" id="cost-of-debt">
                                        <%= analysis.results && analysis.results.costOfDebt ? analysis.results.costOfDebt.toFixed(2) + '%' : '--' %>
                                    </div>
                                    </div>
                                    <div class="calculation-breakdown" id="debt-breakdown">
                                    <div class="breakdown-item">
                                        <span>Before-Tax Cost:</span>
                                        <span id="before-tax-cost">
                                        <%= analysis.costOfDebtInputs ? (analysis.costOfDebtInputs.riskFreeRate + analysis.costOfDebtInputs.creditSpread).toFixed(2) + '%' : '--' %>
                                        </span>
                                    </div>
                                    <div class="breakdown-item">
                                        <span>Tax Shield:</span>
                                        <span id="tax-shield-rate">
                                        <%= analysis.results && analysis.results.taxShield ? (analysis.results.taxShield / company.totalDebt * 100).toFixed(2) + '%' : '--' %>
                                        </span>
                                    </div>
                                    </div>

                                    <!-- Cost of Equity Calculator -->
                                    <div class="section-header">
                                    <h2><i class="bx bx-line-chart"></i> Cost of Equity</h2>
                                    <select id="equity-method" name="equityMethod" class="method-selector">
                                        <option value="CAPM" <%= analysis.costOfEquityInputs && analysis.costOfEquityInputs.method === 'CAPM' ? 'selected' : '' %>>CAPM Model</option>
                                        <option value="DDM" <%= analysis.costOfEquityInputs && analysis.costOfEquityInputs.method === 'DDM' ? 'selected' : '' %>>Dividend Discount Model</option>
                                    </select>
                                    </div>
                                    <div class="section-content">
                                    <div id="capm-inputs" class="method-inputs" style="<%= analysis.costOfEquityInputs && analysis.costOfEquityInputs.method === 'DDM' ? 'display: none;' : '' %>">
                                        <div class="input-row">
                                        <div class="input-group">
                                            <label for="capm-risk-free">Risk-Free Rate</label>
                                            <div class="input-with-currency">
                                            <input type="number" id="capm-risk-free" name="capmRiskFree" value="<%= analysis.costOfEquityInputs && analysis.costOfEquityInputs.capm ? analysis.costOfEquityInputs.capm.riskFreeRate : '' %>" placeholder="2.5" step="0.01">
                                            <span class="unit">%</span>
                                            </div>
                                        </div>
                                        <div class="input-group">
                                            <label for="beta">Beta (β)</label>
                                            <input type="number" id="beta" name="beta" value="<%= analysis.costOfEquityInputs && analysis.costOfEquityInputs.capm ? analysis.costOfEquityInputs.capm.beta : '' %>" placeholder="1.2" step="0.01">
                                        </div>
                                        </div>
                                        <div class="input-group">
                                        <label for="market-return">Market Return</label>
                                        <div class="input-with-currency">
                                            <input type="number" id="market-return" name="marketReturn" value="<%= analysis.costOfEquityInputs && analysis.costOfEquityInputs.capm ? analysis.costOfEquityInputs.capm.marketReturn : '' %>" placeholder="8.0" step="0.01">
                                            <span class="unit">%</span>
                                        </div>
                                        </div>
                                    </div>
                                    <div id="ddm-inputs" class="method-inputs" style="<%= analysis.costOfEquityInputs && analysis.costOfEquityInputs.method === 'CAPM' ? 'display: none;' : '' %>">
                                        <div class="input-row">
                                        <div class="input-group">
                                            <label for="dividend-per-share">Dividend Per Share</label>
                                            <div class="input-with-currency">
                                            <span class="currency">$</span>
                                            <input type="number" id="dividend-per-share" name="dividendPerShare" value="<%= analysis.costOfEquityInputs && analysis.costOfEquityInputs.ddm ? analysis.costOfEquityInputs.ddm.dividendPerShare : '' %>" placeholder="2.50" step="0.01">
                                            </div>
                                        </div>
                                        <div class="input-group">
                                            <label for="current-price">Current Stock Price</label>
                                            <div class="input-with-currency">
                                            <span class="currency">$</span>
                                            <input type="number" id="current-price" name="currentPrice" value="<%= analysis.costOfEquityInputs && analysis.costOfEquityInputs.ddm ? analysis.costOfEquityInputs.ddm.currentPrice : '' %>" placeholder="50.00" step="0.01">
                                            </div>
                                        </div>
                                        </div>
                                        <div class="input-group">
                                        <label for="growth-rate">Dividend Growth Rate</label>
                                        <div class="input-with-currency">
                                            <input type="number" id="growth-rate" name="growthRate" value="<%= analysis.costOfEquityInputs && analysis.costOfEquityInputs.ddm ? analysis.costOfEquityInputs.ddm.growthRate : '' %>" placeholder="3.0" step="0.01">
                                            <span class="unit">%</span>
                                        </div>
                                        </div>
                                    </div>
                                    <div class="calculation-result">
                                        <div class="result-label">Cost of Equity</div>
                                        <div class="result-value" id="cost-of-equity">
                                        <%= analysis.results && analysis.results.costOfEquity ? analysis.results.costOfEquity.toFixed(2) + '%' : '--' %>
                                        </div>
                                    </div>
                                    </div>
                                </form>
                            </div>
                            </div>

                            <!-- WACC Calculator -->
                        <div class="calculator-section full-width">
                                <div class="section-header">
                                <h2><i class="bx bx-pie-chart-alt-2"></i> WACC Analysis</h2>
                                <button class="btn-secondary" onclick="optimizeCapitalStructure()">
                                    <i class="bx bx-target-lock"></i> Optimize Structure
                                </button>
                                </div>
                                <div class="section-content">
                                <div class="wacc-visual">
                                    <div class="capital-structure">
                                    <h4>Capital Structure</h4>
                                    <div class="structure-chart">
                                        <div class="structure-bar">
                                        <div class="equity-portion" id="equity-bar" style="width: <%= analysis.results && analysis.results.debtRatio ? (100 - analysis.results.debtRatio) + '%' : '0%' %>"></div>
                                        <div class="debt-portion" id="debt-bar" style="width: <%= analysis.results && analysis.results.debtRatio ? analysis.results.debtRatio + '%' : '0%' %>"></div>
                                        </div>
                                        <div class="structure-labels">
                                        <span class="equity-label">Equity: <span id="equity-percentage">
                                            <%= analysis.results && analysis.results.debtRatio ? (100 - analysis.results.debtRatio).toFixed(1) + '%' : '--' %>
                                        </span></span>
                                        <span class="debt-label">Debt: <span id="debt-percentage">
                                            <%= analysis.results && analysis.results.debtRatio ? analysis.results.debtRatio.toFixed(1) + '%' : '--' %>
                                        </span></span>
                                        </div>
                                    </div>
                                    </div>
                                    <div class="wacc-result">
                                    <h4>WACC Calculation</h4>
                                    <div class="wacc-formula">
                                        <div class="formula-part">
                                        <span class="component">Equity Component</span>
                                        <span class="value" id="equity-component">
                                            <%= analysis.results && analysis.results.costOfEquity && analysis.results.debtRatio ? ((100 - analysis.results.debtRatio) / 100 * analysis.results.costOfEquity).toFixed(2) + '%' : '--' %>
                                        </span>
                                        </div>
                                        <div class="formula-operator">+</div>
                                        <div class="formula-part">
                                        <span class="component">Debt Component</span>
                                        <span class="value" id="debt-component">
                                            <%= analysis.results && analysis.results.costOfDebt && analysis.results.debtRatio ? (analysis.results.debtRatio / 100 * analysis.results.costOfDebt).toFixed(2) + '%' : '--' %>
                                        </span>
                                        </div>
                                        <div class="formula-operator">=</div>
                                        <div class="formula-result">
                                        <span class="component">WACC</span>
                                        <span class="value final" id="final-wacc">
                                            <%= analysis.results && analysis.results.wacc ? analysis.results.wacc.toFixed(2) + '%' : '--' %>
                                        </span>
                                        </div>
                                    </div>
                                    </div>
                                </div>
                                </div>
                            </div>

                            <!-- Scenario Analysis -->
                            <div class="calculator-section full-width">
                                <div class="section-header">
                                <h2><i class="bx bx-trending-up"></i> Scenario Analysis</h2>
                                <button class="btn-primary" form="scenario-form" type="submit">
                                    <i class="bx bx-play"></i> Run Analysis
                                </button>
                                </div>
                                <div class="section-content">
                                <form id="scenario-form" action="/Debtmanagement/scenario" method="POST">
                                    <div class="scenario-controls">
                                    <div class="scenario-input">
                                        <label for="debt-range-min">Debt Ratio Range</label>
                                        <div class="range-inputs">
                                        <input type="number" id="debt-range-min" name="debtRangeMin" value="<%= analysis.results && analysis.results.scenarioResults ? analysis.results.optimalDebtRatio - 10 : '10' %>" placeholder="10" min="0" max="90">
                                        <span>% to</span>
                                        <input type="number" id="debt-range-max" name="debtRangeMax" value="<%= analysis.results && analysis.results.scenarioResults ? analysis.results.optimalDebtRatio + 10 : '70' %>" placeholder="70" min="10" max="100">
                                        <span>%</span>
                                        </div>
                                    </div>
                                    </div>
                                </form>
                                <div class="scenario-results" id="scenario-chart">
                                    <% if (analysis.results && analysis.results.scenarioResults) { %>
                                    ```chartjs
                                    {
                                        "type": "line",
                                        "data": {
                                        "labels": <%= JSON.stringify(analysis.results.scenarioResults.map(r => r.debtRatio + '%')) %>,
                                        "datasets": [{
                                            "label": "WACC",
                                            "data": <%= JSON.stringify(analysis.results.scenarioResults.map(r => r.wacc)) %>,
                                            "borderColor": "#4caf50",
                                            "backgroundColor": "rgba(76, 175, 80, 0.2)",
                                            "fill": true
                                        }]
                                        },
                                        "options": {
                                        "responsive": true,
                                        "scales": {
                                            "x": { "title": { "display": true, "text": "Debt Ratio (%)" } },
                                            "y": { "title": { "display": true, "text": "WACC (%)" } }
                                        },
                                        "plugins": {
                                            "title": { "display": true, "text": "WACC vs Debt Ratio" }
                                        }
                                        }
                                    }
                                    ```
                                    <% } else { %>
                                    <div class="chart-placeholder">
                                        <i class="bx bx-bar-chart-alt-2"></i>
                                        <p>Run scenario analysis to see WACC optimization</p>
                                    </div>
                                    <% } %>
                                </div>
                                </div>
                            </div>

                            <!-- Analysis Summary -->
                            <div class="analysis-summary">
                                <div class="summary-section">
                                <h3><i class="bx bx-clipboard"></i> Analysis Summary</h3>
                                <div class="summary-content" id="analysis-summary">
                                    <% if (analysis.results && analysis.results.wacc) { %>
                                    <p><strong>Current Capital Structure:</strong></p>
                                    <ul>
                                        <li>WACC: <%= analysis.results.wacc.toFixed(2) %>%</li>
                                        <li>Debt Ratio: <%= analysis.results.debtRatio.toFixed(1) %>%</li>
                                        <li>Cost of Equity: <%= analysis.results.costOfEquity.toFixed(2) %>%</li>
                                        <li>Cost of Debt: <%= analysis.results.costOfDebt.toFixed(2) %>%</li>
                                    </ul>
                                    <% } else { %>
                                    <p>Configure your company information and debt parameters to generate analysis summary.</p>
                                    <% } %>
                                </div>
                                </div>
                                <div class="recommendations-section">
                                <h3><i class="bx bx-bulb"></i> Recommendations</h3>
                                <div class="recommendations-content" id="recommendations">
                                    <% if (analysis.results && analysis.results.debtRatio) { %>
                                    <p><%= analysis.results.debtRatio < 30 ? 'Consider increasing debt to leverage tax benefits and reduce WACC.' : analysis.results.debtRatio > 60 ? 'Reduce debt levels to lower financial risk and optimize WACC.' : 'Current capital structure is balanced; monitor for optimization opportunities.' %></p>
                                    <% } else { %>
                                    <p>Complete the calculations to receive recommendations.</p>
                                    <% } %>
                                </div>
                                </div>
                            </div>
                            
                        </div>
                        </div>

                </div>
                </div>


            </div>



</div>
    

   

    <script src="/js/debtmanagement.js"></script>
    <script src="/socket.io/socket.io.js"></script>

</body>
</html>