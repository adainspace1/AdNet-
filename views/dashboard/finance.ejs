<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Finance Analytics Dashboard</title>
  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Chart.js -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <!-- Lucide Icons -->
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
  <!-- html2pdf.js for PDF export -->
  <script src="https://cdn.jsdelivr.net/npm/html2pdf.js"></script>
    <link rel="stylesheet" href="/css/dashall.css">
    <link rel="stylesheet" href="/css/finance.css">
  <style>
    .sidebar-active { @apply bg-blue-50 text-blue-700 border-l-4 border-blue-600; }
    .gauge { transform: rotate(-90deg); }
    .gauge-circle { fill: none; stroke: #e5e7eb; stroke-width: 12; }
    .gauge-fill { fill: none; stroke-width: 12; stroke-linecap: round; transition: stroke-dashoffset 0.5s ease; }
    .covenant-breach { @apply bg-red-50 border-red-200 text-red-800; }
    .covenant-warning { @apply bg-yellow-50 border-yellow-200 text-yellow-800; }
    .covenant-safe { @apply bg-green-50 border-green-200 text-green-800; }
  </style>
</head>
<body class="">


<div class="all">
  <!-- Sidebar (Included via EJS) -->
  <%- include ("_sidebar1") %>

  <div class="main-content">
    <%- include ("_topnav") %>

    <!-- Mobile Sidebar (Visible on <lg) -->
    <aside class="w-full bg-white rounded-xl shadow-sm border border-gray-200 p-4 lg:hidden mb-6">
      <nav class="grid grid-cols-1 sm:grid-cols-3 gap-2">
        <button class="sidebar-btn sidebar-active w-full text-left px-3 py-2 rounded-lg flex items-center justify-center sm:justify-start space-x-2 text-sm" data-tab="valuation">
          <i data-lucide="calculator" class="w-5 h-5"></i>
          <span>Valuation</span>
        </button>
        <button class="sidebar-btn w-full text-left px-3 py-2 rounded-lg flex items-center justify-center sm:justify-start space-x-2 text-sm text-gray-600 hover:bg-gray-50" data-tab="ratios">
          <i data-lucide="trending-up" class="w-5 h-5"></i>
          <span>Ratios</span>
        </button>
        <button class="sidebar-btn w-full text-left px-3 py-2 rounded-lg flex items-center justify-center sm:justify-start space-x-2 text-sm text-gray-600 hover:bg-gray-50" data-tab="reports">
          <i data-lucide="file-text" class="w-5 h-5"></i>
          <span>Reports</span>
        </button>
      </nav>
    </aside>

    <!-- Header -->
    <header class="bg-white shadow-sm border-b border-gray-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
        <h1 class="text-xl sm:text-2xl font-bold text-gray-900">Finance Analytics</h1>
        <div class="flex flex-wrap gap-2 w-full sm:w-auto">
          <button id="exportPDF" class="flex items-center justify-center space-x-2 px-3 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition text-sm w-full sm:w-auto">
            <i data-lucide="download" class="w-4 h-4"></i>
            <span>Export PDF</span>
          </button>
          <button id="exportExcel" class="flex items-center justify-center space-x-2 px-3 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition text-sm w-full sm:w-auto">
            <i data-lucide="file-spreadsheet" class="w-4 h-4"></i>
            <span>Excel</span>
          </button>
        </div>
      </div>
    </header>

    <!-- Dashboard Summary Cards -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <!-- Total Assets -->
        <div class="bg-white p-4 sm:p-6 rounded-xl shadow-sm border border-gray-200">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-xs sm:text-sm text-gray-500">Total Assets Value</p>
              <p id="totalAssets" class="text-xl sm:text-2xl font-bold text-green-600">$0</p>
            </div>
            <i data-lucide="package" class="w-7 h-7 sm:w-8 sm:h-8 text-green-600"></i>
          </div>
        </div>

        <!-- Total Liabilities -->
        <div class="bg-white p-4 sm:p-6 rounded-xl shadow-sm border border-gray-200">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-xs sm:text-sm text-gray-500">Total Liabilities</p>
              <p id="totalLiabilities" class="text-xl sm:text-2xl font-bold text-red-600">$0</p>
            </div>
            <i data-lucide="landmark" class="w-7 h-7 sm:w-8 sm:h-8 text-red-600"></i>
          </div>
        </div>

        <!-- Health Score -->
        <div class="bg-white p-4 sm:p-6 rounded-xl shadow-sm border border-gray-200">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-xs sm:text-sm text-gray-500">Financial Health Score</p>
              <p id="financialHealth" class="text-xl sm:text-2xl font-bold text-purple-600">0 / 100</p>
            </div>
            <i data-lucide="heart" class="w-7 h-7 sm:w-8 sm:h-8 text-purple-600"></i>
          </div>
        </div>
      </div>
    </section>

    <!-- Main Layout: Sidebar + Content -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col lg:flex-row gap-6">
      
      <!-- Desktop Sidebar (Hidden on <lg) -->
      <aside class="hidden lg:block w-64 bg-white rounded-xl shadow-sm border border-gray-200 p-4 flex-shrink-0">
        <nav class="space-y-1">
          <button class="sidebar-btn sidebar-active w-full text-left px-4 py-3 rounded-lg flex items-center space-x-3" data-tab="valuation">
            <i data-lucide="calculator" class="w-5 h-5"></i>
            <span>Valuation</span>
          </button>
          <button class="sidebar-btn w-full text-left px-4 py-3 rounded-lg flex items-center space-x-3 text-gray-600 hover:bg-gray-50" data-tab="ratios">
            <i data-lucide="trending-up" class="w-5 h-5"></i>
            <span>Ratios</span>
          </button>
          <button class="sidebar-btn w-full text-left px-4 py-3 rounded-lg flex items-center space-x-3 text-gray-600 hover:bg-gray-50" data-tab="reports">
            <i data-lucide="file-text" class="w-5 h-5"></i>
            <span>Reports</span>
          </button>
        </nav>
      </aside>

      <!-- Main Content -->
      <main class="flex-1 space-y-6 w-full">

        <!-- Valuation Tab -->
        <div id="valuation" class="tab-content">
          <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 sm:p-6">
            <h2 class="text-base sm:text-lg font-semibold text-gray-800 mb-4">Inventory Valuation</h2>

            <!-- Table: Responsive Wrapper -->
            <div class="overflow-x-auto -mx-4 sm:mx-0 mb-4">
              <div class="inline-block min-w-full align-middle">
                <table class="min-w-full divide-y divide-gray-200 text-xs sm:text-sm">
                  <thead class="bg-gray-50">
                    <tr>
                      <th class="px-3 py-2 text-left font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap">Item</th>
                      <th class="px-3 py-2 text-left font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap">Qty</th>
                      <th class="px-3 py-2 text-left font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap">Unit Cost</th>
                      <th class="px-3 py-2 text-left font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap">Total Value</th>
                      <th class="px-3 py-2 text-left font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap">COGS Impact</th>
                    </tr>
                  </thead>
                  <tbody class="bg-white divide-y divide-gray-200" id="inventoryTable">
                    <tr class="hover:bg-gray-50">
                      <td class="px-3 py-3 whitespace-nowrap">Widget A</td>
                      <td class="px-3 py-3 whitespace-nowrap">1,200</td>
                      <td class="px-3 py-3 whitespace-nowrap">$42.50</td>
                      <td class="px-3 py-3 font-medium whitespace-nowrap">$51,000</td>
                      <td class="px-3 py-3 text-green-600 whitespace-nowrap">-$8,500</td>
                    </tr>
                    <tr class="hover:bg-gray-50">
                      <td class="px-3 py-3 whitespace-nowrap">Component B</td>
                      <td class="px-3 py-3 whitespace-nowrap">850</td>
                      <td class="px-3 py-3 whitespace-nowrap">$78.20</td>
                      <td class="px-3 py-3 font-medium whitespace-nowrap">$66,470</td>
                      <td class="px-3 py-3 text-red-600 whitespace-nowrap">+$3,200</td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>

            <p class="text-xs text-gray-500 text-center sm:hidden mb-3">← Scroll to see more →</p>

            <!-- Chart -->
            <div class="bg-gray-50 p-4 sm:p-6 rounded-lg">
              <h3 class="text-sm sm:text-md font-semibold mb-3">Inventory Value Over Time</h3>
              <div class="overflow-x-auto -mx-4 sm:mx-0">
                <div class="min-w-[280px] sm:min-w-0">
                  <canvas id="inventoryChart" height="180" class="w-full"></canvas>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Ratios Tab -->
        <div id="ratios" class="tab-content hidden">
          <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-6 mb-6">
            <div class="bg-white p-4 sm:p-6 rounded-xl shadow-sm border border-gray-200 text-center sm:text-left">
              <p class="text-xs sm:text-sm text-gray-500">Current Ratio</p>
              <p id="currentRatio" class="text-2xl sm:text-3xl font-bold text-blue-600">--</p>
            </div>
            <div class="bg-white p-4 sm:p-6 rounded-xl shadow-sm border border-gray-200 text-center sm:text-left">
              <p class="text-xs sm:text-sm text-gray-500">Quick Ratio</p>
              <p id="quickRatio" class="text-2xl sm:text-3xl font-bold text-blue-600">--</p>
            </div>
            <div class="bg-white p-4 sm:p-6 rounded-xl shadow-sm border border-gray-200 text-center sm:text-left">
              <p class="text-xs sm:text-sm text-gray-500">Debt-to-Equity</p>
              <p id="debtEquity" class="text-2xl sm:text-3xl font-bold text-orange-600">--</p>
            </div>
            <div class="bg-white p-4 sm:p-6 rounded-xl shadow-sm border border-gray-200 text-center sm:text-left">
              <p class="text-xs sm:text-sm text-gray-500">Net Profit Margin</p>
              <p id="profitMargin" class="text-2xl sm:text-3xl font-bold text-green-600">--%</p>
            </div>
          </div>

          <div class="bg-white p-4 sm:p-6 rounded-xl shadow-sm border border-gray-200">
            <h3 class="text-sm sm:text-lg font-semibold mb-3">Financial Trends</h3>
            <canvas id="ratioTrendChart" height="180"></canvas>
          </div>
        </div>

        <!-- Reports Tab -->
        <div id="reports" class="tab-content hidden">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 sm:gap-6">
            <div class="bg-white p-4 sm:p-6 rounded-xl shadow-sm border border-gray-200">
              <h3 class="text-sm sm:text-lg font-semibold mb-3">Receivables vs Payables</h3>
              <canvas id="arApChart" height="160"></canvas>
            </div>
            <div class="bg-white p-4 sm:p-6 rounded-xl shadow-sm border border-gray-200">
              <h3 class="text-sm sm:text-lg font-semibold mb-3">Loan Balances vs Asset Values</h3>
              <canvas id="loanAssetChart" height="160"></canvas>
            </div>
          </div>

          <div class="bg-white p-4 sm:p-6 rounded-xl shadow-sm border border-gray-200 mt-4 sm:mt-6">
            <h3 class="text-sm sm:text-lg font-semibold mb-3">Monthly Finance Summary</h3>
            <div class="prose prose-sm max-w-none text-xs sm:text-sm" id="monthlySummary">
              Loading summary...
            </div>
          </div>
        </div>

      </main>
    </div>
  </div>
</div>

  <!-- Scripts -->
  <script>
    lucide.createIcons();

    // Sidebar Navigation
    document.querySelectorAll('.sidebar-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.sidebar-btn').forEach(b => {
          b.classList.remove('sidebar-active', 'bg-blue-50', 'text-blue-700', 'border-blue-600');
          b.classList.add('text-gray-600');
        });
        btn.classList.add('sidebar-active', 'bg-blue-50', 'text-blue-700', 'border-blue-600');
        btn.classList.remove('text-gray-600');

        document.querySelectorAll('.tab-content').forEach(tab => tab.classList.add('hidden'));
        document.getElementById(btn.dataset.tab).classList.remove('hidden');
      });
    });

    // Inventory Valuation Method Change
    document.getElementById('valuationMethod').addEventListener('change', (e) => {
      const method = e.target.value;
      const impact = method === 'LIFO' ? '+12,300' : method === 'Weighted Average' ? '-4,100' : '0';
      document.querySelector('#inventoryTable tr:last-child td:last-child').textContent = impact;
    });


 

    // Gauges
    function updateGauge(elementId, value, max) {
      const circumference = 314;
      const offset = circumference - (value / max) * circumference;
      document.getElementById(elementId).style.strokeDashoffset = offset;
    }
    updateGauge('dscrGauge', 1.95, 3.0);
    updateGauge('leverageGauge', 3.2, 5.0);

    // Export Functions
    document.getElementById('exportPDF').addEventListener('click', () => {
      const element = document.querySelector('main');
      html2pdf().from(element).save('finance-report-nov2025.pdf');
    });

    document.getElementById('exportExcel').addEventListener('click', () => {
      alert('Excel export would use SheetJS (xlsx) in production');
    });
  </script>





<script>
      async function loadFinanceSummary() {
  try {
    const res = await fetch("/user/finance/summary");
    const data = await res.json();

    document.querySelector("#totalAssets").textContent = `$${data.totalAssets.toLocaleString()}`;
    document.querySelector("#totalLiabilities").textContent = `$${data.totalLiabilities.toLocaleString()}`;
    document.querySelector("#activeCovenants").textContent = data.activeCovenants;
    document.querySelector("#financialHealth").textContent = `${data.financialHealth} / 100`;
    } catch (err) {
      console.error("Error loading finance summary:", err);
    }
  }

  loadFinanceSummary();
</script>






<script>
async function loadInventoryValuation() {
  try {
    const res = await fetch("/user/finance/valuation");
    const data = await res.json();
    console.log("Valuation Data:", data);

    const tableBody = document.getElementById("inventoryTable");
    tableBody.innerHTML = "";

    data.valuation.forEach(item => {
      const tr = document.createElement("tr");
      tr.innerHTML = `
        <td class="px-6 py-4 text-sm">${item.name}</td>
        <td class="px-6 py-4 text-sm">${item.qty.toLocaleString()}</td>
        <td class="px-6 py-4 text-sm">$${item.unitCost.toLocaleString()}</td>
        <td class="px-6 py-4 text-sm font-medium">$${item.totalValue.toLocaleString()}</td>
        <td class="px-6 py-4 text-sm ${item.cogsImpact >= 0 ? 'text-green-600' : 'text-red-600'}">
          ${item.cogsImpact >= 0 ? '+' : '-'}$${Math.abs(item.cogsImpact).toLocaleString()}
        </td>
      `;
      tableBody.appendChild(tr);
    });

    // Optional chart update
    const ctx = document.getElementById("inventoryChart");
    new Chart(ctx, {
      type: "line",
      data: {
        labels: data.valuation.map(i => i.name),
        datasets: [{
          label: "Inventory Value",
          data: data.valuation.map(i => i.totalValue),
          borderWidth: 2
        }]
      },
      options: { responsive: true, maintainAspectRatio: false }
    });
  } catch (err) {
    console.error("Error loading inventory valuation:", err);
  }
}

loadInventoryValuation();
</script>






<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  async function loadRatios() {
    try {
      const res = await fetch("/user/finance/ratios");
      const data = await res.json();

      document.querySelector("#currentRatio").textContent = data.ratios.currentRatio;
      document.querySelector("#quickRatio").textContent = data.ratios.quickRatio;
      document.querySelector("#debtEquity").textContent = data.ratios.debtToEquity;
      document.querySelector("#profitMargin").textContent = `${data.ratios.netProfitMargin}%`;

      const ctx = document.getElementById("ratioTrendChart").getContext("2d");
      new Chart(ctx, {
        type: "line",
        data: {
          labels: data.trendData.labels,
          datasets: [{
            label: "Net Profit Margin (%)",
            data: data.trendData.profitMargin,
            borderWidth: 2,
            tension: 0.4
          }]
        },
        options: {
          responsive: true,
          plugins: { legend: { display: false } },
          scales: { y: { beginAtZero: true } }
        }
      });
    } catch (err) {
      console.error("Error loading ratios:", err);
    }
  }

  loadRatios();
</script>





<!-- ===== Chart.js CDN ===== -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
  document.addEventListener("DOMContentLoaded", async () => {
    try {
      const res = await fetch("/api/finance/reports");
      const data = await res.json();

      console.log("Finance Report Data:", data); // 🔍 debug check

      // ===== Chart 1: Receivables vs Payables =====
      const arApCtx = document.getElementById("arApChart");
      if (arApCtx) {
        new Chart(arApCtx, {
          type: "bar",
          data: {
            labels: ["Receivables", "Payables"],
            datasets: [{
              label: "Amount ($)",
              data: [data.receivables, data.payables],
              backgroundColor: ["#3b82f6", "#ef4444"],
              borderRadius: 6
            }]
          },
          options: {
            responsive: true,
            scales: { y: { beginAtZero: true } },
          }
        });
      }

      // ===== Chart 2: Loans vs Assets =====
      const loanAssetCtx = document.getElementById("loanAssetChart");
      if (loanAssetCtx) {
        new Chart(loanAssetCtx, {
          type: "doughnut",
          data: {
            labels: ["Loans", "Assets"],
            datasets: [{
              data: [data.loans, data.assets],
              backgroundColor: ["#f59e0b", "#10b981"],
              hoverOffset: 10,
            }]
          },
          options: {
            plugins: { legend: { position: "bottom" } }
          }
        });
      }

      // ===== Summary =====
      document.getElementById("monthlySummary").innerHTML = `
        <strong>${data.month} ${data.year}:</strong> 
        Receivables at <b>$${data.receivables.toLocaleString()}</b>, 
        Payables at <b>$${data.payables.toLocaleString()}</b>. 
        Asset valuation stands at <b>$${data.assets.toLocaleString()}</b> 
        with loans totaling <b>$${data.loans.toLocaleString()}</b>. 
        ${data.notes || ""}
      `;

    } catch (err) {
      console.error("Error fetching finance report:", err);
      document.getElementById("monthlySummary").textContent = "Failed to load summary.";
    }
  });
</script>









<script>
document.addEventListener("DOMContentLoaded", async () => {
  try {
    const res = await fetch("/api/finance-metrics");
    const data = await res.json();

    // Example metrics from backend
    const { totalAssets, totalLiabilities, netProfitMargin } = data;

    // Financial Health Score formula (you can tweak)
    const healthScore = Math.max(
      0,
      Math.min(100, 70 + (netProfitMargin * 30)) // base 70 + margin contribution
    );

    // Update DOM
    document.getElementById("totalAssets").textContent = `$${totalAssets.toLocaleString()}`;
    document.getElementById("totalLiabilities").textContent = `$${totalLiabilities.toLocaleString()}`;
    document.getElementById("financialHealth").textContent = `${Math.round(healthScore)} / 100`;

    lucide.createIcons(); // refresh icons
  } catch (err) {
    console.error("Failed to load finance metrics:", err);
  }
});
</script>





<script>
document.addEventListener("DOMContentLoaded", async () => {
  try {
    const res = await fetch("/api/finance/ratios"); // Your backend route
    const data = await res.json();

    // Gauges
    const dscr = data.dscr || 0;
    const leverage = data.leverage || 0;
    const dscrGauge = document.getElementById("dscrGauge");
    const leverageGauge = document.getElementById("leverageGauge");

    const dscrOffset = 314 - Math.min(dscr / 3 * 314, 314);
    const leverageOffset = 314 - Math.min(leverage / 5 * 314, 314);

    dscrGauge.style.strokeDashoffset = dscrOffset;
    leverageGauge.style.strokeDashoffset = leverageOffset;

    document.getElementById("dscrValue").textContent = dscr.toFixed(2);
    document.getElementById("leverageValue").textContent = leverage.toFixed(2);

    // Table
    const table = document.getElementById("covenantTableBody");
    table.innerHTML = data.covenants.map(cov => `
      <tr>
        <td class="px-6 py-4">${cov.loan}</td>
        <td class="px-6 py-4">${cov.asset}</td>
        <td class="px-6 py-4">${cov.covenant}</td>
        <td class="px-6 py-4 font-medium">${cov.current}</td>
        <td class="px-6 py-4">${cov.threshold}</td>
        <td class="px-6 py-4">
          <span class="px-2 py-1 text-xs rounded-full ${cov.status === 'Breach' ? 'bg-red-100 text-red-800' : cov.status === 'Warning' ? 'bg-yellow-100 text-yellow-800' : 'bg-green-100 text-green-800'}">${cov.status}</span>
        </td>
      </tr>
    `).join("");

    // Depreciation
    document.getElementById("depreciationValue").textContent = `$${data.depreciation.toLocaleString()}`;
    document.getElementById("bookValue").textContent = `$${data.bookValue.toLocaleString()}`;
    document.getElementById("usefulLife").textContent = `${data.usefulLife} yrs`;
  } catch (err) {
    console.error("Error loading covenants:", err);
  }
});
</script>





</body>
</html>