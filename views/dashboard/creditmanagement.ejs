<script>
  async function loadSummary() {
    try {
      const res = await fetch("/api/credit-summary");
      const data = await res.json();

      document.getElementById("totalReceivables").textContent = `$${data.totalReceivables.toLocaleString()}`;
      document.getElementById("overdueAccounts").textContent = data.overdueAccounts;
      document.getElementById("avgCollectionDays").textContent = `${data.avgCollectionDays} days`;
      document.getElementById("riskAlerts").textContent = data.riskAlerts;
    } catch (err) {
      console.error("Error loading summary:", err);
    }
  }

  loadSummary();
</script>


