<!-- Add Credit Modal -->
<div id="addCreditModal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
  <!-- Scrollable container -->
  <div class="bg-white rounded-lg shadow-lg w-full max-w-md max-h-[90vh] overflow-y-auto p-6">
    <h2 class="text-xl font-semibold mb-4 text-gray-800">Add Credit</h2>
    <form method="post" action="/user/addcredit" id="creditForm">
      <div class="space-y-4">
        <input type="hidden" name="personalId" value="<%= user._id %>">

        <!-- Customer -->
        <div>
          <label class="block text-sm font-medium text-gray-700">Customer Name</label>
          <input type="text" name="customerName" class="w-full p-2 border rounded-md" required />
        </div>

        <!-- Amount -->
        <div>
          <label class="block text-sm font-medium text-gray-700">Amount</label>
          <input type="number" name="amount" id="creditAmount" step="0.01" class="w-full p-2 border rounded-md" required />
        </div>

        <!-- Payment Type -->
        <div>
          <label class="block text-sm font-medium text-gray-700">Payment Type</label>
          <select name="paymentType" class="w-full p-2 border rounded-md" required>
            <option value="">Select...</option>
            <option value="full">Full Payment</option>
            <option value="installment">Installment</option>
          </select>
        </div>

        <!-- Due Date -->
        <div>
          <label class="block text-sm font-medium text-gray-700">Due Date</label>
          <input type="date" name="dueDate" class="w-full p-2 border rounded-md" required />
        </div>

        <!-- Notes -->
        <div>
          <label class="block text-sm font-medium text-gray-700">Notes</label>
          <textarea name="notes" rows="2" class="w-full p-2 border rounded-md" placeholder="Optional notes..."></textarea>
        </div>

        <!-- Interest Checkbox -->
        <div class="flex items-center space-x-2">
          <input type="checkbox" id="interestCheck" name="hasInterest" />
          <label for="interestCheck" class="text-sm text-gray-700">Add Interest?</label>
        </div>

        <!-- Interest Fields -->
        <div id="interestFields" class="hidden space-y-3">
          <div>
            <label class="block text-sm font-medium text-gray-700">Interest Rate</label>
            <input type="number" name="interestRate" placeholder="e.g. 10" step="0.01" class="w-full p-2 border rounded-md" />
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700">Rate Type</label>
            <select name="interestType" class="w-full p-2 border rounded-md">
              <option value="daily">Daily</option>
              <option value="monthly">Monthly</option>
              <option value="yearly">Yearly</option>
            </select>
          </div>
        </div>

        <!-- Threshold Alert (auto-filled) -->
        <div id="thresholdWarning" class="hidden text-sm text-red-600 font-semibold">
          ⚠️ Warning: Customer has reached or exceeded their credit threshold.
        </div>

        <!-- Actions -->
        <div class="flex justify-end space-x-3 mt-4 sticky bottom-0 bg-white py-2">
          <button type="button" id="closeAddCreditModal" class="px-4 py-2 bg-gray-300 rounded-md">Cancel</button>
          <button type="submit" id="submitCredit" class="px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700">
            Save
          </button>
        </div>
      </div>
    </form>
  </div>
</div>








