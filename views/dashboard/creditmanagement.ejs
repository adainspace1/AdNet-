<script>
  const interestCheck = document.getElementById("interestCheck");
  const interestFields = document.getElementById("interestFields");

  interestCheck.addEventListener("change", () => {
    interestFields.classList.toggle("hidden", !interestCheck.checked);
  });
</script>




<script>
  const creditAmount = document.getElementById("creditAmount");
  const thresholdWarning = document.getElementById("thresholdWarning");
  const submitBtn = document.getElementById("submitCredit");

  // toggle interest fields
  interestCheck.addEventListener("change", () => {
    interestFields.classList.toggle("hidden", !interestCheck.checked);
  });

  // 📊 Real-time credit data from session user
  const availableCredit = <%= user.availableCredit %>; 
  const creditLimit = <%= user.creditLimit %>; 
  const warningLimit = availableCredit * 0.2; // 20% of remaining credit
  const debtModeLimit = 20000; // threshold to show "debt mode"

  console.log("🧾 Available Credit:", availableCredit);
  console.log("⚠️ Warning Limit (20%):", warningLimit);

  creditAmount.addEventListener("input", () => {
    const amount = parseFloat(creditAmount.value || 0);

    // reset default state
    thresholdWarning.classList.add("hidden");
    submitBtn.disabled = false;

    if (availableCredit <= debtModeLimit) {
      thresholdWarning.textContent = "🚨 Your available credit is below ₦20,000 — you're in debt mode!";
      thresholdWarning.classList.remove("hidden");
      submitBtn.disabled = true;
    }
    else if (amount > availableCredit) {
      thresholdWarning.textContent = `❌ Credit amount exceeds available credit (₦${availableCredit.toLocaleString()})`;
      thresholdWarning.classList.remove("hidden");
      submitBtn.disabled = true;
    } 
    else if (amount >= warningLimit && amount < availableCredit) {
      thresholdWarning.textContent = `⚠️ Warning: Amount is within 20% of your available credit (₦${warningLimit.toLocaleString()} - ₦${availableCredit.toLocaleString()})`;
      thresholdWarning.classList.remove("hidden");
    }
  });
</script>






<!-- View Credit model -->
<script>
  async function openViewCreditorModal(customerName) {
  const modal = document.getElementById("viewCreditorModal");
  const nameElem = document.getElementById("creditorName");
  const tbody = document.getElementById("creditorRecordsBody");

  modal.classList.remove("hidden");
  nameElem.textContent = `Credits for ${customerName}`;
  tbody.innerHTML = `<tr><td colspan="6" class="text-center py-4 text-gray-500">Loading...</td></tr>`;

  try {
    const res = await fetch(`/api/credits/${encodeURIComponent(customerName)}`);
    const data = await res.json();

    if (!data.credits || data.credits.length === 0) {
      tbody.innerHTML = `<tr><td colspan="6" class="text-center py-4 text-gray-400">No credit records found.</td></tr>`;
      return;
    }

    tbody.innerHTML = data.credits.map(c => `
      <tr class="hover:bg-gray-50">
        <td class="px-4 py-2 text-sm text-gray-700">${new Date(c.createdAt).toLocaleDateString()}</td>
        <td class="px-4 py-2 text-sm text-gray-700">₦${c.amount.toLocaleString()}</td>
        <td class="px-4 py-2 text-sm text-gray-700">₦${c.currentBalance.toLocaleString()}</td>
        <td class="px-4 py-2 text-sm text-gray-700">${c.paymentType}</td>
        <td class="px-4 py-2 text-sm text-gray-700">${new Date(c.dueDate).toLocaleDateString()}</td>
        <td class="px-4 py-2 text-sm text-gray-700">${c.isRepaid ? "Repaid" : (c.daysOverdue > 0 ? "Overdue" : "Active")}</td>
      </tr>
    `).join("");
  } catch (err) {
    console.error("❌ Error loading creditor records:", err);
    tbody.innerHTML = `<tr><td colspan="6" class="text-center py-4 text-red-500">Error loading data</td></tr>`;
  }
}

function closeViewCreditorModal() {
  document.getElementById("viewCreditorModal").classList.add("hidden");
}

function printCreditorRecords() {
  const printContent = document.getElementById("viewCreditorModal").innerHTML;
  const printWindow = window.open("", "", "width=900,height=600");
  printWindow.document.write(`
    <html>
      <head>
        <title>Creditor Records</title>
        <style>
          body { font-family: Poppins, sans-serif; padding: 20px; }
          table { width: 100%; border-collapse: collapse; margin-top: 20px; }
