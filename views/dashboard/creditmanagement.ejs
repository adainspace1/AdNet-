});

async function fetchAndRenderCredits() {
  try {
    const res = await fetch("/api/credits");
    const data = await res.json();
    renderCreditTable(data.credits || []);
    renderBuckets(data.buckets || {});
  } catch (err) {
    console.error("❌ Error fetching credits:", err);
  }
}

function renderCreditTable(credits) {
  const tbody = document.getElementById("creditTableBody");
  if (!tbody) return;

  tbody.innerHTML = credits.map(c => {
    // 🟢 status
    let statusText, statusColor;
    if (c.isRepaid) {
      statusText = "Repaid";
      statusColor = "bg-green-100 text-green-700";
    } else if (c.daysOverdue > 60) {
      statusText = "High Risk";
      statusColor = "bg-red-100 text-red-700";
    } else if (c.daysOverdue > 30) {
      statusText = "Late";
      statusColor = "bg-yellow-100 text-yellow-700";
    } else {
      statusText = "On Track";
      statusColor = "bg-blue-100 text-blue-700";
    }

    return `
      <tr class="hover:bg-gray-50 transition">
        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
          ${c.customerName}
        </td>
        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">
          ₦${c.currentBalance.toLocaleString()}
        </td>
        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
          ${c.paymentType === "installment" ? "Installment" : "Full"}
        </td>
        <td class="px-6 py-4 whitespace-nowrap text-sm ${c.availableCredit < 0 ? 'text-red-600' : 'text-green-600'}">
          $${Math.abs(c.availableCredit).toLocaleString()} ${c.availableCredit < 0 ? '(Over)' : ''}
        </td>
        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">
          ${new Date(c.dueDate).toLocaleDateString()}
        </td>
        <td class="px-6 py-4 whitespace-nowrap">
          <span class="px-2 py-1 text-xs font-semibold rounded-full ${statusColor}">
            ${statusText}
          </span>
        </td>



        <td class="px-6 py-4 whitespace-nowrap">
                   <button
    onclick="openViewCreditorModal('${c.customerName}')"
    class="px-3 py-1.5 bg-gray-100 hover:bg-gray-200 text-gray-800 text-xs font-semibold rounded-lg border border-gray-300 transition-all">
     View
  </button>

          <button
            onclick="openRepayModal('${c.id}', '${c.customerName}', ${c.currentBalance})"
            class="px-3 py-1 bg-blue-600 hover:bg-blue-700 text-white text-xs font-semibold rounded-lg">
            Repay
          </button>
        </td>

      
      </tr>
    `;
  }).join("");
}

function renderBuckets(buckets) {
  document.querySelector('[data-bucket="0_30"]').textContent = `$${buckets["0_30"].toLocaleString()}`;
  document.querySelector('[data-bucket="31_60"]').textContent = `$${buckets["31_60"].toLocaleString()}`;
  document.querySelector('[data-bucket="61_90"]').textContent = `$${buckets["61_90"].toLocaleString()}`;
  document.querySelector('[data-bucket="90_plus"]').textContent = `$${buckets["90_plus"].toLocaleString()}`;
}



function openRepayModal(id, customerName, balance) {
  const modal = document.getElementById("repayModal");
  modal.classList.remove("hidden");

  document.getElementById("repayCreditId").value = id;
  document.getElementById("repayCustomerName").textContent = customerName;
  document.getElementById("repayCurrentBalance").textContent = `$${balance.toLocaleString()}`;
  document.getElementById("amountPaidInput").max = balance;
}







document.addEventListener("DOMContentLoaded", async () => {
  let allCredits = [];
  const creditSearch = document.getElementById("creditSearch");
  const paymentTypeFilter = document.getElementById("paymentTypeFilter");
  const statusFilter = document.getElementById("statusFilter");

  // Fetch all credits once
  const res = await fetch("/api/credits");
  const data = await res.json();
  allCredits = data.credits || [];
  renderCreditTable(allCredits);
  renderBuckets(data.buckets || {});

  // Filter on input / select changes
  creditSearch.addEventListener("input", applyFilters);
  paymentTypeFilter.addEventListener("change", applyFilters);
  statusFilter.addEventListener("change", applyFilters);

  function applyFilters() {
    let filtered = [...allCredits];

    // Search by customer name
    const searchTerm = creditSearch.value.toLowerCase();
    if (searchTerm) {
      filtered = filtered.filter(c => c.customerName.toLowerCase().includes(searchTerm));
    }

    // Filter by payment type
    const paymentType = paymentTypeFilter.value;
    if (paymentType !== "All") {
      filtered = filtered.filter(c => (c.paymentType || "Full").toLowerCase() === paymentType.toLowerCase());
    }

    // Filter by status
    const status = statusFilter.value;
    if (status === "Overdue") {
      filtered = filtered.filter(c => c.daysOverdue > 0);
    } else if (status === "Current") {
      filtered = filtered.filter(c => c.daysOverdue === 0);
    }

    renderCreditTable(filtered);
  }
});















    
