<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css"
      rel="stylesheet"
    />
      <script src="https://cdn.tailwindcss.com"></script>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/boxicons@2.1.4/css/boxicons.min.css"
    />
    <link rel="stylesheet" href="/css/production.css" />
    <title>Production Management System</title>
  </head>
  <body>
    <div class="app-container">
      <!-- Sidebar -->
      <%- include ("_sidebar1") %>

      <!-- Main Content -->
      <div class="main-content">

        <%- include ("_topnav") %>
        <div class="content-header">
          <h1>Production Management</h1>
          <p>
            Monitor and manage your production processes, materials, and costs
          </p>
        </div>

        <div class="content-body">
          <div id="alertContainer"></div>

          <!-- Production Controls -->
          <div class="card">
            <div class="card-header">
              <h2 class="card-title">Production Configuration</h2>
              <p class="card-subtitle">
                Select or create a production type to manage materials and costs
              </p>
            </div>
            <div class="card-body">
              <div class="controls-section">
               

                <div class="control-group">
                  <label class="control-label">New Production Type</label>
                  <input
                    type="text"
                    id="newProductionType"
                    class="form-input"
                    placeholder="Enter it here, if your category don't appear"
                  />
                </div>

                <div
                  class="control-group d-flex align-items-end"
                  style="gap: 12px"
                >
                <button type="button" class="btn btn-outline" onclick="addNewProductionType()">
  <span class="btn-icon">➕</span>
  Add Type
</button>

                  <button
                    class="btn btn-primary"
                    onclick="openAddItemModal()"
                    id="addItemBtn"
                    disabled
                  >
                    <span class="btn-icon">📝</span>
                    Add Item
                  </button>
                </div>
              </div>
            </div>
          </div>

          <!-- Production Table -->
          <div id="productionTableCard" class="card" style="display: none">
            <div class="table-header">
              <h2 class="table-title" id="productionTableTitle">
                Production Items
              </h2>
              <div class="search-box">
                <span class="search-icon">🔍</span>
                <input
                  type="text"
                  id="searchInput"
                  class="search-input"
                  placeholder="Search items..."
                />
              </div>
            </div>

            <div style="overflow-x: auto">
              <table id="productionTable">
                <thead>
                  <tr>
                    <th>Item Name</th>
                    <th>Quantity</th>
                    <th>Unit Price</th>
                    <th>Total Cost</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody id="tableBody"></tbody>
              </table>
            </div>

            <div class="table-footer">
              <div class="total-cost">
                <span class="total-label">Total Production Cost</span>
                <span class="total-amount" id="totalCost">$0.00</span>
              </div>
            </div>
          </div>


               <div class="table-container">
        <div class="table-header">
            <h2>bread - Materials & Components</h2>
            <input type="text" class="search-bar" placeholder="Search items...">
        </div>
        <table class="table">
            <thead>
                <tr>
                    <th>Item Category</th>
                    <th>Item Name</th>
                    <th>Quantity</th>
                    <th>Unit Price</th>
                    <th>Total Cost</th>
                    <th>Note</th>
                    <th>Time</th>
                </tr>
            </thead>
            <tbody>
             <% summary.all.forEach(item => { %>
            <tr>
              <td><%= item.category %></td>
              <td><%= item.itemName %></td>
              <td><%= item.quantity %></td>
              <td>₦<%= item.unitPrice.toLocaleString() %></td>
              <td>₦<%= item.amount.toLocaleString() %></td>
              <td><%= item.notes %></td>
              <td><%= item.createdAt.toLocaleString() %></td>
            </tr>
            <% }) %>
            </tbody>
            <tfoot>
                <tr class="total-row">
                    <td colspan="3">Total Production Cost</td>
                    <td colspan="2" class="total-cost">₦<%= totalProductionAmount.toLocaleString() %></td>
                </tr>
            </tfoot>
        </table>
    </div>
        </div>


    
      </div>
    </div>

     <!-- Modal -->
    <div  id="popupForm" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center hidden z-50">
      <div class="bg-white p-6 rounded-lg w-full max-w-md shadow-lg relative">
        <button onclick="closeModal()" class="absolute top-2 right-2 text-gray-500 hover:text-red-600 text-xl">&times;</button>
        <form action="/user/createproduction" method="post" class="space-y-4">
          <input type="hidden" name="recipientId" value="<%= user.id %>">
          <input type="hidden" name="username" value="<%= user.firstName %> <%= user.lastName %>">
          <div>
<label class="block">Category</label>
<select id="categorySelect" name="category" required class="w-full border rounded px-2 py-1">
  <option value="">Select a category</option>
  <% uniqueCategories.forEach(category => { %>
    <option value="<%= category %>"><%= category.charAt(0).toUpperCase() + category.slice(1) %></option>
  <% }) %>
</select>


          </div>
            <div class="form-group">
                <label class="control-label" for="itemName">Item Name</label>
                <input
                  type="text"
                  id="itemName"
                  name="itemName"
                  class="form-input"
                  placeholder="Enter item name"
                  required
                />
              </div>
<div>
  <label class="block">Unit Price</label>
  <input type="number" id="unitPrice" name="unitPrice" min="0" step="0.01" required class="w-full border rounded px-2 py-1">
</div>
       <div>
  <label class="block">Quantity</label>
  <input type="number" id="quantity" name="quantity" min="0" step="0.01" required class="w-full border rounded px-2 py-1">
</div>
<div>
  <label class="block">Amount (₦)</label>
  <input type="number" id="amount" name="amount" min="0" step="0.01" required class="w-full border rounded px-2 py-1" readonly>
</div>

          <div>
            <label class="block">Notes</label>
            <textarea name="notes" rows="3" class="w-full border rounded px-2 py-1"></textarea>
          </div>
          <button type="submit" class="w-full bg-blue-600 text-white py-2 rounded hover:bg-blue-700">Save</button>
        </form>
      </div>
    </div>

    


    <script>
  const quantityInput = document.getElementById("quantity");
  const unitPriceInput = document.getElementById("unitPrice");
  const amountInput = document.getElementById("amount");

  function updateAmount() {
    const quantity = parseFloat(quantityInput.value) || 0;
    const unitPrice = parseFloat(unitPriceInput.value) || 0;
    const amount = quantity * unitPrice;
    amountInput.value = amount.toFixed(2); // 2 decimal places
  }

  quantityInput.addEventListener("input", updateAmount);
  unitPriceInput.addEventListener("input", updateAmount);
</script>

  

<script>
  function capitalizeFirstLetter(str) {
    return str.charAt(0).toUpperCase() + str.slice(1).toLowerCase();
  }

  function addNewProductionType() {
    const input = document.getElementById("newProductionType");
    const select = document.getElementById("categorySelect");
    const rawValue = input.value.trim();

    if (rawValue === "") {
      document.getElementById("popupForm").style.display = "flex";
      return;
    }

    const value = capitalizeFirstLetter(rawValue);

    // Check if option already exists
    const exists = [...select.options].some(option => option.value.toLowerCase() === value.toLowerCase());

    if (!exists) {
      const newOption = document.createElement("option");
      newOption.value = value;
      newOption.textContent = value;
      newOption.selected = true;
      select.appendChild(newOption);
    } else {
      // If it exists, select the correct one
      select.value = [...select.options].find(option => option.value.toLowerCase() === value.toLowerCase()).value;
    }

    // Show the popup
    document.getElementById("popupForm").style.display = "flex";

    // Clear the input
    input.value = "";
  }

  function closeModal() {
    document.getElementById("popupForm").style.display = "none";
  }
</script>






</body>
</html>
