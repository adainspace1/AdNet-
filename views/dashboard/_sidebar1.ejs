<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/css/sidebar1.css">

  <link
  rel="stylesheet"
  href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css"
/>

</head>
<body>



  <% /* EJS Partial: Reusable Sidebar Navigation for AdNet ERP Dashboard */ %>
<div class="adnet-sidebar-wrapper">
  <!-- Fixed Hamburger Button -->
  <button class="hamburger"><i data-lucide="menu"></i></button>

  <!-- Collapsed Sidebar -->
<nav class="sidebar">
  <ul class="sidebar-nav">
    <li>
      <a href="#" data-module="dashboard" data-tooltip="Dashboard">
        <i class="fa-solid fa-gauge"></i>
        <span>Dashboard</span>
      </a>
    </li>
    <li>
      <a href="#" data-module="finance" data-tooltip="Finance & Accounting">
        <i class="fa-solid fa-dollar-sign"></i>
        <span>Finance & Accounting</span>
      </a>
    </li>
    <li>
      <a href="#" data-module="reconciliation" data-tooltip="Reconciliation">
        <i class="fa-solid fa-rotate"></i>
        <span>Reconciliation</span>
      </a>
    </li>
    <li>
      <a href="#" data-module="sales" data-tooltip="Sales Management">
        <i class="fa-solid fa-cart-shopping"></i>
        <span>Sales Management</span>
      </a>
    </li>
    <li>
      <a href="#" data-module="procurement" data-tooltip="Procurement & Payables">
        <i class="fa-solid fa-box-open"></i>
        <span>Procurement & Payables</span>
      </a>
    </li>
    <li>
      <a href="#" data-module="inventory" data-tooltip="Inventory">
        <i class="fa-solid fa-boxes-stacked"></i>
        <span>Inventory</span>
      </a>
    </li>
    <li>
      <a href="#" data-module="assets" data-tooltip="Assets">
        <i class="fa-solid fa-briefcase"></i>
        <span>Assets</span>
      </a>
    </li>
    <li>
      <a href="#" data-module="debt" data-tooltip="Debt & Credit">
        <i class="fa-solid fa-credit-card"></i>
        <span>Debt & Credit</span>
      </a>
    </li>
    <li>
      <a href="#" data-module="reports" data-tooltip="Reports">
        <i class="fa-solid fa-chart-column"></i>
        <span>Reports</span>
      </a>
    </li>
    <li>
      <a href="#" data-module="settings" data-tooltip="Settings">
        <i class="fa-solid fa-gear"></i>
        <span>Settings</span>
      </a>
    </li>
    <li>
      <a href="#" data-module="support" data-tooltip="Support">
        <i class="fa-solid fa-circle-question"></i>
        <span>Support</span>
      </a>
    </li>
  </ul>
</nav>


  <!-- Fullscreen Overlay (Desktop Only) -->
  <div class="overlay">
    <div class="overlay-content">
      <button class="closefull" aria-label="Close Overlay"><i data-lucide="x"></i></button>
      <!-- Dynamic subtopic content injected here -->
    </div>
  </div>
</div>






<script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>

<script>
  // Ensure DOM is loaded before initializing icons
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof lucide !== 'undefined') {
      lucide.createIcons(); // Initialize Lucide icons
    }
  });

  // Module subtopics
  const modules = {
    dashboard: [
      { name: 'Overview', href: '#' },
      { name: 'Analytics', href: '#' },
      { name: 'Summary', href: '#' }
    ],
    finance: [
      { name: 'Accounts', href: '#' },
      { name: 'Budgets', href: '#' },
      { name: 'Transactions', href: '#' }
    ],
    reconciliation: [
      { name: 'Bank Reconciliation', href: '#' },
      { name: 'Ledger Matching', href: '#' }
    ],
    sales: [
      { name: 'Orders', href: '#' },
      { name: 'Customers', href: '#' },
      { name: 'Invoices', href: '#' }
    ],
    procurement: [
      { name: 'Purchase Orders', href: '#' },
      { name: 'Vendors', href: '#' },
      { name: 'Payments', href: '#' }
    ],
    inventory: [
      { name: 'Stock Levels', href: '#' },
      { name: 'Warehouses', href: '#' },
      { name: 'Transfers', href: '#' }
    ],
    assets: [
      { name: 'Fixed Assets', href: '#' },
      { name: 'Depreciation', href: '#' }
    ],
    debt: [
      { name: 'Loans', href: '#' },
      { name: 'Credit Lines', href: '#' }
    ],
    reports: [
      { name: 'Financial Reports', href: '#' },
      { name: 'Sales Reports', href: '#' },
      { name: 'Inventory Reports', href: '#' }
    ],
    settings: [
      { name: 'User Settings', href: '#' },
      { name: 'System Config', href: '#' }
    ],
    support: [
      { name: 'Help Center', href: '#' },
      { name: 'Contact Support', href: '#' }
    ]
  };

  // Handle sidebar hover (desktop only)
  const sidebar = document.querySelector('.adnet-sidebar-wrapper .sidebar');
  const overlay = document.querySelector('.adnet-sidebar-wrapper .overlay');
  const overlayContent = document.querySelector('.adnet-sidebar-wrapper .overlay-content');

  if (sidebar && overlay && overlayContent) {
    // Collapsed/Expanded State: Hover behavior
    sidebar.addEventListener('mouseenter', () => {
      if (window.innerWidth > 768 && !sidebar.classList.contains('active')) {
        sidebar.classList.add('expanded');
      }
    });

    sidebar.addEventListener('mouseleave', () => {
      if (window.innerWidth > 768 && !sidebar.classList.contains('active')) {
        sidebar.classList.remove('expanded');
      }
    });

    // Overlay Behavior: Show fullscreen overlay on module hover
    document.querySelectorAll('.adnet-sidebar-wrapper .sidebar-nav a').forEach(link => {
      link.addEventListener('mouseenter', () => {
        if (window.innerWidth > 768) {
          const module = link.dataset.module;
          if (modules[module]) {
            overlayContent.innerHTML = `
              <button onclick="closeOverlay()"  class="closefull" aria-label="Close Overlay"><i data-lucide="x"></i></button>
              <h3>${link.querySelector('span').textContent}</h3>
              <ul>
                ${modules[module].map(item => `<li><a href="${item.href}">${item.name}</a></li>`).join('')}
              </ul>
            `;
            overlay.classList.add('active');
            if (typeof lucide !== 'undefined') {
              lucide.createIcons();
            }
          }
        }
      });
    });

    // Overlay Behavior: Close on mouse leave or closefull click
    overlay.addEventListener('mouseleave', () => {
      overlay.classList.remove('active');
    });

    // Define the closeOverlay() function globally
function closeOverlay() {
  const overlay = document.querySelector('.overlay');
  console.log("jjjjjjjjjj"); // For testing
  overlay.classList.remove('active');
}


    // Mobile Behavior: Sidebar toggle
    const hamburger = document.querySelector('.adnet-sidebar-wrapper .hamburger');
    if (hamburger) {
      hamburger.addEventListener('click', () => {
        sidebar.classList.toggle('active');
        sidebar.classList.toggle('expanded');
        overlay.classList.remove('active');
      });
    }

    // Mobile Behavior: Inline sub-menu toggle
    document.querySelectorAll('.adnet-sidebar-wrapper .sidebar-nav a').forEach(link => {
      link.addEventListener('click', (e) => {
        if (window.innerWidth <= 768) {
          e.preventDefault();
          const module = link.dataset.module;
          const parentLi = link.parentElement;
          const existingSubMenu = parentLi.querySelector('.sub-menu');
          
          if (existingSubMenu) {
            existingSubMenu.classList.toggle('active');
          } else if (modules[module]) {
            const subMenuUl = document.createElement('ul');
            subMenuUl.classList.add('sub-menu');
            subMenuUl.innerHTML = modules[module].map(item => `<li><a href="${item.href}">${item.name}</a></li>`).join('');
            parentLi.appendChild(subMenuUl);
            subMenuUl.classList.add('active');
          }
        }
      });
    });
  }
</script>

  <!-- Main Content Area -->
  <script src="/js/sidebar1.js"></script>
  
</body>
</html>