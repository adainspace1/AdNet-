    { name: 'Price Call', href: '/pricecall' }
  ]
};

  // Handle sidebar hover (desktop only)
  const sidebar = document.querySelector('.adnet-sidebar-wrapper .sidebar');
  const overlay = document.querySelector('.adnet-sidebar-wrapper .overlay');
  const overlayContent = document.querySelector('.adnet-sidebar-wrapper .overlay-content');

  if (sidebar && overlay && overlayContent) {
    // Collapsed/Expanded State: Hover behavior
    sidebar.addEventListener('mouseenter', () => {
      if (window.innerWidth > 768 && !sidebar.classList.contains('active')) {
        sidebar.classList.add('expanded');
      }
    });

    sidebar.addEventListener('mouseleave', () => {
      if (window.innerWidth > 768 && !sidebar.classList.contains('active')) {
        sidebar.classList.remove('expanded');
      }
    });

    // Overlay Behavior: Show fullscreen overlay on module hover
    document.querySelectorAll('.adnet-sidebar-wrapper .sidebar-nav a').forEach(link => {
      link.addEventListener('mouseenter', () => {
        if (window.innerWidth > 768) {
          const module = link.dataset.module;
          if (modules[module]) {
            overlayContent.innerHTML = `
              <button onclick="closeOverlay()"  class="closefull" aria-label="Close Overlay"><i class="fa fa-close"></i></button>
              <h3>${link.querySelector('span').textContent}</h3>
              <ul>
                ${modules[module].map(item => `<li><a href="${item.href}">${item.name}</a></li>`).join('')}
              </ul>
            `;
            overlay.classList.add('active');
            if (typeof lucide !== 'undefined') {
              lucide.createIcons();
            }
          }
        }
      });
    });

    // Overlay Behavior: Close on mouse leave or closefull click
    overlay.addEventListener('mouseleave', () => {
      overlay.classList.remove('active');
    });

    // Define the closeOverlay() function globally
function closeOverlay() {
  const overlay = document.querySelector('.overlay');
  console.log("jjjjjjjjjj"); // For testing
  overlay.classList.remove('active');
}


    // Mobile Behavior: Sidebar toggle
    const hamburger = document.querySelector('.adnet-sidebar-wrapper .hamburger');
    if (hamburger) {
      hamburger.addEventListener('click', () => {
        sidebar.classList.toggle('active');
        sidebar.classList.toggle('expanded');
        overlay.classList.remove('active');
      });
    }

    // Mobile Behavior: Inline sub-menu toggle
    document.querySelectorAll('.adnet-sidebar-wrapper .sidebar-nav a').forEach(link => {
      link.addEventListener('click', (e) => {
        if (window.innerWidth <= 768) {
          e.preventDefault();
          const module = link.dataset.module;
          const parentLi = link.parentElement;
          const existingSubMenu = parentLi.querySelector('.sub-menu');
          
          if (existingSubMenu) {
            existingSubMenu.classList.toggle('active');
          } else if (modules[module]) {
            const subMenuUl = document.createElement('ul');
            subMenuUl.classList.add('sub-menu');
            subMenuUl.innerHTML = modules[module].map(item => `<li><a href="${item.href}">${item.name}</a></li>`).join('');
            parentLi.appendChild(subMenuUl);
            subMenuUl.classList.add('active');
          }
        }
      });
    });
  }
</script>

