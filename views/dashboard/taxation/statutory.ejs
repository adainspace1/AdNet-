<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Statutory Compliance Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/jspdf@2.5.1/dist/jspdf.umd.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
</head>
<body>

<div class="all">
  <%- include ("../_sidebar1") %>

  <div class="main-content">
    <%- include ("../_topnav") %>


<div class="container">

  

</div>
    <!-- Header -->
    <header class="bg-white shadow-sm border-b border-gray-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3">
          <div>
            <h1 class="text-xl sm:text-2xl font-bold text-gray-900">Statutory Compliance Dashboard</h1>
            <p class="text-sm text-gray-600 mt-1">Track tax compliance, deadlines, and overall regulatory health.</p>
          </div>
          <button id="generateReport" class="flex items-center gap-2 px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 text-sm font-medium transition">
  <i data-lucide="download" class="w-4 h-4"></i>
  <span>Generate Report</span>
</button>
        </div>
      </div>
    </header>
    

    <!-- Top Stats Cards -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <!-- Compliance Health -->
        <div class="bg-white p-4 sm:p-5 rounded-xl shadow-sm border border-gray-200">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-xs text-gray-500">Compliance Health</p>
              <p id="complianceRate" class="text-lg sm:text-xl font-bold text-green-600">0%</p>
              <p class="text-xs text-green-600">Good Standing</p>
            </div>
            <i data-lucide="activity" class="w-8 h-8 text-green-600 opacity-20"></i>
          </div>
        </div>

        <!-- On-Time Filings -->
        <div class="bg-white p-4 sm:p-5 rounded-xl shadow-sm border border-gray-200">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-xs text-gray-500">On-Time Filings</p>
              <p id="onTimeCount" class="text-lg sm:text-xl font-bold text-blue-600">0</p>
            </div>
            <i data-lucide="check-circle" class="w-8 h-8 text-blue-600 opacity-20"></i>
          </div>
        </div>

        <!-- Overdue Filings -->
        <div class="bg-white p-4 sm:p-5 rounded-xl shadow-sm border border-gray-200">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-xs text-gray-500">Overdue Filings</p>
              <p id="overdueCount" class="text-lg sm:text-xl font-bold text-red-600">0</p>
            </div>
            <i data-lucide="alert-triangle" class="w-8 h-8 text-red-600 opacity-20"></i>
          </div>
        </div>

        <!-- Upcoming Deadlines -->
        <div class="bg-white p-4 sm:p-5 rounded-xl shadow-sm border border-gray-200">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-xs text-gray-500">Upcoming (14d)</p>
              <p id="upcomingCount" class="text-lg sm:text-xl font-bold text-amber-600">0</p>
            </div>
            <i data-lucide="calendar-clock" class="w-8 h-8 text-amber-600 opacity-20"></i>
          </div>
        </div>
      </div>
    </section>

<!-- Charts & Alerts Row -->
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 lg:grid-cols-3 gap-6 pb-6">

  <!-- Compliance Trends Chart -->
  <div class="lg:col-span-2 bg-white p-5 rounded-xl shadow-sm border border-gray-200">
    <div class="flex justify-between items-center mb-4">
      <h3 class="text-sm sm:text-base font-semibold text-gray-800">Compliance Trend</h3>
      <div class="flex gap-2">
        <button id="viewMonthly" class="text-xs px-3 py-1 rounded bg-blue-50 text-blue-700">Monthly</button>
        <button id="viewQuarterly" class="text-xs px-3 py-1 rounded text-gray-600 hover:bg-gray-50">Quarterly</button>
      </div>
    </div>
    <canvas id="complianceChart" height="220"></canvas>
  </div>

  <!-- Health Overview Panel -->
  <div class="bg-white p-5 rounded-xl shadow-sm border border-gray-200 flex flex-col items-center justify-center text-center">
    <h3 class="text-sm font-semibold text-gray-800 mb-3">Compliance Score</h3>
    <div class="relative w-32 h-32">
      <canvas id="healthCircle"></canvas>
      <div class="absolute inset-0 flex items-center justify-center">
        <span id="healthScore" class="text-2xl font-bold text-gray-800">0</span>
      </div>
    </div>
    <p id="lastAudit" class="mt-3 text-xs text-gray-500">Last Audit: </p>
    <p id="standingStatus" class="mt-1 text-sm font-medium text-green-600">Compliant</p>
    <p class="mt-2 text-xs text-gray-600">All filings up-to-date</p>
  </div>
</section>

<!-- Alerts & Recommendations -->
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 lg:grid-cols-2 gap-6 pb-10">

  <!-- Alerts Feed -->
  <div class="bg-white p-5 rounded-xl shadow-sm border border-gray-200">
    <h3 class="text-sm font-semibold text-gray-800 mb-4">Compliance Alerts</h3>
    <div id="alertsFeed" class="space-y-3 max-h-64 overflow-y-auto">
      <!-- Dynamic -->
    </div>
  </div>

  <!-- Recommendations -->
  <div class="bg-white p-5 rounded-xl shadow-sm border border-gray-200">
    <h3 class="text-sm font-semibold text-gray-800 mb-4">Insights & Recommendations</h3>
    <div id="insightsList" class="space-y-3 text-xs sm:text-sm">
      <!-- Dynamic -->
    </div>
  </div>
</section>

</div>
 </div>
</div>











<script>
  document.addEventListener("DOMContentLoaded", async () => {
    try {
      const res = await fetch("/user/statutory/summary");
      const data = await res.json();

      if (!res.ok) throw new Error(data.message || "Failed to fetch summary");

      // ✅ Update UI
      document.getElementById("complianceRate").textContent = `${data.complianceRate}%`;
      document.querySelector("#complianceRate + p").textContent = data.complianceStatus;
      document.getElementById("onTimeCount").textContent = data.onTime;
      document.getElementById("overdueCount").textContent = data.overdue;
      document.getElementById("upcomingCount").textContent = data.upcoming;

      // ✅ Toast notification (if your global showToast exists)
      if (typeof showToast === "function") showToast("Statutory summary updated!", "success");

      if (window.lucide) lucide.createIcons();
    } catch (err) {
      console.error("⚠️ Error loading statutory summary:", err);
      if (typeof showToast === "function") showToast("Failed to load summary", "error");
    }
  });
</script>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  let complianceChart;
  let healthCircle;
  let reportGenerated = false;

  async function fetchReport(period = 'monthly') {
    try {
      const res = await fetch(`/user/report?period=${period}`);
      if (!res.ok) throw new Error("Failed to fetch report");
      const data = await res.json();

      // ✅ Health Score & Standing
      document.getElementById("healthScore").innerText = data.complianceRate ?? 0;
      const standingEl = document.getElementById("standingStatus");
      standingEl.innerText = data.standing || "N/A";
      standingEl.classList.toggle("text-green-600", data.complianceRate >= 80);
      standingEl.classList.toggle("text-red-600", data.complianceRate < 80);

      // ✅ Last Audit
      document.getElementById("lastAudit").innerText = `Last Audit: ${data.lastAudit || 'N/A'}`;

      // ✅ Alerts
      const alertsFeed = document.getElementById("alertsFeed");
      alertsFeed.innerHTML = (data.alerts?.length ? data.alerts.map(a => `
        <div class="p-3 rounded-lg border ${
          a.type === "danger"
            ? "border-red-200 bg-red-50 text-red-700"
            : "border-yellow-200 bg-yellow-50 text-yellow-700"
        }">${a.message}</div>
      `).join("") : `<div class="text-gray-500 italic">No alerts available.</div>`);

      // ✅ Insights
      const insightsList = document.getElementById("insightsList");
      let insightsHTML = "";

      if (data.totalSales !== undefined) {
        insightsHTML += `
          <div class="p-3 rounded-lg bg-purple-50 border border-purple-100 text-purple-800">
            🛒 Total Sales: ₦${data.totalSales.toLocaleString()}
          </div>
        `;
      }

      if (data.totalExpenses !== undefined) {
        insightsHTML += `
          <div class="p-3 rounded-lg bg-rose-50 border border-rose-100 text-rose-800">
            💸 Total Expenses: ₦${data.totalExpenses.toLocaleString()}
          </div>
        `;
      }

      if (data.profit !== undefined) {
        insightsHTML += `
          <div class="p-3 rounded-lg bg-blue-50 border border-blue-100 text-blue-800">
            📈 Profit: ₦${data.profit.toLocaleString()}
          </div>
        `;
      }

      if (data.taxToPay && data.taxToPay > 0) {
        insightsHTML += `
          <div class="p-3 rounded-lg bg-green-50 border border-green-100 text-green-800 font-medium">
            💰 Estimated Tax to Pay: ₦${data.taxToPay.toLocaleString()}
          </div>
        `;
      }

      // Other insights
      if (data.insights?.length) {
        insightsHTML += data.insights.map(i => `
          <div class="p-3 rounded-lg bg-gray-50 border border-gray-100">${i}</div>
        `).join("");
      }

      insightsList.innerHTML = insightsHTML || `<div class="text-gray-500 italic">No insights available.</div>`;

      // ✅ Compliance Chart (bar)
      const ctx = document.getElementById("complianceChart").getContext("2d");
      const labels = ['On Time', 'Overdue', 'Upcoming'];
      const dataset = [data.onTime || 0, data.overdue || 0, data.upcoming || 0];

      if (!complianceChart) {
        complianceChart = new Chart(ctx, {
          type: 'bar',
          data: {
            labels,
            datasets: [{
              label: 'Compliance',
              data: dataset,
              backgroundColor: ['#16a34a','#dc2626','#facc15']
            }]
          },
          options: {
            responsive: true,
            plugins: { legend: { display: false }, tooltip: { enabled: true } },
            scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
          }
        });
      } else {
        complianceChart.data.datasets[0].data = dataset;
        complianceChart.update();
      }

      // ✅ Health Circle (doughnut)
      const healthCtx = document.getElementById("healthCircle").getContext("2d");
      const rate = data.complianceRate || 0;

      if (!healthCircle) {
        healthCircle = new Chart(healthCtx, {
          type: 'doughnut',
          data: {
            labels: ['Compliant','Remaining'],
            datasets: [{
              data: [rate, 100 - rate],
              backgroundColor:['#16a34a','#e5e7eb'],
              borderWidth:0
            }]
          },
          options: { cutout: '70%', plugins: { legend: { display: false } } }
        });
      } else {
        healthCircle.data.datasets[0].data = [rate, 100 - rate];
        healthCircle.update();
      }

    } catch (err) {
      console.error("Error fetching report:", err);
      alert("Failed to load report. Try again later.");
    }
  }

  // ✅ Generate Report Button
  document.getElementById("generateReport").addEventListener("click", async () => {
    const btn = document.getElementById("generateReport");
    btn.disabled = true;
    btn.innerHTML = '<i data-lucide="loader-2" class="w-4 h-4 animate-spin"></i> Generating...';

    await fetchReport();
    reportGenerated = true;

    btn.disabled = false;
    btn.innerHTML = '<i data-lucide="download" class="w-4 h-4"></i> <span>Generate Report</span>';
    lucide.createIcons();
  });

  // ✅ Toggle monthly/quarterly
  document.getElementById("viewMonthly").addEventListener("click", () => {
    if (!reportGenerated) return;
    fetchReport('monthly');
    document.getElementById("viewMonthly").classList.add('bg-blue-50','text-blue-700');
    document.getElementById("viewQuarterly").classList.remove('bg-blue-50','text-blue-700');
  });

  document.getElementById("viewQuarterly").addEventListener("click", () => {
    if (!reportGenerated) return;
    fetchReport('quarterly');
    document.getElementById("viewQuarterly").classList.add('bg-blue-50','text-blue-700');
    document.getElementById("viewMonthly").classList.remove('bg-blue-50','text-blue-700');
  });
</script>



</body>
</html>