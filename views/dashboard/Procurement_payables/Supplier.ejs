<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>


<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>



<script>
  document.addEventListener("DOMContentLoaded", () => {
    const editButtons = document.querySelectorAll(".btn-outline-secondary");
    const saveBtn = document.querySelector(".save-vendor-btn");
    let currentVendorId = null;

    // When Edit is clicked
    editButtons.forEach((btn) => {
      btn.addEventListener("click", async (e) => {
        e.stopPropagation(); // prevent triggering row modal

        // Find the vendor ID from the table row (you must have data-id attr)
        const row = btn.closest("tr");
        currentVendorId = row.getAttribute("data-id");

        // Fetch vendor info
        const res = await fetch(`/api/vendor/${currentVendorId}`);
        const vendor = await res.json();

        // Prefill modal fields
        document.getElementById("companyName").value = vendor.companyName || "";
        document.getElementById("category").value = vendor.category || "";
        document.getElementById("contactInfo").value = vendor.contactInfo || "";
        document.getElementById("address").value = vendor.address || "";
        document.getElementById("bankInfo").value = vendor.bankInfo || "";
        document.getElementById("tags").value = vendor.tags?.join(", ") || "";

        // Show modal
        const modal = new bootstrap.Modal(document.getElementById("addVendorModal"));
        modal.show();
      });
    });

    // Handle Save (Update)
    saveBtn.addEventListener("click", async () => {
      if (!currentVendorId) return alert("No vendor selected!");

      const updatedData = {
        companyName: document.getElementById("companyName").value,
        category: document.getElementById("category").value,
        contactInfo: document.getElementById("contactInfo").value,
        address: document.getElementById("address").value,
        bankInfo: document.getElementById("bankInfo").value,
        tags: document.getElementById("tags").value,
      };

      const res = await fetch(`/api/vendor/${currentVendorId}`, {
        method: "PUT",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify(updatedData),
      });

      const result = await res.json();
      if (res.ok) {
        alert("✅ Vendor updated successfully!");
        location.reload(); // reload to see updated table
      } else {
        alert("❌ " + result.message);
      }
    });
  });
</script>


<script>
document.querySelector(".save-vendor-btn")?.addEventListener("click", async () => {
  try {
    // 🔥 Collect form data
    const UserId = document.getElementById("UserId").value.trim();
    const companyName = document.getElementById("companyName").value.trim();
    const category = document.getElementById("category").value;
    const contactInfo = document.getElementById("contactInfo").value.trim();
    const address = document.getElementById("address").value.trim();
    const bankInfo = document.getElementById("bankInfo").value.trim();
    const tags = document.getElementById("tags").value.trim();
    const files = document.getElementById("uploadDocs").files;

    // 🧩 Basic validation
    if (!companyName || !contactInfo) {
      return alert("Company name and contact info are required.");
    }

    // 🧾 Step 1: Build FormData for possible file uploads
    const formData = new FormData();
    formData.append("UserId", UserId);
    formData.append("companyName", companyName);
    formData.append("category", category);
    formData.append("contactInfo", contactInfo);
    formData.append("address", address);
    formData.append("bankInfo", bankInfo);
    formData.append("tags", tags);

    // 🔥 Attach uploaded files if any
    for (let file of files) {
      formData.append("uploadDocs", file);
    }

    // 🪄 Optional vendor ID (if you want to link to logged-in vendor)
    formData.append("createdBy", window.vendorId || "");

    // 🚀 Step 2: Push to backend
    const res = await axios.post("/api/vendors/add/vendor", formData, {
      headers: { "Content-Type": "multipart/form-data" }
    });

    console.log("✅ Vendor added successfully:", res.data);
    alert("Vendor added successfully!");

    // 🧹 Step 3: Reset form + close modal
    document.querySelector("#addVendorModal form").reset();
    const modal = bootstrap.Modal.getInstance(document.getElementById("addVendorModal"));
    modal.hide();

    // 🔄 Optionally reload vendor list
    location.reload();

  } catch (err) {
    console.error("❌ Error saving vendor:", err);
    alert("Failed to add vendor. Check console for details.");
  }
});
</script>


<script>
document.addEventListener("DOMContentLoaded", () => {
  // Enable tooltips
  const tooltipTriggerList = document.querySelectorAll('[data-bs-toggle="tooltip"]');
  [...tooltipTriggerList].map(el => new bootstrap.Tooltip(el));

  // Add Vendor Modal
  document.querySelector(".add-vendor-btn")?.addEventListener("click", async () => {
    try {
      const vendorId = window.vendorId;
      console.log("🪄 Fetching vendor info for ID:", vendorId);

      const res = await axios.get(`/api/vendors/${vendorId}`);
      const vendor = res.data;
      console.log("📦 Vendor data received:", vendor);

      // 🧠 Works for both vendor & admin
      document.getElementById("companyName").value = 
        vendor.companyName || vendor.fullName || "";

      document.getElementById("contactInfo").value = 
        `${vendor.contactPerson?.name || vendor.fullName || ""}, ${vendor.contactPerson?.email || vendor.email || ""}, ${vendor.contactPerson?.phone || vendor.phone || ""}`;

      document.getElementById("address").value = vendor.address || "";
      document.getElementById("category").value = vendor.category || vendor.plan || "";
      document.getElementById("bankInfo").value = vendor.bankInfo
        ? `${vendor.bankInfo.bankName || ""}, ${vendor.bankInfo.accountNumber || ""}`
        : "";

      document.getElementById("tags").value = vendor.tags?.join(", ") || "";


      // Show modal
      const modal = new bootstrap.Modal(document.getElementById("addVendorModal"));
      modal.show();

    } catch (err) {
      console.error("❌ Error fetching vendor data:", err);
      alert("Could not load vendor data. Please try again.");
    }
  });
});
</script>








<!-- GET ALL Vendors + Handle Modal View -->
<script>
document.addEventListener("DOMContentLoaded", async () => {
  const tableBody = document.querySelector("table tbody");
  const currentUserId = "<%= user.id %>"; // ✅ Logged-in user ID from EJS

  try {
    const res = await fetch("/api/vendors");
    const vendors = await res.json();
    tableBody.innerHTML = "";

    vendors.forEach(vendor => {
      const row = document.createElement("tr");
      row.classList.add("vendor-row");
      row.style.cursor = "pointer";
      row.dataset.vendorId = vendor._id; // ✅ Make ID accessible later

      const isOwner = vendor.UserId === currentUserId;
      const vendorTypeLabel = isOwner ? "Internal" : "External";
      const typeBadgeClass = isOwner ? "bg-info" : "bg-success";
      const ratingStars = "⭐".repeat(Math.round(vendor.rating?.average || 0));

      // 🧩 Actions
      let actionsHTML = `
        <button class="btn btn-sm btn-outline-primary view-vendor-btn" 
          title="View" 
          data-vendor-id="${vendor._id}">
          <i class="fas fa-eye"></i>
        </button>
      `;

      if (isOwner) {
        actionsHTML += `
          <button class="btn btn-sm btn-outline-danger delete-vendor-btn" 
            title="Delete" 
            data-vendor-id="${vendor._id}">
            <i class="fas fa-trash"></i>
          </button>
        `;
      }

      // 🧩 Row content
      row.innerHTML = `
        <td>${vendor.companyName}</td>
        <td><span class="badge ${typeBadgeClass}">${vendorTypeLabel}</span></td>
        <td>${vendor.category}</td>
        <td>${vendor.bankInfo}</td>
        <td>${ratingStars} (${vendor.rating?.average?.toFixed(1) || 0})</td>
        <td>
          <span class="status-badge ${vendor.tier3Verified ? "status-active" : "status-pending"}">
            ${vendor.tier3Verified ? "Active" : "Pending"}
          </span>
        </td>
        <td>${new Date(vendor.createdAt).toLocaleDateString()}</td>
        <td>${actionsHTML}</td>
      `;

      tableBody.appendChild(row);
    });




// 🧠 After table loads → attach event listeners for View buttons





document.addEventListener("click", (e) => {
  const btn = e.target.closest(".view-vendor-btn");
  if (!btn) return;

  (async () => {
    const vendorId = btn.dataset.vendorId;
    console.log("DEBUG: view clicked vendorId =", vendorId);
    if (!vendorId) return alert("Missing vendor id");

    try {
      const res = await axios.get(`/api/vendors/view/${vendorId}`);
      const vendor = res.data;

      // safe access for uploadedDocs and rating
      const logo = vendor.uploadedDocs?.[0] || "https://via.placeholder.com/100";
      const avg = vendor.rating?.average?.toFixed(1) ?? "0.0";
      const total = vendor.rating?.totalReviews ?? 0;

      document.getElementById("vendorProfileModalLabel").innerHTML =
        `<i class="fas fa-user-tie"></i> Vendor Profile: ${vendor.companyName || "N/A"}`;

      const modalBody = document.querySelector("#vendorProfileModal .modal-body");
      modalBody.innerHTML = `
        <div class="text-center mb-3">
          <img src="${logo}" alt="Vendor Logo" class="vendor-logo">
        </div>
        <div class="card mb-3">
          <div class="card-header"><i class="fas fa-building"></i> Company Info</div>
          <div class="card-body">
            <p><strong>Name:</strong> ${vendor.companyName || "N/A"}</p>
            <p><strong>Contact:</strong> ${vendor.contactInfo || "N/A"}</p>
            <p><strong>Category:</strong> ${vendor.category || "N/A"}</p>
            <p><strong>Address:</strong> ${vendor.address || "N/A"}</p>
          </div>
        </div>
        <div class="card mb-3">
          <div class="card-header"><i class="fas fa-star"></i> Ratings</div>
          <div class="card-body">
            <p><strong>Average Rating:</strong> ${avg} (${total} Reviews)</p>
          </div>
        </div>
        <div class="card mb-3">
          <div class="card-header"><i class="fas fa-bank"></i> Bank Info</div>
          <div class="card-body">
            <p><strong>Bank Info:</strong> ${vendor.bankInfo || "N/A"}</p>
            <p><strong>Tier 3 Verification:</strong>
              <span class="verification-badge ${vendor.tier3Verified ? 'verified' : 'unverified'}">
                ${vendor.tier3Verified ? 'Verified ✅' : 'Not Verified ❌'}
              </span>
            </p>
          </div>
        </div>
        <div class="card mb-3">
          <div class="card-header"><i class="fas fa-file-alt"></i> Uploaded Documents</div>
          <div class="card-body">
            <ul>
              ${vendor.uploadedDocs && vendor.uploadedDocs.length > 0
                ? vendor.uploadedDocs.map(doc => `<li><a href="${doc}" target="_blank">View Document</a></li>`).join("")
                : "<li>No documents uploaded</li>"}
            </ul>
          </div>
        </div>
      `;

      // wire footer buttons safely
      const footer = document.querySelector("#vendorProfileModal .modal-footer");
      footer.querySelector(".btn-outline-danger")?.addEventListener("click", () => {
        new bootstrap.Modal(document.getElementById("reportVendorModal")).show();
      });
      footer.querySelector(".btn-outline-secondary")?.addEventListener("click", () => {
        new bootstrap.Modal(document.getElementById("editVendorModal")).show();
      });
      footer.querySelector(".btn-outline-primary")?.addEventListener("click", async () => {
        await loadVendorHistory(vendorId);
        new bootstrap.Modal(document.getElementById("vendorHistoryModal")).show();
      });

      new bootstrap.Modal(document.getElementById("vendorProfileModal")).show();
    } catch (err) {
      console.error("❌ Error fetching vendor data:", err);
      alert("Failed to load vendor details.");
    }
  })();
});




// 🗑️ DELETE BUTTON
    document.querySelectorAll(".delete-vendor-btn").forEach(btn => {
      btn.addEventListener("click", async () => {
        const vendorId = btn.dataset.vendorId;
        const userId = currentUserId;

        if (!confirm("Are you sure you want to delete this vendor? This action cannot be undone!")) return;

        try {
          const res = await axios.delete(`/api/vendors/delete/${vendorId}`, {
            data: { userId },
          });

          alert(res.data.message);
          btn.closest("tr").remove(); // ✅ Instantly remove from table
        } catch (err) {
          console.error("❌ Error deleting vendor:", err);
          const msg = err.response?.data?.message || "Failed to delete vendor.";
          alert(msg);
        }
      });
    });




  } catch (error) {
    console.error("❌ Error loading vendors:", error);
    tableBody.innerHTML = `
      <tr>
        <td colspan="8" class="text-center text-danger">Failed to load vendors</td>
      </tr>
    `;
  }
});
</script>




<!-- APPLICATION VENDORS -->
<script>
document.addEventListener("DOMContentLoaded", () => {
  const modal = document.getElementById("vendorApplicationsModal");
  const tableBody = modal.querySelector("tbody");

  // When modal is opened
  modal.addEventListener("show.bs.modal", async () => {
    tableBody.innerHTML = `<tr><td colspan="6" class="text-center text-muted">Loading applications...</td></tr>`;

    try {
      const res = await fetch("/api/vendor-applications");
      const apps = await res.json();

      if (apps.length === 0) {
        tableBody.innerHTML = `<tr><td colspan="6" class="text-center text-muted">No applications found</td></tr>`;
        return;
      }

      tableBody.innerHTML = ""; // clear the loading row

      apps.forEach(app => {
        const row = document.createElement("tr");

        const docsHTML = app.uploadedDocs?.length
          ? app.uploadedDocs.map((url, i) => `<a href="${url}" target="_blank">Doc ${i + 1}</a>`).join(", ")
          : "No Documents";

        row.innerHTML = `
          <td>${app.companyName}</td>
          <td>${app.category}</td>
          <td>${new Date(app.createdAt).toLocaleDateString()}</td>
          <td>${docsHTML}</td>
          <td>
            <span class="status-badge ${app.tier3Verified ? "status-active" : "status-pending"}">
              ${app.tier3Verified ? "Approved" : "Pending"}
            </span>
          </td>
          <td>
            <button class="btn btn-sm btn-success" title="Approve"><i class="fas fa-check"></i></button>
            <button class="btn btn-sm btn-danger" title="Reject"><i class="fas fa-times"></i></button>
            <button class="btn btn-sm btn-outline-primary" title="View Application"><i class="fas fa-eye"></i></button>
          </td>
        `;

        tableBody.appendChild(row);
      });
    } catch (err) {
      console.error("Error loading vendor applications:", err);
      tableBody.innerHTML = `<tr><td colspan="6" class="text-center text-danger">Failed to load applications</td></tr>`;
    }
  });
});
</script>



<!-- STATS -->
<script>
document.addEventListener("DOMContentLoaded", async () => {
  const cards = document.querySelectorAll(".card-layout .card-body h2");
  const [totalEl, verifiedEl, avgEl, pendingEl] = cards;

  // Optional: show temporary loading state
  totalEl.textContent = verifiedEl.textContent = avgEl.textContent = pendingEl.textContent = "...";

  try {
    const res = await fetch("/api/vendor-stats");
    const data = await res.json();

    totalEl.textContent = data.totalVendors;
    verifiedEl.textContent = data.verifiedVendors;
    avgEl.textContent = data.avgRating;
    pendingEl.textContent = data.pendingApplications;
  } catch (err) {
    console.error("❌ Error fetching vendor stats:", err);
    totalEl.textContent = verifiedEl.textContent = avgEl.textContent = pendingEl.textContent = "—";
  }
});
</script>






<!-- REPORT -->
<script>

document.getElementById("submitReportBtn")?.addEventListener("click", async () => {
  const reason = document.getElementById("reportReason").value.trim();
  const fullname = document.getElementById("Rfullname").value.trim();
  const email = document.getElementById("Remail").value.trim();
  const vendorId = window.vendorId;
  const reporterId = "<%= user.id %>";

  if (!reason) return alert("Please provide a reason.");

  try {
    const res = await axios.post("/api/vendors/report", { vendorId, reporterId, reason, email, fullname });
    alert(res.data.message);
    bootstrap.Modal.getInstance(document.getElementById("reportVendorModal")).hide();
  } catch (err) {
    console.error("❌ Error reporting vendor:", err);
    alert("Failed to submit report.");
  }
});







</script>




<!-- EDIT APLICATION -->
<script>

    if (vendor.UserId === currentUserId) {
  document.querySelector(".edit-vendor-btn").style.display = "inline-block";
} else {
  document.querySelector(".edit-vendor-btn").style.display = "none";
}




document.getElementById("updateVendorBtn")?.addEventListener("click", async () => {
  const vendorId = window.activeVendorId;
  const updates = {
    companyName: document.getElementById("editCompanyName").value,
    category: document.getElementById("editCategory").value,
    contactInfo: document.getElementById("editContact").value,
  };

  try {
    const res = await axios.put(`/api/vendors/update/${vendorId}`, updates);
    alert(res.data.message);
    bootstrap.Modal.getInstance(document.getElementById("editVendorModal")).hide();
    location.reload();
  } catch (err) {
    console.error("❌ Error updating vendor:", err);
    alert("Failed to update vendor.");
  }
});

</script>














<!-- VIEW HISTORY -->
<script>
    async function loadVendorHistory(vendorId) {
  try {
    const res = await axios.get(`/api/vendors/history/${vendorId}`);
    const historyList = document.getElementById("vendorHistoryList");
    historyList.innerHTML = "";

    if (res.data.reports.length === 0) {
      historyList.innerHTML = "<p>No reports found for this vendor.</p>";
      return;
    }

    res.data.reports.forEach((r, i) => {
      historyList.innerHTML += `
        <div class="border p-2 mb-2">
          <strong>#${i + 1}</strong> - ${r.reason}<br>
          <small>Reported by: ${r.reporterId?.name || "Unknown"} on ${new Date(r.date).toLocaleDateString()}</small>
        </div>
      `;
    });
  } catch (err) {
    console.error("❌ Error loading vendor history:", err);
  }
}

</script>











