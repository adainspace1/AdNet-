<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Supplier & Vendor Registry</title>
    <!-- Bootstrap CSS for responsive design -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome for icons -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">

             <link
      href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/boxicons@2.1.4/css/boxicons.min.css"
    />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">


        <link rel="stylesheet" href="/css/accountpayable.css">
        <link rel="stylesheet" href="/css/supplier.css">
    <link rel="stylesheet" href="/css/dashall.css">


</head>
<body>


      <div class="all">
        <%- include ("../_sidebar1") %>


    <div class="main-content">
        <%- include ("../_topnav") %>

<!-- Top Section: Header & Controls -->
<div class="header">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h1>Supplier & Vendor Registry</h1>
            </div>
            <div class="col-md-6 text-end">
                <button class="btn btn-primary action-btn"><i class="fas fa-plus"></i> Add New Vendor</button>
                <button class="btn btn-outline-secondary action-btn"><i class="fas fa-search"></i> Search Vendors</button>
                <button class="btn btn-outline-secondary action-btn"><i class="fas fa-filter"></i> Filters</button>
                <button class="btn btn-outline-secondary action-btn"><i class="fas fa-download"></i> Export</button>
                <button class="btn btn-outline-secondary action-btn"><i class="fas fa-sync"></i> Sync with Bank API</button>
            </div>
        </div>
    </div>
</div>

<!-- Main Table / Directory View -->
<div class="containerr mt-4">
    <div class="card">
        <div class="card-body" id="table-card">
            <table class="table table-hover table-responsive">
                <thead class="table-light">
                    <tr>
                        <th>Vendor Name</th>
                        <th>Vendor ID</th>
                        <th>Category</th>
                        <th>Bank Details</th>
                        <th>Rating</th>
                        <th>Status</th>
                        <th>Last Transaction</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Example Row 1 -->
                    <tr data-bs-toggle="modal" data-bs-target="#vendorProfileModal" style="cursor: pointer;">
                        <td>ABC Supplies Inc.</td>
                        <td>VEN-00045</td>
                        <td>Office Supplies</td>
                        <td>Bank of America, ****1234</td>
                        <td><i class="fas fa-star rating-stars"></i><i class="fas fa-star rating-stars"></i><i class="fas fa-star rating-stars"></i><i class="fas fa-star rating-stars"></i><i class="far fa-star"></i> (4.0)</td>
                        <td><span class="status-badge status-active">Active</span></td>
                        <td>2023-10-15</td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary"><i class="fas fa-eye"></i></button>
                            <button class="btn btn-sm btn-outline-secondary"><i class="fas fa-edit"></i></button>
                            <button class="btn btn-sm btn-outline-danger"><i class="fas fa-ban"></i></button>
                        </td>
                    </tr>
                    <!-- Example Row 2 -->
                    <tr data-bs-toggle="modal" data-bs-target="#vendorProfileModal" style="cursor: pointer;">
                        <td>LogiTrans Logistics</td>
                        <td>VEN-00046</td>
                        <td>Logistics</td>
                        <td>Chase Bank, ****5678</td>
                        <td><i class="fas fa-star rating-stars"></i><i class="fas fa-star rating-stars"></i><i class="fas fa-star rating-stars"></i><i class="far fa-star"></i><i class="far fa-star"></i> (3.0)</td>
                        <td><span class="status-badge status-pending">Pending</span></td>
                        <td>2023-09-20</td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary"><i class="fas fa-eye"></i></button>
                            <button class="btn btn-sm btn-outline-secondary"><i class="fas fa-edit"></i></button>
                            <button class="btn btn-sm btn-outline-danger"><i class="fas fa-ban"></i></button>
                        </td>
                    </tr>
                    <!-- Add more rows as needed -->
                </tbody>
            </table>
        </div>
    </div>

    <!-- Vendor Analytics Widget -->
    <div class="row card-layout">
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h5>Total Vendors</h5>
                    <h2>150</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h5>Verified Vendors</h5>
                    <h2>120</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h5>Average Rating</h5>
                    <h2>4.2</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h5>Vendors with Pending Docs</h5>
                    <h2>5</h2>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Vendor Profile Modal -->
<div class="modal fade" id="vendorProfileModal" tabindex="-1" aria-labelledby="vendorProfileModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="vendorProfileModalLabel"><i class="fas fa-building"></i> Vendor Profile: ABC Supplies Inc.</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <!-- Vendor Information -->
                <div class="card mb-3">
                    <div class="card-header"><i class="fas fa-info-circle"></i> Vendor Information</div>
                    <div class="card-body">
                        <p><strong>Company Name:</strong> ABC Supplies Inc.</p>
                        <p><strong>Contact Person:</strong> John Doe</p>
                        <p><strong>Phone:</strong> +1-123-456-7890</p>
                        <p><strong>Email:</strong> john@abcsupplies.com</p>
                        <p><strong>Address:</strong> 123 Main St, City, State, ZIP</p>
                        <p><strong>Tax ID (TIN):</strong> 12-3456789</p>
                        <p><strong>Registration Number:</strong> REG-001</p>
                        <p><strong>Category:</strong> Office Supplies</p>
                        <p><strong>Services Provided:</strong> Stationery, Furniture</p>
                    </div>
                </div>

                <!-- Bank Details -->
                <div class="card mb-3">
                    <div class="card-header"><i class="fas fa-bank"></i> Bank Details</div>
                    <div class="card-body">
                        <p><strong>Bank Name:</strong> Bank of America</p>
                        <p><strong>Account Number:</strong> ****1234</p>
                        <p><strong>Sort Code:</strong> 123-456</p>
                        <p><strong>Tier-3 Verification:</strong> <span class="verification-badge verified">Verified ✅</span></p>
                        <p><strong>Linked Payment Method:</strong> ACH</p>
                        <p><strong>Currency:</strong> USD</p>
                    </div>
                </div>

                <!-- Ratings & Performance -->
                <div class="card mb-3">
                    <div class="card-header"><i class="fas fa-star"></i> Ratings & Performance</div>
                    <div class="card-body">
                        <p><strong>Rating:</strong> <i class="fas fa-star rating-stars"></i><i class="fas fa-star rating-stars"></i><i class="fas fa-star rating-stars"></i><i class="fas fa-star rating-stars"></i><i class="far fa-star"></i> (4.0)</p>
                        <p><strong>Last 5 Transactions:</strong> Invoice #123 (Paid), #124 (Pending), etc.</p>
                        <p><strong>Average Payment Cycle:</strong> 7 days</p>
                        <p><strong>Reliability:</strong> 95% On-Time Delivery, 2 Disputes</p>
                    </div>
                </div>

                <!-- Documents -->
                <div class="card mb-3">
                    <div class="card-header"><i class="fas fa-file-alt"></i> Documents</div>
                    <div class="card-body">
                        <ul>
                            <li>KYC Doc: <a href="#">View</a> | <button class="btn btn-sm btn-outline-primary">Upload</button></li>
                            <li>Certification: <a href="#">View</a> | <button class="btn btn-sm btn-outline-primary">Upload</button></li>
                            <li>Contract: <a href="#">View</a> | <button class="btn btn-sm btn-outline-primary">Upload</button></li>
                        </ul>
                    </div>
                </div>

                <!-- History -->
                <div class="card">
                    <div class="card-header"><i class="fas fa-history"></i> History</div>
                    <div class="card-body">
                        <p><strong>Purchase Orders:</strong> PO-001, PO-002</p>
                        <p><strong>Invoices:</strong> INV-123, INV-124</p>
                        <p><strong>Payments:</strong> Paid on 2023-10-15 ($500)</p>
                        <p><strong>Disputes:</strong> 1 Resolved</p>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary"><i class="fas fa-edit"></i> Edit Vendor</button>
            </div>
        </div>
    </div>
</div>

<!-- Add/Edit Vendor Modal -->
<div class="modal fade" id="addVendorModal" tabindex="-1" aria-labelledby="addVendorModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addVendorModalLabel"><i class="fas fa-plus"></i> Add New Vendor</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form>
                    <!-- Basic Info -->
                    <div class="mb-3">
                        <h6>Basic Info</h6>
                        <div class="row">
                            <div class="col-md-6">
                                <label for="vendorName" class="form-label">Vendor Name</label>
                                <input type="text" class="form-control" id="vendorName">
                            </div>
                            <div class="col-md-6">
                                <label for="category" class="form-label">Category</label>
                                <select class="form-select" id="category">
                                    <option>Office Supplies</option>
                                    <option>Logistics</option>
                                    <option>Maintenance</option>
                                </select>
                            </div>
                        </div>
                        <div class="row mt-3">
                            <div class="col-md-6">
                                <label for="contactPerson" class="form-label">Contact Person</label>
                                <input type="text" class="form-control" id="contactPerson">
                            </div>
                            <div class="col-md-6">
                                <label for="phone" class="form-label">Phone</label>
                                <input type="tel" class="form-control" id="phone">
                            </div>
                        </div>
                        <div class="row mt-3">
                            <div class="col-md-6">
                                <label for="email" class="form-label">Email</label>
                                <input type="email" class="form-control" id="email">
                            </div>
                            <div class="col-md-6">
                                <label for="address" class="form-label">Address</label>
                                <input type="text" class="form-control" id="address">
                            </div>
                        </div>
                    </div>

                    <!-- Bank Info -->
                    <div class="mb-3">
                        <h6>Bank Info</h6>
                        <div class="row">
                            <div class="col-md-6">
                                <label for="bankName" class="form-label">Bank Name</label>
                                <input type="text" class="form-control" id="bankName">
                            </div>
                            <div class="col-md-6">
                                <label for="accountNumber" class="form-label">Account Number</label>
                                <input type="text" class="form-control" id="accountNumber">
                            </div>
                        </div>
                        <div class="row mt-3">
                            <div class="col-md-6">
                                <label for="sortCode" class="form-label">Sort Code</label>
                                <input type="text" class="form-control" id="sortCode">
                            </div>
                            <div class="col-md-6">
                                <label for="currency" class="form-label">Currency</label>
                                <select class="form-select" id="currency">
                                    <option>USD</option>
                                    <option>EUR</option>
                                    <option>GBP</option>
                                </select>
                            </div>
                        </div>
                        <div class="form-check mt-3">
                            <input class="form-check-input" type="checkbox" id="tier3Verify">
                            <label class="form-check-label" for="tier3Verify">Tier-3 Verification</label>
                        </div>
                    </div>

                    <!-- Documents -->
                    <div class="mb-3">
                        <h6>Documents</h6>
                        <div class="input-group">
                            <input type="file" class="form-control" id="uploadDocs">
                            <button class="btn btn-outline-secondary" type="button">Upload</button>
                        </div>
                    </div>

                    <!-- Ratings -->
                    <div class="mb-3">
                        <h6>Ratings (Optional)</h6>
                        <select class="form-select" id="initialRating">
                            <option>1 Star</option>
                            <option>2 Stars</option>
                            <option>3 Stars</option>
                            <option>4 Stars</option>
                            <option>5 Stars</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary">Save</button>
            </div>
        </div>
    </div>
</div>

    </div>
      </div>
      

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
// ✅ Grab main action buttons
const addBtn = document.querySelector('.btn.btn-primary.action-btn');
const searchBtn = document.querySelector('button i.fas.fa-search')?.closest('button');
const filterBtn = document.querySelector('button i.fas.fa-filter')?.closest('button');
const exportBtn = document.querySelector('button i.fas.fa-download')?.closest('button');
const syncBtn = document.querySelector('button i.fas.fa-sync')?.closest('button');

// ✅ Bootstrap modal helper
function showModal(id) {
  const modal = new bootstrap.Modal(document.getElementById(id));
  modal.show();
}

// ✅ 1. Add Vendor
addBtn.addEventListener('click', () => showModal('addVendorModal'));

// ✅ 2. Search Vendors popup
searchBtn.addEventListener('click', () => {
  const searchModalHTML = `
  <div class="modal fade" id="searchModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title"><i class="fas fa-search"></i> Search Vendors</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <input type="text" class="form-control" placeholder="Enter vendor name, ID or category...">
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
          <button type="button" class="btn btn-primary">Search</button>
        </div>
      </div>
    </div>
  </div>`;
  document.body.insertAdjacentHTML('beforeend', searchModalHTML);
  showModal('searchModal');
});

// ✅ 3. Filters popup
filterBtn.addEventListener('click', () => {
  const filterModalHTML = `
  <div class="modal fade" id="filterModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title"><i class="fas fa-filter"></i> Filter Vendors</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <label class="form-label">Status</label>
          <select class="form-select mb-3">
            <option>All</option>
            <option>Active</option>
            <option>Pending</option>
            <option>Inactive</option>
          </select>
          <label class="form-label">Category</label>
          <select class="form-select">
            <option>All</option>
            <option>Office Supplies</option>
            <option>Logistics</option>
            <option>Maintenance</option>
          </select>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="button" class="btn btn-primary">Apply</button>
        </div>
      </div>
    </div>
  </div>`;
  document.body.insertAdjacentHTML('beforeend', filterModalHTML);
  showModal('filterModal');
});

// ✅ 4. Export confirmation popup
exportBtn.addEventListener('click', () => {
  const exportModalHTML = `
  <div class="modal fade" id="exportModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content text-center p-3">
        <h5><i class="fas fa-download text-success"></i> Export Vendor List?</h5>
        <p>Download as Excel or PDF?</p>
        <div class="d-flex justify-content-center gap-3">
          <button class="btn btn-outline-success"><i class="fas fa-file-excel"></i> Excel</button>
          <button class="btn btn-outline-danger"><i class="fas fa-file-pdf"></i> PDF</button>
        </div>
      </div>
    </div>
  </div>`;
  document.body.insertAdjacentHTML('beforeend', exportModalHTML);
  showModal('exportModal');
});

// ✅ 5. Sync with Bank API popup
syncBtn.addEventListener('click', () => {
  const syncModalHTML = `
  <div class="modal fade" id="syncModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content text-center p-3">
        <h5><i class="fas fa-sync fa-spin text-info"></i> Syncing Vendors...</h5>
        <p class="mt-2">Connecting to Bank API. Please wait.</p>
      </div>
    </div>
  </div>`;
  document.body.insertAdjacentHTML('beforeend', syncModalHTML);
  showModal('syncModal');

  // fake 3s sync process
  setTimeout(() => {
    document.getElementById('syncModal').querySelector('.modal-content').innerHTML = `
      <h5 class="text-success"><i class="fas fa-check-circle"></i> Sync Complete</h5>
      <p>All bank records updated successfully ✅</p>`;
  }, 3000);
});
</script>

</body>
</html>