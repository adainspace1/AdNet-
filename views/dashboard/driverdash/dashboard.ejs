<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Driver Dashboard | AdNet</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap');

    body {
      font-family: 'Outfit', sans-serif;
    }

    .map-container {
      height: 60vh;
      width: 100%;
      position: relative;
      z-index: 0;
    }

    .glass-panel {
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(10px);
      border-top-left-radius: 20px;
      border-top-right-radius: 20px;
      box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.1);
    }

    .online-pulse {
      box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7);
      animation: pulse-green 2s infinite;
    }

    @keyframes pulse-green {
      0% {
        transform: scale(0.95);
        box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7);
      }

      70% {
        transform: scale(1);
        box-shadow: 0 0 0 10px rgba(16, 185, 129, 0);
      }

      100% {
        transform: scale(0.95);
        box-shadow: 0 0 0 0 rgba(16, 185, 129, 0);
      }
    }

    .slide-up {
      animation: slideUp 0.3s ease-out forwards;
    }

    @keyframes slideUp {
      from {
        transform: translateY(100%);
      }

      to {
        transform: translateY(0);
      }
    }
  </style>
</head>

<body class="bg-gray-100 h-screen flex flex-col overflow-hidden">

  <!-- Top Bar -->
  <div
    class="absolute top-0 left-0 right-0 z-20 p-4 flex justify-between items-center bg-gradient-to-b from-black/50 to-transparent">
    <div class="flex items-center space-x-3">
      <div class="w-10 h-10 rounded-full border-2 border-white overflow-hidden">
        <img src="<%= driver.profilePicture || 'https://via.placeholder.com/100' %>" class="w-full h-full object-cover">
      </div>
      <div class="text-white">
        <h1 class="font-bold text-lg leading-tight">
          <%= driver.fullName %>
        </h1>
        <p class="text-xs opacity-80">4.9 ⭐ Rating</p>
      </div>
    </div>
    <button id="onlineToggle"
      class="bg-white text-gray-800 px-4 py-2 rounded-full font-semibold shadow-lg flex items-center space-x-2 transition-all transform active:scale-95">
      <div id="statusIndicator" class="w-3 h-3 rounded-full bg-gray-400"></div>
      <span id="statusText">Go Online</span>
    </button>
  </div>

  <!-- Map -->
  <div id="map" class="map-container flex-grow"></div>

  <!-- Bottom Panel -->
  <div class="glass-panel absolute bottom-0 left-0 right-0 max-h-[50vh] flex flex-col z-20 transition-all duration-300"
    id="bottomPanel">

    <!-- Drag Handle -->
    <div class="w-full flex justify-center pt-3 pb-1">
      <div class="w-12 h-1.5 bg-gray-300 rounded-full"></div>
    </div>

    <!-- Content Area -->
    <div class="p-4 overflow-y-auto pb-20" id="panelContent">

      <!-- Offline State -->
      <div id="offlineState" class="text-center py-8">
        <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4 text-gray-400">
          <i class="fas fa-power-off text-2xl"></i>
        </div>
        <h2 class="text-xl font-bold text-gray-800">You are Offline</h2>
        <p class="text-gray-500 mt-1">Go online to start receiving delivery requests.</p>
      </div>

      <!-- Online / Searching State -->
      <div id="onlineState" class="hidden">
        <div class="flex justify-between items-center mb-4">
          <h2 class="font-bold text-lg text-gray-800">New Requests</h2>
          <span class="text-xs bg-blue-100 text-blue-600 px-2 py-1 rounded-full animate-pulse">Searching...</span>
        </div>

        <div id="ordersList" class="space-y-3">
          <!-- Orders will be injected here via JS -->
        </div>
      </div>

      <!-- Active Order State -->
      <div id="activeOrderState" class="hidden">
        <div class="bg-green-50 border border-green-100 rounded-xl p-4 mb-4">
          <div class="flex justify-between items-start mb-3">
            <div>
              <span class="text-xs font-bold text-green-600 uppercase tracking-wider">Active Delivery</span>
              <h3 class="font-bold text-lg text-gray-900 mt-1" id="activeOrderId">#ORD-1234</h3>
            </div>
            <div class="bg-white p-2 rounded-lg shadow-sm">
              <i class="fas fa-box text-green-500 text-xl"></i>
            </div>
          </div>

          <div class="space-y-3 relative">
            <!-- Connecting Line -->
            <div class="absolute left-[11px] top-2 bottom-2 w-0.5 bg-gray-200 -z-10"></div>

            <div class="flex items-start space-x-3">
              <div
                class="w-6 h-6 rounded-full bg-blue-100 flex items-center justify-center flex-shrink-0 border-2 border-white shadow-sm">
                <div class="w-2 h-2 bg-blue-500 rounded-full"></div>
              </div>
              <div>
                <p class="text-xs text-gray-500">Pickup</p>
                <p class="font-medium text-sm text-gray-800" id="activePickup">Warehouse A</p>
              </div>
            </div>

            <div class="flex items-start space-x-3">
              <div
                class="w-6 h-6 rounded-full bg-red-100 flex items-center justify-center flex-shrink-0 border-2 border-white shadow-sm">
                <div class="w-2 h-2 bg-red-500 rounded-full"></div>
              </div>
              <div>
                <p class="text-xs text-gray-500">Dropoff</p>
                <p class="font-medium text-sm text-gray-800" id="activeDropoff">123 Main St, Lagos</p>
              </div>
            </div>
          </div>

          <div class="mt-4 flex space-x-2">
            <button onclick="updateStatus('delivered')"
              class="flex-1 bg-green-600 text-white py-3 rounded-xl font-semibold shadow-lg hover:bg-green-700 transition-colors">
              Complete Delivery
            </button>
            <a href="tel:+"
              class="w-12 h-12 bg-gray-100 rounded-xl flex items-center justify-center text-gray-600 hover:bg-gray-200">
              <i class="fas fa-phone"></i>
            </a>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Scripts -->
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script>
    // --- State ---
    let isOnline = <%= driver.isOnline %>;
    let currentOrderId = '<%= driver.currentOrderId || "" %>';
    let map, marker, watchId;
    const driverId = '<%= driver._id %>';

    // --- Elements ---
    const onlineToggle = document.getElementById('onlineToggle');
    const statusIndicator = document.getElementById('statusIndicator');
    const statusText = document.getElementById('statusText');
    const offlineState = document.getElementById('offlineState');
    const onlineState = document.getElementById('onlineState');
    const activeOrderState = document.getElementById('activeOrderState');
    const ordersList = document.getElementById('ordersList');

    // --- Initialization ---
    function initMap() {
      // Default to Lagos
      map = L.map('map').setView([6.5244, 3.3792], 13);
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© OpenStreetMap contributors'
      }).addTo(map);

      // Custom Icon
      const carIcon = L.divIcon({
        className: 'custom-div-icon',
        html: "<div style='background-color:#10B981; width: 20px; height: 20px; border-radius: 50%; border: 3px solid white; box-shadow: 0 2px 5px rgba(0,0,0,0.3);'></div>",
        iconSize: [20, 20],
        iconAnchor: [10, 10]
      });

      // Try to get current location immediately
      if (navigator.geolocation) {
        navigator.geolocation.getCurrentPosition(pos => {
          const { latitude, longitude } = pos.coords;
          map.setView([latitude, longitude], 15);
          marker = L.marker([latitude, longitude], { icon: carIcon }).addTo(map);
        });
      }
    }

    // --- Logic ---
    function updateUI() {
      if (currentOrderId) {
        // Active Order Mode
        onlineToggle.classList.add('hidden'); // Hide toggle during active order
        offlineState.classList.add('hidden');
        onlineState.classList.add('hidden');
        activeOrderState.classList.remove('hidden');
        // Fetch order details if needed (simplified here)
        // In real app, fetch order details by ID to populate the view
      } else if (isOnline) {
        // Online Mode
        onlineToggle.classList.remove('hidden');
        statusIndicator.classList.remove('bg-gray-400');
        statusIndicator.classList.add('bg-green-500', 'online-pulse');
        statusText.textContent = "Online";

        offlineState.classList.add('hidden');
        onlineState.classList.remove('hidden');
        activeOrderState.classList.add('hidden');

        startPolling();
        startTracking();
      } else {
        // Offline Mode
        onlineToggle.classList.remove('hidden');
        statusIndicator.classList.remove('bg-green-500', 'online-pulse');
        statusIndicator.classList.add('bg-gray-400');
        statusText.textContent = "Go Online";

        offlineState.classList.remove('hidden');
        onlineState.classList.add('hidden');
        activeOrderState.classList.add('hidden');

        stopPolling();
        stopTracking();
      }
    }

    async function toggleOnline() {
      const newState = !isOnline;

      // Get location for the update
      navigator.geolocation.getCurrentPosition(async (pos) => {
        try {
          const res = await fetch('/driver/api/driver/toggle-online', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              isOnline: newState,
              lat: pos.coords.latitude,
              lng: pos.coords.longitude
            })
          });
          const data = await res.json();
          if (data.success) {
            isOnline = data.isOnline;
            updateUI();
          }
        } catch (err) {
          console.error("Error toggling status:", err);
          alert("Failed to update status. Check connection.");
        }
      }, (err) => {
        alert("Location access is required to go online.");
      });
    }

    // --- Tracking ---
    function startTracking() {
      if (navigator.geolocation) {
        watchId = navigator.geolocation.watchPosition(pos => {
          const { latitude, longitude } = pos.coords;
          if (marker) {
            marker.setLatLng([latitude, longitude]);
          } else {
            // Create marker if not exists
            const carIcon = L.divIcon({
              className: 'custom-div-icon',
              html: "<div style='background-color:#10B981; width: 20px; height: 20px; border-radius: 50%; border: 3px solid white; box-shadow: 0 2px 5px rgba(0,0,0,0.3);'></div>",
              iconSize: [20, 20],
              iconAnchor: [10, 10]
            });
            marker = L.marker([latitude, longitude], { icon: carIcon }).addTo(map);
          }
          map.setView([latitude, longitude], map.getZoom()); // Keep centered

          // TODO: Send location update to server periodically (debounce this)
        }, err => console.error(err), { enableHighAccuracy: true });
      }
    }

    function stopTracking() {
      if (watchId) navigator.geolocation.clearWatch(watchId);
    }

    // --- Polling Orders ---
    let pollInterval;
    function startPolling() {
      fetchOrders(); // Initial fetch
      pollInterval = setInterval(fetchOrders, 5000); // Poll every 5s
    }

    function stopPolling() {
      clearInterval(pollInterval);
    }

    async function fetchOrders() {
      try {
        const res = await fetch('/driver/api/driver/orders');
        const data = await res.json();
        if (data.success) {
          renderOrders(data.orders);
        }
      } catch (err) {
        console.error("Polling error:", err);
      }
    }

    function renderOrders(orders) {
      ordersList.innerHTML = '';
      if (orders.length === 0) {
        ordersList.innerHTML = `
                    <div class="text-center py-4 text-gray-400">
                        <p class="text-sm">Scanning area for requests...</p>
                    </div>`;
        return;
      }

      orders.forEach(order => {
        const el = document.createElement('div');
        el.className = 'bg-white p-4 rounded-xl shadow-sm border border-gray-100 slide-up';
        el.innerHTML = `
                    <div class="flex justify-between items-start mb-3">
                        <div class="flex items-center space-x-2">
                            <div class="bg-blue-50 p-2 rounded-lg text-blue-600">
                                <i class="fas ${order.delivery.type === 'motorcycle' ? 'fa-motorcycle' : 'fa-truck'}"></i>
                            </div>
                            <div>
                                <h3 class="font-bold text-gray-800 capitalize">${order.delivery.type}</h3>
                                <p class="text-xs text-gray-500">2.5 km away</p>
                            </div>
                        </div>
                        <div class="text-right">
                            <span class="block font-bold text-lg text-green-600">₦${order.delivery.price}</span>
                        </div>
                    </div>
                    <div class="space-y-2 mb-4">
                        <div class="flex items-center text-sm text-gray-600">
                            <i class="fas fa-map-marker-alt w-6 text-blue-500"></i>
                            <span class="truncate">${order.delivery.collectionPoint || 'Warehouse'}</span>
                        </div>
                        <div class="flex items-center text-sm text-gray-600">
                            <i class="fas fa-location-arrow w-6 text-red-500"></i>
                            <span class="truncate">${order.delivery.location}</span>
                        </div>
                    </div>
                    <div class="flex space-x-2">
                        <button onclick="acceptOrder('${order._id}')" class="flex-1 bg-black text-white py-2 rounded-lg font-medium hover:bg-gray-800 transition-colors">Accept</button>
                        <button class="px-4 py-2 text-gray-400 hover:text-red-500"><i class="fas fa-times"></i></button>
                    </div>
                `;
        ordersList.appendChild(el);
      });
    }

    async function acceptOrder(orderId) {
      try {
        const res = await fetch('/driver/api/driver/accept-order', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ orderId })
        });
        const data = await res.json();
        if (data.success) {
          currentOrderId = data.order._id;
          // Update UI manually or reload
          document.getElementById('activeOrderId').textContent = '#' + data.order._id.slice(-6).toUpperCase();
          document.getElementById('activePickup').textContent = data.order.delivery.collectionPoint || 'Warehouse';
          document.getElementById('activeDropoff').textContent = data.order.delivery.location;
          updateUI();
        } else {
          alert(data.message);
        }
      } catch (err) {
        alert("Error accepting order");
      }
    }

    async function updateStatus(status) {
      try {
        const res = await fetch('/driver/api/driver/update-status', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ orderId: currentOrderId, status })
        });
        const data = await res.json();
        if (data.success) {
          if (status === 'delivered') {
            alert("Delivery Completed! Great job.");
            currentOrderId = null;
            updateUI();
          }
        }
      } catch (err) {
        alert("Error updating status");
      }
    }

    // --- Event Listeners ---
    onlineToggle.addEventListener('click', toggleOnline);

    // --- Boot ---
    initMap();
    updateUI();

  </script>
</body>

</html>