<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <title>Manual Financial Audit - AdNet</title>
    <link rel="stylesheet" href="/css/dashall.css">
    <link rel="stylesheet" href="/css/auditingmanual.css">
</head>

<body>


    <div class="all">
        <%- include ("../_sidebar1") %>

            <div class="main-content">
                <%- include ("../_topnav") %>
                    <div class="container">
                        <!-- Header Section -->
                        <div class="header">
                            <h1 class="page-title">Manual Financial Audit</h1>
                            <nav class="breadcrumb">
                                <a href="/dashboard">Dashboard</a>
                                <span>›</span>
                                <a href="#auditing">Auditing</a>
                                <span>›</span>
                                <span>Manual Audit</span>
                            </nav>
                            <div class="search-container">
                                <input type="text" class="search-input" placeholder="Search transactions..."
                                    id="searchInput">
                                <span class="search-icon"><i class="fas fa-search"></i>
                                </span>
                            </div>
                        </div>

                        <div class="main-grid">
                            <!-- Audit Form Section -->
                            <div class="audit-form">
                                <h2 class="section-title">Audit Details</h2>
                                <div class="success-message" id="successMessage">
                                    Audit report submitted successfully!
                                </div>

                                <div class="form-grid">
                                    <div class="form-group">
                                        <label class="form-label" for="manualAuditId">Audit ID</label>
                                        <div style="display: flex; gap: 10px;">
                                            <input type="text" class="form-input" id="manualAuditId"
                                                placeholder="e.g. AUD-2026-001">
                                            <button class="btn btn-primary" onclick="createLoadAudit()"
                                                style="padding: 0 15px;">Load</button>
                                        </div>
                                    </div>
                                    <div class="form-group">
                                        <label class="form-label" for="accountName">Account Name/Number</label>
                                        <select class="form-select" id="accountName">
                                            <option value="">Select Account</option>
                                            <option value="Cash Account - 1001">Cash Account - 1001</option>
                                            <option value="Revenue Account - 4001">Revenue Account (Sales)</option>
                                            <option value="Expense Account - 5001">Expense Account</option>
                                        </select>
                                    </div>
                                    <div class="form-group">
                                        <label class="form-label" for="dateFrom">Date From</label>
                                        <input type="date" class="form-input" id="dateFrom">
                                    </div>
                                    <div class="form-group">
                                        <label class="form-label" for="dateTo">Date To</label>
                                        <input type="date" class="form-input" id="dateTo">
                                    </div>
                                </div>

                                <h3 class="section-title">Transaction Review</h3>
                                <table class="transactions-table" id="transactionsTable">
                                    <thead>
                                        <tr>
                                            <th>Transaction ID</th>
                                            <th>Date</th>
                                            <th>Description</th>
                                            <th>Amount</th>
                                            <th>Status</th>
                                            <th>Comments</th>
                                        </tr>
                                    </thead>
                                    <tbody id="transactionsBody">
                                        <!-- Transactions will be populated by JavaScript -->
                                    </tbody>
                                </table>
                            </div>

                            <!-- Findings Panel -->
                            <div class="findings-panel">
                                <h2 class="section-title">Audit Findings</h2>

                                <div class="form-group">
                                    <label class="form-label" for="overallComments">Overall Comments</label>
                                    <textarea class="findings-textarea" id="overallComments"
                                        placeholder="Enter your audit findings and recommendations..."></textarea>
                                </div>

                                <div class="form-group">
                                    <label class="form-label">Supporting Files</label>
                                    <div class="file-upload">
                                        <input type="file" class="file-upload-input" id="supportingFiles" multiple
                                            accept=".pdf,.doc,.docx,.xls,.xlsx,.jpg,.png">
                                        <label for="supportingFiles" class="file-upload-label">
                                            <i class="fas fa-thumbtack"></i>Click to upload files or drag & drop
                                        </label>
                                    </div>
                                    <div id="fileList"></div>
                                </div>

                                <div class="checkbox-group">
                                    <input type="checkbox" class="checkbox" id="auditCompleted">
                                    <label for="auditCompleted">Audit Completed</label>
                                </div>

                                <div class="button-group">
                                    <button class="btn btn-secondary" onclick="saveDraft()">
                                        <i class="fas fa-save"></i>Save Draft
                                    </button>
                                    <button class="btn btn-primary" onclick="submitAudit()">
                                        <i class="fas fa-paper-plane"></i> Submit Audit Report
                                    </button>
                                    <button class="btn btn-secondary" onclick="downloadPDF()">
                                        <i class="fas fa-file-pdf"></i> PDF
                                    </button>
                                    <button class="btn btn-secondary" onclick="downloadCSV()">
                                        <i class="fas fa-file-csv"></i> CSV
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Recent Audits Section -->
                        <div class="recent-audits">
                            <h2 class="section-title">Recent Audit Reports</h2>
                            <div id="recentAuditsList">
                                <!-- Recent audits will be populated by JavaScript -->
                            </div>
                        </div>
                    </div>






            </div>


            <script>
                // Global variables
                let currentAuditId = null;
                let auditTransactions = [];

                // Initialize the dashboard
                function initializeDashboard() {
                    setupDefaultDates();
                    setupEventListeners();
                    loadRecentAudits();
                }

                function setupDefaultDates() {
                    const today = new Date();
                    const firstDay = new Date(today.getFullYear(), today.getMonth(), 1);
                    document.getElementById('dateTo').value = today.toISOString().split('T')[0];
                    document.getElementById('dateFrom').value = firstDay.toISOString().split('T')[0];
                }

                // Create or Load manual audit
                async function createLoadAudit() {
                    const auditId = document.getElementById('manualAuditId').value.trim();
                    const accountName = document.getElementById('accountName').value;
                    const dateFrom = document.getElementById('dateFrom').value;
                    const dateTo = document.getElementById('dateTo').value;

                    if (!auditId || !accountName) {
                        showNotification('Audit ID and Account are required', 'error');
                        return;
                    }

                    try {
                        await fetch('/api/audit/manual/create', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ auditId, accountName, dateFrom, dateTo })
                        });

                        currentAuditId = auditId;
                        showNotification('Audit session active', 'success');
                        loadTransactions(auditId);
                    } catch (error) {
                        showNotification('Error initializing audit', 'error');
                    }
                }

                // Load transactions for audit
                async function loadTransactions(auditId) {
                    const tbody = document.getElementById('transactionsBody');
                    tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;">Loading...</td></tr>';
                    try {
                        const response = await fetch(`/api/audit/manual/transactions/${auditId}`);
                        const result = await response.json();
                        if (result.success) {
                            auditTransactions = result.transactions;
                            populateTransactionsTable(result.transactions);
                        } else {
                            tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;">No data found</td></tr>';
                        }
                    } catch (error) {
                        showNotification('Error loading transactions', 'error');
                    }
                }

                // Load recent audits
                async function loadRecentAudits() {
                    try {
                        const response = await fetch('/api/audit/list');
                        const result = await response.json();
                        if (result.success) populateRecentAudits(result.audits);
                    } catch (error) {
                        console.error(error);
                    }
                }

                // Notification system
                function showNotification(message, type) {
                    const notification = document.createElement('div');
                    notification.className = `notification ${type}`;
                    notification.style.cssText = `position:fixed; top:20px; right:20px; padding:15px; border-radius:8px; color:white; background:${type === 'success' ? '#10b981' : '#ef4444'}; z-index:9999;`;
                    notification.textContent = message;
                    document.body.appendChild(notification);
                    setTimeout(() => notification.remove(), 3000);
                }

                // Populate transactions table
                function populateTransactionsTable(transactions) {
                    const tbody = document.getElementById('transactionsBody');
                    tbody.innerHTML = '';
                    if (!transactions || transactions.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;">No transactions found</td></tr>';
                        return;
                    }
                    transactions.forEach(tx => {
                        const row = document.createElement('tr');
                        row.innerHTML = `
                            <td>${tx.id.substring(0, 8)}...</td>
                            <td>${tx.date}</td>
                            <td>${tx.description}</td>
                            <td class="amount ${tx.amount < 0 ? 'negative' : ''}">₦${Math.abs(tx.amount).toLocaleString()}</td>
                            <td>
                                <select onchange="updateRowStatus('${tx.id}', this.value)">
                                    <option value="Match" ${tx.status === 'Match' ? 'selected' : ''}>Pass</option>
                                    <option value="flagged" ${tx.status === 'flagged' ? 'selected' : ''}>Flagged</option>
                                </select>
                            </td>
                            <td><input type="text" value="${tx.comments || ''}" onchange="updateRowComment('${tx.id}', this.value)"></td>
                        `;
                        tbody.appendChild(row);
                    });
                }

                function updateRowStatus(id, status) {
                    const tx = auditTransactions.find(t => t.id === id);
                    if (tx) tx.status = status;
                }

                function updateRowComment(id, comment) {
                    const tx = auditTransactions.find(t => t.id === id);
                    if (tx) tx.comments = comment;
                }

                // Populate recent audits
                function populateRecentAudits(audits) {
                    const container = document.getElementById('recentAuditsList');
                    container.innerHTML = '';
                    audits.forEach(audit => {
                        const item = document.createElement('div');
                        item.className = 'audit-item';
                        item.style.borderLeft = `5px solid ${audit.verificationStatus === 'confirmed' ? '#10b981' : audit.verificationStatus === 'reported' ? '#ef4444' : '#6b7280'}`;

                        let buttonsHtml = '';
                        if (audit.verificationStatus === 'pending') {
                            buttonsHtml = `
                                <div class="audit-actions" style="margin-top: 10px; display: flex; gap: 5px;">
                                    <button onclick="event.stopPropagation(); verifyAudit('${audit._id}', 'confirm')" class="btn btn-success" style="padding: 2px 8px; font-size: 12px; background: #10b981;">Confirm</button>
                                    <button onclick="event.stopPropagation(); verifyAudit('${audit._id}', 'report')" class="btn btn-danger" style="padding: 2px 8px; font-size: 12px; background: #ef4444;">Report</button>
                                </div>
                            `;
                        } else {
                            buttonsHtml = `<div style="margin-top: 5px; font-weight: bold; font-size: 12px; color: ${audit.verificationStatus === 'confirmed' ? '#10b981' : '#ef4444'}">${audit.verificationStatus.toUpperCase()}</div>`;
                        }

                        item.innerHTML = `
                            <h4>${audit.auditId || audit._id} - ${audit.accountName || 'Manual Audit'}</h4>
                            <small>${new Date(audit.date).toLocaleDateString()}</small>
                            ${buttonsHtml}
                        `;
                        item.onclick = () => {
                            document.getElementById('manualAuditId').value = audit.auditId || audit._id;
                            document.getElementById('accountName').value = audit.accountName;
                            createLoadAudit();
                        };
                        container.appendChild(item);
                    });
                }

                async function verifyAudit(id, action) {
                    if (!confirm(`Are you sure you want to ${action} this audit?`)) return;
                    try {
                        const response = await fetch(`/api/audit/${action}/${id}`, { method: 'POST' });
                        const result = await response.json();
                        if (result.success) {
                            showNotification(`Audit ${action}ed!`, 'success');
                            loadRecentAudits();
                        } else {
                            showNotification(result.message, 'error');
                        }
                    } catch (error) {
                        showNotification(`Error ${action}ing audit`, 'error');
                    }
                }

                function setupEventListeners() {
                    document.getElementById('searchInput').addEventListener('input', e => {
                        const term = e.target.value.toLowerCase();
                        document.querySelectorAll('#transactionsBody tr').forEach(row => {
                            row.style.display = row.textContent.toLowerCase().includes(term) ? '' : 'none';
                        });
                    });
                }

                function saveDraft() { showNotification('Draft saved locally', 'success'); }

                async function submitAudit() {
                    const auditCompleted = document.getElementById('auditCompleted').checked;
                    const overallComments = document.getElementById('overallComments').value;
                    const fileInput = document.getElementById('supportingFiles');

                    if (!currentAuditId || !auditCompleted) {
                        showNotification('Mark audit as completed first', 'error');
                        return;
                    }

                    const formData = new FormData();
                    formData.append('auditId', currentAuditId);
                    formData.append('overallComments', overallComments);
                    formData.append('auditCompleted', auditCompleted);
                    formData.append('transactions', JSON.stringify(auditTransactions));

                    if (fileInput.files.length > 0) {
                        for (let i = 0; i < fileInput.files.length; i++) {
                            formData.append('supportingFiles', fileInput.files[i]);
                        }
                    }

                    try {
                        const response = await fetch('/api/audit/manual/submit', {
                            method: 'POST',
                            body: formData
                        });
                        const result = await response.json();
                        if (result.success) {
                            showNotification('Audit submitted!', 'success');
                            loadRecentAudits();
                        } else {
                            showNotification(result.message || 'Error submitting', 'error');
                        }
                    } catch (error) {
                        showNotification('Error submitting', 'error');
                    }
                }

                function downloadPDF() {
                    if (currentAuditId) window.location.href = `/api/audit/download/pdf/${currentAuditId}`;
                    else showNotification('No audit loaded', 'error');
                }

                function downloadCSV() {
                    if (currentAuditId) window.location.href = `/api/audit/download/csv/${currentAuditId}`;
                    else showNotification('No audit loaded', 'error');
                }

                document.addEventListener('DOMContentLoaded', initializeDashboard);

            </script>
            <script>
                sessionStorage.setItem('redirect', window.location.pathname);
            </script>
    </div>



</body>

</html>