<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Audit Planning & Scheduling</title>
        <!-- Font Awesome 6 Free -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet">
<!-- FullCalendar CSS -->
<link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.css" rel="stylesheet">

<!-- FullCalendar JS -->
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js"></script>

               <link
      href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/boxicons@2.1.4/css/boxicons.min.css"
    />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">


    <link rel="stylesheet" href="/css/auditingplanning.css">
    <link rel="stylesheet" href="/css/dashall.css">
</head>
<body>




         

          <div class="all">
<%- include("../_sidebar1") %>


 <div class="main-content">
    <%- include ("../_topnav") %>



    <div class="container">
        <div class="header">
            <h1>Audit Planning & Scheduling</h1>
            <p>Manage your audit templates, schedule audits, and track compliance activities</p>
        </div>

        <div class="main-layout">
            <!-- Templates Panel -->
            <div class="panel" id="templates-panel">
                <h3>Audit Templates</h3>
                <div class="templates-list" id="templates-list">
                    <!-- Templates will be populated by JavaScript -->
                </div>
                <button class="btn btn-primary" onclick="openTemplateModal()">
                    + New Template
                </button>
            </div>

           <!-- // Calendar Panel -->
            <div id="calendar">

            </div>

            <!-- Recurring Settings Panel -->
            <div class="panel" id="recurring-panel">
                <h3>Recurring Settings</h3>
                <div class="recurring-settings">
                    <div class="form-group">
                        <label>Recurrence</label>
                        <select class="form-control" id="recurrence-frequency" onchange="updateRecurrenceOptions()">
                            <option value="none">None</option>
                            <option value="daily">Daily</option>
                            <option value="weekly">Weekly</option>
                            <option value="monthly">Monthly</option>
                            <option value="quarterly">Quarterly</option>
                            <option value="yearly">Yearly</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Start Date</label>
                        <input type="datetime-local" class="form-control" id="recurrence-start">
                    </div>

                    <div class="form-group" id="weekly-options" style="display: none;">
                        <label>Days of Week</label>
                        <div class="weekly-days">
                            <label class="day-checkbox"><input type="checkbox" value="0"> Sun</label>
                            <label class="day-checkbox"><input type="checkbox" value="1"> Mon</label>
                            <label class="day-checkbox"><input type="checkbox" value="2"> Tue</label>
                            <label class="day-checkbox"><input type="checkbox" value="3"> Wed</label>
                            <label class="day-checkbox"><input type="checkbox" value="4"> Thu</label>
                            <label class="day-checkbox"><input type="checkbox" value="5"> Fri</label>
                            <label class="day-checkbox"><input type="checkbox" value="6"> Sat</label>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>End Rule</label>
                        <select class="form-control" id="end-rule" onchange="updateEndOptions()">
                            <option value="never">Never</option>
                            <option value="after">After N occurrences</option>
                            <option value="date">By date</option>
                        </select>
                    </div>

                    <div class="form-group" id="end-after" style="display: none;">
                        <label>Number of occurrences</label>
                        <input type="number" class="form-control" id="end-count" min="1" value="10">
                    </div>

                    <div class="form-group" id="end-date" style="display: none;">
                        <label>End date</label>
                        <input type="date" class="form-control" id="end-date-input">
                    </div>

                    <button class="btn btn-secondary" onclick="previewRecurrence()">Preview Recurring Events</button>

                    <div class="preview-events" id="preview-container" style="display: none;">
                        <h4>Preview (Next 10 events)</h4>
                        <div id="preview-list"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
 

    <!-- Template Modal -->
    <div id="templateModal" class="modal">
        <div class="modal-content">
            <span class="close" onclick="closeTemplateModal()">&times;</span>
            <h2 id="template-modal-title">New Template</h2>
            <form onsubmit="saveTemplate(event)">
                <div class="form-group">
                    <label>Template Name</label>
                    <input type="text" class="form-control" id="template-name" required>
                </div>
                <div class="form-group">
                    <label>Category</label>
                    <input type="text" class="form-control" id="template-category" required>
                </div>
                <div class="form-group">
                    <label>Default Duration (hours)</label>
                    <input type="number" class="form-control" id="template-duration" min="1" value="2" required>
                </div>
                <div class="form-group">
                    <label>Color</label>
                    <div class="color-picker" id="template-colors">
                        <div class="color-option" style="background: #3788d8" data-color="#3788d8"></div>
                        <div class="color-option" style="background: #28a745" data-color="#28a745"></div>
                        <div class="color-option" style="background: #dc3545" data-color="#dc3545"></div>
                        <div class="color-option" style="background: #ffc107" data-color="#ffc107"></div>
                        <div class="color-option" style="background: #6f42c1" data-color="#6f42c1"></div>
                        <div class="color-option" style="background: #fd7e14" data-color="#fd7e14"></div>
                    </div>
                    <input type="hidden" id="template-color" value="#3788d8">
                </div>
                <div style="display: flex; gap: 10px; margin-top: 20px;">
                    <button type="submit" class="btn btn-primary">Save Template</button>
                    <button type="button" class="btn btn-secondary" onclick="closeTemplateModal()">Cancel</button>
                    <button type="button" class="btn btn-danger" id="delete-template-btn" onclick="deleteTemplate()" style="display: none;">Delete</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Audit Modal -->
    <div id="auditModal" class="modal">
        <div class="modal-content">
            <span class="close" onclick="closeAuditModal()">&times;</span>
            <h2 id="audit-modal-title">Create Audit</h2>
            <form onsubmit="saveAudit(event)">
                <div class="form-group">
                    <label>Audit Title</label>
                    <input type="text" class="form-control" id="audit-title" required>
                </div>
                <div class="form-group">
                    <label>Template</label>
                    <select class="form-control" id="audit-template" onchange="updateAuditFromTemplate()">
                        <option value="">Select Template</option>
                        <!-- Options will be populated by JavaScript -->
                    </select>
                </div>
                <div class="form-group">
                    <label>Start Date & Time</label>
                    <input type="datetime-local" class="form-control" id="audit-start" required>
                </div>
                <div class="form-group">
                    <label>Duration (hours)</label>
                    <input type="number" class="form-control" id="audit-duration" min="1" value="2" required>
                </div>
                <div class="form-group">
                    <label>Description</label>
                    <textarea class="form-control" id="audit-description" rows="3"></textarea>
                </div>
                <div class="form-group">
                    <label>Color</label>
                    <div class="color-picker" id="audit-colors">
                        <div class="color-option" style="background: #3788d8" data-color="#3788d8"></div>
                        <div class="color-option" style="background: #28a745" data-color="#28a745"></div>
                        <div class="color-option" style="background: #dc3545" data-color="#dc3545"></div>
                        <div class="color-option" style="background: #ffc107" data-color="#ffc107"></div>
                        <div class="color-option" style="background: #6f42c1" data-color="#6f42c1"></div>
                        <div class="color-option" style="background: #fd7e14" data-color="#fd7e14"></div>
                    </div>
                    <input type="hidden" id="audit-color" value="#3788d8">
                </div>
                <div style="display: flex; gap: 10px; margin-top: 20px;">
                    <button type="submit" class="btn btn-primary">Save Audit</button>
                    <button type="button" class="btn btn-secondary" onclick="closeAuditModal()">Cancel</button>
                    <button type="button" class="btn btn-danger" id="delete-audit-btn" onclick="deleteAudit()" style="display: none;">Delete</button>
                </div>
            </form>
        </div>
    </div>



 </div>


    <script>
      sessionStorage.setItem('redirect', window.location.pathname);
    </script>
    
    <script>
        // Global variables
        let calendar;
        let templates = []; 
        let audits = [];                                      
        let selectedTemplate = null;
        let editingTemplate = null;
        let editingAudit = null;

        // Initialize the application
        document.addEventListener('DOMContentLoaded', function() {
            initializeData();
            initializeCalendar();
            renderTemplates();
            setupEventListeners();
        });


        // Initialize sample data
        function initializeData() {
            templates = [
                {
                    id: 1,
                    name: 'Financial Compliance Audit',
                    category: 'Financial',
                    color: '#3788d8',
                    duration: 4,
                    icon: '<i class="fa-solid fa-sack-dollar"></i>'
                },
                {
                    id: 2,
                    name: 'IT Security Audit',
                    category: 'Technology',
                    color: '#dc3545',
                    duration: 6,
                    icon: '<i class="fa-solid fa-lock"></i>'
                },
                {
                    id: 3,
                    name: 'Operational Risk Audit',
                    category: 'Operations',
                    color: '#28a745',
                    duration: 3,
                    icon: '<i class="fa-solid fa-gear"></i>'
                }
            ];

            audits = [
                {
                    id: 1,
                    title: 'Q1 Financial Review',
                    start: new Date(2025, 7, 20, 9, 0),
                    duration: 4,
                    color: '#3788d8',
                    description: 'Quarterly financial compliance audit',
                    templateId: 1
                },
                {
                    id: 2,
                    title: 'Security Assessment',
                    start: new Date(2025, 7, 22, 14, 0),
                    duration: 6,
                    color: '#dc3545',
                    description: 'Annual IT security audit',
                    templateId: 2
                },
                {
                    id: 3,
                    title: 'Process Review',
                    start: new Date(2025, 7, 25, 10, 0),
                    duration: 3,
                    color: '#28a745',
                    description: 'Operational process audit',
                    templateId: 3
                },
                {
                    id: 4,
                    title: 'Vendor Audit',
                    start: new Date(2025, 7, 28, 13, 0),
                    duration: 2,
                    color: '#ffc107',
                    description: 'Third-party vendor assessment'
                },
                {
                    id: 5,
                    title: 'Data Privacy Audit',
                    start: new Date(2025, 8, 2, 11, 0),
                    duration: 5,
                    color: '#6f42c1',
                    description: 'GDPR compliance audit'
                }
            ];
        }

          // Run initializeCalendar only after DOM is ready
  document.addEventListener("DOMContentLoaded", function () {
    initializeCalendar();
  });

        // Initialize FullCalendar
        function initializeCalendar() {
            const calendarEl = document.getElementById('calendar');
            calendar = new FullCalendar.Calendar(calendarEl, {
                initialView: 'dayGridMonth',
                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'dayGridMonth,timeGridWeek,timeGridDay'
                },
                editable: true,
                selectable: true,
                selectMirror: true,
                dayMaxEvents: true,
                weekends: true,
                events: getCalendarEvents(),
                select: function(arg) {
                    openAuditModal();
                    document.getElementById('audit-start').value = formatDateTimeLocal(arg.start);
                },
                eventClick: function(arg) {
                    const audit = audits.find(a => a.id == arg.event.id);
                    if (audit) {
                        editingAudit = audit;
                        openAuditModal(audit);
                    }
                },
                eventDrop: function(arg) {
                    const audit = audits.find(a => a.id == arg.event.id);
                    if (audit) {
                        audit.start = arg.event.start;
                    }
                }
            });
    
            calendar.render();
        }


        // Convert audits to calendar events format
        function getCalendarEvents() {
            return audits.map(audit => ({
                id: audit.id,
                title: audit.title,
                start: audit.start,
                end: new Date(audit.start.getTime() + audit.duration * 60 * 60 * 1000),
                backgroundColor: audit.color,
                borderColor: audit.color,
                extendedProps: {
                    description: audit.description
                }
            }));
        }

        // Render templates list
        function renderTemplates() {
            const templatesList = document.getElementById('templates-list');
            templatesList.innerHTML = '';

            templates.forEach(template => {
                const templateEl = document.createElement('div');
                templateEl.className = 'template-item';
                if (selectedTemplate && selectedTemplate.id === template.id) {
                    templateEl.classList.add('selected');
                }
                
                templateEl.innerHTML = `
                    <div class="template-icon" style="background-color: ${template.color}">
                        ${template.icon}
                    </div>
                    <div class="template-info">
                        <h4>${template.name}</h4>
                        <p>${template.category} • ${template.duration}h</p>
                    </div>
                `;

                templateEl.addEventListener('click', () => selectTemplate(template));
                templatesList.appendChild(templateEl);
            });

            updateAuditTemplateOptions();
        }

        // Select template
        function selectTemplate(template) {
            selectedTemplate = template;
            renderTemplates();
        }

        // Setup event listeners
        function setupEventListeners() {
            // Color picker events
            document.querySelectorAll('#template-colors .color-option').forEach(option => {
                option.addEventListener('click', function() {
                    document.querySelectorAll('#template-colors .color-option').forEach(o => o.classList.remove('selected'));
                    this.classList.add('selected');
                    document.getElementById('template-color').value = this.dataset.color;
                });
            });

            document.querySelectorAll('#audit-colors .color-option').forEach(option => {
                option.addEventListener('click', function() {
                    document.querySelectorAll('#audit-colors .color-option').forEach(o => o.classList.remove('selected'));
                    this.classList.add('selected');
                    document.getElementById('audit-color').value = this.dataset.color;
                });
            });

            // Modal close events
            window.addEventListener('click', function(event) {
                const templateModal = document.getElementById('templateModal');
                const auditModal = document.getElementById('auditModal');
                if (event.target === templateModal) {
                    closeTemplateModal();
                }
                if (event.target === auditModal) {
                    closeAuditModal();
                }
            });
        }

        // Template modal functions
        function openTemplateModal(template = null) {
            editingTemplate = template;
            const modal = document.getElementById('templateModal');
            const title = document.getElementById('template-modal-title');
            const deleteBtn = document.getElementById('delete-template-btn');
            
            if (template) {
                title.textContent = 'Edit Template';
                document.getElementById('template-name').value = template.name;
                document.getElementById('template-category').value = template.category;
                document.getElementById('template-duration').value = template.duration;
                document.getElementById('template-color').value = template.color;
                
                // Select color
                document.querySelectorAll('#template-colors .color-option').forEach(option => {
                    option.classList.toggle('selected', option.dataset.color === template.color);
                });
                
                deleteBtn.style.display = 'inline-block';
            } else {
                title.textContent = 'New Template';
                document.getElementById('template-name').value = '';
                document.getElementById('template-category').value = '';
                document.getElementById('template-duration').value = 2;
                document.getElementById('template-color').value = '#3788d8';
                
                // Select first color by default
                document.querySelectorAll('#template-colors .color-option').forEach((option, index) => {
                    option.classList.toggle('selected', index === 0);
                });
                
                deleteBtn.style.display = 'none';
            }
            
            modal.style.display = 'block';
        }

        function closeTemplateModal() {
            document.getElementById('templateModal').style.display = 'none';
            editingTemplate = null;
        }

           function saveTemplate() {
        const id = document.getElementById('templateId').value;
        const name = document.getElementById('templateName').value;
        const checklist = document.getElementById('templateChecklist').value.split('\n').filter(item => item.trim() !== '');
        const duration = parseInt(document.getElementById('templateDuration').value, 10);
        const color = document.getElementById('templateColor').value;

        if (!name || checklist.length === 0 || !duration) {
            alert('Please fill in all template fields.');
            return;
        }

        if (id) {
            // Edit existing template
            const index = templates.findIndex(t => t.id == id);
            if (index !== -1) {
                templates[index] = { id: parseInt(id), name, checklist, duration, color };
            }
        } else {
            // Add new template
            templates.push({
                id: Date.now(),
                name,
                checklist,
                duration,
                color
            });
        }

        closeModal('templateModal');
        renderTemplates();
    }

    function deleteTemplate(id) {
        if (confirm('Are you sure you want to delete this template?')) {
            templates = templates.filter(t => t.id !== id);
            renderTemplates();
        }
    }

    function saveAudit() {
        const id = document.getElementById('auditId').value;
        const title = document.getElementById('auditTitle').value;
        const templateId = document.getElementById('auditTemplate').value;
        const date = document.getElementById('auditDate').value;
        const recurrence = document.getElementById('auditRecurrence').value;

        if (!title || !templateId || !date) {
            alert('Please fill in all audit fields.');
            return;
        }

        const template = templates.find(t => t.id == templateId);
        const endDate = new Date(date);
        endDate.setDate(endDate.getDate() + (template.duration || 1));

        const auditData = {
            id: id ? parseInt(id) : Date.now(),
            title,
            templateId: parseInt(templateId),
            start: date,
            end: endDate.toISOString().split('T')[0],
            recurrence
        };

        if (id) {
            // Edit
            const index = audits.findIndex(a => a.id == id);
            if (index !== -1) {
                audits[index] = auditData;
            }
        } else {
            // Add
            audits.push(auditData);
        }

        closeModal('auditModal');
        renderAudits();
    }

    function deleteAudit(id) {
        if (confirm('Are you sure you want to delete this audit?')) {
            audits = audits.filter(a => a.id !== id);
            renderAudits();
        }
    }

    function updateAuditFromTemplate() {
        const templateId = document.getElementById('auditTemplate').value;
        const template = templates.find(t => t.id == templateId);
        if (template) {
            console.log('Template selected:', template);
        }
    }

    function previewRecurrence() {
        const recurrence = document.getElementById('auditRecurrence').value;
        const startDate = document.getElementById('auditDate').value;
        if (!startDate || recurrence === 'none') {
            document.getElementById('recurrencePreview').innerText = '';
            return;
        }

        let dates = [];
        let current = new Date(startDate);
        for (let i = 0; i < 5; i++) {
            dates.push(current.toISOString().split('T')[0]);
            if (recurrence === 'daily') current.setDate(current.getDate() + 1);
            if (recurrence === 'weekly') current.setDate(current.getDate() + 7);
            if (recurrence === 'monthly') current.setMonth(current.getMonth() + 1);
            if (recurrence === 'quarterly') current.setMonth(current.getMonth() + 3);
            if (recurrence === 'yearly') current.setFullYear(current.getFullYear() + 1);
        }
        document.getElementById('recurrencePreview').innerText = 'Upcoming dates: ' + dates.join(', ');
    }

    document.addEventListener('DOMContentLoaded', renderTemplates);

        // Audit modal functions
        function openAuditModal(audit = null) {
            editingAudit = audit;
            const modal = document.getElementById('auditModal');
            const title = document.getElementById('audit-modal-title');
            const deleteBtn = document.getElementById('delete-audit-btn');
            
            if (audit) {
                title.textContent = 'Edit Audit';
                document.getElementById('audit-title').value = audit.title;
                document.getElementById('audit-template').value = audit.templateId || '';
                document.getElementById('audit-start').value = formatDateTimeLocal(audit.start);
                document.getElementById('audit-duration').value = audit.duration;
                document.getElementById('audit-description').value = audit.description || '';
                document.getElementById('audit-color').value = audit.color;
                
                // Select color
                document.querySelectorAll('#audit-colors .color-option').forEach(option => {
                    option.classList.toggle('selected', option.dataset.color === audit.color);
                });
                
                deleteBtn.style.display = 'inline-block';
            } else {
                title.textContent = 'Create Audit';
                document.getElementById('audit-title').value = '';
                document.getElementById('audit-template').value = '';
                
                // Pre-fill with selected template if available
                if (selectedTemplate) {
                    document.getElementById('audit-title').value = selectedTemplate.name;
                    document.getElementById('audit-template').value = selectedTemplate.id;
                    document.getElementById('audit-duration').value = selectedTemplate.duration;
                    document.getElementById('audit-color').value = selectedTemplate.color;
                    
                    // Select template color
                    document.querySelectorAll('#audit-colors .color-option').forEach(option => {
                        option.classList.toggle('selected', option.dataset.color === selectedTemplate.color);
                    });
                } else {
                    document.getElementById('audit-duration').value = 2;
                    document.getElementById('audit-color').value = '#3788d8';
                    
                    // Select first color by default
                    document.querySelectorAll('#audit-colors .color-option').forEach((option, index) => {
                        option.classList.toggle('selected', index === 0);
                    });
                }
                
                document.getElementById('audit-description').value = '';
                deleteBtn.style.display = 'none';
            }
            
            modal.style.display = 'block';
        }

        function closeAuditModal() {
            document.getElementById('auditModal').style.display = 'none';
            editingAudit = null;
        }

        function saveAudit(event) {
            event.preventDefault();
            
            const title = document.getElementById('audit-title').value;
            const templateId = document.getElementById('audit-template').value || null;
            const start = new Date(document.getElementById('audit-start').value);
            const duration = parseInt(document.getElementById('audit-duration').value);
            const description = document.getElementById('audit-description').value;
            const color = document.getElementById('audit-color').value;
            
            if (editingAudit) {
                editingAudit.title = title;
                editingAudit.templateId = templateId;
                editingAudit.start = start;
                editingAudit.duration = duration;
                editingAudit.description = description;
                editingAudit.color = color;
            } else {
                const newAudit = {
                    id: Math.max(...audits.map(a => a.id), 0) + 1,
                    title,
                    templateId,
                    start,
                    duration,
                    description,
                    color
                };
                audits.push(newAudit);
            }
            
            calendar.removeAllEvents();
            calendar.addEventSource(getCalendarEvents());
            closeAuditModal();
        }

        function deleteAudit() {
            if (editingAudit && confirm('Are you sure you want to delete this audit?')) {
                audits = audits.filter(a => a.id !== editingAudit.id);
                calendar.removeAllEvents();
                calendar.addEventSource(getCalendarEvents());
                closeAuditModal();
            }
        }

        function updateAuditFromTemplate() {
            const templateId = document.getElementById('audit-template').value;
            if (templateId) {
                const template = templates.find(t => t.id == templateId);
                if (template) {
                    if (!document.getElementById('audit-title').value || document.getElementById('audit-title').value === selectedTemplate?.name) {
                        document.getElementById('audit-title').value = template.name;
                    }
                    document.getElementById('audit-duration').value = template.duration;
                    document.getElementById('audit-color').value = template.color;
                    
                    // Select template color
                    document.querySelectorAll('#audit-colors .color-option').forEach(option => {
                        option.classList.toggle('selected', option.dataset.color === template.color);
                    });
                }
            }
        }

        function updateAuditTemplateOptions() {
            const select = document.getElementById('audit-template');
            select.innerHTML = '<option value="">Select Template</option>';
            
            templates.forEach(template => {
                const option = document.createElement('option');
                option.value = template.id;
                option.textContent = template.name;
                select.appendChild(option);
            });
        }

        // Recurrence functions
        function updateRecurrenceOptions() {
            const frequency = document.getElementById('recurrence-frequency').value;
            const weeklyOptions = document.getElementById('weekly-options');
            
            if (frequency === 'weekly') {
                weeklyOptions.style.display = 'block';
            } else {
                weeklyOptions.style.display = 'none';
            }
        }

        function updateEndOptions() {
            const endRule = document.getElementById('end-rule').value;
            const endAfter = document.getElementById('end-after');
            const endDate = document.getElementById('end-date');
            
            endAfter.style.display = endRule === 'after' ? 'block' : 'none';
            endDate.style.display = endRule === 'date' ? 'block' : 'none';
        }

        function previewRecurrence() {
            const frequency = document.getElementById('recurrence-frequency').value;
            const startInput = document.getElementById('recurrence-start').value;
            const endRule = document.getElementById('end-rule').value;
            const endCount = parseInt(document.getElementById('end-count').value) || 10;
            const endDateInput = document.getElementById('end-date-input').value;
            
            if (frequency === 'none' || !startInput) {
                document.getElementById('preview-container').style.display = 'none';
                return;
            }
            
            const startDate = new Date(startInput);
            const endDate = endDateInput ? new Date(endDateInput) : null;
            const previewEvents = generateRecurrencePreview(frequency, startDate, endRule, endCount, endDate);
            
            const previewList = document.getElementById('preview-list');
            previewList.innerHTML = '';
            
            previewEvents.slice(0, 10).forEach(date => {
                const eventDiv = document.createElement('div');
                eventDiv.className = 'preview-event';
                eventDiv.textContent = formatDateTime(date);
                previewList.appendChild(eventDiv);
            });
            
            document.getElementById('preview-container').style.display = 'block';
        }

        function generateRecurrencePreview(frequency, startDate, endRule, endCount, endDate) {
            const events = [new Date(startDate)];
            let currentDate = new Date(startDate);
            let count = 1;
            
            while (count < (endRule === 'after' ? endCount : 50)) {
                let nextDate = new Date(currentDate);
                
                switch (frequency) {
                    case 'daily':
                        nextDate.setDate(nextDate.getDate() + 1);
                        break;
                    case 'weekly':
                        const selectedDays = Array.from(document.querySelectorAll('#weekly-options input:checked'))
                            .map(input => parseInt(input.value));
                        
                        if (selectedDays.length === 0) {
                            nextDate.setDate(nextDate.getDate() + 7);
                        } else {
                            // Find next selected day
                            let found = false;
                            for (let i = 1; i <= 7; i++) {
                                const testDate = new Date(currentDate);
                                testDate.setDate(testDate.getDate() + i);
                                if (selectedDays.includes(testDate.getDay())) {
                                    nextDate = testDate;
                                    found = true;
                                    break;
                                }
                            }
                            if (!found) {
                                nextDate.setDate(nextDate.getDate() + 7);
                            }
                        }
                        break;
                    case 'monthly':
                        nextDate.setMonth(nextDate.getMonth() + 1);
                        break;
                    case 'quarterly':
                        nextDate.setMonth(nextDate.getMonth() + 3);
                        break;
                    case 'yearly':
                        nextDate.setFullYear(nextDate.getFullYear() + 1);
                        break;
                }
                
                if (endRule === 'date' && endDate && nextDate > endDate) {
                    break;
                }
                
                events.push(new Date(nextDate));
                currentDate = nextDate;
                count++;
            }
            
            return events;
        }

        // Utility functions
        function getIconForCategory(category) {
            const icons = {
                'Financial': '<i class="fa-solid fa-sack-dollar"></i>',
                'Technology': '<i class="fa-solid fa-lock"></i>',
                'Operations': '<i class="fa-solid fa-gear"></i>',
                'Risk': '<i class="fa-solid fa-triangle-exclamation"></i>',
                'Compliance': '<i class="fa-solid fa-file-contract"></i>',
                'Quality': '<i class="fa-solid fa-badge-check"></i> <!-- Pro version -->'
            };
            return icons[category] || '📄';
        }

        function formatDateTimeLocal(date) {
            const d = new Date(date);
            d.setMinutes(d.getMinutes() - d.getTimezoneOffset());
            return d.toISOString().slice(0, 16);
        }

        function formatDateTime(date) {
            return date.toLocaleDateString() + ' ' + date.toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
        }

        // Initialize recurrence date to today
        document.addEventListener('DOMContentLoaded', function() {
            const today = new Date();
            document.getElementById('recurrence-start').value = formatDateTimeLocal(today);
        });
    </script>

</div>



    
