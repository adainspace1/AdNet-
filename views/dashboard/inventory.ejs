<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link
      href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/boxicons@2.1.4/css/boxicons.min.css"
    />
    <link rel="stylesheet" href="/css/inventory.css">
    <title>Inventory</title>
    
</head>
<body>
    <div class="layout">
             <!-- Sidebar -->
      <%- include ("_sidebar1") %>
        
        <!-- Main Content -->
                <div class="main-content">
                      <%- include ("_topnav") %>
                            <div class="top-bar">
                                <h1 class="page-title">Physical Goods Inventory <%= user.firstName %> <%= worker && worker.name %></h1>
                                <div class="action-buttons">
                                    <button class="btn btn-outline" id="importBtn">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                                            <polyline points="17 8 12 3 7 8"></polyline>
                                            <line x1="12" y1="3" x2="12" y2="15"></line>
                                        </svg>
                                        Import
                                    </button>
                                    <button class="btn btn-outline" id="exportBtn">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                                            <polyline points="7 10 12 15 17 10"></polyline>
                                            <line x1="12" y1="15" x2="12" y2="3"></line>
                                        </svg>
                                        Export
                                    </button>
                                    <button class="btn btn-primary" id="addAssetBtn">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <line x1="12" y1="5" x2="12" y2="19"></line>
                                            <line x1="5" y1="12" x2="19" y2="12"></line>
                                        </svg>
                                        Add Asset
                                    </button>
                                </div>
                            </div>
                            
                            <!-- Summary Cards -->
                            <div class="summary-cards">
                                <div class="card">
                                    <div class="card-title">Total Inventory Value</div>
                                  <div class="card-value">₦<%= totalInventoryValue.toLocaleString() %></div>
                                    <div class="card-trend">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <polyline points="18 15 12 9 6 15"></polyline>
                                        </svg>
                                        5.8% from last month
                                    </div>
                                </div>
                            
                            <div class="card">
                                <div class="card-title">Total Items Count</div>
                                <div class="card-value"><%= totalItemsCount %></div>
                                <div class="card-trend">
                                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="18 15 12 9 6 15"></polyline>
                                  </svg>
                                  124 new items
                                </div>
                              </div>

                              <div class="card">
                                <div class="card-title">Top Selling Category</div>
                                <div class="card-value"><%= topSellingItem %></div>
                                <div class="card-trend">
                                  +12.3% this quarter
                                </div>
                              </div>

                          
                            </div>
                            
                            <!-- Filters -->
                            <div class="filters">
                                <div class="search-box">
                                    <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <circle cx="11" cy="11" r="8"></circle>
                                        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                                    </svg>
                                    <input type="text" class="search-input" placeholder="Search assets...">
                                </div>
                                
                              <%
                  const itemNamesSet = new Set();
                  inventory.forEach(inv => itemNamesSet.add(inv.itemName));
                %>
                <select class="filter-select" id="nameFilter">
                  <option value="">All Products</option>
                  <% itemNamesSet.forEach(name => { %>
                    <option value="<%= name %>"><%= name %></option>
                  <% }) %>
                </select>

                                
                      
                                
                            <select class="filter-select" id="statusFilter">
                  <option value="">All Status</option>
                  <option value="In Stock">In Stock</option>
                  <option value="Low Stock">Low Stock</option>
                  <option value="Out of Stock">Out of Stock</option>
                </select>
                            </div>
                            
                            <!-- Data Table -->
                            <div class="data-table">
                                <table>
                                    <thead>
                                        <tr>
                                            <th>Product</th>
                                            <th>Category</th>
                                            <th>Quantity</th>
                                            <th>Current Quantity</th>
                                            <th>Unit Price</th>
                                            <th>Selling Price</th>
                                            <th>Status</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>

                                        <% inventory.forEach((item, index) => { %>
                            <tr>
                                            <td>
                                                
                                                    <%= item.itemName %>
                                              
                                            </td>
                                            <td><%= item.category %></td>
                                            <td><%= item.quantity %></td>
                                            <td><%= item.currentquantity %></td>
                                            <td>$<%= item.bcost %></td>
                                            <td>$<%= item.scost %></td>

                                            <td>
                                                <% if (item.currentquantity > 10) { %>
                                                    <span class="status-pill status-active">In Stock</span>
                                                <% } else if (item.currentquantity <= 10 && item.quantity > 0) { %>
                                                    <span class="status-pill status-maintenance">Low Stock</span>
                                                <% } else { %>
                                                    <span class="status-pill status-depreciated">Out of Stock</span>
                                                <% } %>
                                            <td class="action-cell">
                                                <button class="action-btn">
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                                                    </svg>
                                                </button>
                                                <button class="action-btn">
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                        <circle cx="12" cy="12" r="1"></circle>
                                                        <circle cx="19" cy="12" r="1"></circle>
                                                        <circle cx="5" cy="12" r="1"></circle>
                                                    </svg>
                                                </button>
                                            </td>
                            </tr>
                                            <% }) %>
                                        </tbody>
                                </table>
                            </div>


                </div>
                                        <!-- Popup Form -->
                <div class="popup-overlay" id="popup-overlay"></div>
                <div class="popup" id="popup">
                  <form id="inventory-form" method="POST" action="/user/createinventory">
                    <h2>Add Inventory Item</h2>

                            <input type="hidden" name="recipientId" value="<%= user._id %>" required>

                            <input type="hidden" name="username" value="<%= user.firstName %> <%= user.lastName %>" required>
                    <label>Item Name:
                      <input type="text" name="itemName" required>
                    </label>
                    <label>Item Type:
                      <input type="text" name="category" required>
                    </label>
                    <label>Bought Cost:
                      <input type="text" name="bcost" required>
                    </label>
                    <label>Selling Cost:
                      <input type="text" name="scost" required>
                    </label>
                    <label>Quantity:
                      <input type="text" name="quantity" id="quantity" required>
              <input type="hidden" name="currentquantity" id="currentquantity" required>
                    </label>
                    <label>Supplier Name:
                      <input type="text" name="supplier" required>
                    </label>
                    <button type="submit">Post</button>
                    <button type="button" class="close-btn">Close</button>
                  </form>
                </div>


    </div>


  <script>
document.addEventListener("DOMContentLoaded", function () {
  const searchInput = document.getElementById("searchInput");
  const nameFilter = document.getElementById("nameFilter");
  const statusFilter = document.getElementById("statusFilter");
  const tableRows = document.querySelectorAll(".data-table tbody tr");

  function filterTable() {
    const searchValue = searchInput.value.toLowerCase();
    const nameValue = nameFilter.value;
    const statusValue = statusFilter.value;

    tableRows.forEach(row => {
      const productName = row.cells[0].textContent.trim().toLowerCase();
      const statusText = row.cells[6].textContent.trim(); // 7th column = status

      let matchesSearch = productName.includes(searchValue);
      let matchesName = !nameValue || productName === nameValue.toLowerCase();
      let matchesStatus = !statusValue || statusText === statusValue;

      if (matchesSearch && matchesName && matchesStatus) {
        row.style.display = "";
      } else {
        row.style.display = "none";
      }
    });
  }

  searchInput.addEventListener("input", filterTable);
  nameFilter.addEventListener("change", filterTable);
  statusFilter.addEventListener("change", filterTable);
});
</script>

  


   <script>

      const quantityInput = document.getElementById('quantity');
  const currentQuantityInput = document.getElementById('currentquantity');

  quantityInput.addEventListener('input', () => {
    currentQuantityInput.value = quantityInput.value;
  });

    function showDetails(index) {
      const sections = document.querySelectorAll('.details-section');
      sections.forEach(section => section.classList.remove('visible'));

      const target = document.getElementById('details-' + index);
      if (target) {
        target.classList.add('visible');
      }

      const items = document.querySelectorAll('.inventory-list-item');
      items.forEach(item => item.classList.remove('selected'));
      if (items[index]) {
        items[index].classList.add('selected');
      }
    }

    window.onload = () => {
      showDetails(0);
    };

    document.addEventListener('DOMContentLoaded', () => {
      const addButton = document.getElementById('addAssetBtn');
      const popup = document.getElementById('popup');
      const overlay = document.getElementById('popup-overlay');
      const closeBtn = document.querySelector('.close-btn');
      const form = document.getElementById('inventory-form');

      addButton.addEventListener('click', () => {
        popup.classList.add('visible');
        overlay.classList.add('visible');
      });

      const closePopup = () => {
        popup.classList.remove('visible');
        overlay.classList.remove('visible');
        form.reset();
      };

      closeBtn.addEventListener('click', closePopup);
      overlay.addEventListener('click', closePopup);
    });
  </script>


<script src="/js/inventory.js"></script>
</body>
</html>