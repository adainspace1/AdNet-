<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0"> 
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/boxicons@2.1.4/css/boxicons.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" integrity="sha512-Evv84Mr4kqVGRNSgIGL/F/aIDqQb7xQ2vcrdIwxfjThSH8CSR7PBEakCr51Ck+w+/U6swU2Im1vVX0SVk9ABhg==" crossorigin="anonymous" referrerpolicy="no-referrer" />
  <title>Budget Manager</title>
  <link rel="stylesheet" href="/css/budget.css">
  <link rel="stylesheet" href="/css/dashall.css">
</head>
<body>




  <div class="all">
            <!-- Sidebar -->
    <%- include ("_sidebar1") %>
    
    <!-- Main Content -->
<div class="main-content">
    <%- include ("_topnav") %>



    <div class="container">
  <h1>💰 Budget Manager</h1>

  <!-- Dashboard UI Sections -->
  <section class="dashboard">

  <!-- 🔁 RECURRING Budgets -->
  <div class="dashboard-section">
    <h2>🔁 Recurring Budgets</h2>
    
      <!-- ➕ CREATE Button -->
  <button class="create-btn" id="createBudgetBtn">➕ Create New Budget</button>

    <% const recurringBudgets = budgets.filter(b => b.recurrence !== 'none'); %>
    <% if (recurringBudgets.length === 0) { %>
      <p style="color: gray;">No recurring budgets to display.</p>
    <% } else { %>
      <div class="budget-list">
        <% recurringBudgets.forEach(b => { %>
          <div class="budget-card">
            <h3>Category: <%= b.title %></h3>
            <p>Initial Amount: ₦<%= b.amount.toLocaleString() %></p>
            <p>Current Amount: ₦<%= b.currentamount.toLocaleString() %></p>
            <p>Re-occurs Every: <%= b.recurrence %></p>
            <p>Since: <%= new Date(b.startDate).toDateString() %></p>
            <% if (b.endDate) { %>
              <p>Ends: <%= new Date(b.endDate).toDateString() %></p>
            <% } else { %>
              <p>Ends: Ongoing</p>
            <% } %>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

  <!-- 📅 CURRENT Budgets (with spending) -->
  <div class="dashboard-section">
    <h2>📅 Current Budgets (Used)</h2>
    <% const currentBudgets = budgets.filter(b => (!b.recurrence || b.recurrence === 'none') && b.amount !== b.currentamount); %>
    <% if (currentBudgets.length === 0) { %>
      <p style="color: gray;">No used current budgets to display.</p>
    <% } else { %>
      <div class="budget-list">
        <% currentBudgets.forEach(b => { %>
          <div class="budget-card">
            <h3>Category: <%= b.title %></h3>
            <p>Initial Amount: ₦<%= b.amount.toLocaleString() %></p>
            <p>Current Amount: ₦<%= b.currentamount.toLocaleString() %></p>
            <p>From: <%= new Date(b.startDate).toDateString() %></p>
            <p>To: <%= b.endDate ? new Date(b.endDate).toDateString() : 'N/A' %></p>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

  <!-- 📊 Budget Usage Summary -->
  <div class="dashboard-section">
    <h2>📊 Budget Usage Summary</h2>
    <% if (budgets.length === 0) { %>
      <p style="color: gray;">No budget data available yet.</p>
    <% } else { %>
      <div id="budgetSummary">
        <canvas id="usageChart"></canvas>
      </div>
    <% } %>
  </div>

  <!-- 📂 ARCHIVED Budgets -->
  <div class="dashboard-section">
    <h2>📂 Archived / Expired Budgets</h2>
    <% const archivedBudgets = budgets.filter(b => b.endDate && new Date(b.endDate) < new Date()); %>
    <% if (archivedBudgets.length === 0) { %>
      <p style="color: gray;">No archived budgets to display.</p>
    <% } else { %>
      <div class="budget-list">
        <% archivedBudgets.forEach(b => { %>
          <div class="budget-card expired">
            <h3><%= b.title %></h3>
            <p>Initial Amount: ₦<%= b.amount.toLocaleString() %></p>
            <p>Ended on: <%= new Date(b.endDate).toDateString() %></p>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

</section>




     <!-- Modal for Budget Creation -->
    <div id="budgetModal" class="modal">
      <div class="modal-content">
        <span class="close-btn">&times;</span>
        <h2>Create New Budget</h2>
        <form id="budgetForm" action="/user/Budgets/create" method="POST">
          <input type="hidden" name="recipientId" value="<%= user._id %>">
          <input type="text" name="title" placeholder="Budget Title" required>
          <input type="number" id="damount" name="amount" placeholder="Total Amount" required>
          <div id="categoryList">
            <div class="category-row">
              <input type="text" name="categoryName" placeholder="Category Name" required>
              <button type="button" class="remove-category">✖</button>
            </div>
          </div>
          <input type="hidden"  name="currentamount" placeholder="Current Amount" required>
          <button type="button" id="addCategory">+ Add Category</button>
          <input type="date" name="startDate" required>
          <input type="date" name="endDate">
          <select name="recurrence" required>
            <option value="none">None</option>
            <option value="weekly">Weekly</option>
            <option value="monthly">Monthly</option>
            <option value="yearly">Yearly</option>
          </select>
          <textarea name="notes" placeholder="Notes (Optional)"></textarea>
          <button type="submit">Save Budget</button>
          <button id="closeBudgetModal">Close</button>
        </form>
      </div>
    </div>
</div>
</div>
  </div>






  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script src="/js/budget.js"></script>



<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const ctx = document.getElementById("usageChart").getContext("2d");
    const labels = <%- chartLabels %>;
    const data = <%- chartData %>;

    new Chart(ctx, {
      type: 'bar',
      data: {
        labels: labels,
        datasets: [{
          label: 'Amount Spent per Category',
          data: data,
          backgroundColor: 'rgba(54, 162, 235, 0.6)',
          borderColor: 'rgba(54, 162, 235, 1)',
          borderWidth: 1
        }]
      },
      options: {
        responsive: true,
        scales: {
          y: {
            beginAtZero: true
          }
        }
      }
    });
  });
</script>


<script>
  document.addEventListener("DOMContentLoaded", () => {
    const modal = document.getElementById("budgetModal");
    const openBtn = document.getElementById("createBudgetBtn") || document.getElementById("openBudgetModal");
    const closeBtn = document.querySelector(".close-btn");
    const closeFormBtn = document.getElementById("closeBudgetModal");
    const addCategoryBtn = document.getElementById("addCategory");
    const categoryList = document.getElementById("categoryList");

    // 🔘 Open Modal
    if (openBtn) {
      openBtn.addEventListener("click", () => {
        modal.style.display = "flex";
      });
    }

    // ❌ Close Modal
    closeBtn.addEventListener("click", () => {
      modal.style.display = "none";
    });

    closeFormBtn.addEventListener("click", (e) => {
      e.preventDefault();
      modal.style.display = "none";
    });

    // ✖ Click outside modal to close
    window.addEventListener("click", (e) => {
      if (e.target === modal) {
        modal.style.display = "none";
      }
    });

    // ➕ Add new category row
    addCategoryBtn.addEventListener("click", () => {
      const row = document.createElement("div");
      row.classList.add("category-row");
      row.innerHTML = `
        <input type="text" name="categoryName[]" placeholder="Category Name" required>
        <button type="button" class="remove-category">✖</button>
      `;
      categoryList.appendChild(row);
    });

    // ❌ Remove category row
    categoryList.addEventListener("click", (e) => {
      if (e.target.classList.contains("remove-category")) {
        e.preventDefault();
        e.target.parentElement.remove();
      }
    });

    // Optional: handle form submission here (disable default if needed)
    // document.getElementById("budgetForm").addEventListener("submit", (e) => {
    //   e.preventDefault(); // remove this if submitting to server
    //   // handle form data here if using AJAX
    // });
  });
</script>



<script>
  document.addEventListener("DOMContentLoaded", () => {
    const amountInput = document.getElementById("damount");
    const currentAmountInput = document.querySelector('input[name="currentamount"]');
    const budgetForm = document.getElementById("budgetForm");

    // 🔁 Update current amount when total amount changes
    function updateCurrentAmount() {
      const val = parseFloat(amountInput.value);
      if (!isNaN(val)) {
        currentAmountInput.value = val;
      } else {
        currentAmountInput.value = '';
      }
    }

    // Auto-update on input
    amountInput.addEventListener("input", updateCurrentAmount);

    // Ensure it's correct on form submit
    budgetForm.addEventListener("submit", updateCurrentAmount);
  });
</script>



</body>
</html>