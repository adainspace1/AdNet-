<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Automation Settings - Debt Collection</title>
    <link
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/dashall.css">
    <link rel="stylesheet" href="/css/automationsettings.css">
  </head>
  <body>
    <!-- Header -->

    <div class="all">
      <!-- Sidebar -->
      <%- include ("_sidebar1") %>
    <!-- Main Content -->
    <main class="main-content">

       <%- include ("_topnav") %>

           <header class="header">
      <div class="container">
        <div class="header-content">
          <h1 class="header-title">Automation Settings</h1>
          <div class="header-actions">
            <button
              class="theme-toggle"
              onclick="toggleTheme()"
              title="Toggle Theme"
            >
              <i class="fas fa-moon"></i>
            </button>
            <button class="btn btn-primary" onclick="openModal()">
              <i class="fas fa-plus"></i>
              Create New Automation
            </button>
          </div>
        </div>
      </div>
    </header>

      <div class="container">


        <!-- Stats Grid -->
        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-icon" style="background: #dbeafe; color: #1d4ed8">
              <i class="fas fa-robot"></i>
            </div>
            <div class="stat-value">12</div>
            <div class="stat-label">Active Automations</div>
          </div>
          <div class="stat-card">
            <div class="stat-icon" style="background: #dcfce7; color: #16a34a">
              <i class="fas fa-check-circle"></i>
            </div>
            <div class="stat-value">245</div>
            <div class="stat-label">Executions This Month</div>
          </div>
          <div class="stat-card">
            <div class="stat-icon" style="background: #fef3c7; color: #d97706">
              <i class="fas fa-clock"></i>
            </div>
            <div class="stat-value">2.3h</div>
            <div class="stat-label">Time Saved</div>
          </div>
          <div class="stat-card">
            <div class="stat-icon" style="background: #fecaca; color: #dc2626">
              <i class="fas fa-exclamation-triangle"></i>
            </div>
            <div class="stat-value">3</div>
            <div class="stat-label">Failed Executions</div>
          </div>
        </div>

        <!-- Automation Grid -->
        <div class="automation-grid">
          <div class="automation-card">
            <div class="automation-header">
              <div>
                <h3 class="automation-title">Overdue Payment Reminder</h3>
                <span class="automation-trigger"
                  >When payment is overdue by 7 days</span
                >
                <p class="automation-action">
                  Send email reminder to debtor and assign to collection agent
                </p>
              </div>
              <label class="toggle-switch">
                <input
                  type="checkbox"
                  checked
                  onchange="toggleAutomation(this)"
                />
                <span class="toggle-slider"></span>
              </label>
            </div>
            <div class="automation-footer">
              <div class="automation-actions">
                <button
                  class="btn-icon"
                  onclick="testAutomation()"
                  title="Test Automation"
                >
                  <i class="fas fa-play"></i>
                </button>
                <button
                  class="btn-icon"
                  onclick="editAutomation()"
                  title="Edit"
                >
                  <i class="fas fa-edit"></i>
                </button>
                <button
                  class="btn-icon"
                  onclick="duplicateAutomation()"
                  title="Duplicate"
                >
                  <i class="fas fa-copy"></i>
                </button>
                <button
                  class="btn-icon delete"
                  onclick="deleteAutomation()"
                  title="Delete"
                >
                  <i class="fas fa-trash"></i>
                </button>
              </div>
              <div class="last-run">Last run: 2 hours ago</div>
            </div>
          </div>

          <div class="automation-card">
            <div class="automation-header">
              <div>
                <h3 class="automation-title">New Customer Welcome</h3>
                <span class="automation-trigger"
                  >When new customer is added</span
                >
                <p class="automation-action">
                  Send welcome email and create initial assessment task
                </p>
              </div>
              <label class="toggle-switch">
                <input
                  type="checkbox"
                  checked
                  onchange="toggleAutomation(this)"
                />
                <span class="toggle-slider"></span>
              </label>
            </div>
            <div class="automation-footer">
              <div class="automation-actions">
                <button
                  class="btn-icon"
                  onclick="testAutomation()"
                  title="Test Automation"
                >
                  <i class="fas fa-play"></i>
                </button>
                <button
                  class="btn-icon"
                  onclick="editAutomation()"
                  title="Edit"
                >
                  <i class="fas fa-edit"></i>
                </button>
                <button
                  class="btn-icon"
                  onclick="duplicateAutomation()"
                  title="Duplicate"
                >
                  <i class="fas fa-copy"></i>
                </button>
                <button
                  class="btn-icon delete"
                  onclick="deleteAutomation()"
                  title="Delete"
                >
                  <i class="fas fa-trash"></i>
                </button>
              </div>
              <div class="last-run">Last run: 1 day ago</div>
            </div>
          </div>

          <div class="automation-card">
            <div class="automation-header">
              <div>
                <h3 class="automation-title">High-Value Debt Alert</h3>
                <span class="automation-trigger"
                  >When debt amount > ₦500,000</span
                >
                <p class="automation-action">
                  Notify manager and flag for priority collection
                </p>
              </div>
              <label class="toggle-switch">
                <input type="checkbox" onchange="toggleAutomation(this)" />
                <span class="toggle-slider"></span>
              </label>
            </div>
            <div class="automation-footer">
              <div class="automation-actions">
                <button
                  class="btn-icon"
                  onclick="testAutomation()"
                  title="Test Automation"
                >
                  <i class="fas fa-play"></i>
                </button>
                <button
                  class="btn-icon"
                  onclick="editAutomation()"
                  title="Edit"
                >
                  <i class="fas fa-edit"></i>
                </button>
                <button
                  class="btn-icon"
                  onclick="duplicateAutomation()"
                  title="Duplicate"
                >
                  <i class="fas fa-copy"></i>
                </button>
                <button
                  class="btn-icon delete"
                  onclick="deleteAutomation()"
                  title="Delete"
                >
                  <i class="fas fa-trash"></i>
                </button>
              </div>
              <div class="last-run">Never run</div>
            </div>
          </div>

          <div class="automation-card">
            <div class="automation-header">
              <div>
                <h3 class="automation-title">Payment Confirmation</h3>
                <span class="automation-trigger">When payment is received</span>
                <p class="automation-action">
                  Send confirmation email and update customer balance
                </p>
              </div>
              <label class="toggle-switch">
                <input
                  type="checkbox"
                  checked
                  onchange="toggleAutomation(this)"
                />
                <span class="toggle-slider"></span>
              </label>
            </div>
            <div class="automation-footer">
              <div class="automation-actions">
                <button
                  class="btn-icon"
                  onclick="testAutomation()"
                  title="Test Automation"
                >
                  <i class="fas fa-play"></i>
                </button>
                <button
                  class="btn-icon"
                  onclick="editAutomation()"
                  title="Edit"
                >
                  <i class="fas fa-edit"></i>
                </button>
                <button
                  class="btn-icon"
                  onclick="duplicateAutomation()"
                  title="Duplicate"
                >
                  <i class="fas fa-copy"></i>
                </button>
                <button
                  class="btn-icon delete"
                  onclick="deleteAutomation()"
                  title="Delete"
                >
                  <i class="fas fa-trash"></i>
                </button>
              </div>
              <div class="last-run">Last run: 30 minutes ago</div>
            </div>
          </div>
        </div>
      </div>
    </main>

    <!-- Modal -->
    <div id="automationModal" class="modal">
      <div class="modal-content">
        <div class="modal-header">
          <h2 class="modal-title">Create New Automation</h2>
          <button class="modal-close" onclick="closeModal()">
            <i class="fas fa-times"></i>
          </button>
        </div>
        <div class="modal-body">
          <div class="step-indicator">
            <div class="step active" data-step="1">
              <span class="step-number">1</span>
              <span>Trigger</span>
            </div>
            <div class="step" data-step="2">
              <span class="step-number">2</span>
              <span>Conditions</span>
            </div>
            <div class="step" data-step="3">
              <span class="step-number">3</span>
              <span>Actions</span>
            </div>
            <div class="step" data-step="4">
              <span class="step-number">4</span>
              <span>Timing</span>
            </div>
            <div class="step" data-step="5">
              <span class="step-number">5</span>
              <span>Review</span>
            </div>
          </div>

          <div id="step1" class="step-content">
            <div class="form-group">
              <label class="form-label">Automation Name</label>
              <input
                type="text"
                class="form-control"
                placeholder="Enter automation name"
              />
            </div>
            <div class="form-group">
              <label class="form-label">Select Trigger</label>
              <select class="form-control">
                <option value="">Choose a trigger...</option>
                <option value="debt_overdue">When a debt is overdue</option>
                <option value="payment_received">
                  When a payment is received
                </option>
                <option value="customer_added">
                  When a new customer is added
                </option>
                <option value="amount_threshold">
                  When debt amount exceeds threshold
                </option>
                <option value="payment_plan_created">
                  When a payment plan is created
                </option>
              </select>
            </div>
          </div>

          <div id="step2" class="step-content" style="display: none">
            <div class="form-group">
              <label class="form-label">Add Conditions (Optional)</label>
              <div id="conditions-container">
                <div class="condition-group">
                  <div class="form-group" style="margin-bottom: 0; flex: 1">
                    <select class="form-control">
                      <option value="">Select field...</option>
                      <option value="amount">Amount</option>
                      <option value="customer_type">Customer Type</option>
                      <option value="region">Region</option>
                      <option value="days_overdue">Days Overdue</option>
                    </select>
                  </div>
                  <div class="form-group" style="margin-bottom: 0; flex: 1">
                    <select class="form-control">
                      <option value="greater_than">Greater than</option>
                      <option value="less_than">Less than</option>
                      <option value="equals">Equals</option>
                      <option value="contains">Contains</option>
                    </select>
                  </div>
                  <div class="form-group" style="margin-bottom: 0; flex: 1">
                    <input
                      type="text"
                      class="form-control"
                      placeholder="Value"
                    />
                  </div>
                  <button
                    class="condition-remove"
                    onclick="removeCondition(this)"
                  >
                    Remove
                  </button>
                </div>
              </div>
              <button class="add-condition" onclick="addCondition()">
                + Add Condition
              </button>
            </div>
          </div>

          <div id="step3" class="step-content" style="display: none">
            <div class="form-group">
              <label class="form-label">Select Actions</label>
              <div style="display: flex; flex-direction: column; gap: 0.5rem">
                <label style="display: flex; align-items: center; gap: 0.5rem">
                  <input type="checkbox" value="send_email" />
                  <span>Send Email</span>
                </label>
                <label style="display: flex; align-items: center; gap: 0.5rem">
                  <input type="checkbox" value="assign_agent" />
                  <span>Assign to Agent</span>
                </label>
                <label style="display: flex; align-items: center; gap: 0.5rem">
                  <input type="checkbox" value="change_status" />
                  <span>Change Payment Status</span>
                </label>
                <label style="display: flex; align-items: center; gap: 0.5rem">
                  <input type="checkbox" value="add_tag" />
                  <span>Add Tag or Flag</span>
                </label>
                <label style="display: flex; align-items: center; gap: 0.5rem">
                  <input type="checkbox" value="notify_manager" />
                  <span>Notify Manager</span>
                </label>
              </div>
            </div>
          </div>

          <div id="step4" class="step-content" style="display: none">
            <div class="form-group">
              <label class="form-label">Execution Timing</label>
              <select class="form-control" onchange="toggleDelayInput(this)">
                <option value="immediate">Execute immediately</option>
                <option value="delay_hours">Delay by hours</option>
                <option value="delay_days">Delay by days</option>
              </select>
            </div>
            <div class="form-group" id="delayInput" style="display: none">
              <label class="form-label">Delay Amount</label>
              <input
                type="number"
                class="form-control"
                placeholder="Enter delay amount"
                min="1"
              />
            </div>
          </div>

          <div id="step5" class="step-content" style="display: none">
            <div class="form-group">
              <h3 style="margin-bottom: 1rem">Review Your Automation</h3>
              <div
                style="
                  background: #f8fafc;
                  padding: 1rem;
                  border-radius: 8px;
                  margin-bottom: 1rem;
                "
              >
                <h4 style="margin-bottom: 0.5rem">Trigger:</h4>
                <p id="reviewTrigger" style="margin: 0; color: #64748b">
                  When a debt is overdue
                </p>
              </div>
              <div
                style="
                  background: #f8fafc;
                  padding: 1rem;
                  border-radius: 8px;
                  margin-bottom: 1rem;
                "
              >
                <h4 style="margin-bottom: 0.5rem">Conditions:</h4>
                <p id="reviewConditions" style="margin: 0; color: #64748b">
                  No conditions set
                </p>
              </div>
              <div
                style="
                  background: #f8fafc;
                  padding: 1rem;
                  border-radius: 8px;
                  margin-bottom: 1rem;
                "
              >
                <h4 style="margin-bottom: 0.5rem">Actions:</h4>
                <p id="reviewActions" style="margin: 0; color: #64748b">
                  No actions selected
                </p>
              </div>
              <div
                style="background: #f8fafc; padding: 1rem; border-radius: 8px"
              >
                <h4 style="margin-bottom: 0.5rem">Timing:</h4>
                <p id="reviewTiming" style="margin: 0; color: #64748b">
                  Execute immediately
                </p>
              </div>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button
            class="btn btn-secondary"
            onclick="previousStep()"
            id="prevBtn"
            style="display: none"
          >
            Previous
          </button>
          <div style="display: flex; gap: 1rem">
            <button class="btn btn-secondary" onclick="testAutomationModal()">
              Test Automation
            </button>
            <button class="btn btn-primary" onclick="nextStep()" id="nextBtn">
              Next
            </button>
          </div>
        </div>
      </div>
    </div>
    </div>

    <script>
      let currentStep = 1;
      const totalSteps = 5;

      // Theme Toggle
      function toggleTheme() {
        document.body.classList.toggle("dark-mode");
        const themeIcon = document.querySelector(".theme-toggle i");
        if (document.body.classList.contains("dark-mode")) {
          themeIcon.className = "fas fa-sun";
          localStorage.setItem("theme", "dark");
        } else {
          themeIcon.className = "fas fa-moon";
          localStorage.setItem("theme", "light");
        }
      }

      // Load saved theme
      function loadTheme() {
        const savedTheme = localStorage.getItem("theme");
        if (savedTheme === "dark") {
          document.body.classList.add("dark-mode");
          document.querySelector(".theme-toggle i").className = "fas fa-sun";
        }
      }

      // Modal Functions
      function openModal() {
        document.getElementById("automationModal").classList.add("show");
        currentStep = 1;
        updateStepIndicator();
      }

      function closeModal() {
        document.getElementById("automationModal").classList.remove("show");
        resetForm();
      }

      function resetForm() {
        currentStep = 1;
        document.querySelectorAll(".step-content").forEach((step) => {
          step.style.display = "none";
        });
        document.getElementById("step1").style.display = "block";
        updateStepIndicator();
      }

      function nextStep() {
        if (currentStep < totalSteps) {
          document.getElementById(`step${currentStep}`).style.display = "none";
          currentStep++;
          document.getElementById(`step${currentStep}`).style.display = "block";
          updateStepIndicator();

          if (currentStep === totalSteps) {
            updateReviewSection();
            document.getElementById("nextBtn").textContent =
              "Create Automation";
          }
        } else {
          // Create automation
          createAutomation();
        }
      }

      function previousStep() {
        if (currentStep > 1) {
          document.getElementById(`step${currentStep}`).style.display = "none";
          currentStep--;
          document.getElementById(`step${currentStep}`).style.display = "block";
          updateStepIndicator();

          if (currentStep < totalSteps) {
            document.getElementById("nextBtn").textContent = "Next";
          }
        }
      }

      function updateStepIndicator() {
        document.querySelectorAll(".step").forEach((step, index) => {
          const stepNumber = index + 1;
          step.classList.remove("active", "completed");

          if (stepNumber === currentStep) {
            step.classList.add("active");
          } else if (stepNumber < currentStep) {
            step.classList.add("completed");
          }
        });

        // Update button visibility
        document.getElementById("prevBtn").style.display =
          currentStep > 1 ? "block" : "none";
      }

      function updateReviewSection() {
        // Get form values and update review section
        const triggerSelect = document.querySelector("#step1 select");
        const actionCheckboxes = document.querySelectorAll(
          '#step3 input[type="checkbox"]:checked'
        );
        const timingSelect = document.querySelector("#step4 select");

        document.getElementById("reviewTrigger").textContent =
          triggerSelect.options[triggerSelect.selectedIndex].text;

        const selectedActions = Array.from(actionCheckboxes).map(
          (cb) => cb.nextElementSibling.textContent
        );
        document.getElementById("reviewActions").textContent =
          selectedActions.length > 0
            ? selectedActions.join(", ")
            : "No actions selected";

        document.getElementById("reviewTiming").textContent =
          timingSelect.options[timingSelect.selectedIndex].text;
      }

      function toggleDelayInput(select) {
        const delayInput = document.getElementById("delayInput");
        delayInput.style.display =
          select.value !== "immediate" ? "block" : "none";
      }

      function addCondition() {
        const container = document.getElementById("conditions-container");
        const conditionGroup = document.createElement("div");
        conditionGroup.className = "condition-group";
        conditionGroup.innerHTML = `
                <div class="form-group" style="margin-bottom: 0; flex: 1;">
                    <select class="form-control">
                        <option value="">Select field...</option>
                        <option value="amount">Amount</option>
                        <option value="customer_type">Customer Type</option>
                        <option value="region">Region</option>
                        <option value="days_overdue">Days Overdue</option>
                    </select>
                </div>
                <div class="form-group" style="margin-bottom: 0; flex: 1;">
                    <select class="form-control">
                        <option value="greater_than">Greater than</option>
                        <option value="less_than">Less than</option>
                        <option value="equals">Equals</option>
                        <option value="contains">Contains</option>
                    </select>
                </div>
                <div class="form-group" style="margin-bottom: 0; flex: 1;">
                    <input type="text" class="form-control" placeholder="Value">
                </div>
                <button class="condition-remove" onclick="removeCondition(this)">Remove</button>
            `;
        container.appendChild(conditionGroup);
      }

      function removeCondition(button) {
        button.parentElement.remove();
      }

      function createAutomation() {
        // Simulate creating automation
        showNotification("Automation created successfully!", "success");
        closeModal();

        // Add new automation card to the grid (simulation)
        setTimeout(() => {
          location.reload(); // In a real app, you'd add the new card dynamically
        }, 1000);
      }

      function testAutomation() {
        showNotification("Test automation executed successfully!", "success");
      }

      function testAutomationModal() {
        showNotification(
          "Test automation will be executed when created.",
          "info"
        );
      }

      function editAutomation() {
        showNotification("Edit functionality coming soon!", "info");
      }

      function duplicateAutomation() {
        showNotification("Automation duplicated successfully!", "success");
      }

      function deleteAutomation() {
        if (confirm("Are you sure you want to delete this automation?")) {
          showNotification("Automation deleted successfully!", "success");
        }
      }

      function toggleAutomation(toggle) {
        const status = toggle.checked ? "activated" : "deactivated";
        showNotification(`Automation ${status} successfully!`, "success");
      }

      function showNotification(message, type) {
        const notification = document.createElement("div");
        notification.style.cssText = `
                position: fixed;
                top: 20px;
                right: 20px;
                background: ${
                  type === "success"
                    ? "#22c55e"
                    : type === "error"
                    ? "#ef4444"
                    : "#3b82f6"
                };
                color: white;
                padding: 1rem 1.5rem;
                border-radius: 8px;
                z-index: 10000;
                font-weight: 500;
                box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
                animation: slideInRight 0.3s ease;
            `;
        notification.textContent = message;
        document.body.appendChild(notification);

        setTimeout(() => {
          notification.style.animation = "slideOutRight 0.3s ease";
          setTimeout(() => notification.remove(), 300);
        }, 3000);
      }

      // Close modal when clicking outside
      document
        .getElementById("automationModal")
        .addEventListener("click", function (e) {
          if (e.target === this) {
            closeModal();
          }
        });

      // Add CSS for notification animations
      const style = document.createElement("style");
      style.textContent = `
            @keyframes slideInRight {
                from { transform: translateX(100%); opacity: 0; }
                to { transform: translateX(0); opacity: 1; }
            }
            @keyframes slideOutRight {
                from { transform: translateX(0); opacity: 1; }
                to { transform: translateX(100%); opacity: 0; }
            }
        `;
      document.head.appendChild(style);

      // Initialize theme on page load
      loadTheme();
    </script>
  </body>
</html>
