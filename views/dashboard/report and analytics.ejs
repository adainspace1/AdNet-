<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Inventory Reports & Analytics</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.9.1/chart.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

    <link rel="stylesheet" href="/css/dashall.css" />
    <link rel="stylesheet" href="/css/report.css">

               <link
      href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/boxicons@2.1.4/css/boxicons.min.css"
    />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">



  </head>
  <body>
    <div class="all">
      <%- include ("_sidebar1") %>

      <div class="main-content">
        <%- include ("_topnav") %>
<div class="container">
    <!-- Breadcrumb Navigation -->
    <nav class="breadcrumb">
        <a href="#dashboard">Dashboard</a> &gt;
        <a href="#inventory">Inventory Management</a> &gt;
        <span>Reports & Analytics</span>
    </nav>

    <!-- Header -->
    <div class="header">
        <h1>📊 Inventory Reports & Analytics</h1>
        <p>Data-driven insights for optimal inventory performance</p>
    </div>

    <!-- Controls -->
    <form id="reportForm" class="controls">
        <input type="date" name="startDate" id="startDate" value="2025-07-01" />
        <input type="date" name="endDate" id="endDate" value="2025-07-31" />
        <select name="category" id="categoryFilter">
            <option value="">All Categories</option>
        </select>
        <select name="supplier" id="supplierFilter">
            <option value="">All Suppliers</option>
        </select>
        <button type="submit">🔄 Refresh Data</button>
        <button type="button" onclick="generateReport()">📋 Generate Report</button>
    </form>

<!-- KPIs -->
<div class="kpi-grid">
  <div class="kpi-card green">
    <div class="kpi-header">
      <span class="kpi-title">Inventory Turnover</span>
    </div>
    <div class="kpi-value" id="turnoverValue"><%= kpis.turnover %></div>
    <div class="kpi-change"><%= kpis.turnoverChange || "→ No change" %></div>
  </div>

  <div class="kpi-card yellow">
    <div class="kpi-header">
      <span class="kpi-title">Average Inventory</span>
    </div>
    <div class="kpi-value" id="avgInventoryValue">$<%= kpis.avgInventoryValue %></div>
    <div class="kpi-change"><%= kpis.avgInventoryChange || "→ No change" %></div>
  </div>

  <!-- <div class="kpi-card yellow">
    <div class="kpi-header">
      <span class="kpi-title">Stock-to-Sales Ratio</span>
    </div>
    <div class="kpi-value" id="stockToSalesValue"><%= kpis.stockToSalesRatio %></div>
    <div class="kpi-change">→ No change</div>
  </div> -->

  <!-- <div class="kpi-card green">
    <div class="kpi-header">
      <span class="kpi-title">Sell-Through Rate</span>
    </div>
    <div class="kpi-value" id="sellThroughValue"><%= kpis.sellThroughRate %>%</div>
    <div class="kpi-change">→ No change</div>
  </div> -->

  <div class="kpi-card red">
    <div class="kpi-header">
      <span class="kpi-title">Fill Rate (LIFR)</span>
    </div>
    <div class="kpi-value" id="fillRateValue"><%= kpis.fillRate %>%</div>
    <div class="kpi-change">→ No change</div>
  </div>
</div>


<!-- Charts -->
<div class="charts-grid">
    <div class="chart-container">
        <h3>📈 Monthly Sales vs Inventory Trend</h3>
        <canvas id="salesInventoryChart"></canvas>
    </div>
    <div class="chart-container">
        <h3>📊 Turnover Ratio Trend</h3>
        <canvas id="turnoverTrendChart"></canvas>
    </div>
    <div class="chart-container">
        <h3>🥧 Fill Rate by Supplier</h3>
        <canvas id="fillRateChart"></canvas>
    </div>
    <div class="chart-container">
        <h3>📊 Stock Level Distribution</h3>
        <canvas id="stockDistributionChart"></canvas>
    </div>
</div>

<!-- Data Table -->
<div class="data-table-container">
    <div class="table-header">
        <h3>📋 Detailed Inventory Performance</h3>
    </div>
    <table>
        <thead>
            <tr>
                <th>Status</th>
                <th>Product Name</th>
                <th>Category</th>
                <th>Sales</th>
                <th>Avg Inventory</th>
                <th>Turnover Ratio</th>
                <th>STR (%)</th>
                <th>LIFR (%)</th>
                <th>Supplier</th>
            </tr>
        </thead>
        <tbody>
            <% table.forEach(item => { %>
                <tr>
                    <td><%= item.status %></td>
                    <td><%= item.name %></td>
                    <td><%= item.category %></td>
                    <td><%= item.sales %></td>
                    <td><%= item.avgInventory %></td>
                    <td><%= item.turnover %></td>
                    <td><%= item.str %></td>
                    <td><%= item.lifr %></td>
                    <td><%= item.supplier %></td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</div>

<!-- Alerts -->
<div class="alerts-section">
    <h3>⚠️ Performance Alerts & Recommendations</h3>
    <% alerts.forEach(alert => { %>
        <div class="alert-item"><%= alert %></div>
    <% }) %>
</div>

</div>

<!-- ✅ Chart.js CDN -->
 <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
 <script>
// ✅ Helper: format big numbers (2M, 33K, etc.)
function formatCompactNumber(num) {
  return new Intl.NumberFormat("en", {
    notation: "compact",
    compactDisplay: "short",
    maximumFractionDigits: 1
  }).format(num);
}

// ✅ Format initial KPI values when page loads
document.addEventListener("DOMContentLoaded", () => {
  const turnover = document.getElementById("turnoverValue");
  const avgInventory = document.getElementById("avgInventoryValue");
//   const stockToSales = document.getElementById("stockToSalesValue");
//   const sellThrough = document.getElementById("sellThroughValue");
  const fillRate = document.getElementById("fillRateValue");

  if (turnover) turnover.textContent = formatCompactNumber(parseFloat(turnover.textContent));
  if (avgInventory) avgInventory.textContent = "$" + formatCompactNumber(parseFloat(avgInventory.textContent.replace("$","")));
  if (stockToSales) stockToSales.textContent = formatCompactNumber(parseFloat(stockToSales.textContent));
  if (sellThrough) sellThrough.textContent = formatCompactNumber(parseFloat(sellThrough.textContent)) + "%";
  if (fillRate) fillRate.textContent = formatCompactNumber(parseFloat(fillRate.textContent)) + "%";
});

// ✅ Form submit (AJAX KPI update)
document.getElementById("reportForm").addEventListener("submit", function(e) {
  e.preventDefault();

  const formData = new FormData(this);
  const params = new URLSearchParams(formData);
  params.append("ajax", "true");

  fetch(`/reportandanalysis?${params.toString()}`)
    .then(res => res.json())
    .then(data => {
      document.getElementById("turnoverValue").textContent = formatCompactNumber(data.kpis.turnover);
      document.getElementById("avgInventoryValue").textContent = "$" + formatCompactNumber(data.kpis.avgInventoryValue);
    //   document.getElementById("stockToSalesValue").textContent = formatCompactNumber(data.kpis.stockToSales);
    //   document.getElementById("sellThroughValue").textContent = formatCompactNumber(data.kpis.sellThrough) + "%";
      document.getElementById("fillRateValue").textContent = formatCompactNumber(data.kpis.fillRate) + "%";
    })
    .catch(err => console.error("Error fetching KPI data:", err));
});

// ✅ Standalone refresh button
async function refreshData() {
  const startDate = document.querySelector('input[name="startDate"]').value;
  const endDate = document.querySelector('input[name="endDate"]').value;
  const category = document.querySelector('select[name="category"]')?.value || "";
  const supplier = document.querySelector('select[name="supplier"]')?.value || "";

  try {
    const res = await fetch(`/reportandanalysis?ajax=true&startDate=${startDate}&endDate=${endDate}&category=${category}&supplier=${supplier}`);
    const data = await res.json();

    document.getElementById("turnoverValue").textContent = formatCompactNumber(data.kpis.turnover);
    document.getElementById("avgInventoryValue").textContent = "$" + formatCompactNumber(data.kpis.avgInventoryValue);
    // document.getElementById("stockToSalesValue").textContent = formatCompactNumber(data.kpis.stockToSales);
    // document.getElementById("sellThroughValue").textContent = formatCompactNumber(data.kpis.sellThrough) + "%";
    document.getElementById("fillRateValue").textContent = formatCompactNumber(data.kpis.fillRate) + "%";
  } catch (err) {
    console.error("Error refreshing report:", err);
  }
}

// ✅ Generate PDF
function generateReport() {
  const table = document.querySelector(".data-table-container table");
  if (!table) return alert("No data table found!");
  const pdf = new jspdf.jsPDF({ orientation: "landscape", unit: "pt", format: "a4" });
  pdf.html(table, {
    callback: (doc) => doc.save("Inventory_Report.pdf"),
    x: 20, y: 20
  });
}

// ✅ Initialize Charts
document.addEventListener('DOMContentLoaded', function() {
  const chartsData = <%- JSON.stringify(charts) %>;

  window.salesInventoryChart = new Chart(document.getElementById('salesInventoryChart'), {
    type: 'line',
    data: {
      labels: chartsData.monthlyData.map(m => `${m._id.month}/${m._id.year}`),
      datasets: [
        { label: 'Sales', data: chartsData.monthlyData.map(m => m.totalSales), borderColor: 'blue', fill: false },
      ]
    }
  });

  window.turnoverTrendChart = new Chart(document.getElementById('turnoverTrendChart'), {
    type: 'line',
    data: {
      labels: chartsData.turnoverTrend.map(t => t.label),
      datasets: [
        { label: 'Turnover', data: chartsData.turnoverTrend.map(t => t.turnover), borderColor: 'green', fill: false }
      ]
    }
  });

  window.fillRateChart = new Chart(document.getElementById('fillRateChart'), {
    type: 'pie',
    data: {
      labels: chartsData.fillRateBySupplier.map(f => f._id),
      datasets: [{
        data: chartsData.fillRateBySupplier.map(f => f.fillRate),
        backgroundColor: ['#4CAF50','#FFC107','#2196F3','#FF5722']
      }]
    }
  });

  window.stockDistributionChart = new Chart(document.getElementById('stockDistributionChart'), {
    type: 'bar',
    data: {
      labels: chartsData.stockDistribution.map(s => s._id),
      datasets: [{
        label: 'Stock Levels',
        data: chartsData.stockDistribution.map(s => s.totalStock),
        backgroundColor: '#673AB7'
      }]
    }
  });
});
</script>





<script>
        sessionStorage.setItem("redirect", window.location.pathname);
      </script>
    </div>
  </body>
</html>
