<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Inventory & Warehouse Management</title>

  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet"/>

  <style>
    .tab-content {
      display: none;
      opacity: 0;
      transition: opacity 0.3s ease-in-out;
    }
    .tab-content.active {
      display: block;
      opacity: 1;
    }
    .tab-button {
      transition: all 0.3s ease;
    }
    .tab-button.active {
      background-color: #4361ee;
      color: white;
    }
    .card-hover {
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .card-hover:hover {
      transform: translateY(-4px);
      box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
    }
  </style>
</head>
<body class="bg-gray-50 text-gray-800 font-sans">

<div class="min-h-screen">
  <!-- Header -->
  <div class="bg-white shadow-sm border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5">
      <h1 class="text-2xl md:text-3xl font-bold text-gray-900 flex items-center gap-3">
        <i class="fas fa-warehouse text-blue-600"></i>
        Inventory & Warehouse Management
      </h1>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <!-- Tab Navigation -->
    <div class="flex flex-wrap gap-2 mb-8 border-b border-gray-200 overflow-x-auto">
      <button class="tab-button px-5 py-3 text-sm font-medium rounded-t-lg border border-transparent active" data-tab="catalog">
        <i class="fas fa-cubes mr-2"></i>Catalog & SKUs
      </button>
      <button class="tab-button px-5 py-3 text-sm font-medium rounded-t-lg border border-transparent" data-tab="locations">
        <i class="fas fa-map-marked-alt mr-2"></i>Stock Locations
      </button>
      <button class="tab-button px-5 py-3 text-sm font-medium rounded-t-lg border border-transparent" data-tab="movements">
        <i class="fas fa-exchange-alt mr-2"></i>Stock Movements
      </button>
      <button class="tab-button px-5 py-3 text-sm font-medium rounded-t-lg border border-transparent" data-tab="reorder">
        <i class="fas fa-redo mr-2"></i>Reorder Rules
      </button>
      <button class="tab-button px-5 py-3 text-sm font-medium rounded-t-lg border border-transparent" data-tab="valuation">
        <i class="fas fa-calculator mr-2"></i>Valuation Methods
      </button>
      <button class="tab-button px-5 py-3 text-sm font-medium rounded-t-lg border border-transparent" data-tab="shipping">
        <i class="fas fa-truck mr-2"></i>Pick/Pack/Ship
      </button>
    </div>

    <!-- Tab Contents -->
    <div class="space-y-8">

      <!-- 1. Catalog & SKUs -->
      <div id="catalog" class="tab-content active">
        <div class="bg-white rounded-xl shadow-sm p-6 card-hover">
          <h2 class="text-xl font-bold text-gray-900 mb-2 flex items-center gap-2">
            <i class="fas fa-cubes text-blue-600"></i> Product Catalog & SKUs
          </h2>
          <p class="text-gray-600 mb-6">Manage product attributes, Bill of Materials (BOM), variants, barcodes, and categories.</p>
          <div class="bg-gray-50 border-2 border-dashed border-gray-300 rounded-lg p-8 text-center">
            <i class="fas fa-barcode text-4xl text-gray-400 mb-3"></i>
            <p class="text-gray-500">SKU List, Variants, BOM Editor, Barcode Generator</p>
          </div>
        </div>
      </div>

      <!-- 2. Stock Locations & Multi-warehouse -->
      <div id="locations" class="tab-content">
        <div class="bg-white rounded-xl shadow-sm p-6 card-hover">
          <h2 class="text-xl font-bold text-gray-900 mb-2 flex items-center gap-2">
            <i class="fas fa-map-marked-alt text-green-600"></i> Stock Locations & Multi-Warehouse
          </h2>
          <p class="text-gray-600 mb-6">Track inventory across warehouses, bins, and zones. Manage transfers and cycle counts.</p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="bg-gray-50 border-2 border-dashed border-gray-300 rounded-lg p-6 text-center">
              <i class="fas fa-exchange-alt text-3xl text-gray-400 mb-2"></i>
              <p class="text-gray-500">Inter-Warehouse Transfers</p>
            </div>
            <div class="bg-gray-50 border-2 border-dashed border-gray-300 rounded-lg p-6 text-center">
              <i class="fas fa-clipboard-check text-3xl text-gray-400 mb-2"></i>
              <p class="text-gray-500">Cycle Count Scheduler</p>
            </div>
          </div>
        </div>
      </div>

      <!-- 3. Stock Movements & Transactions -->
      <div id="movements" class="tab-content">
        <div class="bg-white rounded-xl shadow-sm p-6 card-hover">
          <h2 class="text-xl font-bold text-gray-900 mb-2 flex items-center gap-2">
            <i class="fas fa-exchange-alt text-purple-600"></i> Stock Movements & Transactions
          </h2>
          <p class="text-gray-600 mb-6">Record receipts, adjustments, consumption, and track by lot/serial numbers.</p>
          <div class="overflow-x-auto">
            <table class="min-w-full bg-gray-50 border border-gray-300 rounded-lg">
              <thead class="bg-gray-100">
                <tr>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-700 uppercase">Type</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-700 uppercase">Date</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-700 uppercase">Qty</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-700 uppercase">Lot/Serial</th>
                </tr>
              </thead>
              <tbody class="text-sm text-gray-600">
                <tr class="border-t"><td colspan="4" class="px-4 py-8 text-center text-gray-400">No transactions yet</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- 4. Reorder Rules & Procurement Triggers -->
      <div id="reorder" class="tab-content">
        <div class="bg-white rounded-xl shadow-sm p-6 card-hover">
          <h2 class="text-xl font-bold text-gray-900 mb-2 flex items-center gap-2">
            <i class="fas fa-redo text-orange-600"></i> Reorder Rules & Procurement Triggers
          </h2>
          <p class="text-gray-600 mb-6">Set min/max levels, lead times, and automate purchase order creation.</p>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div class="bg-gradient-to-br from-yellow-50 to-amber-50 border border-amber-200 rounded-lg p-5 text-center">
              <div class="text-3xl font-bold text-amber-700">12</div>
              <p class="text-sm text-amber-800 mt-1">Low Stock Alerts</p>
            </div>
            <div class="bg-gradient-to-br from-blue-50 to-indigo-50 border border-indigo-200 rounded-lg p-5 text-center">
              <div class="text-3xl font-bold text-indigo-700">8</div>
              <p class="text-sm text-indigo-800 mt-1">Auto POs Pending</p>
            </div>
            <div class="bg-gradient-to-br from-green-50 to-emerald-50 border border-emerald-200 rounded-lg p-5 text-center">
              <div class="text-3xl font-bold text-emerald-700">94%</div>
              <p class="text-sm text-emerald-800 mt-1">Fill Rate</p>
            </div>
          </div>
        </div>
      </div>

      <!-- 5. Inventory Valuation Methods -->
      <div id="valuation" class="tab-content">
        <div class="bg-white rounded-xl shadow-sm p-6 card-hover">
          <h2 class="text-xl font-bold text-gray-900 mb-2 flex items-center gap-2">
            <i class="fas fa-calculator text-teal-600"></i> Inventory Valuation Methods
          </h2>
          <p class="text-gray-600 mb-6">Choose FIFO, LIFO, or Weighted Average. View cost layers and valuation reports.</p>
          <div class="space-y-4">
            <div class="flex items-center justify-between p-4 bg-teal-50 border border-teal-200 rounded-lg">
              <div class="flex items-center gap-3">
                <i class="fas fa-check-circle text-teal-600"></i>
                <span class="font-medium">FIFO (First In, First Out)</span>
              </div>
              <span class="text-sm text-teal-700 bg-teal-100 px-3 py-1 rounded-full">Active</span>
            </div>
            <div class="flex items-center justify-between p-4 bg-gray-50 border border-gray-300 rounded-lg">
              <div class="flex items-center gap-3">
                <i class="fas fa-circle text-gray-400"></i>
                <span class="font-medium text-gray-600">LIFO / Weighted Average</span>
              </div>
              <span class="text-sm text-gray-500">Available</span>
            </div>
          </div>
        </div>
      </div>

      <!-- 6. Pick/Pack/Ship & Delivery Tracking -->
      <div id="shipping" class="tab-content">
        <div class="bg-white rounded-xl shadow-sm p-6 card-hover">
          <h2 class="text-xl font-bold text-gray-900 mb-2 flex items-center gap-2">
            <i class="fas fa-truck text-indigo-600"></i> Pick, Pack & Ship
          </h2>
          <p class="text-gray-600 mb-6">Generate picking lists, integrate with carriers, and track delivery status in real-time.</p>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-center">
            <div class="p-5 bg-indigo-50 border border-indigo-200 rounded-lg">
              <i class="fas fa-clipboard-list text-3xl text-indigo-600 mb-2"></i>
              <p class="font-semibold">Picking Lists</p>
            </div>
            <div class="p-5 bg-purple-50 border border-purple-200 rounded-lg">
              <i class="fas fa-box-open text-3xl text-purple-600 mb-2"></i>
              <p class="font-semibold">Packing Station</p>
            </div>
            <div class="p-5 bg-emerald-50 border border-emerald-200 rounded-lg">
              <i class="fas fa-shipping-fast text-3xl text-emerald-600 mb-2"></i>
              <p class="font-semibold">Live Tracking</p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
  // Tab switching with fade
  document.querySelectorAll('.tab-button').forEach(button => {
    button.addEventListener('click', () => {
      const target = button.getAttribute('data-tab');

      // Remove active from all
      document.querySelectorAll('.tab-button').forEach(btn => {
        btn.classList.remove('active', 'bg-blue-600', 'text-white', 'border-blue-600');
        btn.classList.add('border-transparent');
      });
      document.querySelectorAll('.tab-content').forEach(content => {
        content.classList.remove('active');
      });

      // Add active to clicked
      button.classList.add('active', 'bg-blue-600', 'text-white');
      button.classList.remove('border-transparent');
      document.getElementById(target).classList.add('active');
    });
  });
</script>

</body>
</html>