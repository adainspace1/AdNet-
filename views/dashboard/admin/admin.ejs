    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // ==========================================
        // LIVE DASHBOARD WITH BACKEND INTEGRATION
        // ==========================================

        // ========== BUTTON EVENT HANDLERS ========== 
        document.addEventListener('DOMContentLoaded', function() {
            // Quick Actions
            document.getElementById('quickAddCompanyBtn')?.addEventListener('click', function() {
                alert('Show Register New Company popup');
            });
            document.getElementById('quickAddUserBtn')?.addEventListener('click', function() {
                const addUserPopup = document.getElementById('addUserPopup');
                addUserPopup.style.display = 'flex';
                // Re-initialize role selection when popup opens
                setTimeout(() => {
                    console.log('🔧 Re-initializing role selection from quick add...');
                    initializeRoleSelection();
                }, 100);
            });
            document.getElementById('downloadReportBtn')?.addEventListener('click', function() {
                alert('Download Monthly Financial Report as PDF');
            });
            document.getElementById('refreshDashboardBtn')?.addEventListener('click', function() {
                location.reload();
            });

            // Company Management
            document.getElementById('registerCompanyBtn')?.addEventListener('click', function() {
                alert('Show Register Company popup');
            });

            // Plan Management
            document.getElementById('createPlanBtn')?.addEventListener('click', function() {
                alert('Show Create New Plan popup');
            });

            // Tax Report
            document.getElementById('generateTaxReportBtn')?.addEventListener('click', function() {
                alert('Generate Tax Compliance Report (PDF)');
            });

            // Financial Export
            document.getElementById('exportFinancialBtn')?.addEventListener('click', function() {
                alert('Export Financial Reports (CSV/PDF)');
            });

            // Add User Popup (custom)
            const addUserPopup = document.getElementById('addUserPopup');
            const addUserBtn = document.getElementById('addUserBtn');
            const addUserForm = document.getElementById('addUserForm');
            if (addUserBtn && addUserPopup) {
                addUserBtn.addEventListener('click', () => {
                    console.log('🔘 Opening user popup...');
                    addUserPopup.style.display = 'flex';
                    // Re-initialize role selection when popup opens
                    setTimeout(() => {
                        console.log('🔧 Re-initializing role selection...');
                        initializeRoleSelection();
                    }, 100);
                });
            }
            // Handle role checkbox changes
            function handleRoleChange(event) {
                const cb = event.target;
                const role = cb.value;
                const select = document.querySelector(`select[name="accessLevel[${role}]"]`);
                
                console.log(`Role ${role} changed to:`, cb.checked);
                
                if (select) {
                    if (cb.checked) {
                        select.disabled = false;
                        select.required = true;
                        select.style.opacity = '1';
                        select.style.backgroundColor = '#fff';
                        select.style.borderColor = '#007bff';
                        console.log(`✅ Enabled access level for ${role}`);
                    } else {
                        select.disabled = true;
                        select.required = false;
                        select.value = '';
                        select.style.opacity = '0.5';
                        select.style.backgroundColor = '#f1f3f4';
                        select.style.borderColor = '#dee2e6';
                        console.log(`❌ Disabled access level for ${role}`);
                    }
                } else {
                    console.error(`❌ Could not find select for role: ${role}`);
                }
            }

            // Initialize role selection functionality
            function initializeRoleSelection() {
                console.log('🔧 Initializing role selection...');
                document.querySelectorAll('input[name="roles"]').forEach(cb => {
                    // Remove existing listeners to avoid duplicates
                    cb.removeEventListener('change', handleRoleChange);
                    // Add the event listener
                    cb.addEventListener('change', handleRoleChange);
                    console.log(`Added listener for role: ${cb.value}`);
                });
            }

            // Close popup function
            window.closePopup = function() {
                if (addUserPopup) {
                    addUserPopup.style.display = 'none';
                    // Reset form when closing
                    const form = document.getElementById('addUserForm');
                    if (form) {
                        form.reset();
                        form.dataset.id = '';
                        // Reset all role checkboxes and selects
                        document.querySelectorAll('input[name="roles"]').forEach(cb => {
                            cb.checked = false;
                            cb.dispatchEvent(new Event('change'));
                        });
                    }
                }
            };

            // Initialize role selection on page load
            initializeRoleSelection();

            // Add User Form Submission (roles array)
            if (addUserForm) {
                addUserForm.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    
                    try {
                        const formData = new FormData(addUserForm);
                        const payload = { 
                            roles: [],
                            adminId: '<%= user._id %>' // Add adminId for new workers
                        };
                        
                        // Process form data
                        for (let [key, value] of formData.entries()) {
                            if (key === 'roles') {
                                const access = formData.get(`accessLevel[${value}]`) || 'basic';
                                payload.roles.push({ role: value, accessLevel: access });
                            } else if (!key.startsWith('accessLevel[')) {
                                payload[key] = value;
                            }
                        }
                        
                        // Determine if editing or creating
                        const id = addUserForm.dataset.id;
                        const url = id ? `/workers/${id}` : '/user/users';
                        const method = id ? 'PUT' : 'POST';
                        
                        console.log('Submitting worker:', { url, method, payload });
                        
                        const response = await fetch(url, {
                            method,
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(payload)
                        });
                        
                        const result = await response.json();
                        
                        if (response.ok && result.success !== false) {
                            console.log('Worker saved successfully:', result);
                            window.closePopup();
                            loadWorkers(); // Reload the workers table
                        } else {
                            console.error('Error saving worker:', result);
                            alert(result.message || 'Failed to save worker. Please try again.');
                        }
                        
                    } catch (error) {
                        console.error('Error submitting form:', error);
                        alert('An error occurred while saving the worker. Please try again.');
                    }
                });
            }

            // Fetch & render workers (table)
            async function loadWorkers() {
                const tbody = document.getElementById('usersTbody');
                if (tbody) {
                    const res = await fetch(`/workers/<%= user._id %>`);
                    const workers = await res.json();
                    tbody.innerHTML = '';
                    workers.forEach(w => {
                        const tr = document.createElement('tr');
                        tr.innerHTML = `
                            <td>${w.name}</td>
                            <td>${new Date(w.createdAt).toLocaleDateString()}</td>
                            <td>
                              ${w.roles.map(r => `<span class="badge bg-info me-1">${r.role} (${r.accessLevel})</span>`).join(' ')}
                            </td>
                            <td>
                              <button class="edit-btn btn btn-sm btn-info" data-id="${w._id}">Edit</button>
                              <button class="delete-btn btn btn-sm btn-danger" data-id="${w._id}">Delete</button>
                            </td>
                        `;
                        tbody.appendChild(tr);
                    });
                }
            }
            loadWorkers();

            // Edit user (prefill roles)
            document.getElementById('usersTbody').addEventListener('click', async (e) => {
                if (e.target.classList.contains('edit-btn')) {
                    const id = e.target.dataset.id;
                    const res = await fetch(`/get/workers/${id}`);
                    const worker = await res.json();
                    addUserPopup.style.display = 'flex';
                    addUserForm.dataset.id = worker._id;
                    addUserForm.name.value = worker.name;
                    addUserForm.email.value = worker.email;
                    addUserForm.phone.value = worker.phone || '';
                    addUserForm.username.value = worker.username;
                    addUserForm.notes.value = worker.notes || '';
                    addUserForm.password.value = '';
                    // reset roles
                    document.querySelectorAll('input[name="roles"]').forEach(cb => {
                        cb.checked = false;
                        cb.dispatchEvent(new Event('change'));
                    });
                    worker.roles.forEach(r => {
                        const cb = document.querySelector(`input[name="roles"][value="${r.role}"]`);
                        if (cb) {
                            cb.checked = true;
                            cb.dispatchEvent(new Event('change'));
                            document.querySelector(`#permissions-${r.role} select`).value = r.accessLevel;
                        }
                    });
                }
                if (e.target.classList.contains('delete-btn')) {
                    const id = e.target.dataset.id;
                    if (!confirm('Are you sure you want to delete this worker?')) return;
                    const res = await fetch(`/workers/${id}`, { method: 'DELETE' });
                    await res.json();
                    window.location.reload();
                }
            });
        });
        
        const userRole = '<%= user.role || "SuperAdmin" %>'; // From server-side EJS
        const userId = '<%= user._id %>';

        document.addEventListener('DOMContentLoaded', async function() {
            console.log('Dashboard initializing for role:', userRole);

            // ========== CONDITIONAL RENDERING BASED ON ROLE ==========
            document.querySelectorAll('#sidebar li').forEach(item => {
                const requiredRoles = item.getAttribute('data-role-access');
                const planRestriction = item.getAttribute('data-plan-restriction');
                const link = item.querySelector('a');
                const targetId = link ? link.getAttribute('href').substring(1) : null;
                const targetPane = targetId ? document.getElementById(targetId) : null;

                // Check role access (server-side validated)
                if (requiredRoles && !requiredRoles.split(',').includes(userRole) && !requiredRoles.includes('SuperAdmin')) {
                    item.classList.add('hidden-module');
                    if (targetPane) targetPane.classList.add('hidden-module');
                }
            });

            // ========== LOAD KPI DATA FROM BACKEND ==========
            async function loadKPIData() {
                try {
                    const response = await fetch('/api/admin/kpi');
                    const data = await response.json();
                    
                    // Update KPI cards with real data
                    document.querySelectorAll('.card-kpi .card-title').forEach((el, idx) => {
                        const values = [data.totalCompanies, data.revenue, data.pendingAudits, data.overdueTax];
                        el.textContent = values[idx] || 0;
                    });

                    console.log('KPI Data loaded:', data);
                } catch (err) {
                    console.error('Error loading KPI:', err);
                }
            }

            // ========== LOAD COMPANIES DATA ==========
            async function loadCompaniesData() {
                try {
                    const response = await fetch('/api/admin/companies');
                    const companies = await response.json();
                    
                    const tbody = document.querySelector('#companies tbody');
                    if (!tbody) return;

                    tbody.innerHTML = companies.map(c => `
                        <tr>
                            <td>${c.id.substring(0, 8)}</td>
                            <td>${c.name}</td>
                            <td><span class="badge bg-info">${c.subscription}</span></td>
                            <td><span class="badge bg-${c.complianceStatus === 'Compliant' ? 'success' : 'danger'}">${c.complianceStatus}</span></td>
                            <td>Auditor Name</td>
                            <td><button class="btn btn-sm btn-primary">View Profile</button></td>
                        </tr>
                    `).join('');

                    console.log('Companies loaded:', companies.length);
                } catch (err) {
                    console.error('Error loading companies:', err);
                }
            }

            // ========== LOAD USERS DATA ==========
            async function loadUsersData() {
                try {
                    const response = await fetch('/api/admin/users');
                    const users = await response.json();
                    
                    // Update users table in modal/panel
                    console.log('Users loaded:', users.length);
                } catch (err) {
                    console.error('Error loading users:', err);
                }
            }

            // ========== LOAD AUDITS DATA ==========
            async function loadAuditsData() {
                try {
                    const response = await fetch('/api/admin/audits');
                    const audits = await response.json();
                    
                    const tbody = document.querySelector('#audits tbody');
                    if (!tbody) return;

                    tbody.innerHTML = audits.map(a => `
                        <tr>
                            <td>${a.auditId}</td>
                            <td>${a.company}</td>
                            <td>${a.auditor}</td>
                            <td><span class="badge bg-${a.status === 'Completed' ? 'success' : a.status === 'Ongoing' ? 'warning' : 'info'}">${a.status}</span></td>
                            <td>${new Date(a.startDate).toLocaleDateString()}</td>
                            <td><button class="btn btn-sm btn-primary">View/Upload Report</button></td>
                        </tr>
                    `).join('');

                    console.log('Audits loaded:', audits.length);
                } catch (err) {
                    console.error('Error loading audits:', err);
                }
            }

            // ========== LOAD TAX DATA ==========
            async function loadTaxData() {
                try {
                    const response = await fetch('/api/admin/taxes');
                    const data = await response.json();
                    
                    // Update tax status cards
                    document.querySelectorAll('.row .card-body h2').forEach((el, idx) => {
                        const values = [data.paidCount, data.pendingCount, data.overdueCount];
                        el.textContent = values[idx] || 0;
                    });

                    // Update tax table
                    const tbody = document.querySelector('#taxation tbody');
                    if (tbody) {
                        tbody.innerHTML = data.records.map(t => `
                            <tr>
                                <td>T${Math.random().toString(36).substr(2, 5).toUpperCase()}</td>
                                <td>${t.company}</td>
                                <td>Tax Officer</td>
                                <td><span class="badge bg-${t.status === 'Paid' ? 'success' : t.status === 'Pending' ? 'info' : 'danger'}">${t.status}</span></td>
                                <td>${new Date(t.dueDate).toLocaleDateString()}</td>
                                <td><button class="btn btn-sm btn-primary">Review</button></td>
                            </tr>
                        `).join('');
                    }

                    console.log('Tax data loaded');
                } catch (err) {
                    console.error('Error loading tax data:', err);
                }
            }

            // ========== LOAD BILLING DATA ==========
            async function loadBillingData() {
                try {
                    const response = await fetch('/api/admin/billing');
                    const data = await response.json();
                    
                    // Update billing cards
                    const billingCardsTitles = document.querySelectorAll('#financial .card h4');
                    if (billingCardsTitles.length >= 3) {
                        billingCardsTitles[0].nextElementSibling.textContent = `₦${(data.totalRevenue / 1000000).toFixed(1)}M`;
                        billingCardsTitles[1].nextElementSibling.textContent = data.pendingInvoices;
                        billingCardsTitles[2].nextElementSibling.textContent = data.activeSubscriptions;
                    }

                    console.log('Billing data loaded');
                } catch (err) {
                    console.error('Error loading billing data:', err);
                }
            }

            // ========== LOAD LOGISTICS DATA ==========
            async function loadLogisticsData() {
                try {
                    const response = await fetch('/api/admin/logistics');
                    const data = await response.json();
                    
                    console.log('Logistics data:', data);
                } catch (err) {
                    console.error('Error loading logistics data:', err);
                }
            }

            // ========== LOAD ACTIVITIES ==========
            async function loadActivities() {
                try {
                    const response = await fetch('/api/admin/activities');
                    const activities = await response.json();
                    
                    const activitiesList = document.querySelector('.card .list-group-flush');
                    if (activitiesList) {
                        activitiesList.innerHTML = activities.map(a => `
                            <li class="list-group-item">${a.description} (${new Date(a.timestamp).toLocaleTimeString()})</li>
                        `).join('');
                    }

                    console.log('Activities loaded');
                } catch (err) {
                    console.error('Error loading activities:', err);
                }
            }

            // ========== INITIALIZE ALL DATA LOADS ==========
            console.log('Loading dashboard data...');
            
            await loadKPIData();
            await loadCompaniesData();
            await loadUsersData();
            await loadAuditsData();
            await loadTaxData();
            await loadBillingData();
            await loadLogisticsData();
            await loadActivities();

            console.log('Dashboard initialized with live data');

            // ========== AUTO-REFRESH DATA EVERY 30 SECONDS ==========
            setInterval(() => {
                loadKPIData();
                loadActivities();
            }, 30000);
        });





    </script>

    <script>
document.addEventListener("DOMContentLoaded", () => {
  const activityList = document.getElementById("activityList");

  fetch("/api/userActivities/activities")
    .then(res => res.json())
    .then(data => {
      if (!data.success || data.activities.length === 0) {
        activityList.innerHTML =
          `<li class="list-group-item text-muted">No recent activities</li>`;
        return;
      }

      activityList.innerHTML = "";

      data.activities.forEach(act => {
        const timeAgo = timeSince(new Date(act.createdAt));

        const badge =
          act.action === "BLOCKED"
            ? `<span class="badge bg-danger ms-2">BLOCKED</span>`
            : `<span class="badge bg-success ms-2">ALLOWED</span>`;

        activityList.innerHTML += `
          <li class="list-group-item">
            <strong>${act.workerUsername}</strong>
            accessed <strong>${act.page}</strong>
            ${badge}
            <div class="text-muted small">${timeAgo}</div>
          </li>
        `;
      });
    })
    .catch(() => {
      activityList.innerHTML =
        `<li class="list-group-item text-danger">Failed to load activities</li>`;
    });
});

// simple time ago helper
function timeSince(date) {
  const seconds = Math.floor((new Date() - date) / 1000);
  const intervals = [
    { label: "yr", seconds: 31536000 },
    { label: "mo", seconds: 2592000 },
    { label: "d", seconds: 86400 },
    { label: "hr", seconds: 3600 },
    { label: "min", seconds: 60 },
  ];

  for (const i of intervals) {
    const count = Math.floor(seconds / i.seconds);
    if (count > 0) return `${count} ${i.label}${count > 1 ? "s" : ""} ago`;
  }
  return "just now";
}
</script>


