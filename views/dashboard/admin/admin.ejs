<!-- ADD / EDIT USER POPUP -->
<div class="popup" id="addUserPopup">
  <form id="addUserForm" class="popup-box">
    <input type="hidden" name="adminId" value="<%= user._id %>">

    <h3>Create / Edit User</h3>

    <input name="name" placeholder="Full name" required />
    <input name="email" placeholder="Email" required />
    <input name="username" placeholder="Username" required />
    <input name="phone" placeholder="Phone number" />
    <input name="password" placeholder="Password (leave empty to keep)" />
    <textarea name="notes" placeholder="Notes (optional)" rows="3"></textarea>

    <h4>Roles & Permissions</h4>

    <div class="roles-grid">

      <label>
        <input type="checkbox" name="roles" value="inventory" />
        Inventory
      </label>
      <select name="accessLevel[inventory]" disabled>
        <option value="">Access</option>
        <option value="basic">Basic</option>
        <option value="max">Max</option>
        <option value="admin">Admin</option>
      </select>

      <label>
        <input type="checkbox" name="roles" value="sales" />
        Sales
      </label>
      <select name="accessLevel[sales]" disabled>
        <option value="">Access</option>
        <option value="basic">Basic</option>
        <option value="max">Max</option>
        <option value="admin">Admin</option>
      </select>

      <label>
        <input type="checkbox" name="roles" value="finance" />
        Finance
      </label>
      <select name="accessLevel[finance]" disabled>
        <option value="">Access</option>
        <option value="basic">Basic</option>
        <option value="max">Max</option>
        <option value="admin">Admin</option>
      </select>

      <label>
        <input type="checkbox" name="roles" value="logistics" />
        Logistics
      </label>
      <select name="accessLevel[logistics]" disabled>
        <option value="">Access</option>
        <option value="basic">Basic</option>
        <option value="max">Max</option>
        <option value="admin">Admin</option>
      </select>

      <label>
        <input type="checkbox" name="roles" value="audit" />
        Audit
      </label>
      <select name="accessLevel[audit]" disabled>
        <option value="">Access</option>
        <option value="basic">Basic</option>
        <option value="max">Max</option>
        <option value="admin">Admin</option>
      </select>

    </div>

    <div class="popup-actions">
      <button type="submit" class="btn primary">Save</button>
      <button type="button" id="closePopup" class="btn">Cancel</button>
    </div>

    <h4 class="mt-4">Role Permissions Matrix</h4>
    <p class="text-muted">
      Permissions are controlled dynamically using the roles array and accessLevel.
    </p>
  </form>
