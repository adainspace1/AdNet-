<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/admin.css" />
    <link rel="stylesheet" href="/css/dashall.css">

    <title>Super Amin</title>

 
  </head>

  <body>
    <!-- Sidebar -->
<%- include("../_sidebar1") %>
    <!-- End Sidebar -->
<!-- Main Content -->
    <div class="content">
      <!-- Navbar -->
      <nav>
        <form action="#">
          <div class="form-input">
            <input type="search" placeholder="Search..." />
            <button class="search-btn" type="submit">
              <i class="bx bx-search"></i>
            </button>
          </div>
        </form>
        <input type="checkbox" id="theme-toggle" hidden />
        <label for="theme-toggle" class="theme-toggle"></label>
        <a href="#" class="notif">
          <i class="bx bx-bell"></i>
          <span class="count">12</span>
        </a>
        <a href="#" class="profile">
          <img src="images/profile-1.jpg" />
        </a>
      </nav>
      <!-- End Navbar -->

      <main>
        <!-- Profile (FinanceHub Style) -->
        <section class="financehub-profile">
          <div class="profile-header">
            <div class="avatar">JD</div>
            <div class="profile-info">
              <h1><%= user.firstName
                %> <%= user.lastName
                %></h1>
              <p>Super Admin • Member since 2023</p>
            </div>
          </div>

          <div class="tabs">
            <button class="tab active" onclick="showTab('overview')">
              Overview
            </button>
            <button class="tab" onclick="showTab('personal')">
              Personal Info
            </button>
            <button class="tab" onclick="showTab('accounts')">
              Accounts
            </button>
            <button class="tab" onclick="showTab('settings')">
              Settings
            </button>
          </div>

          <!-- Overview -->
          <div id="overview" class="tab-content active">
            <div class="overview-cards">
              <div class="card">
                <h3>1,074</h3>
                <p>Completed Deals</p>
              </div>
              <div class="card">
                <h3>3,944</h3>
                <p>Client Engagements</p>
              </div>
              <div class="card">
                <h3>14,721</h3>
                <p>Market Inquiries</p>
              </div>
              <div class="card">
                <h3>$6,742</h3>
                <p>Revenue Generated</p>
              </div>
            </div>
          </div>

          <!-- Personal Info -->
          <div id="personal" class="tab-content">
            <div class="info-grid">
              <div class="info-item">
                <label for="full-name">Full Name</label>
                <input type="text" id="full-name" value="John Doe" readonly />
              </div>
              <div class="info-item">
                <label for="email">Email</label>
                <input
                  type="email"
                  id="email"
                  value="johndoe@example.com"
                  readonly
                />
              </div>
              <div class="info-item">
                <label for="phone">Phone</label>
                <input
                  type="text"
                  id="phone"
                  value="+234 801 234 5678"
                  readonly
                />
              </div>
              <div class="info-item">
                <label for="role">Role</label>
                <input
                  type="text"
                  id="role"
                  value="Super Admin"
                  readonly
                />
              </div>
            </div>
            <button id="save-profile-btn">Save Changes</button>
          </div>

          <!-- Accounts -->
          <div id="accounts" class="tab-content">
            <p>Connected accounts will be listed here.</p>
          </div>

          <!-- Settings -->
          <div id="settings" class="tab-content">
            <p>Profile and system settings go here.</p>
          </div>
        </section>
        <!-- End Profile -->
         <!-- Insights -->
        <ul class="insights">
          <li>
            <i class="bx bx-briefcase-alt"></i>
            <span class="info">
              <h3>1,074</h3>
              <p>Completed Deals</p>
            </span>
          </li>
          <li>
            <i class="bx bx-bar-chart-alt-2"></i>
            <span class="info">
              <h3>3,944</h3>
              <p>Client Engagements</p>
            </span>
          </li>
          <li>
            <i class="bx bx-trending-up"></i>
            <span class="info">
              <h3>14,721</h3>
              <p>Market Inquiries</p>
            </span>
          </li>
          <li>
            <i class="bx bx-wallet"></i>
            <span class="info">
              <h3>$6,742</h3>
              <p>Revenue Generated</p>
            </span>
          </li>
        </ul>
        <!-- End Insights -->

        <div class="bottom-data">
          <!-- Orders -->
          <div class="orders">
  <div class="header">
    <i class="bx bx-receipt"></i>
    <h3>Registered User</h3>
    <i class="bx bx-plus"></i>
    <i class="bx bx-filter"></i>
    <i class="bx bx-search"></i>
  </div>
  <table>
    <thead>
      <tr>
        <th>User</th>
        <th>Created Date</th>
        <th>Status</th>
        <th>Actions</th> <!-- New column -->
      </tr>
    </thead>
    <tbody>
      <!-- Workers will be rendered dynamically -->
    </tbody>
  </table>
</div>


          <!-- Reminders -->
          <div class="reminders">
            <div class="header">
              <i class="bx bx-note"></i>
              <h3>Reminders</h3>
              <i class="bx bx-filter"></i>
              <i class="bx bx-plus"></i>
            </div>
            <ul class="task-list">
              <li class="completed">
                <div class="task-title">
                  <i class="bx bx-check-circle"></i>
                  <p>Meeting with Adam Comms</p>
                </div>
              </li>
            </ul>
          </div>
        </div>

    <!-- Popup Form -->
<div id="addUserPopup" class="popup">
        <div class="popup-content">
            <h2>Create Worker Account</h2>
            <form id="addUserForm">
                <!-- Hidden field for admin -->
                <input type="hidden" name="adminId" value="USER_ID_HERE">
                
                <div class="form-grid">
                    <div class="form-group">
                        <label>Full Name</label>
                        <input type="text" name="name" required>
                    </div>
                    
                    <div class="form-group">
                        <label>Email</label>
                        <input type="email" name="email" required>
                    </div>
                    
                    <div class="form-group">
                        <label>Phone</label>
                        <input type="text" name="phone">
                    </div>
                    
                    <div class="form-group">
                        <label>Username</label>
                        <input type="text" name="username" required>
                    </div>
                    
                    <div class="form-group">
                        <label>Password</label>
                        <input type="password" name="password" required>
                    </div>
                    

                </div>

                <!-- Roles & Permissions Section -->
                <div class="roles-section">
                    <div class="section-title">Roles & Permissions</div>

                    <input type="hidden" name="adminId" value="<%= user._id %>">

                    
                    <div class="role-selection">
                        <div class="role-checkbox" data-role="inventory">
                            <input type="checkbox" id="role-inventory" name="roles" value="inventory">
                            <label for="role-inventory">Inventory</label>
                        </div>
                        <div class="role-checkbox" data-role="sales">
                            <input type="checkbox" id="role-sales" name="roles" value="sales">
                            <label for="role-sales">Sales</label>
                        </div>
                        <div class="role-checkbox" data-role="finance">
                            <input type="checkbox" id="role-finance" name="roles" value="finance">
                            <label for="role-finance">Finance</label>
                        </div>
                        <div class="role-checkbox" data-role="hr">
                            <input type="checkbox" id="role-hr" name="roles" value="hr">
                            <label for="role-hr">HR</label>
                        </div>
                        <div class="role-checkbox" data-role="custom">
                            <input type="checkbox" id="role-custom" name="roles" value="custom">
                            <label for="role-custom">Custom</label>
                        </div>
                    </div>

                    <div class="selected-roles-summary" id="rolesSummary" style="display: none;">
                        <div class="summary-text">Selected roles: <span id="selectedRolesList"></span></div>
                    </div>

                    <!-- Access Levels for each role -->
                    <div class="permissions-container">
                        <!-- Inventory Access Level -->
                        <div class="role-permissions" id="permissions-inventory">
                            <div class="role-title">Inventory Access Level</div>
                            <div class="form-group">
                                <label>Access Level</label>
                                <select name="accessLevel[inventory]" disabled required>
                                    <option value="">Select Access Level</option>
                                    <option value="basic">Basic</option>
                                    <option value="max">Max</option>
                                    <option value="admin">Admin</option>
                                </select>
                            </div>
                        </div>

                        <!-- Sales Access Level -->
                        <div class="role-permissions" id="permissions-sales">
                            <div class="role-title">Sales Access Level</div>
                            <div class="form-group">
                                <label>Access Level</label>
                                <select name="accessLevel[sales]" disabled required>
                                    <option value="">Select Access Level</option>
                                    <option value="basic">Basic</option>
                                    <option value="max">Max</option>
                                    <option value="admin">Admin</option>
                                </select>
                            </div>
                        </div>

                        <!-- Finance Access Level -->
                        <div class="role-permissions" id="permissions-finance">
                            <div class="role-title">Finance Access Level</div>
                            <div class="form-group">
                                <label>Access Level</label>
                                <select name="accessLevel[finance]" disabled required>
                                    <option value="">Select Access Level</option>
                                    <option value="basic">Basic</option>
                                    <option value="max">Max</option>
                                    <option value="admin">Admin</option>
                                </select>
                            </div>
                        </div>

                        <!-- HR Access Level -->
                        <div class="role-permissions" id="permissions-hr">
                            <div class="role-title">HR Access Level</div>
                            <div class="form-group">
                                <label>Access Level</label>
                                <select name="accessLevel[hr]" disabled required>
                                    <option value="">Select Access Level</option>
                                    <option value="basic">Basic</option>
                                    <option value="max">Max</option>
                                    <option value="admin">Admin</option>
                                </select>
                            </div>
                        </div>

                        <!-- Custom Access Level -->
                        <div class="role-permissions" id="permissions-custom">
                            <div class="role-title">Custom Access Level</div>
                            <div class="form-group">
                                <label>Access Level</label>
                                <select name="accessLevel[custom]" disabled required>
                                    <option value="">Select Access Level</option>
                                    <option value="basic">Basic</option>
                                    <option value="max">Max</option>
                                    <option value="admin">Admin</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-group full-width">
                    <label>Notes (Optional)</label>
                    <textarea name="notes" placeholder="Additional notes about this user..."></textarea>
                </div>

                <div class="form-actions">
                    <button type="submit">Create User</button>
                    <button type="button" onclick="closePopup()">Cancel</button>
                </div>
            </form>
        </div>
    </div>
        
      </main>
    </div>
    





    <script src="/js/admin.js"></script>
    <script src="/js/roles.js"></script>
<script>
  document.addEventListener("DOMContentLoaded", async () => {
    /* -------------------------------
       ROLE SELECTION HANDLING
    -------------------------------- */
    const roleCheckboxes = document.querySelectorAll('input[name="roles"]');
    const roleContainers = document.querySelectorAll('.role-checkbox');
    const rolesSummary = document.getElementById('rolesSummary');
    const selectedRolesList = document.getElementById('selectedRolesList');

    // Toggle checkbox if container is clicked
    roleContainers.forEach(container => {
      container.addEventListener('click', function(e) {
        if (e.target.tagName !== 'INPUT') {
          const checkbox = this.querySelector('input[type="checkbox"]');
          checkbox.checked = !checkbox.checked;
          checkbox.dispatchEvent(new Event('change'));
        }
      });
    });

    // Handle role selection
    roleCheckboxes.forEach(checkbox => {
      checkbox.addEventListener('change', function () {
        const role = this.value;
        const container = this.closest('.role-checkbox');
        const permissionsContainer = document.getElementById(`permissions-${role}`);
        const accessSelect = permissionsContainer ? permissionsContainer.querySelector('select[name*="accessLevel"]') : null;

        if (this.checked) {
          container.classList.add('selected');
          if (permissionsContainer) permissionsContainer.classList.add('active');
          if (accessSelect) {
            accessSelect.removeAttribute('disabled');
            accessSelect.setAttribute('required', 'true');
            console.log('Access level reset for', role, "enabled");
          }
        } else {
          container.classList.remove('selected');
          if (permissionsContainer) permissionsContainer.classList.remove('active');
          if (accessSelect) {
            accessSelect.value = '';
            accessSelect.setAttribute('disabled', 'true');
            accessSelect.removeAttribute('required');
            console.log('Access level reset for', role, "disabled");
          }
        }

        updateRolesSummary();
      });
    });

    function updateRolesSummary() {
      const selectedRoles = Array.from(roleCheckboxes)
        .filter(cb => cb.checked)
        .map(cb => cb.value);

      if (selectedRoles.length > 0) {
        rolesSummary.style.display = 'block';
        selectedRolesList.textContent = selectedRoles.join(', ');
      } else {
        rolesSummary.style.display = 'none';
      }
    }

    /* -------------------------------
       FETCH WORKERS FOR THIS ADMIN
    -------------------------------- */
    const tbody = document.querySelector(".orders table tbody");
    if (tbody) {
      try {
        const res = await fetch(`/workers/<%= user._id %>`);
        const workers = await res.json();

        tbody.innerHTML = "";
        workers.forEach(worker => {
  const tr = document.createElement("tr");
  tr.innerHTML = `
    <td>
      <img src="/images/load.jpeg" alt="${worker.name}" />
      <p>${worker.name}</p>
    </td>
    <td>${new Date(worker.createdAt).toLocaleDateString()}</td>
    <td>
      <i class="bx bx-check-circle" title="${worker.roles.map(r => r.role).join(', ')}"></i>
    </td>
    <td>
      <button class="edit-btn" data-id="${worker._id}">Edit</button>
      <button class="delete-btn" data-id="${worker._id}">Delete</button>
    </td>
  `;
  tbody.appendChild(tr);
});

      } catch (err) {
        console.error("Failed to load workers:", err);
      }
    }

    /* -------------------------------
       POPUP HANDLING
    -------------------------------- */
    const addUserPopup = document.getElementById("addUserPopup");
    const addUserBtn = document.querySelector(".bx-plus");
    const addUserForm = document.getElementById("addUserForm");

    if (addUserBtn && addUserPopup) {
      addUserBtn.addEventListener("click", () => {
        addUserPopup.style.display = "flex";
      });
    }

    function closePopup() {
      if (addUserPopup) {
        addUserPopup.style.display = "none";
      }
    }
    window.closePopup = closePopup; // make available globally if used in HTML

    /* -------------------------------
       FORM SUBMISSION
    -------------------------------- */
if (addUserForm) {
  addUserForm.addEventListener("submit", async (e) => {
    e.preventDefault();

    const formData = new FormData(addUserForm);
    const userData = {};
    userData.roles = [];

    for (let [key, value] of formData.entries()) {
      if (key === "roles") {
        const role = value;
        const accessLevel = formData.get(`accessLevel[${role}]`) || "basic";
        userData.roles.push({ role, accessLevel });
      } else if (!key.startsWith("accessLevel[")) {
        userData[key] = value;
      }
    }

    try {
      const id = addUserForm.dataset.id; // if present → update
      const url = id ? `/workers/${id}` : "/user/users";
      const method = id ? "PUT" : "POST";

      const res = await fetch(url, {
        method,
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(userData),
      });

      const result = await res.json();

      if (res.ok) {
        alert(result.message);
        closePopup();
        addUserForm.reset();
        delete addUserForm.dataset.id;
        window.location.reload();
      } else {
        alert(result.message || "Error saving worker");
      }
    } catch (err) {
      console.error(err);
      alert("Something went wrong while saving user.");
    }
  });
}


// Delegate clicks for Edit/Delete
tbody.addEventListener("click", async (e) => {
  if (e.target.classList.contains("edit-btn")) {
    const id = e.target.dataset.id;

    try {
      const res = await fetch(`/workers/${id}`);
      const worker = await res.json();

      if (res.ok) {
        // Prefill popup
        addUserPopup.style.display = "flex";
        addUserForm.dataset.id = worker._id; // store for update

        addUserForm.name.value = worker.name;
        addUserForm.email.value = worker.email;
        addUserForm.phone.value = worker.phone || "";
        addUserForm.username.value = worker.username;
        addUserForm.notes.value = worker.notes || "";

        // reset password (only if you want to force new)
        addUserForm.password.value = "";

        // handle roles + access
        document.querySelectorAll('input[name="roles"]').forEach(cb => {
          cb.checked = false;
          cb.dispatchEvent(new Event('change'));
        });

        worker.roles.forEach(r => {
          const cb = document.querySelector(`input[name="roles"][value="${r.role}"]`);
          if (cb) {
            cb.checked = true;
            cb.dispatchEvent(new Event('change'));

            const sel = document.querySelector(`#permissions-${r.role} select`);
            if (sel) sel.value = r.accessLevel;
          }
        });
      } else {
        alert(worker.message || "Failed to fetch worker");
      }
    } catch (err) {
      console.error(err);
      alert("Error fetching worker details");
    }
  }

  if (e.target.classList.contains("delete-btn")) {
    const id = e.target.dataset.id;
    if (!confirm("Are you sure you want to delete this worker?")) return;

    try {
      const res = await fetch(`/workers/${id}`, { method: "DELETE" });
      const result = await res.json();
      if (res.ok) {
        alert(result.message);
        window.location.reload();
      } else {
        alert(result.message || "Failed to delete worker");
      }
    } catch (err) {
      console.error(err);
      alert("Error deleting worker");
    }
  }
});


    /* -------------------------------
       PROFILE TAB HANDLING
    -------------------------------- */
    window.showTab = function(tabId, event) {
      document
        .querySelectorAll(".financehub-profile .tab")
        .forEach((btn) => btn.classList.remove("active"));
      document
        .querySelectorAll(".financehub-profile .tab-content")
        .forEach((tab) => tab.classList.remove("active"));

      event.target.classList.add("active");
      document.getElementById(tabId).classList.add("active");
    };

    const saveBtn = document.getElementById("save-profile-btn");
    const inputs = document.querySelectorAll(".info-item input");

    document.addEventListener("dblclick", () => {
      inputs.forEach((input) => input.removeAttribute("readonly"));
      if (saveBtn) saveBtn.style.display = "inline-block";
    });

    if (saveBtn) {
      saveBtn.addEventListener("click", () => {
        inputs.forEach((input) => input.setAttribute("readonly", true));
        saveBtn.style.display = "none";
        alert("Profile updated successfully!");
      });
    }
  });
</script>

  </body>
</html>