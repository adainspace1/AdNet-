<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Accounts Payable Dashboard</title>
  <!-- Boxicons -->
  <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet" />
  <!-- Font Awesome -->
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
  <!-- Custom CSS -->
  <link rel="stylesheet" href="/css/dashall.css">
  <link rel="stylesheet" href="/css/accountpayable.css">
</head>

<body>

  <div class="all">
    <%- include ("_sidebar1") %>

      <div class="main-content">
        <%- include ("_topnav") %>

          <div class="container">

            <h1 class="page-title">Accounts Payable</h1>

            <!-- Summary Cards -->
            <div class="summary-grid">
              <div class="summary-card total">
                <h3>Total Outstanding</h3>
                <div class="amount">₦<%= summary.totalOutstanding.toLocaleString() %>
                </div>
                <div class="trend">
                  <i class="fas fa-arrow-down"></i>
                  <span>Data live from DB</span>
                </div>
              </div>

              <div class="summary-card overdue">
                <h3>Overdue Amount</h3>
                <div class="amount">₦<%= summary.overdueAmount.toLocaleString() %>
                </div>
                <div class="trend">
                  <i class="fas fa-arrow-up"></i>
                  <span>
                    <%= summary.overdueCount %> invoices overdue
                  </span>
                </div>
              </div>

              <div class="summary-card pending">
                <h3>Pending Payments</h3>
                <div class="amount">₦<%= summary.pendingAmount.toLocaleString() %>
                </div>
                <div class="trend">
                  <i class="fas fa-clock"></i>
                  <span>
                    <%= summary.pendingCount %> invoices pending
                  </span>
                </div>
              </div>

              <div class="summary-card upcoming">
                <h3>Due This Week</h3>
                <div class="amount">₦<%= summary.dueThisWeekAmount.toLocaleString() %>
                </div>
                <div class="trend">
                  <i class="fas fa-calendar"></i>
                  <span>
                    <%= summary.dueThisWeekCount %> invoices due
                  </span>
                </div>
              </div>
            </div>

            <!-- Filters -->
            <div class="filters">
              <h3>Filter Invoices</h3>
              <div class="filter-grid">
                <div class="filter-group">
                  <label for="dateFrom">Date From</label>
                  <input type="date" id="dateFrom">
                </div>
                <div class="filter-group">
                  <label for="dateTo">Date To</label>
                  <input type="date" id="dateTo">
                </div>
                <div class="filter-group">
                  <label for="vendor">Vendor</label>
                  <input type="text" id="vendor" placeholder="Search Vendor...">
                </div>
                <div class="filter-group">
                  <label for="status">Status</label>
                  <select id="status">
                    <option value="">All Status</option>
                    <option value="paid">Paid</option>
                    <option value="partial">Partial</option>
                    <option value="unpaid">Unpaid</option>
                  </select>
                </div>
              </div>
            </div>

            <!-- Invoice Table -->
            <div class="table-container">
              <div class="table-header">
                <h3>Invoice List</h3>
                <div class="header-actions">
                  <button class="add-btn" id="openApForm">
                    <i class="fas fa-plus"></i> Add New
                  </button>
                  <button class="export-btn">
                    <i class="fas fa-download"></i> Export
                  </button>
                </div>
              </div>
              <div class="table-wrapper">
                <table id="invoiceTable">
                  <thead>
                    <tr>
                      <th>Vendor Name</th>
                      <th>Invoice Number</th>
                      <th>Due Date</th>
                      <th>Amount</th>
                      <th>Remaining</th>
                      <th>Status</th>
                      <th>Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (accountPayables.length> 0) { %>
                      <% accountPayables.forEach(item=> {
                        const dueDate = new Date(item.dueDate);
                        const today = new Date();
                        const isOverdue = dueDate < today && item.status !=='paid' ; %>
                          <tr>
                            <td>
                              <%= item.vendorName %>
                            </td>
                            <td>#<%= item.invoiceNumber || item.id %>
                            </td> <!-- Fallback if no invoiceNumber -->
                            <td>
                              <% if (isOverdue) { %>
                                <span class="status-badge status-overdue">Overdue (<%= dueDate.toLocaleDateString() %>
                                    )</span>
                                <% } else { %>
                                  <%= dueDate.toLocaleDateString() %>
                                    <% } %>
                            </td>
                            <td>₦<%= item.amount.toLocaleString() %>
                            </td>
                            <td>₦<%= item.ramount.toLocaleString() %>
                            </td>
                            <td>
                              <% if (item.status==='paid' ) { %>
                                <span class="status-badge status-paid">Paid</span>
                                <% } else if (item.status==='partial' ) { %>
                                  <span class="status-badge status-partial">Partial</span>
                                  <% } else { %>
                                    <span class="status-badge status-unpaid">Unpaid</span>
                                    <% } %>
                            </td>
                            <td>
                              <div class="action-buttons">
                                <% if (item.status !=='paid' ) { %>
                                  <button class="btn btn-primary"
                                    onclick="openPayForm('<%= item._id %>', <%= item.ramount %>)">
                                    <i class="fas fa-credit-card"></i> Pay
                                  </button>
                                  <% } %>
                                    <button class="btn btn-secondary">
                                      <i class="fas fa-eye"></i> View
                                    </button>
                              </div>
                            </td>
                          </tr>
                          <% }) %>
                            <% } else { %>
                              <tr>
                                <td colspan="7" style="text-align: center; padding: 2rem;">No invoices found.</td>
                              </tr>
                              <% } %>
                  </tbody>
                </table>
              </div>
            </div>

          </div>
      </div>
  </div>

  <!-- Add AP Modal -->
  <div id="apFormPopup" class="modal"
    style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); align-items: center; justify-content: center;">
    <div class="popup-inner">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
        <h2 style="font-size: 1.25rem; font-weight: 700;">Add Accounts Payable</h2>
        <button id="closeApForm"
          style="background: none; border: none; font-size: 1.5rem; cursor: pointer;">&times;</button>
      </div>

      <form id="apForm" action="/user/createApayable" method="POST">
        <!-- Hidden Fields -->
        <input type="text" name="recipientId" value="<%= user._id %>" hidden>
        <input type="text" name="username" value="<%= user.firstName %> <%= user.lastName %>" hidden>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
          <div class="filter-group">
            <label>Vendor Name</label>
            <input name="vendorName" type="text" required />
          </div>
          <div class="filter-group">
            <label>Invoice Number</label>
            <input name="invoiceNumber" type="text" required />
          </div>
          <div class="filter-group">
            <label>Amount (₦)</label>
            <input name="amount" id="amount" type="number" required />
          </div>
          <!-- Hidden Remaining Amount -->
          <input name="ramount" id="Remainingamount" type="number" hidden />

          <div class="filter-group">
            <label>Due Date</label>
            <input name="dueDate" type="date" required />
          </div>
          <div class="filter-group">
            <label>Status</label>
            <select name="status" required>
              <option value="unpaid">Unpaid</option>
              <option value="partial">Partial</option>
              <option value="paid">Paid</option>
            </select>
          </div>
          <div class="filter-group" style="grid-column: span 2;">
            <label>Notes</label>
            <input name="notes" type="text" />
          </div>
        </div>

        <div style="margin-top: 1.5rem; text-align: right;">
          <button type="button" class="btn btn-secondary" id="cancelApForm"
            style="margin-right: 0.5rem;">Cancel</button>
          <button type="submit" class="add-btn">Submit</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Pay Now Modal -->
  <div id="payFormModal" class="modal"
    style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); align-items: center; justify-content: center;">
    <div class="popup-inner" style="max-width: 400px;">
      <h2 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 1rem;">Record Payment</h2>

      <form action="/user/PayApayable" method="POST">
        <input type="text" name="id" id="apId" hidden />

        <div class="filter-group" style="margin-bottom: 1rem;">
          <label>Amount to Pay (₦)</label>
          <input type="number" name="amountPaid" id="amountPaid" required />
          <small id="payError" style="color: var(--danger-color); display: none;">Amount exceeds balance.</small>
        </div>

        <div class="filter-group" style="margin-bottom: 1.5rem;">
          <label>Note</label>
          <textarea name="note" rows="3"
            style="width: 100%; padding: 0.5rem; border: 1px solid var(--border-color); border-radius: 0.5rem;"></textarea>
        </div>

        <div style="text-align: right;">
          <button type="button" class="btn btn-secondary" onclick="closePayForm()"
            style="margin-right: 0.5rem;">Cancel</button>
          <button type="submit" class="btn btn-primary">Submit Payment</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Scripts -->
  <script>
    // Toggle AP Form
    const apModal = document.getElementById("apFormPopup");
    document.getElementById("openApForm").addEventListener("click", () => {
      apModal.style.display = "flex";
    });
    document.getElementById("closeApForm").addEventListener("click", () => {
      apModal.style.display = "none";
    });
    document.getElementById("cancelApForm").addEventListener("click", () => {
      apModal.style.display = "none";
    });

    // Sync Amount to Remaining Amount
    const amountInput = document.getElementById("amount");
    const remainingInput = document.getElementById("Remainingamount");
    amountInput.addEventListener("input", () => {
      remainingInput.value = amountInput.value;
    });

    // Pay Form Logic
    let currentRemaining = 0;
    function openPayForm(id, remaining) {
      currentRemaining = remaining;
      document.getElementById('apId').value = id;
      document.getElementById('amountPaid').value = '';
      document.getElementById('payFormModal').style.display = 'flex';
    }
    function closePayForm() {
      document.getElementById('payFormModal').style.display = 'none';
    }

    document.getElementById('amountPaid').addEventListener('input', function () {
      if (parseFloat(this.value) > currentRemaining) {
        document.getElementById('payError').style.display = 'block';
      } else {
        document.getElementById('payError').style.display = 'none';
      }
    });

    // Filter Logic (Simple Client-Side)
    const filterInputs = document.querySelectorAll('.filters input, .filters select');
    filterInputs.forEach(input => {
      input.addEventListener('change', filterTable);
      input.addEventListener('keyup', filterTable);
    });

    function filterTable() {
      const vendorFilter = document.getElementById('vendor').value.toLowerCase();
      const statusFilter = document.getElementById('status').value.toLowerCase();
      // Date filters can be added here

      const rows = document.querySelectorAll('#invoiceTable tbody tr');
      rows.forEach(row => {
        const vendorName = row.cells[0].textContent.toLowerCase();
        const status = row.cells[5].textContent.toLowerCase();

        let matches = true;
        if (vendorFilter && !vendorName.includes(vendorFilter)) matches = false;
        if (statusFilter && !status.includes(statusFilter)) matches = false;

        row.style.display = matches ? '' : 'none';
      });
    }
  </script>
</body>

</html>