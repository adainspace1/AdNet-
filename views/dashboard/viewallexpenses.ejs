<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
      <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/boxicons@2.1.4/css/boxicons.min.css">
    <title>Expenses History</title>
    <link rel="stylesheet" href="/css/viewallexpenses.css">
</head>
<body style="background-color: #031224;">
       <!-- Sidebar -->
   <%- include ("_sidebar1") %>

    <div class="container">
        <h1>Expenses History</h1>

   <div class="stat-cards">
  <div class="stat-card">
    <div class="stat-label">Total Expenses</div>
    <div class="stat-value" id="total-amount">₦<%= totalAmount.toLocaleString() %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Number of Transactions</div>
    <div class="stat-value" id="transaction-count"><%= totalTransactions %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Average Expense</div>
    <div class="stat-value" id="average-expense">₦<%= averageExpense.toLocaleString() %></div>
  </div>
</div>


        <div class="filters">
            <div class="filter-item">
                <label for="search">Search</label>
                <input type="text" id="search" placeholder="Search by description or category...">
            </div>
            <div class="filter-item">
                <label for="category">Category</label>
                <select id="category">
                    <option value="">All Categories</option>
                </select>
            </div>
            <div class="filter-item">
                <label for="date-from">From Date</label>
                <input type="date" id="date-from">
            </div>
            <div class="filter-item">
                <label for="date-to">To Date</label>
                <input type="date" id="date-to">
            </div>
            <div class="filter-item" style="display: flex; align-items: flex-end;">
                <button id="reset-filters">Reset Filters</button>
            </div>
        </div>
<div class="tablee">
        <table id="expenses-table">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Description</th>
                    <th>Category</th>
                    <th>Amount</th>
                </tr>
            </thead>
            <tbody id="expenses-data">
                <!-- Expense data will be populated here -->
            </tbody>
        </table>
        </div>
        <div id="no-results" class="no-results" style="display: none;">
            No expenses found matching your filters.
        </div>

        <div class="pagination" id="pagination">
            <!-- Pagination will be added here -->
        </div>
    </div>






  <script src="/js/viewallexpense.js"></script>
</body>
</html>