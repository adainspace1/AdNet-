<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
let forecastChartInstance = null;
let stockDepletionChartInstance = null;

document.getElementById("forecastForm").addEventListener("submit", function (e) {
    e.preventDefault();

    const productSelect = document.getElementById("productSelect");
    const selectedOption = productSelect.options[productSelect.selectedIndex];

    const currentStock = parseInt(document.getElementById("currentStock").value);
    const forecastPeriod = parseInt(document.getElementById("forecastPeriod").value);
    const leadTime = parseInt(document.getElementById("leadTime").value);
    const safetyStock = parseInt(document.getElementById("safetyStock").value) || 0;
    const historicalSales = document.getElementById("historicalSales").value
        .split(",")
        .map(s => parseFloat(s.trim()))
        .filter(s => !isNaN(s));
    const orderCost = parseFloat(document.getElementById("orderCost").value);
    const holdingCost = parseFloat(document.getElementById("holdingCost").value);

    if (historicalSales.length === 0) {
        alert("Please provide at least some historical sales data.");
        return;
    }

    const salesVelocity = historicalSales.reduce((a, b) => a + b, 0) / historicalSales.length;
    const daysCoverage = currentStock / salesVelocity;
    const reorderPoint = Math.ceil(salesVelocity * leadTime + safetyStock);
    const reorderQuantity = Math.max(
        0,
        Math.ceil(salesVelocity * forecastPeriod - currentStock + safetyStock)
    );

    // EOQ calculation
    let eoq = null;
    if (!isNaN(orderCost) && !isNaN(holdingCost) && holdingCost > 0) {
        eoq = Math.ceil(Math.sqrt((2 * orderCost * salesVelocity * 365) / (holdingCost / 100)));
    }

    // Update forecast metrics
    document.getElementById("salesVelocity").textContent = salesVelocity.toFixed(1);
    document.getElementById("daysCoverage").textContent = daysCoverage.toFixed(0) + ' days';
    document.getElementById("reorderPoint").textContent = reorderPoint + ' units';
    document.getElementById("reorderQuantity").textContent = reorderQuantity + ' units';

    const recList = document.getElementById("recommendationsList");
    recList.innerHTML = [
        `✔️ Maintain at least <strong>${reorderPoint}</strong> units on hand to avoid stockouts.`,
        reorderQuantity === 0
            ? "✅ You have sufficient stock for the forecast period."
            : `📦 Reorder <strong>${reorderQuantity}</strong> units now to cover the next ${forecastPeriod} days.`,
        eoq ? `📐 Economic Order Quantity (EOQ): <strong>${eoq}</strong>` : "",
        `🔄 Review supplier lead time and historical sales regularly for accuracy.`
    ]
        .filter(item => item)
        .map(item => `<div class="recommendation-item">${item}</div>`)
        .join('');

    document.getElementById("resultsContent").classList.remove("hidden");
    document.getElementById("noResults").classList.add("hidden");

    // 📊 CHARTS
    drawForecastChart(historicalSales, salesVelocity, forecastPeriod);
    drawStockDepletionChart(currentStock, salesVelocity, forecastPeriod);
});

// 👇 Auto-fill current stock, order cost, and estimated holding cost on product change
document.getElementById("productSelect").addEventListener("change", function () {
    const selectedOption = this.options[this.selectedIndex];

    const stock = selectedOption.getAttribute("data-currentstock");
    const bcost = parseFloat(selectedOption.getAttribute("data-bcost"));
    const scost = selectedOption.getAttribute("data-scost");

    if (stock) document.getElementById("currentStock").value = stock;
    if (!isNaN(bcost)) {
        document.getElementById("orderCost").value = bcost;

        // Auto-calculate holding cost as 25% of bcost annually
        const estimatedHoldingCost = (bcost * 0.25).toFixed(2);
        document.getElementById("holdingCost").value = estimatedHoldingCost;
    }
});

// 🎯 Draw Forecast Chart
function drawForecastChart(historicalSales, salesVelocity, forecastPeriod) {
    const ctx = document.getElementById("forecastChart").getContext("2d");
    const projected = Array.from({ length: forecastPeriod }, () => salesVelocity);

    const labels = [
        ...historicalSales.map((_, i) => `Day ${i + 1}`),
        ...projected.map((_, i) => `+${i + 1}`)
    ];

    const data = {
        labels: labels,
        datasets: [
            {
                label: "Historical Sales",
                data: historicalSales,
                backgroundColor: "rgba(54, 162, 235, 0.5)"
            },
            {
                label: "Projected Sales",
                data: [...Array(historicalSales.length).fill(null), ...projected],
                backgroundColor: "rgba(75, 192, 192, 0.5)"
            }
        ]
    };

    if (forecastChartInstance) forecastChartInstance.destroy();
    forecastChartInstance = new Chart(ctx, {
        type: "bar",
        data: data,
        options: {
            responsive: true,
            scales: {
                y: { beginAtZero: true }
            }
        }
    });
}

// 📉 Draw Stock Depletion Chart
function drawStockDepletionChart(currentStock, salesVelocity, forecastPeriod) {
    const ctx = document.getElementById("stockDepletionChart").getContext("2d");

    const labels = Array.from({ length: forecastPeriod }, (_, i) => `Day ${i + 1}`);
    const depletionData = labels.map((_, i) => Math.max(currentStock - salesVelocity * i, 0));

    if (stockDepletionChartInstance) stockDepletionChartInstance.destroy();
    stockDepletionChartInstance = new Chart(ctx, {
        type: "line",
        data: {
            labels: labels,
            datasets: [{
                label: "Stock Level",
                data: depletionData,
                fill: false,
                borderColor: "rgba(255, 99, 132, 1)",
                tension: 0.3
            }]
        },
        options: {
            responsive: true,
            scales: {
                y: { beginAtZero: true }
            }
        }
    });
}
</script>





