            <form class="forecast-form" id="forecastForm">
  <div class="form-group">
    <label for="productSelect">Select Product</label>
    <select id="productSelect" required>
      <option value="">Choose a product...</option>
      <% products.forEach(product => { %>
        <option 
          value="<%= product._id %>" 
          data-itemname="<%= product.itemName %>"
          data-category="<%= product.category %>"
          data-currentstock="<%= product.currentquantity %>"
          data-bcost="<%= product.bcost %>"
          data-scost="<%= product.scost %>"
          data-supplier="<%= product.supplier %>"
        >
          <%= product.itemName %> (<%= product.category %>, Qty: <%= product.currentquantity %>)
        </option>
      <% }) %>
    </select>
  </div>

  <div class="form-group">
    <label for="forecastPeriod">Forecast Period (days)</label>
    <input type="number" id="forecastPeriod" value="30" min="1" max="365" required>
  </div>

  <div class="form-group">
    <label for="currentStock">Current Stock Level</label>
    <input type="number" id="currentStock" min="0" required>
  </div>

  <div class="form-group">
    <label for="leadTime">Lead Time (days)</label>
    <input type="number" id="leadTime" value="7" min="1" required>
  </div>

  <div class="form-group">
    <label for="safetyStock">Safety Stock (optional)</label>
    <input type="number" id="safetyStock" value="20" min="0" placeholder="Auto-calculated if empty">
  </div>

  <div class="form-group">
    <label for="historicalSales">Historical Sales Data (units sold per day, comma-separated)</label>
    <textarea id="historicalSales" rows="3" placeholder="e.g., 12,15,8,20,18,10,25,14...">12,15,8,20,18,10,25,14</textarea>
  </div>

    <div class="form-group">
    <label for="orderCost">Order Cost (₦)</label>
    <input type="number" id="orderCost" step="0.01" placeholder="For EOQ calculation">
    </div>


  <div class="form-group">
    <label for="holdingCost">Holding Cost (% per year)</label>
    <input type="number" id="holdingCost" step="0.01" placeholder="For EOQ calculation">
  </div>

  <button type="submit" class="btn">🚀 Generate Forecast</button>
</form>


