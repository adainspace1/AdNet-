<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Liquidity Ledger</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/ledgerliquidity.css">
  <link rel="stylesheet" href="/css/dashall.css">


           <link
      href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/boxicons@2.1.4/css/boxicons.min.css"
    />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">

  <style>
    input, select {
      width: 100%;
      padding: 8px 10px;
      border: 1px solid #ccc;
      border-radius: 8px;
      font-size: 13px;
      font-family: 'Poppins', sans-serif;
      box-sizing: border-box;
    }
  </style>
</head>
<body>




  <div class="all">

       <%- include ("_sidebar1") %>

       <div class="main-content">

        <%- include ("_topnav") %>

          <div class="container">
   <div class="two">
     <h1>Liquidity Ledger</h1>
    <p style="color:#555;">Comprehensive monitoring of your financial liquidity status with full control and insights.</p>
   </div>

    <button class="btn btn-primary" id="toggleFormBtn"><i class="fas fa-plus"></i> Add Liquidity Entry</button>

    <div class="overlay" id="overlay"></div>
    <div class="formcontainer" id="formcontainer">
      <h2>Liquidity Ledger</h2>
 <form action="/ledgerliquidity" method="POST">
    <div>
      <label for="cash">Cash on Hand ($)</label>
      <input type="number" min="0" step="0.01" name="cash" required>
    </div>

    <div>
      <label for="bank">Bank Balance ($)</label>
      <input type="number" min="0" step="0.01" name="bank" required>
    </div>

    <div>
      <label for="liabilities">Short-Term Liabilities ($)</label>
      <input type="number" min="0" step="0.01" name="liabilities" required>
    </div>

    <button type="submit">Save and Calculate</button>
  </form>
    </div>

<% if (liquidity) { %>
  <div class="summary">
    <h3>Liquidity Summary</h3>
    <p>Cash: $<%= liquidity.cash || 0 %></p>
    <p>Bank: $<%= liquidity.bank || 0 %></p>
    <p>Liabilities: $<%= liquidity.liabilities || 0 %></p>
    <h4>Net Liquidity: $<%= liquidity.netLiquidity.toLocaleString() || 0 %></h4>
  </div>
<% } %>


    <div class="table-container">
      <div style="display:flex; justify-content:space-between; align-items:center;">
        <h2> Ledger Records</h2>
        <button id="exportBtn" class="btn btn-primary"><i class="fas fa-file-export"></i> Export CSV</button>
      </div>
      <div class="dt">
             <table>
        <thead>
          <tr>
            <th>Date</th>
            <th>Description</th>
            <th>Type</th>
            <th>Amount ($)</th>
            <th>Actions</th>
          </tr>
        </thead>
   <tbody id="ledgerTableBody">
  <% liquidityEntries.forEach((entry, index) => { %>
    <tr>
      <td><%= new Date(entry.createdAt).toLocaleDateString() %></td>
      <td>Cash: $<%= entry.cash.toFixed(2) %>, Bank: $<%= entry.bank.toFixed(2) %></td>
      <td>Liabilities: $<%= entry.liabilities.toFixed(2) %></td>
      <td><strong>$<%= entry.netLiquidity.toFixed(2) %></strong></td>
      <td class="actions">
        <!-- <form action="/ledgerliquidity/edit/<%= entry._id %>" method="GET" style="display:inline;">
          <button type="submit" class="edit" title="Edit"><i class="fas fa-edit"></i></button>
        </form> -->
        <form action="/ledgerliquidity/delete/<%= entry._id %>" method="POST" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this entry?');">
          <button type="submit" class="delete" title="Delete"><i class="fas fa-trash"></i></button>
        </form>
      </td>
    </tr>
  <% }) %>
</tbody>

      </table>
      </div>
 
    </div>
  </div>

       </div>

  </div>








  <script>


    const toggleFormBtn = document.getElementById('toggleFormBtn');
    const formcontainer = document.getElementById('formcontainer');
    const overlay = document.getElementById('overlay');

    // Toggle form visibility
    toggleFormBtn.addEventListener('click', () => {
      formcontainer.classList.toggle('show');
      overlay.classList.toggle('show');
    });
// Close only when overlay (not form) is clicked
overlay.addEventListener('click', (e) => {
  if (e.target === overlay) {
    formcontainer.classList.remove('show');
    overlay.classList.remove('show');
    ledgerForm.reset(); // reset form only on close
  }
});


  const exportBtn = document.getElementById('exportBtn');

    const ledgerForm = document.getElementById('ledgerForm');
    const formButtonText = document.getElementById('formButtonText');

    // Reset form button handler
    ledgerForm.addEventListener('reset', () => {
      document.getElementById('description').value = '';
      document.getElementById('type').value = '';
      document.getElementById('amount').value = '';
      document.getElementById('date').valueAsDate = new Date();
      document.getElementById('editIndex').value = '-1';
      formButtonText.textContent = 'Add Entry';
    });
  exportBtn.addEventListener('click', function () {
    const entries = <%- JSON.stringify(liquidityEntries || []) %>;

    console.log('Liquidity Entries in browser:', entries);

    if (entries.length === 0) {
      alert('No entries to export.');
      return;
    }
    let csvContent = "data:text/csv;charset=utf-8,Date,Description,Type,Amount\n";
    entries.forEach(e => {
      csvContent += `${new Date(e.createdAt).toLocaleDateString()},"Cash: $${e.cash.toFixed(2)}, Bank: $${e.bank.toFixed(2)}",Liabilities: $${e.liabilities.toFixed(2)},${e.netLiquidity.toFixed(2)}\n`;
    });
    const encodedUri = encodeURI(csvContent);
    const link = document.createElement('a');
    link.setAttribute('href', encodedUri);
    link.setAttribute('download', 'liquidity_ledger.csv');
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
  });
  </script>
</body>
</html>