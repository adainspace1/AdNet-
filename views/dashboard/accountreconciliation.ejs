       <script>
/* ---------- CONFIG ---------- */
const API = { 
  walletStatus: '/user/api/wallet/status',
  walletCreate: '/user/api/wallet/create',
  banksList: '/user/api/banks/list',
  banksLink: '/user/api/banks/link',
  linkedBanks: '/user/api/linked-banks',
  resolveAccount: '/resolveAccount',
};

/* ---------- INIT ---------- */
document.addEventListener('DOMContentLoaded', async () => {
  populateBankDropdown();
  await initWalletState();
  await loadLinkedBanks();
  initializeFormHandlers();
});

/* ---------- WALLET: status & create ---------- */
async function initWalletState() {
  try {
    const res = await fetch(API.walletStatus);
    const json = await res.json();

    const balEl = document.getElementById('walletBalance');
    balEl.textContent = json.balance != null ? formatCurrency(json.balance) : '₦0.00';

    if (!json.hasWallet) showNoWalletAlert();
    else hideNoWalletAlert();

    const createBtn = document.querySelector('button[onclick="createWallet()"]');
    createBtn.textContent = json.hasWallet ? `Wallet: ${json.provider || 'n/a'}` : '🏦 Create Wallet';
  } catch (err) {
    console.error('Wallet init error', err);
  }
}


// Show banner alert if no wallet
async function showNoWalletAlert() {
  try {
    const res = await fetch('/user/api/wallet/check');
    const json = await res.json();

    // Only show if the user has NO wallet
    if (!json.success || json.hasWallet) {
      hideNoWalletAlert();
      return;
    }

    if (document.getElementById('walletAlert')) return; // prevent duplicates

    const main = document.querySelector('.dashboard-container .dashboard-header');
    const alert = document.createElement('div');
    alert.id = 'walletAlert';
    alert.className = 'wallet-alert';
    alert.innerHTML = `
      <strong>Notice:</strong> You don't have a wallet created yet. Some features require a wallet.
      <button id="dismissWalletAlert" class="small-link">Dismiss</button>
      <button id="quickCreateWallet" class="btn btn-sm">Create Wallet</button>
    `;
    main.appendChild(alert);

    // Dismiss button
    document.getElementById('dismissWalletAlert').addEventListener('click', () => alert.remove());

    // Quick create wallet button
    document.getElementById('quickCreateWallet').addEventListener('click', () => showCreateWalletModal());
  } catch (err) {
    console.error("Wallet check failed", err);
  }
}

function hideNoWalletAlert() {
  const el = document.getElementById('walletAlert');
  if (el) el.remove();
}

// Modal-like prompt (for provider choice)
async function showCreateWalletModal() {
  const provider = prompt('Choose wallet provider: "paystack" or "onepipe" (type exact):', 'paystack');
  if (!provider) return;
  if (!['paystack','onepipe'].includes(provider.toLowerCase())) {
    alert('Invalid provider. Type "paystack" or "onepipe".');
    return;
  }
  await createWallet(provider.toLowerCase());
  hideNoWalletAlert(); // ✅ remove banner once wallet is created
}

// Create wallet API call
async function createWallet(provider) {
  try {
    const res = await fetch('/user/api/wallet/create', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ provider })
    });
    const json = await res.json();
    if (json.success) {
      alert("Wallet created successfully!");
      // update balance display if available
      if (document.getElementById("walletBalance")) {
        document.getElementById("walletBalance").textContent =
          new Intl.NumberFormat('en-NG', { style: 'currency', currency: 'NGN' })
          .format(json.wallet.balance);
      }
    } else {
      alert(json.message || "Failed to create wallet");
    }
  } catch (err) {
    console.error("Create wallet error", err);
    alert("Error creating wallet, please try again.");
  }
}


async function createWallet() {
  try {
    const res = await fetch(API.walletCreate, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ provider: 'paystack' })
    });
    const json = await res.json();
    if (json.success) {
      alert('Wallet created successfully.');
      await initWalletState();
    } else {
      alert('Failed to create wallet: ' + (json.message || 'unknown'));
    }
  } catch (err) {
    console.error('createWallet error', err);
    alert('An error occurred creating wallet.');
  }
}

/* ---------- BANKS: list, link, display ---------- */
async function populateBankDropdown() {
  const bankSelect = document.getElementById('bankSelect');
  try {
    const res = await fetch(API.banksList);
    const data = await res.json(); // expected: [{code, name}, ...]
    // clear existing except placeholder
    bankSelect.innerHTML = '<option value="">Choose your bank...</option>';
    data.forEach(b => {
      const opt = document.createElement('option');
      opt.value = b.code;
      opt.textContent = b.name;
      bankSelect.appendChild(opt);
    });
  } catch (err) {
    console.error('Error loading banks', err);
  }
}

async function loadLinkedBanks() {
  const container = document.getElementById('banksGrid');
  const noBanks = document.getElementById('noBanks');
  try {
    const res = await fetch(API.linkedBanks);
    const data = await res.json(); // expected: array of linked banks
    if (!Array.isArray(data) || data.length === 0) {
      noBanks.style.display = 'block';
      container.style.display = 'none';
      return;
    }
    noBanks.style.display = 'none';
    container.style.display = 'grid';
    container.innerHTML = '';
    data.forEach(bank => container.appendChild(createBankCard(bank)));
  } catch (err) {
    console.error('loadLinkedBanks', err);
  }
}

function createBankCard(bank) {
  const card = document.createElement('div');
  card.className = 'bank-card';
  const transactionsHtml = createTransactionsTable(bank.transactions || []);
  card.innerHTML = `
    <div class="bank-header">
      <div class="bank-info">
        <h3>${bank.bankName}</h3>
        <div class="bank-details">${bank.accountName || ''}<br>${bank.accountNumber || ''}</div>
      </div>
      <div class="bank-balance">
        <div class="balance-text">Balance</div>
        <div class="balance-value">${formatCurrency(bank.balance || 0)}</div>
      </div>
    </div>
    <div class="transactions-section">
      <h4>📊 Recent Transactions</h4>
      ${transactionsHtml}
    </div>
  `;
  return card;
}

function createTransactionsTable(transactions) {
  if (!transactions || transactions.length === 0) {
    return '<div class="no-transactions">No recent transactions</div>';
  }
  let rows = '<table class="transactions-table"><thead><tr><th>Date</th><th>Description</th><th>Amount</th><th>Type</th></tr></thead><tbody>';
  transactions.slice(0, 10).forEach(tx => {
    const amt = tx.amount >= 0 ? '+' + formatCurrency(tx.amount) : formatCurrency(tx.amount);
    const cls = tx.amount >= 0 ? 'amount-credit' : 'amount-debit';
    rows += `<tr><td>${formatDate(tx.date)}</td><td>${tx.description}</td><td class="${cls}">${amt}</td><td>${tx.type || ''}</td></tr>`;
  });
  rows += '</tbody></table>';
  return rows;
}

/* ---------- FORM HANDLERS ---------- */
/* ---------- FORM HANDLERS ---------- */
function initializeFormHandlers() {
  const form = document.getElementById('bankLinkingForm');
  const bankSelect = document.getElementById('bankSelect');
  const accountNumber = document.getElementById('accountNumber');

  let resolvedAccountName = null;

  bankSelect.addEventListener('change', tryResolveAccount);
  accountNumber.addEventListener('input', function() {
    this.value = this.value.replace(/\D/g, '');
    if (this.value.length === 10) {
      this.classList.remove('error');
      tryResolveAccount();
    } else {
      this.classList.add('error');
      resolvedAccountName = null;
      updateAccountNameField('');
      toggleSubmit(false);
    }
  });

  async function tryResolveAccount() {
    const bankCode = bankSelect.value;
    const acct = accountNumber.value;
    if (!bankCode || acct.length !== 10) return;

    updateAccountNameField('Resolving...');
    toggleSubmit(false);

    try {
      const res = await fetch(API.resolveAccount, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ bankCode, accountNumber: acct })
      });
      const json = await res.json();
      if (json.success && json.accountName) {
        resolvedAccountName = json.accountName;
        updateAccountNameField(resolvedAccountName);
        toggleSubmit(true);
      } else {
        resolvedAccountName = null;
        updateAccountNameField('❌ Unable to resolve');
        toggleSubmit(false);
      }
    } catch (err) {
      console.error('resolve error', err);
      resolvedAccountName = null;
      updateAccountNameField('❌ Error resolving');
      toggleSubmit(false);
    }
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!resolvedAccountName) {
      alert('Please resolve account name before submitting.');
      return;
    }

    const fd = new FormData(form);
    const payload = {
      bankCode: fd.get('bank'),
      accountNumber: fd.get('accountNumber'),
      accountName: resolvedAccountName,
      bvn: fd.get('bvn'),
      pin: fd.get('pin') || null,
      consent: fd.get('consent') === 'on'
    };

    const submitBtn = form.querySelector('button[type="submit"]');
    const originalText = submitBtn.innerHTML;
    submitBtn.disabled = true;
    submitBtn.innerHTML = 'Linking...';

    try {
      const res = await fetch(API.banksLink, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      const json = await res.json();
      if (json.success) {
        alert('Bank linked successfully.');
        form.reset();
        updateAccountNameField('');
        hideAdditionalFields();
        await loadLinkedBanks();
      } else {
        alert('Failed to link: ' + (json.message || 'unknown'));
      }
    } catch (err) {
      console.error('link error', err);
      alert('Error linking bank. Check console.');
    } finally {
      submitBtn.disabled = false;
      submitBtn.innerHTML = originalText;
    }
  });

  function updateAccountNameField(value) {
    let el = document.getElementById('resolvedAccountName');
    if (!el) {
      el = document.createElement('div');
      el.id = 'resolvedAccountName';
      el.className = 'form-group resolved-account';
      accountNumber.closest('.form-group').after(el);
    }
    el.innerHTML = value ? `<strong>Account Name:</strong> ${value}` : '';
  }

  function toggleSubmit(enable) {
    const btn = form.querySelector('button[type="submit"]');
    btn.disabled = !enable;
  }
}

/* ---------- ADDITIONAL FIELDS ---------- */
function showAdditionalFields() {
  const container = document.getElementById('additionalFields');
  container.innerHTML = `
    <div class="alert alert-warning">
      <strong>Additional verification required</strong><br>
      Your selected bank requires additional authentication.
    </div>
    <div class="form-group">
      <label for="pin">Transaction PIN</label>
      <input type="password" id="pin" name="pin" class="form-control" placeholder="Enter your 4-digit PIN" maxlength="4" required>
    </div>
  `;
  container.classList.add('show');
}
function hideAdditionalFields() {
  const container = document.getElementById('additionalFields');
  container.classList.remove('show');
  setTimeout(()=> container.innerHTML = '', 200);
}

/* ---------- UTILS ---------- */
function formatCurrency(amount) {
  return new Intl.NumberFormat('en-NG', { style:'currency', currency:'NGN', minimumFractionDigits:2 }).format(Math.abs(amount));
}
function formatDate(dateString) {
  const d = new Date(dateString);
  return d.toLocaleDateString('en-NG', { month:'short', day:'numeric' });
}







