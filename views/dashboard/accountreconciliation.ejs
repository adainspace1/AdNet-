<script>
  async function loadCashFlowInsights() {
    try {
      const res = await fetch("/cashflow-insights/<%= user._id %>");
      const data = await res.json();

      document.querySelector(".metric-value.overdue").textContent = `₦${data.overduePayments.toLocaleString()}`;
      document.querySelector(".metric-value.due-week").textContent = `₦${data.dueThisWeek.toLocaleString()}`;
      document.querySelector(".metric-value.available").textContent = `₦${data.availableBalance.toLocaleString()}`;
    } catch (err) {
      console.error("Failed to load insights", err);
    }
  }

  document.addEventListener("DOMContentLoaded", loadCashFlowInsights);
</script>




<script>
document.addEventListener("DOMContentLoaded", async () => {
  const recipientId = "<%= user._id %>"; // logged-in user

  // ====================
  // 🔹 Fetch Aging Analysis
  // ====================
  try {
    const res = await fetch(`/api/aging-analysis/${recipientId}`);
    const data = await res.json();

    const chart = document.querySelector(".aging-chart");
    if (chart) {
      chart.innerHTML = ""; // clear default template

      Object.values(data).forEach(bucket => {
        // Decide bar color class based on label
        let colorClass = "current";
        if (bucket.label.includes("31-60")) colorClass = "moderate";
        else if (bucket.label.includes("61-90")) colorClass = "old";
        else if (bucket.label.includes("90+")) colorClass = "overdue";

        const width = bucket.total > 0 ? Math.min((bucket.total / 2000000) * 100, 100) : 0;

        const div = document.createElement("div");
        div.classList.add("aging-item");
        div.innerHTML = `
          <div class="aging-label">${bucket.label}</div>
          <div class="aging-bar">
            <div class="aging-fill ${colorClass}" style="width: ${width}%"></div>
          </div>
          <div class="aging-amount">₦${bucket.total.toLocaleString()}</div>
        `;
        chart.appendChild(div);
      });
    }
  } catch (err) {
    console.error("Error loading aging analysis:", err);
  }

  // ====================
  // 🔹 Fetch Workflow Status
  // ====================
  try {
    const res = await fetch(`/api/workflow-status/${recipientId}`);
    const steps = await res.json();

    const wfContainer = document.querySelector(".workflow-steps");
    if (wfContainer) {
      wfContainer.innerHTML = ""; // clear default template

      steps.forEach(step => {
        let iconClass = "bx-edit";
        if (step.status === "completed") iconClass = "bx-check";
        else if (step.status === "active") iconClass = "bx-time";

        wfContainer.innerHTML += `
          <div class="workflow-step ${step.status}">
            <div class="step-icon">
              <i class="bx ${iconClass}"></i>
            </div>
            <div class="step-content">
              <div class="step-title">${step.step}</div>
              <div class="step-subtitle">${step.subtitle}</div>
              ${step.step === "Journal Entries" ? `
                <div class="je-actions">
                  <button class="btn-small">Review</button>
                  <button class="btn-small">Approve</button>
                </div>
              ` : ""}
            </div>
          </div>
        `;
      });
    }
  } catch (err) {
    console.error("Error loading workflow status:", err);
  }
});
</script>





<!-- top and seocnd stats -->
  <script>
    document.addEventListener("DOMContentLoaded", async () => {
      // Function to show error message
      const showError = (message) => {
        const errorDiv = document.createElement("div");
        errorDiv.className = "error-message";
        errorDiv.textContent = message;
        document.querySelector(".showerrorhere").prepend(errorDiv);
      };

      // Initial dashboard stats fetch
      try {
        const res = await fetch("/dashboard-stats");
        if (!res.ok) {
          throw new Error(`HTTP error! status: ${res.status}`);
        }
        const stats = await res.json();

        // Update Accounts Payable Card
        const apCard = document.querySelector(".stat-card.ap");
        apCard.querySelector("h3").textContent = `₦${stats.totalAP.toLocaleString('en-NG', { minimumFractionDigits: 2 })}`;
        const apChange = stats.totalAP > 0 ? -12.3 : 0; // Placeholder logic
        apCard.querySelector(".stat-change").textContent = `${apChange}%`;
        apCard.querySelector(".stat-change").classList.remove("positive", "negative", "neutral");
        apCard.querySelector(".stat-change").classList.add(apChange < 0 ? "negative" : "neutral");

        // Update Accounts Receivable Card
        const arCard = document.querySelector(".stat-card.ar");
        arCard.querySelector("h3").textContent = `₦${stats.totalAR.toLocaleString('en-NG', { minimumFractionDigits: 2 })}`;
        const arChange = stats.totalAR > 0 ? 8.7 : 0; // Placeholder logic
        arCard.querySelector(".stat-change").textContent = `+${arChange}%`;
        arCard.querySelector(".stat-change").classList.remove("positive", "negative", "neutral");
        arCard.querySelector(".stat-change").classList.add(arChange > 0 ? "positive" : "neutral");

        // Update Auto-Matched Today Card
        const matchedCard = document.querySelector(".stat-card.matched");
        matchedCard.querySelector("h3").textContent = stats.autoMatchedToday.toLocaleString();
        const matchedChange = stats.autoMatchedToday > 0 ? 15.2 : 0; // Placeholder logic
        matchedCard.querySelector(".stat-change").textContent = `+${matchedChange}%`;
        matchedCard.querySelector(".stat-change").classList.remove("positive", "negative", "neutral");
        matchedCard.querySelector(".stat-change").classList.add(matchedChange > 0 ? "positive" : "neutral");

        // Update Discrepancies Card
        const discrepancyCard = document.querySelector(".stat-card.discrepancy");
        discrepancyCard.querySelector("h3").textContent = stats.discrepancies.toLocaleString();
        const discrepancyChange = stats.discrepancies > 0 ? 0 : 0; // Placeholder logic
        discrepancyCard.querySelector(".stat-change").textContent = `${discrepancyChange}%`;
        discrepancyCard.querySelector(".stat-change").classList.remove("positive", "negative", "neutral");
        discrepancyCard.querySelector(".stat-change").classList.add("neutral");

        // Update Reconciliation Overview Card
        const reconCard = document.querySelector(".dashboard-card.large");
        // Accounts Payable Progress
        const apProgress = reconCard.querySelector(".summary-item:nth-child(1) .progress-fill");
        const apProgressText = reconCard.querySelector(".summary-item:nth-child(1) span");
        const apReconPercent = stats.totalAP > 0 ? 78 : 0; // Placeholder logic
        apProgress.style.width = `${apReconPercent}%`;
