          <i class="bx bx-user"></i>
          <span>Admin & Driver</span>
          <i class="bx bx-chevron-down chevron"></i>
        </button>
        <div class="dropdown-contentt">
          <div class="submenu">
            <div class="submenu-section" id="admin-driver-section">
              <div class="submenu-title">
                <span>Admin & Driver</span>
                <i class="bx bx-chevron-down chevron"></i>
              </div>
              <div class="submenu-items">
                <a href="/admin" class="submenu-link">Admin Dashboard</a>
                <a href="/driver-dash" class="submenu-link">Driver Dashboard</a>
              </div>
            </div>
          </div>
        </div>
