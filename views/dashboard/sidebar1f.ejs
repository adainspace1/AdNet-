      <button class="all-dropdown-btn">
    <i class="bx bxs-dashboard"></i>
    <span>Pos & Bookkeeping</span>
    <i class="bx bx-chevron-down chevron"></i>
  </button>
      <div class="main-drop main-dropdown-content" id="posandbookkeepingdrop">
      
      <!-- POS Dropdown -->
      <div class="dropdown" id="pos-dropdown">
        <button class="dropdown-btn">
          <i class="bx bx-cog" id="icons"></i>
          <span>POS</span>
          <i class="bx bx-chevron-down chevron"></i>
        </button>
        <div class="dropdown-contentt">
          <div class="submenu">
            <!-- Sales Section -->
            <div class="submenu-section" id="sales-section">
              <div class="submenu-title">
                <span>Sales</span>
                <i class="bx bx-chevron-down chevron"></i>
              </div>
              <div class="submenu-items">
                <a href="/Sales" class="submenu-link">New Sale Interface</a>
                <a href="/salehistory" class="submenu-link">Sales History</a>
                <a href="/salesmetricoverview" class="submenu-link">Sales Metrics Overview</a>
                <a href="/salesforecast" class="submenu-link">Sales Forecast</a>
              
              </div>
            </div>

            <!-- Expenses Section -->
            <div class="submenu-section" id="expenses-section">
              <div class="submenu-title">
                <span>Expenses</span>
                <i class="bx bx-chevron-down chevron"></i>
              </div>
              <div class="submenu-items">
                <a href="/Expenses" class="submenu-link">Add New Expense</a>
                <a href="/viewallexpenses" class="submenu-link">View All Expenses</a>
              </div>
            </div>

            <!-- Inventory Section -->
            <div class="submenu-section" id="inventory-section">
              <div class="submenu-title">
                <span>Inventory</span>
                <i class="bx bx-chevron-down chevron"></i>
              </div>
              <div class="submenu-items">
                <a href="/Inventory" class="submenu-link">Product List</a>
                <a href="/inventorytracking" class="submenu-link">Inventory Tracking</a>
                <a href="/inventoryforecast" class="submenu-link">Inventory Forecast</a>
                <a href="/reportandanalysis" class="submenu-link">Inventory Reports & Analytics</a>
                <a href="/pricecall" class="submenu-link">Price Calculator</a>
              </div>
            </div>

            <!-- Production Section -->
            <div class="submenu-section" id="production-section">
              <div class="submenu-title">
                <span>Production</span>
                <i class="bx bx-chevron-down chevron"></i>
              </div>
              <div class="submenu-items">
                <a href="/Production" class="submenu-link">Production</a>
                <a href="/pricedeterminant" class="submenu-link">Price Determination</a>
              </div>
            </div>

            <!-- Orders Section (moved under POS as it's sales/order related) -->
            <div class="submenu-section" id="orders-section">
              <div class="submenu-title">
                <span>Orders</span>
                <i class="bx bx-chevron-down chevron"></i>
              </div>
              <div class="submenu-items">
                <a href="/OrderManagement" class="submenu-link">Manage Orders</a>
                <a href="/order-placed/:buyername/:orderId" class="submenu-link">Order Confirmation</a>
