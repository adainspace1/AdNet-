      <div class="dropdown" id="setup-dropdown">
        <button class="dropdown-btn">
          <i class="bx bx-wrench"></i>
          <span>Setup</span>
          <i class="bx bx-chevron-down chevron"></i>
        </button>
        <div class="dropdown-contentt">
          <div class="submenu">
            <div class="submenu-section" id="setup-section">
