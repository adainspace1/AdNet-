   <div class="thelrealloader">
    <div class="loader">
      <div class="d-loader">
      </div>
      <p> Adnet </p>
    </div>

  </div>
  

  <script>
    setTimeout( () => {
      document.querySelector(".thelrealloader").style.display = "none"
    }, 1000);
    
    </script>



  <!-- Main Content Area -->
  <script src="/js/sidebar1.js"></script>
