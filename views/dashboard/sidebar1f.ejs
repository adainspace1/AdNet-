            <div class="submenu-section" id="crm-metrics-section">
              <div class="submenu-title">
                <span>CRM & Metrics</span>
                <i class="bx bx-chevron-down chevron"></i>
              </div>
              <div class="submenu-items">
                <a href="/crm" class="submenu-link">CRM</a>
                <a href="/Debtmanagement" class="submenu-link">Debt Management</a>
              </div>
            </div>

            <!-- Assets Section (moved under Bookkeeping as it's financial/asset management related) -->
            <div class="submenu-section" id="assets-section">
              <div class="submenu-title">
                <span>Assets</span>
                <i class="bx bx-chevron-down chevron"></i>
