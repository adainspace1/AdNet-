            <div class="submenu-section" id="budget-payroll-section">
              <div class="submenu-title">
                <span>Budget & Payroll</span>
                <i class="bx bx-chevron-down chevron"></i>
              </div>
              <div class="submenu-items">
                <a href="/budget" class="submenu-link">Budget</a>
                <a href="/payroll" class="submenu-link">Payroll</a>
              </div>
            </div>

