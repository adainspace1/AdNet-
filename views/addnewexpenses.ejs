<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Expense Tracker Dashboard</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.9.1/chart.min.js"></script>
    <link
      href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/boxicons@2.1.4/css/boxicons.min.css"
    />
    <link rel="stylesheet" href="/css/addnewexpenses.css" />
  </head>
  <body>
    <div class="all">
      <!-- Sidebar -->
      <%- include ("_sidebar1") %>

      <!-- Main Content -->
      <div class="container">
        <!-- Summary Cards -->
        <div class="summary-cards">
          <div class="summary-card">
            <h3>Total Expenses For Today</h3>
            <div class="amount">$838.25</div>
            <div class="trend up">↑ 12% from last month</div>
          </div>
          <div class="summary-card">
            <h3>Budget</h3>
            <div class="amount">$1343.51</div>
            <div class="trend up">↑ 5% from last month</div>
          </div>
          <div class="summary-card">
            <h3>Total Transactions For Today</h3>
            <div class="amount">20</div>
            <div class="trend down">↓ 3% from last month</div>
          </div>
        </div>

        <!-- Charts -->
        <div class="charts-row">
          <div class="chart-container">
            <div class="chart-header">
              <div class="chart-title">Expenses by Category Over Time</div>
              <div class="chart-options">This Month ▼</div>
            </div>
            <canvas id="barChart"></canvas>
          </div>
          <div class="chart-container">
            <div class="chart-header">
              <div class="chart-title">Monthly Expense Trend</div>
            </div>
            <canvas id="lineChart"></canvas>
          </div>
        </div>

        <!-- Transactions Table -->
        <div class="transactions">
          <div class="transactions-header">
            <div class="chart-title">Expense Transactions</div>
            <a href="/viewallexpenses" class="view-all">View All Expenses →</a>
          </div>
          <div class="table-container">
            <table>
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Description</th>
                  <th>Category</th>
                  <th>Amount</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>2023/5/17</td>
                  <td>Lunch for the team</td>
                  <td>Supplies</td>
                  <td>$78.50</td>
                  <td><span class="status approved">Approved</span></td>
                </tr>
                <tr>
                  <td>2023/5/14</td>
                  <td>Ride share expenses</td>
                  <td>Transport</td>
                  <td>$45.00</td>
                  <td><span class="status approved">Approved</span></td>
                </tr>
                <tr>
                  <td>2023/5/12</td>
                  <td>Software subscription billing</td>
                  <td>Software</td>
                  <td>$139.99</td>
                  <td><span class="status approved">Approved</span></td>
                </tr>
                <tr>
                  <td>2023/5/11</td>
                  <td>Marketing campaign ads</td>
                  <td>Marketing</td>
                  <td>$299.99</td>
                  <td><span class="status approved">Approved</span></td>
                </tr>
                <tr>
                  <td>2023/5/09</td>
                  <td>Team lunch event</td>
                  <td>Events</td>
                  <td>$145.75</td>
                  <td><span class="status approved">Approved</span></td>
                </tr>
                <tr>
                  <td>2023/5/07</td>
                  <td>Payment to client</td>
                  <td>Supplies</td>
                  <td>$230.00</td>
                  <td><span class="status approved">Approved</span></td>
                </tr>
                <tr>
                  <td>2023/5/05</td>
                  <td>Software subscription (tech)</td>
                  <td>Software</td>
                  <td>$89.99</td>
                  <td><span class="status approved">Approved</span></td>
                </tr>
                <tr>
                  <td>2023/5/03</td>
                  <td>Consulting fees</td>
                  <td>Services</td>
                  <td>$450.00</td>
                  <td><span class="status approved">Approved</span></td>
                </tr>
                <tr>
                  <td>2023/5/01</td>
                  <td>Marketing campaign printing</td>
                  <td>Marketing</td>
                  <td>$120.00</td>
                  <td><span class="status approved">Approved</span></td>
                </tr>
                <tr>
                  <td>2023/4/30</td>
                  <td>Mobile testing review</td>
                  <td>Testing</td>
                  <td>$85.00</td>
                  <td><span class="status declined">Declined</span></td>
                </tr>
                <tr>
                  <td>2023/4/28</td>
                  <td>Bus mandate</td>
                  <td>Transport</td>
                  <td>$65.00</td>
                  <td><span class="status approved">Approved</span></td>
                </tr>
                <tr>
                  <td>2023/4/26</td>
                  <td>Office supplies</td>
                  <td>Supplies</td>
                  <td>$128.50</td>
                  <td><span class="status approved">Approved</span></td>
                </tr>
                <tr>
                  <td>2023/4/24</td>
                  <td>Team building event</td>
                  <td>Events</td>
                  <td>$320.00</td>
                  <td><span class="status approved">Approved</span></td>
                </tr>
                <tr>
                  <td>2023/4/21</td>
                  <td>Software subscription (app)</td>
                  <td>Software</td>
                  <td>$69.99</td>
                  <td><span class="status pending">Pending</span></td>
                </tr>
                <tr>
                  <td>2023/4/17</td>
                  <td>Travel return taxi</td>
                  <td>Marketing</td>
                  <td>$35.00</td>
                  <td><span class="status approved">Approved</span></td>
                </tr>
                <tr>
                  <td>2023/4/14</td>
                  <td>Office supplies</td>
                  <td>Supplies</td>
                  <td>$95.75</td>
                  <td><span class="status approved">Approved</span></td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Add Expense Button -->
        <button class="add-expense-btn" id="addExpenseBtn">+</button>

        <!-- Add Expense Modal -->
        <div class="modal" id="expenseModal">
          <div class="modal-content">
            <div class="modal-header">
              <h3 class="modal-title">Add New Expense</h3>
              <button class="close-modal" id="closeModal">&times;</button>
            </div>
            <div class="modal-body">
              <form id="expenseForm">
                <div class="form-group">
                  <label for="expenseDescription" class="form-label"
                    >Description</label
                  >
                  <input
                    type="text"
                    id="expenseDescription"
                    class="form-control"
                    placeholder="Enter expense description"
                    required
                  />
                </div>
                <div class="form-group">
                  <label for="expenseAmount" class="form-label"
                    >Amount ($)</label
                  >
                  <input
                    type="number"
                    id="expenseAmount"
                    class="form-control"
                    placeholder="0.00"
                    step="0.01"
                    min="0"
                    required
                  />
                </div>
                <div class="form-group">
                  <label for="expenseCategory" class="form-label"
                    >Category</label
                  >
                  <select id="expenseCategory" class="form-control" required>
                    <option value="">Select a category</option>
                    <option value="Supplies">Supplies</option>
                    <option value="Transport">Transport</option>
                    <option value="Software">Software</option>
                    <option value="Marketing">Marketing</option>
                    <option value="Events">Events</option>
                    <option value="Services">Services</option>
                    <option value="Testing">Testing</option>
                  </select>
                </div>
                <div class="form-group">
                  <label for="expenseDate" class="form-label">Date</label>
                  <input
                    type="date"
                    id="expenseDate"
                    class="form-control"
                    required
                  />
                </div>
              </form>
            </div>
            <div class="modal-footer">
              <button class="btn btn-secondary" id="cancelExpense">
                Cancel
              </button>
              <button class="btn btn-primary" id="saveExpense">
                Save Expense
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script src="/js/addnewexpenses.js"></script>
  </body>
</html>
