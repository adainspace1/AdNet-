<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Adnet - Personal</title>
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="stylesheet" href="/css/person.css" />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/boxicons@2.1.4/css/boxicons.min.css"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="registration-container">
      <!-- Sidebar -->
      <%- include ("_sidebar2") %>

      <!-- Main Content -->
      <main class="main-content">
        <!-- Header -->
        <header class="header">
          <h1>Activate <span>Wizdek Media</span></h1>
        </header>

        <!-- Step Indicator -->
        <div class="stepper">
          <div id="ss1" class="step-indicator">1</div>
          <div id="ss2" class="step-indicator">2</div>
          <div id="ss3" class="step-indicator">3</div>
          <div id="ss4" class="step-indicator">4</div>
        </div>

        <!-- Form -->
        <form id="stepperForm" method="POST" action="/api/auth/submitform">
  <!-- Step 1: Personal -->
  <div class="step1">
    <p class="error-msg">Pls fill all fiels</p> <!-- Error placeholder -->
    <h2>Tell us more about yourself</h2>
    <p>
      To help us get to know you better, we need to verify some of your
      personal information.
    </p>
    <div class="form-group">
      <label for="firstName">First Name</label>
      <input
        type="text"
        id="firstName"
        name="firstName"
        placeholder="John"
        required
      />
    </div>
    <div class="form-group">
      <label for="lastName">Last Name</label>
      <input
        type="text"
        id="lastName"
        name="lastName"
        placeholder="Doe"
        required
      />
    </div>
    <div class="form-group">
      <label for="bio">Bio</label>
      <textarea name="bio" id="bio"></textarea>
    </div>
    <div class="form-group">
      <label for="portfolioUrl">Portfolio</label>
      <input
        type="text"
        id="portfolioUrl"
        name="portfolioUrl"
        placeholder="https://sanzy-portfolio.com"
        required
      />
    </div>
    <button id="nextBtn1" class="btn next-btn">
      <i class="bx bx-right-arrow-alt"></i> Next
    </button>
  </div>

  <!-- Step 2: Contact Information -->
  <div class="step2">
    <p class="error-msg">Pls fill all fiels</p> <!-- Error placeholder -->
    <h2>Step 2: Contact Information</h2>
    <div class="form-group">
      <label for="email">Email Address</label>
      <input
        type="email"
        id="email"
        name="email"
        placeholder="example@domain.com"
        required
      />
    </div>
    <div class="form-group">
      <label for="phone">Phone Number</label>
      <input
        type="tel"
        id="phone"
        name="phone"
        placeholder="+123 456 7890"
        required
      />
    </div>
    <div class="form-group">
      <label for="password">password</label>
      <input
        type="password"
        id="password"
        name="password"
        placeholder="***********"
        required
      />
    </div>
    <div class="buttons">
      <button id="prevBtn1" class="btn back-btn" type="button">
        <i class="bx bx-left-arrow-alt"></i> Previous
      </button>
      <button id="nextBtn2" class="btn next-btn" type="button">
        <i class="bx bx-right-arrow-alt"></i> Next
      </button>
    </div>
  </div>

  <!-- Step 3: Address -->
  <div class="step3">
    <p class="error-msg">Pls fill all fiels</p> <!-- Error placeholder -->
    <h2>Step 3: Address</h2>
    <div class="form-group">
      <label for="streetAddress">Street Address</label>
      <input
        type="text"
        id="streetAddress"
        name="streetAddress"
        placeholder="123 Main St"
        required
      />
    </div>
    <div class="form-group">
      <label for="city">City</label>
      <input
        type="text"
        id="city"
        name="city"
        placeholder="City"
        required
      />
    </div>
    <div class="form-group">
      <label for="state">State</label>
      <input
        type="text"
        id="state"
        name="state"
        placeholder="State"
        required
      />
    </div>
    <div class="form-group">
      <label for="country">Country</label>
      <input
        type="text"
        id="country"
        name="country"
        placeholder="Country"
        required
      />
    </div>
    <div class="form-group">
      <label for="plan">Plan</label>
      <input
        type="text"
        id="plan"
        name="plan"
        placeholder="Premium"
        required
      />
    </div>
    <div class="form-group">
      <label for="zipCode">Zip Code</label>
      <input
        type="text"
        id="zipCode"
        name="zipCode"
        placeholder="Zip Code"
        required
      />
    </div>
    <div class="buttons">
      <button id="prevBtn2" class="btn back-btn" type="button">
        <i class="bx bx-left-arrow-alt"></i> Previous
      </button>
      <button id="nextBtn3" class="btn next-btn" type="button">
        <i class="bx bx-right-arrow-alt"></i> Next
      </button>
    </div>
  </div>

        <!-- Step 4: Confirmation -->
      <!-- Step 4: Confirmation -->
      <div class="step4">
        <h2>Step 4: Confirmation</h2>
        <p class="preview-subtitle">Please review your details before submitting:</p>

        <div id="reviewContent" class="preview-box">
          <!-- JS will insert the details here -->
        </div>

        <div class="buttons">
          <button id="prevBtn3" class="btn back-btn" type="button">
            <i class="bx bx-left-arrow-alt"></i> Previous
          </button>
          <button id="submitBtn" class="btn next-btn" type="submit">
            <i class="bx bx-right-arrow-alt"></i> Submit
          </button>
        </div>
      </div>

</form>
      </main>
    </div>


    <script>
      document.querySelector("#Personal").classList.add("active")
    </script>

     <!-- Link the external JavaScript file -->
    <script src="/js/person.js"></script>
  </body>
</html>
